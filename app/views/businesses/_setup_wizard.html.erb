<% analytics ||= nil %>
<% system_statuses ||= {} %>
<% ga4_status = system_statuses["ga4"] || Aicoo::SystemStatusResolver.call("ga4", business:) %>
<% gsc_status = system_statuses["gsc"] || Aicoo::SystemStatusResolver.call("gsc", business:) %>
<% serp_status = system_statuses["serp"] || Aicoo::SystemStatusResolver.call("serp", business:) %>
<% lp_ready = landing_page_counts.values.sum.positive? %>
<% steps = [
  [ "GA4", ga4_status.connected? || ga4_status.warning?, ga4_status.detail_url || google_settings_business_path(business), ga4_status.reason ],
  [ "GSC", gsc_status.connected? || gsc_status.warning?, gsc_status.detail_url || google_settings_business_path(business), gsc_status.reason ],
  [ "SERP", serp_status.connected? || serp_status.warning?, serp_status.detail_url || admin_serp_settings_path(business_id: business.id), serp_status.reason ],
  [ "LP", lp_ready, admin_aicoo_lab_public_landing_pages_path, "公開LPを作成/公開" ]
] %>

<section class="dashboard-section" id="business-setup">
  <div class="section-heading">
    <div>
      <h2>初回設定ウィザード</h2>
      <p>このBusinessを動かすための順番です。設定場所はこのBusiness内に集約しています。</p>
    </div>
  </div>

  <div class="metric-grid aicoo-owner-secondary">
    <% steps.each_with_index do |(label, done, path, description), index| %>
      <div class="metric-card">
        <span><%= index + 1 %>. <%= label %></span>
        <strong><%= done ? "完了" : "未設定" %></strong>
        <small><%= description %></small><br>
        <%= link_to(done ? "確認する" : "設定する", path, class: "button secondary") %>
      </div>
    <% end %>
  </div>
</section>
