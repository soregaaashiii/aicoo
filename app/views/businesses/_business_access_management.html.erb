<% access_overview = business_access_overview %>
<% analytics_site = access_overview.analytics_site %>

<section class="dashboard-section" id="business-access-urls">
  <div class="section-heading">
    <div>
      <h2>公開確認URL</h2>
      <p>Service本体、複数LP、共通計測を分離して管理します。LPはCloudflare Pagesなどの静的ホスティングを前提に改善します。</p>
    </div>
  </div>

  <div class="metric-grid business-access-grid">
    <div class="metric-card business-access-card" id="business-service-access-card">
      <div class="business-access-card-heading">
        <div>
          <span>Service</span>
          <strong><%= business_services.size %>件</strong>
        </div>
        <small>Renderで動くサービス本体</small>
      </div>

      <div class="business-access-item-list">
        <% business_services.each do |service| %>
          <% metadata = service.metadata.to_h %>
          <article class="business-access-list-item">
            <div>
              <strong><%= service.name %></strong>
              <small><%= service.render_service.presence || "Render未設定" %></small>
            </div>
            <dl class="business-access-values">
              <dt>GitHub</dt>
              <dd><%= service.repository.presence || "未設定" %></dd>
              <dt>Production</dt>
              <dd><%= service.url.presence || "未設定" %></dd>
              <dt>Health Check</dt>
              <dd><%= metadata["health_check_url"].presence || "未設定" %></dd>
            </dl>
            <div class="business-access-card-actions">
              <details class="business-access-editor">
                <summary class="button secondary">編集</summary>
                <%= render "business_service_access_form", business:, service: %>
              </details>
              <% if service.url.present? %>
                <%= link_to "開く", service.url, class: "button secondary", target: "_blank", rel: "noopener" %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>

      <% if business_services.empty? %>
        <p class="aicoo-empty-state">Serviceは未登録です。サービス本体のGitHub・Render・Productionを登録してください。</p>
      <% end %>

      <details class="business-access-editor business-access-add-editor">
        <summary class="button">+ Service追加</summary>
        <%= render "business_service_access_form", business:, service: nil %>
      </details>
    </div>

    <div class="metric-card business-access-card" id="business-campaign-access-card">
      <div class="business-access-card-heading">
        <div>
          <span>Campaign</span>
          <strong><%= business_campaigns.size %>件</strong>
        </div>
        <small>CampaignごとにLPを分析・改善</small>
      </div>

      <div class="business-access-item-list business-campaign-list">
        <% campaign_dashboard.each do |campaign_row| %>
          <% campaign = campaign_row.fetch(:campaign) %>
          <article class="business-access-list-item business-campaign-item" id="business-campaign-<%= campaign.id %>">
            <div class="business-access-item-heading">
              <div>
                <strong><%= campaign.name %></strong>
                <small><%= campaign.campaign_type_label %> / <%= campaign.status_label %></small>
              </div>
              <span class="pill">期待利益順位 <%= campaign_row.fetch(:rank) %>位</span>
            </div>
            <div class="campaign-kpi-grid">
              <span>LP <strong><%= campaign_row.fetch(:lp_count) %></strong></span>
              <span>PV <strong><%= number_with_delimiter(campaign_row.fetch(:pageviews)) %></strong></span>
              <span>CV <strong><%= campaign_row.fetch(:conversions) %></strong></span>
              <span>CV率 <strong><%= campaign_row[:conversion_rate] ? number_to_percentage(campaign_row[:conversion_rate] * 100, precision: 2) : "未計測" %></strong></span>
              <span>問い合わせ <strong><%= campaign_row.fetch(:inquiries).to_i %></strong></span>
              <span>契約 <strong><%= campaign_row.fetch(:contracts).to_i %></strong></span>
              <span>売上 <strong><%= number_to_currency(campaign_row.fetch(:revenue_yen), unit: "¥", precision: 0) %></strong></span>
              <span>期待利益 <strong><%= number_to_currency(campaign_row.fetch(:expected_profit_yen), unit: "¥", precision: 0) %></strong></span>
              <span>期待時給 <strong><%= number_to_currency(campaign_row.fetch(:expected_hourly_value_yen), unit: "¥", precision: 0) %></strong></span>
              <span>改善候補 <strong><%= campaign_row.fetch(:improvement_candidate_count) %></strong></span>
            </div>
            <div class="business-access-card-actions">
              <details class="business-access-editor">
                <summary class="button secondary">Campaign編集</summary>
                <%= render "business_campaign_form", business:, campaign: %>
              </details>
              <details class="business-access-editor">
                <summary class="button">+ LP追加</summary>
                <%= render "landing_page_creation_form", business:, campaign: %>
              </details>
              <% if campaign_row.fetch(:lp_count).zero? %>
                <%= button_to "アーカイブ",
                              remove_campaign_business_access_settings_path(business, campaign_id: campaign.id),
                              method: :delete,
                              class: "button danger",
                              data: { turbo_confirm: "#{campaign.name}をアーカイブしますか？" } %>
              <% end %>
            </div>

            <div class="campaign-lp-list">
              <% campaign_row.fetch(:landing_pages).each do |lp_row| %>
                <% landing_page = lp_row.fetch(:landing_page) %>
                <% metadata = landing_page.metadata.to_h %>
                <details class="campaign-lp-row" id="external-lp-<%= landing_page.id %>">
                  <summary>
                    <span><strong><%= lp_row.fetch(:rank) %>位 <%= landing_page.landing_page_name %></strong> <span class="pill"><%= landing_page.landing_page_public_status_label %></span></span>
                    <span>CV <%= lp_row[:conversion_rate] ? number_to_percentage(lp_row[:conversion_rate] * 100, precision: 2) : "未計測" %></span>
                    <span>期待利益 <%= number_to_currency(lp_row.fetch(:expected_profit_yen), unit: "¥", precision: 0) %></span>
                    <span>候補 <%= lp_row.fetch(:improvement_candidate_count) %></span>
                    <span><%= landing_page.landing_page_sync_status_label %></span>
                  </summary>
                  <dl class="business-access-values lp-analysis-values">
                    <dt>URL</dt><dd><%= landing_page.landing_page_url.presence || "未設定" %></dd>
                    <dt>GitHub</dt><dd><%= landing_page.landing_page_repository_url.presence || "未設定" %></dd>
                    <dt>PV</dt><dd><%= number_with_delimiter(lp_row.fetch(:pageviews)) %></dd>
                    <dt>GSC</dt><dd><%= number_with_delimiter(lp_row.fetch(:impressions)) %>表示 / <%= lp_row.fetch(:clicks) %>クリック / CTR <%= lp_row[:ctr] ? number_to_percentage(lp_row[:ctr] * 100, precision: 2) : "未計測" %> / 順位 <%= lp_row[:average_position] || "未計測" %></dd>
                    <dt>商談 / 契約</dt><dd><%= lp_row.fetch(:deals).to_i %> / <%= lp_row.fetch(:contracts).to_i %></dd>
                    <dt>期待CV / 時給</dt><dd><%= lp_row.fetch(:expected_cv).to_f.round(2) %> / <%= number_to_currency(lp_row.fetch(:expected_hourly_value_yen), unit: "¥", precision: 0) %></dd>
                    <dt>Cloudflare</dt><dd><%= metadata["cloudflare_deploy_status"].presence || "未デプロイ" %> / <%= metadata["cloudflare_preview_url"].presence || "Preview未設定" %> / 最終Deploy <%= lp_row[:last_deploy_at] ? l(lp_row[:last_deploy_at], format: :short) : "未実施" %></dd>
                    <dt>A/Bテスト</dt><dd><%= landing_page.landing_page_ab_test["name"].presence || "未実施" %> <%= landing_page.landing_page_ab_test["variant"].presence %> <%= landing_page.landing_page_ab_test["winner"] ? "勝者" : nil %> <%= landing_page.landing_page_ab_test["win_rate"].present? ? number_to_percentage(landing_page.landing_page_ab_test["win_rate"].to_f * 100, precision: 1) : nil %></dd>
                  </dl>
                  <div class="business-access-card-actions">
                    <% if metadata["lovable_generation_run_id"].present? %>
                      <%= link_to "Promptレビュー",
                                  business_lovable_landing_page_path(business, landing_page_id: landing_page.id, anchor: "lovable-prompt"),
                                  class: "button" %>
                    <% end %>
                    <details class="business-access-editor">
                      <summary class="button secondary">編集</summary>
                      <%= render "external_landing_page_form", business:, landing_page:, campaign: %>
                    </details>
                    <% if landing_page.landing_page_url.present? %>
                      <%= link_to "開く", landing_page.landing_page_url, class: "button secondary", target: "_blank", rel: "noopener" %>
                    <% end %>
                    <%= button_to "同期", landing_page_task_business_access_settings_path(business, landing_page_id: landing_page.id), method: :post, class: "button secondary" %>
                    <% if landing_page.landing_page_public_status == "published" %>
                      <%= button_to "改善を開始", improve_landing_page_business_access_settings_path(business, landing_page_id: landing_page.id), method: :post, class: "button" %>
                      <%= button_to "停止", landing_page_status_business_access_settings_path(business, landing_page_id: landing_page.id), method: :patch, params: { public_status: "stopped" }, class: "button secondary" %>
                    <% else %>
                      <%= button_to "公開中にする", landing_page_status_business_access_settings_path(business, landing_page_id: landing_page.id), method: :patch, params: { public_status: "published" }, class: "button secondary" %>
                    <% end %>
                    <%= button_to "削除", remove_landing_page_business_access_settings_path(business, landing_page_id: landing_page.id), method: :delete, class: "button danger", data: { turbo_confirm: "#{landing_page.landing_page_name}を削除しますか？" } %>
                  </div>
                  <details class="lp-improvement-history">
                    <summary>改善履歴 <%= lp_row.fetch(:improvement_history).size %>件</summary>
                    <% if lp_row.fetch(:improvement_history).any? %>
                      <% lp_row.fetch(:improvement_history).first(10).each do |history| %>
                        <p><%= l(history.fetch(:occurred_at), format: :short) %> / <%= history.fetch(:change_content) %> / 期待 <%= number_to_currency(history.fetch(:expected_profit_yen), unit: "¥", precision: 0) %> / 実績 <%= number_to_currency(history.fetch(:actual_profit_yen), unit: "¥", precision: 0) %> / <%= history.fetch(:result) %></p>
                      <% end %>
                    <% else %>
                      <p>改善履歴はまだありません。</p>
                    <% end %>
                  </details>
                </details>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>

      <% if business_campaigns.empty? %>
        <p class="aicoo-empty-state">Campaignは未登録です。最初にSEO、広告、比較などの運用単位を追加してください。</p>
      <% end %>

      <details class="business-access-editor business-access-add-editor">
        <summary class="button">+ Campaign追加</summary>
        <%= render "business_campaign_form", business:, campaign: nil %>
      </details>
    </div>

    <div class="metric-card business-access-card" id="business-lp-access-card">
      <div class="business-access-card-heading">
        <div>
          <span>LP</span>
          <strong><%= external_landing_pages.size %>件</strong>
        </div>
        <small>Cloudflare Pages / page_path単位</small>
      </div>

      <div class="business-access-item-list">
        <% campaign_dashboard.flat_map { |row| row.fetch(:landing_pages) }.sort_by { |row| [ -row.fetch(:expected_profit_yen), row.fetch(:landing_page).id ] }.first(8).each do |lp_row| %>
          <% landing_page = lp_row.fetch(:landing_page) %>
          <article class="business-access-list-item">
            <div>
              <strong><%= landing_page.landing_page_name %></strong>
              <small><%= landing_page.business_campaign&.name || "未分類" %> / <%= landing_page.landing_page_public_status_label %></small>
            </div>
            <dl class="business-access-values">
              <dt>期待利益</dt>
              <dd><%= number_to_currency(lp_row.fetch(:expected_profit_yen), unit: "¥", precision: 0) %></dd>
              <dt>Page Path</dt>
              <dd><%= landing_page.landing_page_ga4_path.presence || "生成待ち" %></dd>
              <dt>Pipeline</dt>
              <dd><%= landing_page.metadata.to_h["planning_status"].presence || landing_page.landing_page_sync_status_label %></dd>
            </dl>
            <div class="business-access-card-actions">
              <% if landing_page.metadata.to_h["lovable_generation_run_id"].present? %>
                <%= link_to "Promptレビュー",
                            business_lovable_landing_page_path(business, landing_page_id: landing_page.id, anchor: "lovable-prompt"),
                            class: "button secondary" %>
              <% end %>
              <% if landing_page.landing_page_url.present? %>
                <%= link_to "開く", landing_page.landing_page_url, class: "button secondary", target: "_blank", rel: "noopener" %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>

      <% if external_landing_pages.empty? %>
        <p class="aicoo-empty-state">LPはまだありません。目的を選ぶだけでAICOOが制作内容を考えます。</p>
      <% end %>

      <% if business_campaigns.first %>
        <%= link_to "+ LP追加",
                    business_path(business, anchor: "business-campaign-#{business_campaigns.first.id}"),
                    class: "button" %>
      <% else %>
        <p class="aicoo-help-text">LP追加の前にCampaignを1件追加してください。</p>
      <% end %>
    </div>

    <div class="metric-card business-access-card" id="business-measurement-access-card">
      <div class="business-access-card-heading">
        <div>
          <span>計測</span>
          <strong>LP共通</strong>
        </div>
        <small>GA4 1 Property / GSC 1 Domain</small>
      </div>

      <dl class="business-access-values">
        <dt>Cloudflare Project</dt>
        <dd><%= business.metadata.to_h["lp_cloudflare_project_name"].presence || "未設定" %></dd>
        <dt>Cloudflare Production</dt>
        <dd><%= business.metadata.to_h["lp_cloudflare_production_url"].presence || "未設定" %></dd>
        <dt>GA4</dt>
        <dd><%= analytics_site&.ga4_property_id.presence || "未設定" %></dd>
        <dt>Measurement ID</dt>
        <dd><%= access_overview.ga4_measurement_id.presence || "未設定" %></dd>
        <dt>GSC</dt>
        <dd><%= analytics_site&.gsc_site_url.presence || "未設定" %></dd>
        <dt>計測ドメイン</dt>
        <dd><%= analytics_site&.public_url.presence || analytics_site&.domain.presence || "未設定" %></dd>
        <dt>Activity API</dt>
        <dd><%= access_overview.activity_api_enabled? ? "接続済み" : "未設定" %></dd>
      </dl>

      <p class="aicoo-help-text">LP追加時はGA4/GSCを新設しません。各LPのpage_pathとURLで同じ接続から抽出します。</p>

      <details class="business-access-editor business-access-add-editor">
        <summary class="button"><%= analytics_site ? "共通計測を編集" : "共通計測を設定" %></summary>
        <%= form_with url: measurement_business_access_settings_path(business), method: :patch, scope: :measurement_access, class: "business-access-form" do |form| %>
          <div class="field">
            <%= form.label :public_url, "Cloudflare Pages共通URL" %>
            <%= form.url_field :public_url, value: analytics_site&.public_url, placeholder: "https://lp.example.com" %>
          </div>
          <div class="field">
            <%= form.label :cloudflare_project_name, "Cloudflare Pages Project" %>
            <%= form.text_field :cloudflare_project_name, value: business.metadata.to_h["lp_cloudflare_project_name"], placeholder: "business-lps" %>
          </div>
          <div class="field">
            <%= form.label :cloudflare_production_url, "Cloudflare Production URL" %>
            <%= form.url_field :cloudflare_production_url, value: business.metadata.to_h["lp_cloudflare_production_url"], placeholder: "https://lp.example.com" %>
          </div>
          <div class="field">
            <%= form.label :cloudflare_branch, "Cloudflare Branch" %>
            <%= form.text_field :cloudflare_branch, value: business.metadata.to_h["lp_cloudflare_branch"] || "main" %>
          </div>
          <div class="field">
            <%= form.label :ga4_measurement_id, "GA4 Measurement ID" %>
            <%= form.text_field :ga4_measurement_id, value: access_overview.ga4_measurement_id, placeholder: "G-XXXXXXXXXX" %>
          </div>
          <div class="field">
            <%= form.label :ga4_property_id, "GA4 Property ID" %>
            <%= form.text_field :ga4_property_id, value: analytics_site&.ga4_property_id %>
          </div>
          <div class="field">
            <%= form.label :gsc_site_url, "GSC Domain URL" %>
            <%= form.url_field :gsc_site_url, value: analytics_site&.gsc_site_url, placeholder: "https://lp.example.com" %>
          </div>
          <div class="field checkbox-field">
            <%= form.check_box :activity_api_enabled, { checked: access_overview.activity_api_enabled? }, "1", "0" %>
            <%= form.label :activity_api_enabled, "Activity APIを有効にする" %>
          </div>
          <div class="actions compact-actions">
            <%= form.submit "保存", class: "button" %>
            <%= link_to "Google接続", admin_analytics_sites_path, class: "button secondary" %>
            <%= link_to "Activity API詳細", admin_source_app_connections_path, class: "button secondary" %>
          </div>
        <% end %>
      </details>
    </div>

    <div class="metric-card business-access-card" id="business-lp-planner-card">
      <div class="business-access-card-heading">
        <div>
          <span>改善Planner</span>
          <strong><%= landing_page_planner.total_missing_count %> LP</strong>
        </div>
        <small>期待利益（円）だけで順位付け</small>
      </div>

      <div class="business-access-item-list">
        <% landing_page_planner.recommendations.each_with_index do |recommendation, index| %>
          <article class="business-access-list-item lp-planner-recommendation">
            <div class="business-access-item-heading">
              <div>
                <span><%= index + 1 %>位</span>
                <strong><%= recommendation.fetch("purpose_label") %> あと<%= recommendation.fetch("missing_count") %>件</strong>
              </div>
              <strong><%= number_to_currency(recommendation.fetch("expected_profit_yen"), unit: "¥", precision: 0) %></strong>
            </div>
          </article>
        <% end %>
      </div>

      <% if landing_page_planner.recommendations.any? %>
        <%= button_to "+ おすすめLPを作る",
                      recommended_landing_page_plan_business_access_settings_path(business),
                      method: :post,
                      class: "button",
                      data: { turbo_confirm: "#{landing_page_planner.total_missing_count}件の生成レビューを作成します。まだLovableやCloudflareへは送信しません。" } %>
      <% else %>
        <p class="aicoo-empty-state">現在のCampaign目標と検索需要に対する不足LPはありません。</p>
      <% end %>
    </div>
  </div>
</section>
