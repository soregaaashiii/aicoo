<%= form_with(model: business, class: "form") do |form| %>
  <%= hidden_field_tag :return_to, local_assigns[:return_to] if local_assigns[:return_to].present? %>

  <% if business.errors.any? %>
    <div class="errors">
      <h2><%= pluralize(business.errors.count, "error") %> prohibited this business from being saved:</h2>

      <ul>
        <% business.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.textarea :description %>
  </div>

  <div class="field">
    <%= form.label :status %>
    <%= form.select :status, Business::STATUSES.map { |status| [status.humanize, status] } %>
  </div>

  <% if business.aicoo_internal_codex? %>
    <fieldset class="aicoo-card aicoo-card-compact">
      <legend>Codex対象プロジェクト</legend>
      <p class="aicoo-lab-help">このBusinessはAICOO内部プロジェクトです。AICOO本体Repositoryを使うため、project_key / repository / path の入力は不要です。</p>
      <span class="pill status-healthy">AICOO内部プロジェクト（接続済み）</span>
    </fieldset>
  <% else %>
    <fieldset class="aicoo-card aicoo-card-compact">
      <legend>Codex対象プロジェクト</legend>
      <div class="field">
        <%= form.label :project_key, "project_key" %>
        <%= form.text_field :project_key, placeholder: "例: suelog" %>
      </div>
      <div class="field">
        <%= form.label :local_project_path, "local_project_path" %>
        <%= form.text_field :local_project_path, placeholder: "例: /Users/.../suelog" %>
      </div>
      <div class="field">
        <%= form.label :repository_name, "repository_name" %>
        <%= form.text_field :repository_name, placeholder: "例: suelog" %>
      </div>
    </fieldset>
  <% end %>

  <fieldset class="aicoo-card aicoo-card-compact">
    <legend>自動改訂</legend>
    <p class="aicoo-lab-help">このBusinessだけの自動改訂モードです。Automaticでも本番Deployは承認制です。</p>
    <div class="aicoo-grid aicoo-grid-3">
      <% Business::AUTO_REVISION_MODES.each do |mode| %>
        <label class="aicoo-card aicoo-card-compact">
          <%= form.radio_button :auto_revision_mode, mode %>
          <strong><%= auto_revision_mode_label(mode) %></strong>
          <small><%= auto_revision_mode_description(mode) %></small>
        </label>
      <% end %>
    </div>
    <% if business.automatic_auto_revision? %>
      <div class="error-toast">現在このBusinessは自動改訂対象です。低リスクだけ自動でCodex投入準備まで進みます。</div>
    <% end %>
  </fieldset>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
