            <td><%= form.text_field :repository, placeholder: "GitHub repo" %></td>
            <td><%= form.text_field :deploy_target, placeholder: "Render / Vercel" %></td>
            <td><%= form.text_field :render_service, placeholder: "Render service" %></td>
            <td><%= form.text_field :stripe_account, placeholder: "Stripe" %></td>
            <td><%= form.text_field :domain, placeholder: "example.com" %></td>
