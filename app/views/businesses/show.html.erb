  <div class="actions compact-actions">
    <%= link_to "代理指標一覧", business_metric_dailies_path, class: "button secondary" %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>proxy_score重み</h2>
    <p>この事業の代理指標計算に使っている重みです。事業別重みがなければ全体共通、さらに無ければ固定デフォルトを使います。</p>
  </div>

  <% proxy_weight = @business.current_proxy_score_weight %>
  <div class="metric-grid">
    <div class="metric-card"><span>confidence_score</span><strong><%= proxy_weight.confidence_score %></strong></div>
    <div class="metric-card"><span>source</span><strong><%= proxy_weight.persisted? ? proxy_weight.source_type : "code_default" %></strong></div>
    <% ProxyScoreWeight::DEFAULT_WEIGHTS.each_key do |column| %>
      <div class="metric-card"><span><%= column %></span><strong><%= number_with_precision(proxy_weight.public_send(column), precision: 4) %></strong></div>
    <% end %>
  </div>

  <h3>直近の補正ログ</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>日時</th>
          <th>期間</th>
          <th>confidence</th>
          <th>補正率</th>
          <th>理由</th>
        </tr>
      </thead>
      <tbody>
        <% @business.proxy_score_weight_adjustment_logs.order(adjusted_at: :desc).limit(5).each do |log| %>
          <tr>
            <td><%= l(log.adjusted_at, format: :short) %></td>
            <td><%= log.start_date %>〜<%= log.end_date %></td>
            <td class="number"><%= log.confidence_score %></td>
            <td class="number"><%= number_to_percentage(log.adjustment_rate.to_d * 100, precision: 3) %></td>
            <td><%= log.reason %></td>
          </tr>
        <% end %>
        <% if @business.proxy_score_weight_adjustment_logs.empty? %>
          <tr><td colspan="5">まだ補正ログはありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

