  </div>

  <% google_api_run = @google_api_import_run %>
  <div class="metric-grid">
    <div class="metric-card">
      <span>Business</span>
      <strong><%= @business.name %></strong>
      <small>Google連携設定</small>
    </div>
    <div class="metric-card">
      <span>Google Credential</span>
      <strong><%= @google_credential&.name || "未設定" %></strong>
      <small><%= @google_credential&.google_account_email.presence || @google_credential&.client_id.presence || "-" %></small>
    </div>
    <div class="metric-card">
      <span>GA4接続</span>
      <strong><%= @ga4_connection_summary.status_label %></strong>
      <small>Property ID: <%= @ga4_connection_summary.identifier.presence || "-" %> / <%= @ga4_connection_summary.setting_source %></small>
    </div>
    <div class="metric-card">
      <span>GSC接続</span>
      <strong><%= @gsc_connection_summary.status_label %></strong>
      <small>Site URL: <%= @gsc_connection_summary.identifier.presence || "-" %> / <%= @gsc_connection_summary.setting_source %></small>
    </div>
    <div class="metric-card">
      <span>GA4最終取得</span>
      <strong><%= @ga4_connection_summary.last_fetched_at ? l(@ga4_connection_summary.last_fetched_at, format: :short) : "-" %></strong>
      <small>取得件数: <%= @ga4_connection_summary.last_count %>件</small>
    </div>
    <div class="metric-card">
      <span>GSC最終取得</span>
      <strong><%= @gsc_connection_summary.last_fetched_at ? l(@gsc_connection_summary.last_fetched_at, format: :short) : "-" %></strong>
      <small>取得件数: <%= @gsc_connection_summary.last_count %>件</small>
    </div>
    <div class="metric-card">
      <span>GA4最後のエラー</span>
      <strong><%= @ga4_connection_summary.last_error.present? ? "あり" : "なし" %></strong>
      <small><%= @ga4_connection_summary.last_error.presence&.truncate(80) || "-" %></small>
    </div>
    <div class="metric-card">
      <span>取得状態</span>
      <strong><%= google_api_run ? google_api_run.status_label : "未実行" %></strong>
      <small><%= google_api_run&.source_types&.join(" / ") || "Google API" %></small>
    </div>
    <div class="metric-card">
      <span>最終実行</span>
      <strong><%= google_api_run&.started_at ? l(google_api_run.started_at, format: :short) : "-" %></strong>
      <small>完了: <%= google_api_run&.finished_at ? l(google_api_run.finished_at, format: :short) : "-" %></small>
    </div>
    <div class="metric-card">
      <span>更新件数</span>
      <strong><%= google_api_run&.updated_metric_count.to_i %>件</strong>
      <small>取得日数: <%= google_api_run&.fetched_days || GoogleApiImportRun::DEFAULT_FETCH_DAYS %>日</small>
    </div>
    <div class="metric-card">
      <span>処理時間</span>
      <strong><%= google_api_run&.duration_seconds ? "#{google_api_run.duration_seconds.to_f.round(1)}秒" : "-" %></strong>
