<section class="dashboard-section" id="business-google">
  <div class="section-heading">
    <h2>Google API直取得</h2>
    <p>AICOO共通Google認証またはBusiness個別設定を使い、GA4/GSC APIからBusinessMetricDailyへ直接保存します。</p>
  </div>

  <% google_api_run = @google_api_import_run %>
  <div class="metric-grid">
    <div class="metric-card">
      <span>取得状態</span>
      <strong><%= google_api_run ? google_api_run.status_label : "未実行" %></strong>
      <small><%= google_api_run&.source_types&.join(" / ") || "Google API" %></small>
    </div>
    <div class="metric-card">
      <span>最終実行</span>
      <strong><%= google_api_run&.started_at ? l(google_api_run.started_at, format: :short) : "-" %></strong>
      <small>完了: <%= google_api_run&.finished_at ? l(google_api_run.finished_at, format: :short) : "-" %></small>
    </div>
    <div class="metric-card">
      <span>更新件数</span>
      <strong><%= google_api_run&.updated_metric_count.to_i %>件</strong>
      <small>取得日数: <%= google_api_run&.fetched_days || GoogleApiImportRun::DEFAULT_FETCH_DAYS %>日</small>
    </div>
    <div class="metric-card">
      <span>処理時間</span>
      <strong><%= google_api_run&.duration_seconds ? "#{google_api_run.duration_seconds.to_f.round(1)}秒" : "-" %></strong>
      <small>非同期Jobで取得します</small>
    </div>
  </div>

  <% if google_api_run&.failed? %>
    <div class="alert-banner alert-banner-danger">
      Google API取得に失敗しました。原因全文は実行履歴で確認してください。
      <%= link_to "実行履歴を見る", admin_execution_runs_path, class: "button secondary" %>
    </div>
  <% elsif google_api_run&.running? %>
    <div class="alert-banner alert-banner-info">
      Google API取得を実行中です。完了後にBusinessMetricDailyの更新件数が表示されます。
    </div>
  <% end %>

  <div class="inline-form">
    <div class="field compact-field">
      <label>GSC site_url</label>
      <input type="text" value="<%= analytics.settings[:gsc_site_url] %>" readonly>
    </div>
    <div class="field compact-field">
      <label>GA4 property_id</label>
      <input type="text" value="<%= analytics.settings[:ga4_property_id] %>" readonly>
    </div>
    <%= button_to "Google APIから取得",
                  import_google_api_business_path(@business),
                  method: :post,
                  class: "button",
                  data: { aicoo_loading_label: "Google API取得中..." },
                  form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "Google API取得中..." } },
                  disabled: analytics.settings[:gsc_site_url].blank? && analytics.settings[:ga4_property_id].blank? %>
    <%= button_to "GSCだけ取得",
                  import_gsc_business_path(@business),
                  method: :post,
                  class: "button secondary",
                  data: { aicoo_loading_label: "GSC取得中..." },
                  form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "GSC取得中..." } },
                  disabled: analytics.settings[:gsc_site_url].blank? %>
    <%= button_to "GA4だけ取得",
                  import_ga4_business_path(@business),
                  method: :post,
                  class: "button secondary",
                  data: { aicoo_loading_label: "GA4取得中..." },
                  form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "GA4取得中..." } },
                  disabled: analytics.settings[:ga4_property_id].blank? %>
    <%= link_to "Google紐付けを編集", edit_business_path(@business, return_to: business_path(@business, anchor: "business-google"), anchor: "data-source-link-settings"), class: "button secondary" %>
    <%= link_to "実行履歴", admin_execution_runs_path, class: "button secondary" %>
  </div>
</section>

<section class="dashboard-section" id="business-serp">
