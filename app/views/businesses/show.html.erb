                  <% if lp_evaluation.promotable? %>
                    <%= button_to "MVP開発へ進める",
                                  promote_to_mvp_business_path(@business),
                                  method: :post,
                                  params: { landing_page_id: landing_page.id },
                                  class: "button",
                                  data: { turbo_confirm: "このBusinessをMVP開発フェーズへ昇格します。よろしいですか？", disable_with: "MVP昇格中..." } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="aicoo-empty-state">このBusinessに紐づく公開LPはまだありません。</p>
  <% end %>
  <p class="aicoo-help-text">
    LPの公開状態は draft / scheduled / published / paused / archived で管理します。公開中LPだけが / と /lp と sitemap.xml に反映されます。
  </p>
</section>

