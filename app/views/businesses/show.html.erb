  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>日時</th>
          <th>DataSource</th>
          <th>種別</th>
          <th>ファイル名</th>
          <th>行数</th>
          <th>プレビュー</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_data_imports.each do |data_import| %>
          <tr>
            <td><%= l(data_import.imported_at, format: :short) %></td>
            <td><%= data_import.data_source.name %></td>
            <td><%= data_import.data_source.source_type %></td>
            <td><%= data_import.filename %></td>
            <td class="number"><%= data_import.row_count %></td>
            <td class="wide-text"><%= truncate(data_import.processed_text.presence || data_import.raw_text, length: 140) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>行動候補</h2>
    <p>この事業フォルダに属する ActionCandidate です。</p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>行動タイトル</th>
          <th>期待利益</th>
          <th>期待時給</th>
          <th>最終スコア</th>
          <th>状態</th>
        </tr>
      </thead>
      <tbody>
        <% @action_candidates.each do |action_candidate| %>
          <tr>
            <td><%= link_to action_candidate.title, action_candidate %></td>
            <td class="number"><%= number_to_currency(action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></td>
            <td class="number"><%= action_candidate.expected_hourly_value_yen.present? ? number_to_currency(action_candidate.expected_hourly_value_yen, unit: "¥", precision: 0) : "-" %></td>
            <td class="number"><%= number_with_precision(action_candidate.final_score, precision: 1) %></td>
            <td><span class="pill"><%= action_candidate.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<div class="actions">
  <%= link_to "事業一覧に戻る", businesses_path, class: "button secondary" %>
  <%= button_to "Destroy", @business, method: :delete, class: "danger" %>
</div>
</div>
