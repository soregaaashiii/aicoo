                <% if lp_url && landing_page.public_status.in?(%w[published paused]) %>
                  <%= link_to lp_url, lp_url, target: "_blank", rel: "noopener" %>
                <% else %>
                  -
                <% end %>
              </td>
              <td><span class="pill"><%= landing_page.public_status %></span></td>
              <td><%= landing_page.published_at ? l(landing_page.published_at, format: :short) : "-" %></td>
              <td><%= number_with_delimiter(lp_evaluation.pv) %></td>
              <td><%= number_with_delimiter(lp_evaluation.cta_clicks) %></td>
              <td><%= number_with_delimiter(lp_evaluation.cv) %></td>
              <td><%= lp_evaluation.pv.positive? ? number_to_percentage(lp_evaluation.cvr * 100, precision: 1) : "-" %></td>
              <td>
                <%= number_with_delimiter(lp_evaluation.gsc_clicks) %> clicks /
                <%= number_with_delimiter(lp_evaluation.gsc_impressions) %> imp
              </td>
              <td><%= lp_evaluation.trend_label %></td>
              <td><span class="pill status-<%= lp_evaluation.verdict == "poor" ? "warning" : "healthy" %>"><%= lp_evaluation.verdict %></span></td>
              <td><%= lp_evaluation.recommendation %></td>
              <td><%= lp_evaluation.improvement_count %>件</td>
              <td>
