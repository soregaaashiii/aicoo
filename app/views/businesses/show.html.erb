                  class: "button secondary",
                  data: { aicoo_loading_label: "GSC取得中..." },
                  form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "GSC取得中..." } },
                  disabled: analytics.settings[:gsc_site_url].blank? %>
    <%= button_to "GA4だけ取得",
                  import_ga4_business_path(@business),
                  method: :post,
                  class: "button secondary",
                  data: { aicoo_loading_label: "GA4取得中..." },
                  form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "GA4取得中..." } },
                  disabled: analytics.settings[:ga4_property_id].blank? %>
    <%= link_to "Google紐付けを編集", edit_business_path(@business, return_to: business_path(@business, anchor: "business-google"), anchor: "data-source-link-settings"), class: "button secondary" %>
    <%= link_to "Business別Google設定", google_settings_business_path(@business), class: "button secondary" %>
    <%= link_to "実行履歴", admin_execution_runs_path, class: "button secondary" %>
  </div>
</section>

<section class="dashboard-section" id="business-serp">
  <div class="section-heading">
    <h2>SERP競合分析</h2>
    <p>SERPは新規事業探索専用です。既存Business改善はGSC・GA4・内部データで判断します。</p>
  </div>

  <% serp_cost = Aicoo::CostEngine.new(business: @business).estimate("serp") %>
  <div class="metric-grid">
    <div class="metric-card">
      <span>SERP</span>
      <strong><%= @business.serp_enabled? ? "ON" : "OFF" %></strong>
    </div>
    <div class="metric-card">
      <span>Active検索クエリ</span>
      <strong><%= @business.business_serp_keywords.active.count %>件</strong>
    </div>
    <div class="metric-card">
      <span>SERP Queries</span>
      <strong><%= @business.serp_queries.enabled.count %>件</strong>
    </div>
    <div class="metric-card">
      <span>追加待ち候補</span>
      <strong><%= @business.business_serp_keywords.pending.count %>件</strong>
    </div>
    <div class="metric-card">
      <span>前回取得</span>
      <strong><%= @recent_serp_analyses.first&.analyzed_at ? l(@recent_serp_analyses.first.analyzed_at, format: :short) : "未実行" %></strong>
    </div>
  </div>

  <div class="aicoo-card aicoo-card-compact">
    <strong>SERP Queries</strong>
    <p>Daily Runで実行する検索クエリです。Priorityが小さいものから順に実行します。</p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Priority</th>
            <th>Query</th>
            <th>Category</th>
            <th>Enabled</th>
            <th>Last Run</th>
            <th>Success</th>
            <th>Failure</th>
          </tr>
        </thead>
        <tbody>
          <% @business.serp_queries.by_priority.limit(8).each do |query| %>
            <tr>
              <td><%= query.priority %></td>
              <td class="wide-text"><%= query.query %></td>
              <td><span class="pill"><%= query.category %></span></td>
              <td><span class="pill"><%= query.enabled? ? "ON" : "OFF" %></span></td>
              <td><%= query.last_run_at ? l(query.last_run_at, format: :short) : "-" %></td>
              <td><%= query.success_count %></td>
              <td><%= query.failure_count %></td>
            </tr>
          <% end %>
          <% if @business.serp_queries.empty? %>
            <tr><td colspan="7">SERP Queryはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="notice compact-notice">
      SERPは新規事業探索専用になりました。既存Businessの改善はGSC・GA4・内部データで判定します。
    </div>
  </div>

  <div class="aicoo-card aicoo-card-compact">
    <strong>SERP分析コスト</strong>
    <p>
      <span class="pill cost-level-<%= serp_cost.cost_level %>"><%= serp_cost.execution_mode %></span>
      予想コスト <%= number_to_currency(serp_cost.estimated_cost_yen, unit: "¥", precision: 0) %> /
      期待利益 <%= number_to_currency(serp_cost.expected_profit_yen, unit: "¥", precision: 0) %> /
      ROI <%= serp_cost.roi ? number_with_precision(serp_cost.roi, precision: 1) : "無料/未計算" %>
    </p>
    <p class="muted">既存Business改善はGSC・GA4・内部データを使います。SERPはCEO MODEの新規事業探索専用です。</p>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>AIで候補生成</h2>
    <p>Business情報と最新DataImportを材料に、行動候補を生成します。</p>
  </div>

  <%= form_with url: generate_ai_candidates_business_path(@business), method: :post, class: "inline-form" do |form| %>
    <div class="field compact-field">
      <%= form.label :action_count, "生成件数" %>
      <%= form.select :action_count, [[3, 3], [5, 5], [10, 10]], selected: 5 %>
    </div>
    <%= form.submit "AIで候補生成", class: "button" %>
  <% end %>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>データアップロード</h2>
    <p>CSV/TXTを判断材料として保存し、次回のAI候補生成に渡します。</p>
  </div>

  <%= form_with url: business_data_imports_path(@business), scope: :data_import, multipart: true, class: "form" do |form| %>
    <div class="grid">
      <div class="field">
        <%= form.label :source_type, "データ種別" %>
        <%= form.select :source_type, DataSource::SOURCE_TYPES.map { |type| [type.humanize, type] } %>
      </div>
      <div class="field">
        <%= form.label :name, "データソース名" %>
        <%= form.text_field :name, placeholder: "例: GSC 2026-06" %>
      </div>
      <div class="field">
        <%= form.label :status, "状態" %>
        <%= form.select :status, DataSource::STATUSES.map { |status| [status.humanize, status] } %>
      </div>
      <div class="field">
        <%= form.label :file, "CSV/TXTファイル" %>
        <%= form.file_field :file, accept: ".csv,.txt,text/csv,text/plain" %>
      </div>
    </div>
    <div class="field">
      <%= form.label :notes, "メモ" %>
      <%= form.textarea :notes, rows: 3 %>
    </div>
    <div class="actions">
      <%= form.submit "データアップロード", class: "button" %>
    </div>
  <% end %>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>判断材料</h2>
    <p>このBusinessに紐づくDataSourceと最新アップロードです。</p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>DataSource</th>
          <th>種別</th>
          <th>状態</th>
          <th>Import数</th>
          <th>最終更新</th>
          <th>最新ファイル</th>
          <th>行数</th>
        </tr>
      </thead>
      <tbody>
        <% @data_sources.each do |data_source| %>
          <% latest_import = data_source.data_imports.max_by(&:imported_at) %>
          <tr>
            <td><%= data_source.name %></td>
            <td><%= data_source.source_type %></td>
            <td><span class="pill"><%= data_source.status %></span></td>
            <td class="number"><%= data_source.data_imports.size %></td>
            <td><%= latest_import&.imported_at ? l(latest_import.imported_at, format: :short) : "-" %></td>
            <td><%= latest_import&.filename || "-" %></td>
            <td class="number"><%= latest_import&.row_count || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>DataImport一覧</h2>
    <p>手動アップロードとGSC自動取得の履歴です。</p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>日時</th>
          <th>DataSource</th>
          <th>種別</th>
          <th>ファイル名</th>
          <th>行数</th>
          <th>プレビュー</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_data_imports.each do |data_import| %>
          <tr>
            <td><%= l(data_import.imported_at, format: :short) %></td>
            <td><%= data_import.data_source.name %></td>
            <td><%= data_import.data_source.source_type %></td>
            <td><%= data_import.filename %></td>
            <td class="number"><%= data_import.row_count %></td>
            <td class="wide-text"><%= truncate(data_import.processed_text.presence || data_import.raw_text, length: 140) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="dashboard-section" id="ai-improvement-proposals">
  <div class="section-heading">
    <div>
      <h2>AI改善提案</h2>
      <p>このBusinessのActionCandidateとAutoRevisionTaskを、期待利益と実行しやすさで確認します。</p>
    </div>
    <%= link_to "今日の事業改善", owner_focus_path, class: "button secondary" %>
  </div>

  <div class="aicoo-grid aicoo-grid-2">
    <div class="aicoo-card aicoo-card-compact">
      <h3>改善候補</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>改善</th>
              <th>期待利益</th>
              <th>理由</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @ai_improvement_action_candidates.each do |candidate| %>
              <tr>
                <td><%= link_to candidate.title, candidate %></td>
                <td class="number"><%= number_to_currency(candidate.expected_profit_yen, unit: "¥", precision: 0) %></td>
                <td class="wide-text"><%= truncate(candidate.evaluation_reason.presence || candidate.description, length: 90) %></td>
                <td class="actions compact-actions">
                  <%= button_to "Codex用プロンプト作成",
                                generate_codex_prompt_draft_action_candidate_path(candidate),
                                method: :post,
                                class: "button secondary" %>
                </td>
              </tr>
            <% end %>
            <% if @ai_improvement_action_candidates.empty? %>
              <tr><td colspan="4">AI改善提案はまだありません。</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="aicoo-card aicoo-card-compact">
      <h3>Codex改修候補</h3>
      <div class="aicoo-inline-panel">
        <h4>このBusinessの送信待ちTask</h4>
        <p class="muted">Cloud Codex API連携は未実装です。プロンプトをコピーして手動送信し、送信後に記録してください。</p>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>改修</th>
                <th>状態</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody>
              <% @business_codex_waiting_tasks.each do |task| %>
                <tr>
                  <td><%= link_to task.title, task %></td>
                  <td><span class="pill"><%= task.status %></span></td>
                  <td class="actions compact-actions">
                    <button type="button"
                            class="button secondary"
                            onclick="navigator.clipboard.writeText(this.dataset.prompt)"
                            data-prompt="<%= h(task.codex_prompt) %>">
                      Codex用プロンプトをコピー
                    </button>
                    <%= link_to "プロンプト確認", export_codex_prompt_auto_revision_task_path(task), class: "button secondary" %>
                    <%= button_to "手動送信済みにする", mark_codex_submission_submitted_auto_revision_task_path(task), method: :patch, class: "button" %>
                  </td>
                </tr>
              <% end %>
              <% if @business_codex_waiting_tasks.empty? %>
                <tr><td colspan="3">このBusinessの送信待ちTaskはありません。</td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>改修</th>
              <th>状態</th>
              <th>リスク</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @ai_improvement_auto_revision_tasks.each do |task| %>
              <tr>
                <td><%= link_to task.title, task %></td>
                <td><span class="pill"><%= task.status %></span></td>
                <td><span class="pill"><%= task.risk_level %></span></td>
                <td class="actions compact-actions">
                  <%= link_to "プロンプト確認", export_codex_prompt_auto_revision_task_path(task), class: "button secondary" %>
                </td>
              </tr>
            <% end %>
            <% if @ai_improvement_auto_revision_tasks.empty? %>
              <tr><td colspan="4">Codex改修候補はまだありません。</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>行動候補</h2>
    <p>この事業フォルダに属する ActionCandidate です。</p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>行動タイトル</th>
          <th>期待利益</th>
          <th>期待時給</th>
          <th>最終スコア</th>
          <th>状態</th>
        </tr>
      </thead>
      <tbody>
        <% @action_candidates.each do |action_candidate| %>
          <tr>
            <td><%= link_to action_candidate.title, action_candidate %></td>
            <td class="number"><%= number_to_currency(action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></td>
            <td class="number"><%= action_candidate.expected_hourly_value_yen.present? ? number_to_currency(action_candidate.expected_hourly_value_yen, unit: "¥", precision: 0) : "-" %></td>
            <td class="number"><%= number_with_precision(action_candidate.final_score, precision: 1) %></td>
            <td><span class="pill"><%= action_candidate.status %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<div class="actions">
  <%= link_to "事業一覧に戻る", businesses_path, class: "button secondary" %>
  <% if @business.deleted? %>
    <%= button_to "復元",
                  restore_business_path(@business),
                  method: :patch,
                  class: "button",
                  data: { turbo_confirm: "「#{@business.name}」を復元します。" } %>
  <% else %>
    <%= form_with url: business_path(@business), method: :delete, local: true, class: "actions compact-actions" do %>
      <%= select_tag :deletion_reason,
                     options_for_select(BusinessesController::DELETION_REASONS, "その他"),
                     aria: { label: "削除理由" } %>
      <%= submit_tag "削除",
                     class: "button danger",
                     data: {
                       turbo_confirm: "「#{@business.name}」を削除しますか？\n事業一覧・ランキング・Daily Run・自動改修の対象外になります。\n関連データは保持され、後から復元できます。"
                     } %>
    <% end %>
  <% end %>
</div>
</div>
