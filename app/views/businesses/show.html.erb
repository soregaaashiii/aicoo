    <div class="metric-card"><span>今月 proxy_score</span><strong><%= number_with_precision(@business.current_month_proxy_score, precision: 2) %></strong></div>
    <div class="metric-card"><span>累計 proxy_score</span><strong><%= number_with_precision(@business.cumulative_proxy_score, precision: 2) %></strong></div>
