<% content_for :title, @business.name %>

<% header_actions = capture do %>
    <%= link_to "Edit", edit_business_path(@business), class: "button secondary" %>
    <%= link_to "LP・計測連携", business_lp_integration_path(@business), class: "button secondary" %>
    <%= link_to "Codex接続を開く", admin_codex_connection_path(business_id: @business.id, anchor: "codex-businesses"), class: "button secondary" %>
    <%= link_to "収益記録を追加", new_revenue_event_path(revenue_event: { business_id: @business.id }), class: "button secondary" %>
    <%= link_to "代理指標を追加", new_business_metric_daily_path(business_metric_daily: { business_id: @business.id }), class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: @business.name,
             description: "このBusinessのGoogle連携、SERP、LP、Daily Run、Learningをここから運用します。",
             active_main: :revenue,
             actions: header_actions %>

<%= render "navigation", business: @business, current_section: "概要" %>

<% production_access_url = normalize_public_access_url(@business.business_execution_profile&.production_url) %>
<% service_access_rows = @business_services.map { |service| [service, business_service_access_url(service)] } %>
<% visible_service_access_rows = service_access_rows.select { |_service, url| url.present? } %>
<% landing_page_access_rows = @business_landing_pages.map { |landing_page| [landing_page, business_landing_page_access_path(landing_page)] } %>
<% visible_landing_page_access_rows = landing_page_access_rows.select { |_landing_page, path| path.present? } %>
<% primary_service_row = visible_service_access_rows.first || service_access_rows.first %>
<% primary_business_service = primary_service_row&.first || @primary_business_service %>
<% service_access_url = primary_service_row&.last %>
<% access_overview = @business_access_overview %>
<% external_lp_url = normalize_public_access_url(access_overview.lp_public_url) %>
<% internal_lp_path = visible_landing_page_access_rows.first&.last %>
<% lp_access_url = external_lp_url.presence || internal_lp_path %>
<% lp_registered = access_overview.source_prototype.present? || visible_landing_page_access_rows.any? %>
<% lp_source_options = [
     ["Lovable GitHub", "lovable_github"],
     ["GitHub", "github"],
     ["公開URL", "public_url"],
     ["Figma", "figma"],
     ["ZIP", "zip_export"],
     ["手動", "manual"]
   ] %>

<section class="dashboard-section" id="business-access-urls">
  <div class="section-heading">
    <div>
      <h2>公開確認URL</h2>
      <p>事業一覧から作成されたサービスとLPの見た目を、まずここから確認します。</p>
    </div>
  </div>

  <div class="metric-grid business-access-grid">
    <div class="metric-card business-access-card" id="business-service-access-card">
      <span>Service</span>
      <% if service_access_url.present? %>
        <strong class="business-access-connected">接続済み</strong>
        <dl class="business-access-values">
          <dt>Service URL</dt>
          <dd><%= service_access_url %></dd>
          <dt>GitHubリポジトリ</dt>
          <dd><%= access_overview.app_repository_url.presence || "未設定" %></dd>
          <dt>ブランチ</dt>
          <dd><%= access_overview.app_branch %></dd>
        </dl>
      <% else %>
        <strong>URL未設定</strong>
        <small>Serviceの公開URLと実装リポジトリを、このカードから登録します。</small>
      <% end %>

      <div class="business-access-card-actions">
        <details class="business-access-editor">
          <summary class="button"><%= service_access_url.present? ? "編集" : "Service URLを登録" %></summary>
          <%= form_with url: service_business_access_settings_path(@business), method: :patch, scope: :service_access, class: "business-access-form" do |form| %>
            <%= form.hidden_field :business_service_id, value: primary_business_service&.id %>
            <div class="field">
              <%= form.label :service_url, "Service URL" %>
              <%= form.url_field :service_url, value: primary_business_service&.url, placeholder: "https://service.example.com" %>
            </div>
            <div class="field">
              <%= form.label :domain, "Domain" %>
              <%= form.text_field :domain, value: primary_business_service&.domain, placeholder: "service.example.com" %>
            </div>
            <div class="field">
              <%= form.label :github_repository, "GitHubリポジトリURL" %>
              <%= form.url_field :github_repository, value: access_overview.app_repository_url, placeholder: "https://github.com/owner/repository" %>
            </div>
            <div class="field">
              <%= form.label :branch, "ブランチ" %>
              <%= form.text_field :branch, value: access_overview.app_branch, placeholder: "main" %>
            </div>
            <div class="actions compact-actions">
              <%= form.submit "保存", class: "button" %>
              <%= link_to "キャンセル", business_path(@business, anchor: "business-access-urls"), class: "button secondary" %>
            </div>
          <% end %>
        </details>
        <% if service_access_url.present? %>
          <%= link_to "開く", service_access_url, class: "button secondary", target: "_blank", rel: "noopener" %>
        <% end %>
      </div>
    </div>

    <div class="metric-card business-access-card" id="business-lp-access-card">
      <span>LP</span>
      <% if lp_registered %>
        <strong class="business-access-connected">登録済み</strong>
        <dl class="business-access-values">
          <dt>作成元</dt>
          <dd><%= access_overview.source_prototype ? access_overview.lp_source_type_label : "AICOO LP" %></dd>
          <dt>リポジトリURL</dt>
          <dd><%= access_overview.lp_source_repository_url.presence || "未設定" %></dd>
          <dt>公開URL</dt>
          <dd><%= lp_access_url.presence || "未設定" %></dd>
          <dt>状態</dt>
          <dd><%= access_overview.source_prototype ? access_overview.lp_public_status_label : visible_landing_page_access_rows.first&.first&.public_status %></dd>
          <dt>最終同期日時</dt>
          <dd><%= access_overview.last_sync_at ? l(access_overview.last_sync_at, format: :short) : "未同期" %></dd>
        </dl>
      <% else %>
        <strong>公開LPなし</strong>
        <small>LP作成元・実装先・公開URLを、このカードから登録します。</small>
      <% end %>

      <div class="business-access-card-actions">
        <details class="business-access-editor">
          <summary class="button"><%= lp_registered ? "編集" : "LPを登録" %></summary>
          <%= form_with url: landing_page_business_access_settings_path(@business), method: :patch, scope: :lp_access, class: "business-access-form" do |form| %>
            <div class="field">
              <%= form.label :source_type, "LP作成元の種類" %>
              <%= form.select :source_type,
                              options_for_select(lp_source_options, access_overview.lp_source_type) %>
            </div>
            <div class="field">
              <%= form.label :source_repository_url, "LP作成元リポジトリURL" %>
              <%= form.url_field :source_repository_url, value: access_overview.lp_source_repository_url, placeholder: "https://github.com/owner/lp-source" %>
            </div>
            <div class="field">
              <%= form.label :source_branch, "LP作成元ブランチ" %>
              <%= form.text_field :source_branch, value: access_overview.lp_source_branch, placeholder: "main" %>
            </div>
            <div class="field">
              <%= form.label :lovable_project_url, "LovableプロジェクトURL" %>
              <%= form.url_field :lovable_project_url, value: access_overview.lovable_project_url, placeholder: "https://lovable.dev/projects/..." %>
            </div>
            <div class="field">
              <%= form.label :public_url, "公開LP URL" %>
              <%= form.url_field :public_url, value: access_overview.lp_public_url, placeholder: "https://service.example.com" %>
            </div>
            <div class="field">
              <%= form.label :public_status, "状態" %>
              <%= form.select :public_status, options_for_select([["下書き", "draft"], ["公開", "published"], ["一時停止", "paused"]], access_overview.lp_public_status) %>
            </div>
            <div class="field">
              <%= form.label :app_repository_url, "実装先リポジトリ" %>
              <%= form.url_field :app_repository_url, value: access_overview.app_repository_url, placeholder: "https://github.com/owner/service" %>
            </div>
            <div class="field">
              <%= form.label :app_branch, "実装先ブランチ" %>
              <%= form.text_field :app_branch, value: access_overview.app_branch, placeholder: "main" %>
            </div>
            <div class="actions compact-actions">
              <%= form.submit "保存", class: "button" %>
              <%= button_tag "LP取り込みタスクを作成", type: "submit", name: "commit_action", value: "create_task", class: "button secondary" %>
              <%= link_to "キャンセル", business_path(@business, anchor: "business-access-urls"), class: "button secondary" %>
            </div>
          <% end %>
        </details>
        <% if lp_access_url.present? %>
          <%= link_to "LPを開く", lp_access_url, class: "button secondary", target: "_blank", rel: "noopener" %>
        <% end %>
        <% if lp_registered && access_overview.app_repository_url.present? %>
          <%= button_to "LP取り込みタスクを作成",
                        landing_page_task_business_access_settings_path(@business),
                        method: :post,
                        class: "button secondary" %>
        <% end %>
      </div>
    </div>

    <div class="metric-card business-access-card" id="business-production-access-card">
      <span>Production URL</span>
      <% if production_access_url.present? %>
        <strong class="business-access-connected">接続済み</strong>
        <dl class="business-access-values">
          <dt>Production URL</dt>
          <dd><%= production_access_url %></dd>
          <dt>Render Service</dt>
          <dd><%= access_overview.render_service_name.presence || "未設定" %></dd>
          <dt>最終確認日時</dt>
          <dd><%= access_overview.last_verified_at ? l(access_overview.last_verified_at, format: :short) : "未確認" %></dd>
          <dt>ヘルスチェック結果</dt>
          <dd><%= access_overview.last_verification_status.presence || "未確認" %></dd>
        </dl>
      <% else %>
        <strong>未設定</strong>
        <small>本番URL・Render・Health Checkを、このカードから登録します。</small>
      <% end %>

      <div class="business-access-card-actions">
        <details class="business-access-editor">
          <summary class="button"><%= production_access_url.present? ? "編集" : "本番URLを登録" %></summary>
          <%= form_with url: production_business_access_settings_path(@business), method: :patch, scope: :production_access, class: "business-access-form" do |form| %>
            <div class="field">
              <%= form.label :production_url, "Production URL" %>
              <%= form.url_field :production_url, value: access_overview.production_url, placeholder: "https://service.example.com" %>
            </div>
            <div class="field">
              <%= form.label :health_check_url, "Health Check URL" %>
              <%= form.url_field :health_check_url, value: access_overview.health_check_url, placeholder: "https://service.example.com/up" %>
            </div>
            <div class="field">
              <%= form.label :render_service_name, "Render Service名" %>
              <%= form.text_field :render_service_name, value: access_overview.render_service_name, placeholder: "service-web" %>
            </div>
            <div class="field">
              <%= form.label :deploy_target, "Deploy Target" %>
              <%= form.select :deploy_target,
                              options_for_select(BusinessExecutionProfile::DEPLOY_TARGETS.map { |target| [target, target] }, access_overview.execution_profile&.deploy_target) %>
            </div>
            <div class="field checkbox-field">
              <%= form.check_box :auto_deploy_enabled, { checked: access_overview.auto_deploy_enabled? }, "1", "0" %>
              <%= form.label :auto_deploy_enabled, "自動デプロイを有効にする" %>
            </div>
            <div class="actions compact-actions">
              <%= form.submit "保存", class: "button" %>
              <%= link_to "キャンセル", business_path(@business, anchor: "business-access-urls"), class: "button secondary" %>
            </div>
          <% end %>
        </details>
        <% if production_access_url.present? %>
          <%= link_to "本番を開く", production_access_url, class: "button secondary", target: "_blank", rel: "noopener" %>
          <%= button_to "接続確認",
                        verify_production_business_access_settings_path(@business),
                        method: :post,
                        class: "button secondary" %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<section class="dashboard-section" id="business-lifecycle">
  <div class="section-heading">
    <div>
      <h2>事業ホーム</h2>
      <p>Idea、LP検証、サービス公開、改善・学習をこのBusiness配下で管理します。</p>
    </div>
    <div class="actions compact-actions">
      <%= link_to "Lifecycle変更", edit_business_path(@business, return_to: business_path(@business, anchor: "business-lifecycle")), class: "button secondary" %>
      <%= link_to "次にやる", owner_focus_path, class: "button secondary" %>
    </div>
  </div>
  <% period_30d_for_home = @business_analytics_summary.periods.fetch(30) %>
  <div class="metric-grid">
    <% if @system_statuses.present? %>
      <% %w[ga4 gsc serp daily_run traffic codex].each do |key| %>
        <% system_status = @system_statuses[key] %>
        <% next unless system_status %>
        <div class="metric-card status-<%= system_status.status_level %>">
          <span><%= system_status.label %></span>
          <strong><%= system_status.display_label %></strong>
          <small><%= system_status.reason %></small>
          <% if system_status.next_action.present? && system_status.detail_url.present? %>
            <%= link_to system_status.next_action, system_status.detail_url, class: "button secondary" %>
          <% end %>
          <% if Rails.env.development? %>
            <details>
              <summary>StatusResolver debug</summary>
              <pre><%= JSON.pretty_generate(system_status.to_h) %></pre>
            </details>
          <% end %>
        </div>
      <% end %>
    <% end %>
    <div class="metric-card">
      <span>現在フェーズ</span>
      <strong><%= lifecycle_stage_label(@business.lifecycle_stage) %></strong>
      <small><%= lifecycle_stage_description(@business.lifecycle_stage) %></small>
    </div>
    <div class="metric-card">
      <span>Business Type</span>
      <strong><%= business_type_label(@business.business_type) %></strong>
      <small>ActionCandidate生成Playbookに反映</small>
    </div>
    <div class="metric-card">
      <span>今日の状況</span>
      <strong><%= @pipeline_run.stuck? ? "要対応" : @pipeline_run.status %></strong>
      <small><%= @pipeline_run.stuck? ? @pipeline_run.stuck_reason : "Stage: #{stage_label(@pipeline_run.current_stage)}" %></small>
    </div>
    <div class="metric-card">
      <span>30日売上</span>
      <strong><%= number_to_currency(period_30d_for_home.revenue_yen, unit: "¥", precision: 0) %></strong>
      <small>Revenue / CV / クリックを統合</small>
    </div>
    <div class="metric-card">
      <span>改善候補</span>
      <strong><%= @business.action_candidates.where(status: %w[idea approved]).count %>件</strong>
      <small>改修開始・実行待ち</small>
    </div>
    <div class="metric-card">
      <span>LP状況</span>
      <strong><%= @landing_page_counts.fetch("published", 0) %> published</strong>
      <small>全<%= @business_landing_pages.count %>件</small>
    </div>
    <div class="metric-card">
      <span>Service状況</span>
      <strong><%= @business_services.where(status: "live").count %> live</strong>
      <small>全<%= @business_services.count %>件</small>
    </div>
    <div class="metric-card">
      <span>学習状態</span>
      <strong><%= @business_playbook&.learned? ? "学習中" : "不足" %></strong>
      <small>Playbook confidence <%= @business_playbook ? number_with_precision(@business_playbook.confidence_score, precision: 1) : "-" %></small>
    </div>
    <div class="metric-card">
      <span>次にやること</span>
      <strong><%= @pipeline_run.stuck? ? "Pipeline復旧" : "改善候補確認" %></strong>
      <small><%= @pipeline_run.stuck? ? @pipeline_run.recovery_message.to_s.truncate(60) : "Action / LP / Serviceを確認" %></small>
    </div>
  </div>
</section>

<section class="dashboard-section" id="business-prototypes">
  <div class="section-heading">
    <div>
      <h2>Prototypes</h2>
      <p>この事業に紐づくRepository、デザイン、公開URLを管理します。</p>
    </div>
    <span class="pill"><%= @business_prototypes.size %>件</span>
  </div>

  <% if @business_prototypes.any? %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>種別</th>
            <th>名前</th>
            <th>URL / 保存場所</th>
            <th>解析</th>
            <th>完成度</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @business_prototypes.each do |prototype| %>
            <tr>
              <td><span class="pill"><%= prototype.prototype_type_label %></span></td>
              <td><%= prototype.display_name %></td>
              <td class="prototype-location">
                <% if prototype.prototype_type.in?(BusinessPrototype::URL_TYPES) %>
                  <%= link_to truncate(prototype.location, length: 72), prototype.location, target: "_blank", rel: "noopener" %>
                <% else %>
                  <%= prototype.location %>
                <% end %>
              </td>
              <td><span class="pill status-<%= prototype.analysis_status == "failed" ? "critical" : "healthy" %>"><%= prototype.analysis_status %></span></td>
              <td><%= prototype.analysis.to_h["completion_percentage"].presence || "-" %><%= "%" if prototype.analysis.to_h["completion_percentage"].present? %></td>
              <td>
                <div class="actions compact-actions">
                  <%= link_to "編集", edit_business_business_prototype_path(@business, prototype), class: "button secondary" %>
                  <%= button_to "削除", business_business_prototype_path(@business, prototype), method: :delete, class: "button danger", data: { turbo_confirm: "このPrototypeを削除します。Business本体は削除されません。" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">Prototypeはまだ登録されていません。</div>
  <% end %>

  <details class="prototype-add-panel">
    <summary class="button secondary">Prototypeを追加</summary>
    <%= render "business_prototypes/form", business: @business, prototype: @business.business_prototypes.new %>
  </details>
</section>

<section class="dashboard-section" id="business-resource">
  <div class="section-heading">
    <div>
      <h2>運用負荷</h2>
      <p>このBusinessに今日時間を使う価値を、コスト・エラー・反応・改善候補から判断します。</p>
    </div>
    <span class="pill status-<%= @attention_score.score >= 20 ? "warning" : "healthy" %>">
      Attention Score <%= @attention_score.score %>
    </span>
  </div>
  <div class="metric-grid">
    <div class="metric-card">
      <span>Resource Status</span>
      <strong><%= resource_status_label(@business.resource_status) %></strong>
      <small><%= resource_status_description(@business.resource_status) %></small>
    </div>
    <div class="metric-card">
      <span>月額コスト</span>
      <strong><%= number_to_currency(@resource_summary.monthly_cost_yen, unit: "¥", precision: 0) %></strong>
      <small>
        API <%= number_to_currency(@resource_summary.estimated_api_cost_yen, unit: "¥", precision: 0) %> /
        AI <%= number_to_currency(@resource_summary.estimated_ai_cost_yen, unit: "¥", precision: 0) %> /
        Infra <%= number_to_currency(@resource_summary.estimated_infra_cost_yen, unit: "¥", precision: 0) %>
      </small>
    </div>
    <div class="metric-card">
      <span>推定保守時間</span>
      <strong><%= @resource_summary.estimated_maintenance_minutes %>分/月</strong>
      <small>エラー・問い合わせ・改善候補から推定</small>
    </div>
    <div class="metric-card">
      <span>エラー / 問い合わせ</span>
      <strong><%= @resource_summary.error_count %> / <%= @resource_summary.inquiry_count %></strong>
      <small>直近30日</small>
    </div>
    <div class="metric-card">
      <span>最終改善日</span>
      <strong><%= @resource_summary.last_improvement_at ? l(@resource_summary.last_improvement_at, format: :short) : "-" %></strong>
      <small>Action / Revision / Activity</small>
    </div>
    <div class="metric-card">
      <span>最終反応日</span>
      <strong><%= @resource_summary.last_reaction_at ? l(@resource_summary.last_reaction_at, format: :short) : "-" %></strong>
      <small>LP / Signup / Metric</small>
    </div>
    <div class="metric-card">
      <span>最終売上日</span>
      <strong><%= @resource_summary.last_revenue_on || "-" %></strong>
      <small>RevenueEvent</small>
    </div>
    <div class="metric-card">
      <span>次回確認予定日</span>
      <strong><%= @resource_summary.next_review_on || "-" %></strong>
      <small><%= @resource_summary.auto_snooze_reason %></small>
    </div>
  </div>
  <div class="aicoo-grid aicoo-grid-2">
    <div class="aicoo-card aicoo-card-compact">
      <h3>Attention理由</h3>
      <ul class="compact-list">
        <% @attention_score.reasons.each do |reason| %>
          <li><%= reason %></li>
        <% end %>
      </ul>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Owner操作で運用状態を変更</h3>
      <div class="actions compact-actions">
        <% Business::RESOURCE_STATUSES.each do |status| %>
          <%= button_to resource_status_label(status),
                        update_resource_status_business_path(@business),
                        method: :patch,
                        params: { resource_status: status, reason: "Business詳細からOwner操作で#{status}へ変更" },
                        class: @business.resource_status == status ? "button" : "button secondary",
                        data: { turbo_confirm: "運用状態を#{status}へ変更します。自動変更ではなくOwner操作として記録します。" } %>
        <% end %>
      </div>
      <% if @resource_summary.auto_snooze_recommended %>
        <p class="aicoo-help-text">Watch提案: <%= @resource_summary.auto_snooze_reason %></p>
      <% end %>
    </div>
  </div>
</section>

<section class="dashboard-section" id="business-scaling">
  <div class="section-heading">
    <div>
      <h2>Scaling評価</h2>
      <p>production状態のBusinessを、売上・継続・CVR・改善余地からScalingへ進めるか判断します。</p>
    </div>
    <% if @scaling_evaluation.promotable? %>
      <%= button_to "Scalingへ進める",
                    promote_to_scaling_business_path(@business),
                    method: :post,
                    class: "button",
                    data: { turbo_confirm: "このBusinessをScalingフェーズへ昇格します。よろしいですか？", disable_with: "Scaling昇格中..." } %>
    <% end %>
  </div>
  <div class="metric-grid">
    <div class="metric-card">
      <span>判定</span>
      <strong><%= @scaling_evaluation.verdict %></strong>
      <small>推奨投資先: <%= @scaling_evaluation.recommended_investment %></small>
    </div>
    <div class="metric-card">
      <span>月間売上 / 粗利</span>
      <strong><%= number_to_currency(@scaling_evaluation.monthly_revenue_yen, unit: "¥", precision: 0) %></strong>
      <small>粗利 <%= number_to_currency(@scaling_evaluation.gross_profit_yen, unit: "¥", precision: 0) %></small>
    </div>
    <div class="metric-card">
      <span>有料ユーザー</span>
      <strong><%= number_with_delimiter(@scaling_evaluation.paid_users) %>人</strong>
      <small>LTV仮説 <%= number_to_currency(@scaling_evaluation.ltv_hypothesis_yen, unit: "¥", precision: 0) %></small>
    </div>
    <div class="metric-card">
      <span>CAC仮説</span>
      <strong><%= number_to_currency(@scaling_evaluation.cac_hypothesis_yen, unit: "¥", precision: 0) %></strong>
      <small>LTV/CACを確認</small>
    </div>
    <div class="metric-card">
      <span>継続率 / 解約率</span>
      <strong><%= number_to_percentage(@scaling_evaluation.retention_rate * 100, precision: 1) %></strong>
      <small>解約率 <%= number_to_percentage(@scaling_evaluation.churn_rate * 100, precision: 1) %></small>
    </div>
    <div class="metric-card">
      <span>CVR</span>
      <strong><%= number_to_percentage(@scaling_evaluation.cvr * 100, precision: 1) %></strong>
      <small>直近30日</small>
    </div>
    <div class="metric-card">
      <span>トレンド</span>
      <strong><%= @scaling_evaluation.trend_7d_label %></strong>
      <small>30日: <%= @scaling_evaluation.trend_30d_label %></small>
    </div>
    <div class="metric-card">
      <span>改善余地</span>
      <strong><%= @scaling_evaluation.improvement_room.first %></strong>
      <small><%= @scaling_evaluation.improvement_room.drop(1).join(" / ").presence || "優先施策を絞り込み済み" %></small>
    </div>
  </div>
  <div class="aicoo-card aicoo-card-compact">
    <div class="section-heading compact">
      <div>
        <h3>Scaling Ready Check</h3>
        <p>投資を増やす前に、データ・仮説・改善候補が揃っているか確認します。</p>
      </div>
      <span class="pill status-<%= @scaling_ready_check.ready? ? "healthy" : "warning" %>">
        <%= @scaling_ready_check.ready? ? "Scaling可能" : "不足あり" %>
      </span>
    </div>
    <div class="system-status-grid compact">
      <% @scaling_ready_check.checks.each do |check| %>
        <div class="system-status-card status-<%= check.passed ? "healthy" : "warning" %>">
          <span><%= check.label %></span>
          <strong><%= check.passed ? "OK" : "要確認" %></strong>
          <small><%= check.message %></small>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%= render "setup_wizard",
           business: @business,
           analytics: @business_analytics_summary,
           recent_serp_analyses: @recent_serp_analyses,
           landing_page_counts: @landing_page_counts,
           system_statuses: @system_statuses %>

<%= render @business %>

<section class="dashboard-section" id="business-overview">
  <div class="section-heading">
    <div>
      <h2>概要</h2>
      <p>Business Analytics: GSC / GA4 / Revenue / Action / Learning をこのBusiness単位で確認します。</p>
    </div>
    <div class="actions compact-actions">
      <%= link_to "Google", "#business-google", class: "button secondary" %>
      <%= link_to "SERP", "#business-serp", class: "button secondary" %>
      <%= link_to "LP", "#business-lp", class: "button secondary" %>
      <%= link_to "Service", "#business-services", class: "button secondary" %>
      <%= link_to "Timeline", "#business-timeline", class: "button secondary" %>
      <%= link_to "Daily Run", "#business-daily-run", class: "button secondary" %>
      <%= link_to "Learning", "#business-learning", class: "button secondary" %>
    </div>
  </div>

  <% analytics = @business_analytics_summary %>
  <% period_7d = analytics.periods.fetch(7) %>
  <% period_30d = analytics.periods.fetch(30) %>

  <div class="business-analytics-overview">
    <div class="metric-card">
      <span>Health</span>
      <strong><%= analytics.health ? number_with_precision(analytics.health.health_score, precision: 1) : "データ不足" %></strong>
      <small><%= analytics.warning_count %> warnings</small>
    </div>
    <div class="metric-card">
      <span>Last Sync</span>
      <strong><%= analytics.last_sync_at ? l(analytics.last_sync_at, format: :short) : "未接続" %></strong>
      <small>GSC / GA4 / Revenue</small>
    </div>
    <div class="metric-card">
      <span>GSC clicks 7日 / 30日</span>
      <strong><%= number_with_delimiter(period_7d.gsc_clicks) %> / <%= number_with_delimiter(period_30d.gsc_clicks) %></strong>
      <small>CTR <%= business_analytics_value(period_30d.gsc_ctr, percentage: true) %></small>
    </div>
    <div class="metric-card">
      <span>GA4 sessions 7日 / 30日</span>
      <strong><%= number_with_delimiter(period_7d.ga4_sessions) %> / <%= number_with_delimiter(period_30d.ga4_sessions) %></strong>
      <small>pageviews <%= number_with_delimiter(period_30d.ga4_pageviews) %></small>
    </div>
    <div class="metric-card">
      <span>Engagement</span>
      <strong><%= number_with_precision(period_30d.engagement_score, precision: 1) %>/100</strong>
      <small>
        滞在 <%= number_with_precision(period_30d.average_engagement_time_seconds, precision: 0) %>秒 /
        回遊 <%= number_with_precision(period_30d.views_per_session, precision: 2) %>
      </small>
    </div>
    <div class="metric-card">
      <span>Revenue 7日 / 30日</span>
      <strong><%= number_to_currency(period_7d.revenue_yen, unit: "¥", precision: 0) %> / <%= number_to_currency(period_30d.revenue_yen, unit: "¥", precision: 0) %></strong>
      <small>RevenueEvent</small>
    </div>
    <div class="metric-card">
      <span>Pending Actions</span>
      <strong><%= period_30d.pending_actions %></strong>
      <small>ActionCandidate</small>
    </div>
  </div>

  <% if analytics.warnings.any? %>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Connection / Data Warnings</h3>
      <ul class="compact-list">
        <% analytics.warnings.each do |warning| %>
          <li><%= warning %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="aicoo-card aicoo-card-compact">
    <div class="section-heading">
      <div>
        <h3>Connection Status</h3>
        <p>このBusinessが使う分析ツールの紐付け状態です。</p>
      </div>
      <%= link_to "紐付け設定", edit_business_path(@business, anchor: "data-source-link-settings"), class: "button secondary" %>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <% @business_data_source_statuses.each do |status| %>
        <div class="metric-card">
          <span><%= status.source_key.upcase %></span>
          <strong><%= status.status_label %></strong>
          <small>
            <%= status.connection_summary %>
            <% if status.last_sync_at %>
              / 最終 <%= l(status.last_sync_at, format: :short) %>
            <% end %>
          </small>
        </div>
      <% end %>
      <% codex_status = @data_source_settings_presenter.codex_status(@business) %>
      <div class="metric-card">
        <span>CODEX</span>
        <strong><%= codex_status.status_label %></strong>
        <small><%= codex_status.summary %></small>
      </div>
    </div>
  </div>

  <% if @suelog_db_health %>
    <div class="aicoo-card aicoo-card-compact" id="suelog-db-status">
      <div class="section-heading">
        <div>
          <h3>吸えログDB連携</h3>
          <p>吸えログ本番PostgreSQLを読み取り専用で参照し、店舗確認・記事候補の判断に使います。</p>
        </div>
        <span class="pill status-<%= @suelog_db_health.success? ? "healthy" : "warning" %>">
          <%= @suelog_db_health.success? ? "接続済み" : "スキップ" %>
        </span>
      </div>
      <div class="metric-grid aicoo-owner-secondary">
        <div class="metric-card">
          <span>Shop</span>
          <strong><%= @suelog_db_health.shops_count || "-" %></strong>
          <small>shops</small>
        </div>
        <div class="metric-card">
          <span>Article</span>
          <strong><%= @suelog_db_health.articles_count || "-" %></strong>
          <small>articles</small>
        </div>
        <div class="metric-card">
          <span>ShopClick 30日</span>
          <strong><%= @suelog_db_health.shop_clicks_count || "-" %></strong>
          <small>shop_clicks</small>
        </div>
        <div class="metric-card">
          <span>今回生成</span>
          <strong><%= @suelog_db_candidate_counts.to_h.values.sum %>件</strong>
          <small>
            喫煙確認 <%= @suelog_db_candidate_counts.to_h["smoking_info_verify"].to_i %> /
            電話確認 <%= @suelog_db_candidate_counts.to_h["shop_phone_verify"].to_i %> /
            新規記事 <%= @suelog_db_candidate_counts.to_h["article_create"].to_i %> /
            記事改訂 <%= @suelog_db_candidate_counts.to_h["article_update"].to_i %>
          </small>
        </div>
      </div>
      <% unless @suelog_db_health.success? %>
        <p class="aicoo-empty-state">理由: <%= @suelog_db_health.code %> / <%= @suelog_db_health.message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="aicoo-card aicoo-card-compact" id="auto-revision">
    <div class="section-heading">
      <div>
        <h3>自動改訂 / 自動デプロイ</h3>
        <p>このBusinessだけの改訂・Deployループ設定です。AutomaticでもDeploy Precheckに失敗した場合はOwner確認へ落とします。</p>
      </div>
    </div>
    <%= form_with model: @business, method: :patch, class: "aicoo-form" do |form| %>
      <%= hidden_field_tag :return_to, business_path(@business, anchor: "auto-revision") %>
      <h4>Auto Build Policy</h4>
      <div class="metric-grid aicoo-owner-secondary">
        <div class="metric-card"><span>Auto Build</span><strong><%= @business.auto_build_enabled? ? "ON" : "OFF" %></strong></div>
        <div class="metric-card"><span>Owner確認</span><strong><%= @business.auto_build_requires_approval? ? "必須" : "不要" %></strong></div>
        <div class="metric-card"><span>Risk</span><strong><%= @business.auto_build_risk_level %></strong></div>
        <div class="metric-card"><span>新規LP自動Deploy</span><strong><%= @business.new_lp_auto_deploy_enabled? ? "ON" : "OFF" %></strong></div>
        <div class="metric-card"><span>Deploy停止</span><strong><%= @business.auto_deploy_suspended? ? "停止中" : "稼働可" %></strong></div>
        <div class="metric-card"><span>Build Queue</span><strong><%= @business.auto_build_tasks.active.count %>件</strong></div>
      </div>
      <label>
        <%= form.check_box :auto_build_enabled %>
        Auto Build対象にする
      </label>
      <label>
        <%= form.check_box :auto_build_requires_approval %>
        Owner確認を必須にする
      </label>
      <label>
        <%= form.check_box :new_lp_auto_deploy_enabled %>
        新規LP/Lab Businessに限り低リスク自動merge/deployを許可する
      </label>
      <label>
        <%= form.check_box :auto_deploy_suspended %>
        自動deployを停止する
      </label>
      <% if @business.auto_deploy_suspended? %>
        <p class="error-toast">停止理由: <%= @business.auto_deploy_suspended_reason.presence || "未記録" %></p>
      <% end %>
      <div class="field">
        <%= form.label :auto_build_risk_level, "Risk Level" %>
        <%= form.select :auto_build_risk_level, Business::AUTO_BUILD_RISK_LEVELS.map { |level| [level, level] } %>
      </div>
      <p class="aicoo-lab-help">新規LP自動Deployは、Idea / LP検証 / MVP、収益なし、production扱いでないBusiness、Risk LOWのみ有効です。</p>

      <h4>Auto Revision Mode</h4>
      <div class="aicoo-grid aicoo-grid-3">
        <% Business::AUTO_REVISION_MODES.each do |mode| %>
          <label class="aicoo-card aicoo-card-compact">
            <%= form.radio_button :auto_revision_mode, mode %>
            <strong><%= auto_revision_mode_label(mode) %></strong>
            <small><%= auto_revision_mode_description(mode) %></small>
          </label>
        <% end %>
      </div>
      <% if @business.automatic_auto_revision? %>
        <div class="error-toast">現在このBusinessは自動改訂対象です。低リスクのみ自動でCodex投入準備まで進みます。</div>
      <% end %>

      <h4>Auto Deploy Mode</h4>
      <div class="aicoo-grid aicoo-grid-3">
        <% Business::AUTO_DEPLOY_MODES.each do |mode| %>
          <label class="aicoo-card aicoo-card-compact">
            <%= form.radio_button :auto_deploy_mode, mode %>
            <strong><%= auto_deploy_mode_label(mode) %></strong>
            <small><%= auto_deploy_mode_description(mode) %></small>
          </label>
        <% end %>
      </div>
      <% if @business.automatic_auto_deploy? %>
        <div class="error-toast">現在このBusinessは自動デプロイ対象です。Deploy前にテスト成功、Git clean、rollback commit、Google異常なしを確認します。</div>
      <% end %>
      <div class="actions compact-actions">
        <%= form.submit "自動設定を保存", class: "button secondary" %>
        <%= link_to "Codex準備前を見る", auto_revision_tasks_path(status: "waiting_approval"), class: "button secondary" %>
      </div>
    <% end %>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>開始</th>
            <th>状態</th>
            <th>Risk</th>
            <th>Task</th>
            <th>変更</th>
            <th>Test</th>
            <th>Deploy</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @auto_revision_run_logs.each do |log| %>
            <tr>
              <td><%= log.started_at ? l(log.started_at, format: :short) : l(log.created_at, format: :short) %></td>
              <td><span class="pill"><%= log.status %></span></td>
              <td><%= log.risk_level.presence || "-" %></td>
              <td><%= log.auto_revision_task ? link_to(log.auto_revision_task.title, log.auto_revision_task) : "-" %></td>
              <td class="number"><%= log.changed_files_count %></td>
              <td><%= log.test_result.presence || "-" %></td>
              <td><%= log.deploy_result.presence || "Deploy確認待ち" %></td>
              <td>
                <%= button_to "Rollback",
                              admin_auto_revision_run_log_rollback_path(log),
                              method: :patch,
                              class: "button secondary",
                              data: { turbo_confirm: "この自動改訂ログにRollback requestedを記録しますか？" } %>
              </td>
            </tr>
          <% end %>
          <% if @auto_revision_run_logs.empty? %>
            <tr><td colspan="8">自動改訂ログはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <section class="dashboard-section" id="pipeline-recovery">
    <div class="section-heading">
      <div>
        <h3>Pipeline復旧</h3>
        <p>Businessの自動ループが止まった時だけ、原因と復旧操作を確認します。</p>
      </div>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>Pipeline</span><strong><%= @pipeline_run.status %></strong></div>
      <div class="metric-card"><span>現在Stage</span><strong><%= stage_label(@pipeline_run.current_stage) %></strong></div>
      <div class="metric-card"><span>詰まり</span><strong><%= @pipeline_run.stuck? ? @pipeline_run.stuck_reason : "なし" %></strong></div>
      <div class="metric-card"><span>自動復旧</span><strong><%= @pipeline_run.auto_recoverable? ? "可能" : "手動確認" %></strong></div>
    </div>
    <% if @pipeline_run.stuck? %>
      <div class="notice-toast">
        <strong>Pipelineが停止しています。</strong>
        <p><%= @pipeline_run.recovery_message.presence || "原因を確認して復旧操作を選んでください。" %></p>
        <div class="actions compact-actions">
          <%= button_to "再試行", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "retry" }, class: "button secondary" %>
          <%= button_to "スキップ", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "skip" }, class: "button secondary" %>
          <%= button_to "次へ進む", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "approve" }, class: "button secondary" %>
          <%= button_to "停止", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "stop" }, class: "button secondary" %>
          <%= button_to "終了", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "end" }, class: "button secondary", data: { turbo_confirm: "このPipelineを終了しますか？" } %>
          <a href="#pipeline-recovery-log-table" class="button secondary">復旧ログを見る</a>
        </div>
      </div>
    <% end %>
    <div class="table-wrap" id="pipeline-recovery-log-table">
      <table>
        <thead>
          <tr>
            <th>日時</th>
            <th>Stage</th>
            <th>理由</th>
            <th>操作</th>
            <th>結果</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          <% @pipeline_recovery_logs.each do |log| %>
            <tr>
              <td><%= l(log.executed_at, format: :short) %></td>
              <td><%= stage_label(log.stage) %></td>
              <td><%= log.stuck_reason %></td>
              <td><%= log.action %></td>
              <td><%= log.success? ? "成功" : "失敗" %></td>
              <td><%= truncate(log.error_message.presence || "-", length: 80) %></td>
            </tr>
          <% end %>
          <% if @pipeline_recovery_logs.empty? %>
            <tr><td colspan="6">復旧ログはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="business-analytics-status-grid">
    <div class="aicoo-card aicoo-card-compact">
      <h3>GSC</h3>
      <p><%= analytics.data_status[:gsc_connected] ? "接続済み" : "未接続 / データ不足" %></p>
      <small>clicks / impressions / CTR / average_position</small>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>GA4</h3>
      <p><%= analytics.data_status[:ga4_connected] ? "接続済み" : "未接続 / データ不足" %></p>
      <small>sessions / pageviews / active_users / conversions</small>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Engagement</h3>
      <p><%= analytics.data_status[:has_engagement_data] ? "データあり" : "データ不足" %></p>
      <small>滞在時間 / 回遊率 / Engagement Rate / CV率 / Scroll</small>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Revenue</h3>
      <p><%= analytics.data_status[:has_revenue_data] ? "データあり" : "データ不足" %></p>
      <small>revenue_yen / affiliate_clicks / phone_clicks / map_clicks</small>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Learning</h3>
      <p><%= analytics.data_status[:has_learning_data] ? "学習データあり" : "データ不足" %></p>
      <small>Decision Log / Playbook / Practicality / Evidence</small>
    </div>
  </div>

  <div class="section-heading">
    <h2>Data Source Cost</h2>
    <p>分析できるかではなく、分析する価値があるかを確認します。</p>
  </div>
  <div class="business-analytics-status-grid">
    <% analytics.cost_estimates.select { |estimate| %w[gsc ga4 serp explore x youtube openai].include?(estimate.source_key) }.each do |estimate| %>
      <div class="aicoo-card aicoo-card-compact">
        <h3><%= estimate.name %></h3>
        <p>
          <span class="pill cost-level-<%= estimate.cost_level %>"><%= estimate.execution_mode %></span>
          <span class="pill status-<%= estimate.connection_status_level %>"><%= estimate.connection_label || "未紐付け" %></span>
          <%= estimate.business_enabled ? "利用ON" : "BusinessでOFF" %>
        </p>
        <small>
          予想コスト <%= number_to_currency(estimate.estimated_cost_yen, unit: "¥", precision: 0) %> /
          期待利益 <%= number_to_currency(estimate.expected_profit_yen, unit: "¥", precision: 0) %> /
          ROI <%= estimate.roi ? number_with_precision(estimate.roi, precision: 1) : "無料/未計算" %><br>
          接続先: <%= estimate.connection_summary || "詳細未設定" %>
        </small>
      </div>
    <% end %>
  </div>
  <div class="actions compact-actions">
    <%= link_to "Data Source紐付けを編集", edit_business_path(@business, anchor: "data-source-link-settings"), class: "button secondary" %>
  </div>

  <div class="section-heading">
    <h2>Analysis Sources</h2>
    <p>今日このBusinessで回す価値が高い分析候補です。Manualは実行前にコストとROIを確認します。</p>
  </div>
  <% if analytics.analysis_candidates.any? %>
    <div class="business-analytics-status-grid">
      <% analytics.analysis_candidates.each do |candidate| %>
        <div class="aicoo-card aicoo-card-compact">
          <h3><%= candidate.display_name %></h3>
          <p>
            <span class="pill cost-level-<%= candidate.manual? ? "high" : candidate.execution_mode %>"><%= candidate.execution_mode %></span>
            <span class="pill status-<%= candidate.status == "pending" ? "warning" : "healthy" %>"><%= candidate.status %></span>
          </p>
          <small>
            期待値 <%= number_to_currency(candidate.expected_value_yen, unit: "¥", precision: 0) %> /
            予想コスト <%= number_to_currency(candidate.estimated_cost_yen, unit: "¥", precision: 0) %> /
            ROI <%= candidate.roi_label %><br>
            Last Run: <%= candidate.last_run_at ? l(candidate.last_run_at, format: :short) : "未実行" %><br>
            <%= candidate.reason %>
          </small>
        </div>
      <% end %>
    </div>
  <% else %>
