<% content_for :title, @business.name %>

<% header_actions = capture do %>
    <%= link_to "Edit", edit_business_path(@business), class: "button secondary" %>
    <% unless @business.aicoo_internal_codex? %>
      <% if @business.business_execution_profile %>
        <%= link_to "Execution Profile編集", edit_admin_business_execution_profile_path(@business.business_execution_profile), class: "button secondary" %>
      <% else %>
        <%= link_to "Execution Profile作成", new_admin_business_execution_profile_path(business_id: @business.id), class: "button secondary" %>
      <% end %>
    <% end %>
    <%= link_to "収益記録を追加", new_revenue_event_path(revenue_event: { business_id: @business.id }), class: "button secondary" %>
    <%= link_to "代理指標を追加", new_business_metric_daily_path(business_metric_daily: { business_id: @business.id }), class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: @business.name,
             description: "このBusinessのGoogle連携、SERP、LP、Daily Run、Learningをここから運用します。",
             active_main: :revenue,
             actions: header_actions %>

<%= render "navigation", business: @business, current_section: "概要" %>
<%= render "setup_wizard",
           business: @business,
           analytics: @business_analytics_summary,
           recent_serp_analyses: @recent_serp_analyses,
           landing_page_counts: @landing_page_counts %>

<%= render @business %>

<section class="dashboard-section" id="business-overview">
  <div class="section-heading">
    <div>
      <h2>概要</h2>
      <p>Business Analytics Dashboard: GSC / GA4 / Revenue / Action / Learning をこのBusiness単位で確認します。</p>
    </div>
    <div class="actions compact-actions">
      <%= link_to "Google", "#business-google", class: "button secondary" %>
      <%= link_to "SERP", "#business-serp", class: "button secondary" %>
      <%= link_to "LP", "#business-lp", class: "button secondary" %>
      <%= link_to "Daily Run", "#business-daily-run", class: "button secondary" %>
      <%= link_to "Learning", "#business-learning", class: "button secondary" %>
    </div>
  </div>

  <% analytics = @business_analytics_summary %>
  <% period_7d = analytics.periods.fetch(7) %>
  <% period_30d = analytics.periods.fetch(30) %>

  <div class="business-analytics-overview">
    <div class="metric-card">
      <span>Health</span>
      <strong><%= analytics.health ? number_with_precision(analytics.health.health_score, precision: 1) : "データ不足" %></strong>
      <small><%= analytics.warning_count %> warnings</small>
    </div>
    <div class="metric-card">
      <span>Last Sync</span>
      <strong><%= analytics.last_sync_at ? l(analytics.last_sync_at, format: :short) : "未接続" %></strong>
      <small>GSC / GA4 / Revenue</small>
    </div>
    <div class="metric-card">
      <span>GSC clicks 7日 / 30日</span>
      <strong><%= number_with_delimiter(period_7d.gsc_clicks) %> / <%= number_with_delimiter(period_30d.gsc_clicks) %></strong>
      <small>CTR <%= business_analytics_value(period_30d.gsc_ctr, percentage: true) %></small>
    </div>
    <div class="metric-card">
      <span>GA4 sessions 7日 / 30日</span>
      <strong><%= number_with_delimiter(period_7d.ga4_sessions) %> / <%= number_with_delimiter(period_30d.ga4_sessions) %></strong>
      <small>pageviews <%= number_with_delimiter(period_30d.ga4_pageviews) %></small>
    </div>
    <div class="metric-card">
      <span>Engagement</span>
      <strong><%= number_with_precision(period_30d.engagement_score, precision: 1) %>/100</strong>
      <small>
        滞在 <%= number_with_precision(period_30d.average_engagement_time_seconds, precision: 0) %>秒 /
        回遊 <%= number_with_precision(period_30d.views_per_session, precision: 2) %>
      </small>
    </div>
    <div class="metric-card">
      <span>Revenue 7日 / 30日</span>
      <strong><%= number_to_currency(period_7d.revenue_yen, unit: "¥", precision: 0) %> / <%= number_to_currency(period_30d.revenue_yen, unit: "¥", precision: 0) %></strong>
      <small>RevenueEvent</small>
    </div>
    <div class="metric-card">
      <span>Pending Actions</span>
      <strong><%= period_30d.pending_actions %></strong>
      <small>ActionCandidate</small>
    </div>
  </div>

  <% if analytics.warnings.any? %>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Connection / Data Warnings</h3>
      <ul class="compact-list">
        <% analytics.warnings.each do |warning| %>
          <li><%= warning %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="aicoo-card aicoo-card-compact">
    <div class="section-heading">
      <div>
        <h3>Connection Status</h3>
        <p>このBusinessが使う分析ツールの紐付け状態です。</p>
      </div>
      <%= link_to "紐付け設定", edit_business_path(@business, anchor: "data-source-link-settings"), class: "button secondary" %>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <% @business_data_source_statuses.each do |status| %>
        <div class="metric-card">
          <span><%= status.source_key.upcase %></span>
          <strong><%= status.status_label %></strong>
          <small>
            <%= status.connection_summary %>
            <% if status.last_sync_at %>
              / 最終 <%= l(status.last_sync_at, format: :short) %>
            <% end %>
          </small>
        </div>
      <% end %>
      <% codex_status = @data_source_settings_presenter.codex_status(@business) %>
      <div class="metric-card">
        <span>CODEX</span>
        <strong><%= codex_status.status_label %></strong>
        <small><%= codex_status.summary %></small>
      </div>
    </div>
  </div>

  <div class="aicoo-card aicoo-card-compact" id="auto-revision">
    <div class="section-heading">
      <div>
        <h3>自動改訂</h3>
        <p>このBusinessだけの改訂ループ設定です。AutomaticでもDeployは最後に承認します。</p>
      </div>
    </div>
    <%= form_with model: @business, method: :patch, class: "aicoo-form" do |form| %>
      <%= hidden_field_tag :return_to, business_path(@business, anchor: "auto-revision") %>
      <div class="aicoo-grid aicoo-grid-3">
        <% Business::AUTO_REVISION_MODES.each do |mode| %>
          <label class="aicoo-card aicoo-card-compact">
            <%= form.radio_button :auto_revision_mode, mode %>
            <strong><%= auto_revision_mode_label(mode) %></strong>
            <small><%= auto_revision_mode_description(mode) %></small>
          </label>
        <% end %>
      </div>
      <% if @business.automatic_auto_revision? %>
        <div class="error-toast">現在このBusinessは自動改訂対象です。低リスクのみ自動でCodex投入準備まで進みます。</div>
      <% end %>
      <div class="actions compact-actions">
        <%= form.submit "自動改訂設定を保存", class: "button secondary" %>
        <%= link_to "承認待ちを見る", auto_revision_tasks_path(status: "waiting_approval"), class: "button secondary" %>
      </div>
    <% end %>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>開始</th>
            <th>状態</th>
            <th>Risk</th>
            <th>Task</th>
            <th>変更</th>
            <th>Test</th>
            <th>Deploy</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @auto_revision_run_logs.each do |log| %>
            <tr>
              <td><%= log.started_at ? l(log.started_at, format: :short) : l(log.created_at, format: :short) %></td>
              <td><span class="pill"><%= log.status %></span></td>
              <td><%= log.risk_level.presence || "-" %></td>
              <td><%= log.auto_revision_task ? link_to(log.auto_revision_task.title, log.auto_revision_task) : "-" %></td>
              <td class="number"><%= log.changed_files_count %></td>
              <td><%= log.test_result.presence || "-" %></td>
              <td><%= log.deploy_result.presence || "Deploy承認待ち" %></td>
              <td>
                <%= button_to "Rollback",
                              admin_auto_revision_run_log_rollback_path(log),
                              method: :patch,
                              class: "button secondary",
                              data: { turbo_confirm: "この自動改訂ログにRollback requestedを記録しますか？" } %>
              </td>
            </tr>
          <% end %>
          <% if @auto_revision_run_logs.empty? %>
            <tr><td colspan="8">自動改訂ログはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="business-analytics-status-grid">
    <div class="aicoo-card aicoo-card-compact">
      <h3>GSC</h3>
      <p><%= analytics.data_status[:gsc_connected] ? "接続済み" : "未接続 / データ不足" %></p>
      <small>clicks / impressions / CTR / average_position</small>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>GA4</h3>
      <p><%= analytics.data_status[:ga4_connected] ? "接続済み" : "未接続 / データ不足" %></p>
      <small>sessions / pageviews / active_users / conversions</small>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Engagement</h3>
      <p><%= analytics.data_status[:has_engagement_data] ? "データあり" : "データ不足" %></p>
      <small>滞在時間 / 回遊率 / Engagement Rate / CV率 / Scroll</small>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Revenue</h3>
      <p><%= analytics.data_status[:has_revenue_data] ? "データあり" : "データ不足" %></p>
      <small>revenue_yen / affiliate_clicks / phone_clicks / map_clicks</small>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Learning</h3>
      <p><%= analytics.data_status[:has_learning_data] ? "学習データあり" : "データ不足" %></p>
      <small>Decision Log / Playbook / Practicality / Evidence</small>
    </div>
  </div>

  <div class="section-heading">
    <h2>Data Source Cost</h2>
    <p>分析できるかではなく、分析する価値があるかを確認します。</p>
  </div>
  <div class="business-analytics-status-grid">
    <% analytics.cost_estimates.select { |estimate| %w[gsc ga4 serp explore x youtube openai].include?(estimate.source_key) }.each do |estimate| %>
      <div class="aicoo-card aicoo-card-compact">
        <h3><%= estimate.name %></h3>
        <p>
          <span class="pill cost-level-<%= estimate.cost_level %>"><%= estimate.execution_mode %></span>
          <span class="pill status-<%= estimate.connection_status_level %>"><%= estimate.connection_label || "未紐付け" %></span>
          <%= estimate.business_enabled ? "利用ON" : "BusinessでOFF" %>
        </p>
        <small>
          予想コスト <%= number_to_currency(estimate.estimated_cost_yen, unit: "¥", precision: 0) %> /
          期待利益 <%= number_to_currency(estimate.expected_profit_yen, unit: "¥", precision: 0) %> /
          ROI <%= estimate.roi ? number_with_precision(estimate.roi, precision: 1) : "無料/未計算" %><br>
          接続先: <%= estimate.connection_summary || "詳細未設定" %>
        </small>
      </div>
    <% end %>
  </div>
  <div class="actions compact-actions">
    <%= link_to "Data Source紐付けを編集", edit_business_path(@business, anchor: "data-source-link-settings"), class: "button secondary" %>
  </div>

  <div class="section-heading">
    <h2>Analysis Sources</h2>
    <p>今日このBusinessで回す価値が高い分析候補です。Manualは実行前にコストとROIを確認します。</p>
  </div>
  <% if analytics.analysis_candidates.any? %>
    <div class="business-analytics-status-grid">
      <% analytics.analysis_candidates.each do |candidate| %>
        <div class="aicoo-card aicoo-card-compact">
          <h3><%= candidate.display_name %></h3>
          <p>
            <span class="pill cost-level-<%= candidate.manual? ? "high" : candidate.execution_mode %>"><%= candidate.execution_mode %></span>
            <span class="pill status-<%= candidate.status == "pending" ? "warning" : "healthy" %>"><%= candidate.status %></span>
          </p>
          <small>
            期待値 <%= number_to_currency(candidate.expected_value_yen, unit: "¥", precision: 0) %> /
            予想コスト <%= number_to_currency(candidate.estimated_cost_yen, unit: "¥", precision: 0) %> /
            ROI <%= candidate.roi_label %><br>
            Last Run: <%= candidate.last_run_at ? l(candidate.last_run_at, format: :short) : "未実行" %><br>
            <%= candidate.reason %>
          </small>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="aicoo-card aicoo-card-compact">
      <p class="aicoo-empty-state">今日のAnalysis Candidateはまだありません。Daily Run後、またはSYSTEM MODEのAnalysis Monitorから生成してください。</p>
    </div>
  <% end %>

  <div class="business-analytics-chart-grid">
    <%= render "analytics_chart",
               title: "GSCグラフ",
               series: analytics.gsc_series,
               metrics: [
                 { key: "clicks", label: "clicks" },
                 { key: "impressions", label: "impressions" },
                 { key: "ctr", label: "CTR" },
                 { key: "average_position", label: "average_position" }
               ] %>

    <%= render "analytics_chart",
               title: "GA4グラフ",
               series: analytics.ga4_series,
               metrics: [
                 { key: "sessions", label: "sessions" },
                 { key: "pageviews", label: "pageviews" },
                 { key: "active_users", label: "active_users" },
                 { key: "conversions", label: "conversions" }
               ] %>

    <%= render "analytics_chart",
               title: "Engagementグラフ",
               series: analytics.engagement_series,
               metrics: [
                 { key: "average_engagement_time_seconds", label: "平均滞在秒" },
                 { key: "views_per_session", label: "Views/Session" },
                 { key: "engagement_rate", label: "Engagement Rate" },
                 { key: "conversion_rate", label: "CV率" },
                 { key: "scroll_rate", label: "Scroll率" },
                 { key: "engagement_score", label: "Engagement Score" }
               ] %>

    <%= render "analytics_chart",
               title: "Revenueグラフ",
               series: analytics.revenue_series,
               metrics: [
                 { key: "revenue_yen", label: "revenue_yen" },
                 { key: "affiliate_clicks", label: "affiliate_clicks" },
                 { key: "phone_clicks", label: "phone_clicks" },
                 { key: "map_clicks", label: "map_clicks" }
               ] %>

    <%= render "analytics_chart",
               title: "Actionグラフ",
               series: analytics.action_series,
               metrics: [
                 { key: "action_candidates", label: "ActionCandidate生成数" },
                 { key: "executions", label: "実行数" },
                 { key: "results", label: "Result登録数" }
               ] %>

    <%= render "analytics_chart",
               title: "Learningグラフ",
               series: analytics.learning_series,
               metrics: [
                 { key: "decision_logs", label: "Decision Log件数" },
                 { key: "playbook_confidence", label: "Playbook Confidence" },
                 { key: "practicality_average", label: "Practicality平均" },
                 { key: "evidence_average", label: "Evidence平均" }
               ] %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>Integration Health</h2>
    <p>このBusinessの外部連携・データ更新・学習状態を監視します。</p>
  </div>
  <% if @integration_health %>
    <div class="metric-grid">
      <div class="metric-card"><span>Health Score</span><strong><%= number_with_precision(@integration_health.health_score, precision: 1) %></strong></div>
      <div class="metric-card"><span>Warning</span><strong><%= @integration_health.warning_count %>件</strong></div>
      <div class="metric-card"><span>Last Sync</span><strong><%= @integration_health.last_sync_at ? l(@integration_health.last_sync_at, format: :short) : "-" %></strong></div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>連携</th><th>状態</th><th>最終取得</th><th>最終成功</th><th>件数</th><th>Warning</th></tr>
        </thead>
        <tbody>
          <% [@integration_health.gsc, @integration_health.ga4, @integration_health.serp, @integration_health.explore, @integration_health.daily_run, @integration_health.playbook, @integration_health.decision_log].each do |health| %>
            <tr>
              <td><%= health.source.upcase %></td>
              <td><span class="pill"><%= health.status %></span></td>
              <td><%= health.last_fetched_at ? l(health.last_fetched_at, format: :short) : "-" %></td>
              <td><%= health.last_success_at ? l(health.last_success_at, format: :short) : "-" %></td>
              <td><%= health.count.is_a?(Hash) ? health.count.map { |key, value| "#{key}:#{value}" }.join(" / ") : health.count %></td>
              <td><%= health.warning.presence || "正常" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @integration_health.warnings.any? %>
      <div class="aicoo-card aicoo-card-compact">
        <h3>Warnings</h3>
        <ul class="compact-list">
          <% @integration_health.warnings.each do |warning| %>
            <li><%= warning %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% else %>
    <p class="aicoo-empty-state">Integration Healthを集計できませんでした。</p>
  <% end %>
</section>

<section class="dashboard-section" id="business-learning">
  <div class="section-heading">
    <h2>Business Playbook</h2>
    <p>このBusinessで成功しやすいActionTypeを、実績・収益・Decision Logから自動学習します。</p>
  </div>
  <% if @business_playbook&.learned? %>
    <div class="metric-grid">
      <div class="metric-card"><span>Confidence</span><strong><%= number_with_precision(@business_playbook.confidence_score, precision: 1) %></strong></div>
      <div class="metric-card"><span>得意Action</span><strong><%= @business_playbook.top_action_type.presence || "-" %></strong></div>
      <div class="metric-card"><span>苦手Action</span><strong><%= @business_playbook.worst_action_type.presence || "-" %></strong></div>
      <div class="metric-card"><span>平均収益</span><strong><%= number_to_currency(@business_playbook.average_actual_profit_yen.to_d, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>平均Practicality</span><strong><%= number_with_precision(@business_playbook.average_practicality_score.to_d, precision: 1) %></strong></div>
      <div class="metric-card"><span>平均Evidence</span><strong><%= number_with_precision(@business_playbook.average_evidence_score.to_d, precision: 1) %></strong></div>
    </div>
    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card aicoo-card-compact">
        <h3>おすすめAction</h3>
        <ul class="compact-list">
          <% @business_playbook.action_type_rows.first(5).each do |row| %>
            <li><strong><%= row["type"] %></strong> / score <%= number_with_precision(row["score"].to_d, precision: 1) %> / 採用率 <%= number_to_percentage(row["adoption_rate"].to_d * 100, precision: 1) %></li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>最近改善すべきAction</h3>
        <ul class="compact-list">
          <% @business_playbook.action_type_rows.reverse.first(5).each do |row| %>
            <li><strong><%= row["type"] %></strong> / score <%= number_with_precision(row["score"].to_d, precision: 1) %> / sample <%= row["sample_count"] %></li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>一番効くTask TOP10</h3>
        <ul class="compact-list">
          <% @business_playbook.task_rows.first(10).each do |row| %>
            <li>
              <strong><%= row["task"] || row["type"] %></strong>
              / score <%= number_with_precision(row["score"].to_d, precision: 1) %>
              / 成功率 <%= number_to_percentage(row["success_rate"].to_d * 100, precision: 1) %>
              / 完了率 <%= number_to_percentage(row["completion_rate"].to_d * 100, precision: 1) %>
              / Engagement改善 <%= number_with_precision(row["average_engagement_delta"].to_d, precision: 2) %>
            </li>
          <% end %>
          <% if @business_playbook.task_rows.empty? %>
            <li>Task単位の学習はまだ不足しています。</li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>おすすめAnalysis</h3>
        <ul class="compact-list">
          <% @business_playbook.analysis_rows.first(8).each do |row| %>
            <li>
              <strong><%= row["source"] || row["type"] %></strong>
              / ROI <%= number_with_precision(row["roi"].to_d, precision: 1) %>
              / 完了率 <%= number_to_percentage(row["completion_rate"].to_d * 100, precision: 1) %>
              / sample <%= row["sample_count"] %>
            </li>
          <% end %>
          <% if @business_playbook.analysis_rows.empty? %>
            <li>Analysis単位の学習はまだ不足しています。</li>
          <% end %>
        </ul>
      </div>
    </div>
  <% else %>
    <p class="aicoo-empty-state">Business Playbookはまだ学習不足です。ActionResult、RevenueEvent、Decision Logが増えると自動で形成されます。</p>
  <% end %>
</section>

<section class="dashboard-section" id="business-settings">
  <div class="section-heading">
    <h2>Codex対象プロジェクト</h2>
    <p>ActionCandidateからCodex Prompt Draftを作る時に使う実行先です。</p>
  </div>
  <div class="metric-grid">
    <div class="metric-card"><span>Codex状態</span><strong><%= @business.codex_execution_label %></strong></div>
    <div class="metric-card"><span>Execution Type</span><strong><%= @business.codex_execution_type %></strong></div>
    <div class="metric-card"><span>Repository</span><strong><%= @business.codex_repository_name.presence || "未設定" %></strong></div>
    <% unless @business.aicoo_internal_codex? %>
      <div class="metric-card"><span>local_project_path</span><strong><%= @business.codex_local_project_path.presence || "未設定" %></strong></div>
    <% end %>
  </div>
</section>

<% unless @business.aicoo_internal_codex? %>
<section class="dashboard-section">
  <div class="section-heading">
    <h2>Execution Profile</h2>
    <p>AutoRevisionTaskを送る対象リポジトリ、テスト、デプロイ方法です。</p>
  </div>

  <% if (profile = @business.business_execution_profile) %>
    <div class="metric-grid">
      <div class="metric-card"><span>execution_type</span><strong><%= profile.execution_type %></strong></div>
      <div class="metric-card"><span>Repository</span><strong><%= profile.display_repository_name %></strong></div>
      <div class="metric-card"><span>Type</span><strong><%= profile.repository_type %></strong></div>
