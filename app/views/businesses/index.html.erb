<% content_for :title, "事業フォルダ" %>

<% header_actions = capture do %>
  <%= link_to "事業を追加", new_business_path, class: "button" %>
  <%= link_to "収益記録", revenue_events_path, class: "button secondary" %>
  <%= link_to "代理指標", business_metric_dailies_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "事業フォルダ",
             description: "Business は行動候補を分類するためのフォルダです。判断の主役は行動候補です。",
             active_main: :revenue,
             actions: header_actions %>

<nav class="tabs">
  <%= link_to "事業一覧", businesses_path(tab: "businesses"), class: @active_tab == "businesses" ? "active" : nil %>
  <%= link_to "SERP新規事業候補 #{@serp_new_business_board.pending_count}", businesses_path(tab: "serp_candidates"), class: @active_tab == "serp_candidates" ? "active" : nil %>
</nav>

<% if @active_tab == "serp_candidates" %>
  <section class="dashboard-section" id="serp-new-business-candidates">
    <div class="section-heading">
      <div>
        <h2>SERP新規事業候補</h2>
        <p>SERPがGoogle上を走って見つけた候補です。新規事業候補は自動でBusiness作成とLP公開まで進めます。ここでは候補と作成結果だけ確認します。</p>
      </div>
      <%= link_to "事業一覧へ", businesses_path(tab: "businesses"), class: "button secondary" %>
    </div>

    <% if @serp_new_business_board.candidates.any? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>候補</th>
              <th>根拠検索クエリ</th>
              <th>想定顧客</th>
              <th>収益モデル</th>
              <th>期待利益</th>
              <th>最初の検証</th>
              <th>状態</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @serp_new_business_board.candidates.each do |row| %>
              <% candidate = row.action_candidate %>
              <tr>
                <td>
                  <strong><%= link_to row.title, candidate %></strong><br>
                  <small><%= truncate(row.problem, length: 90) %></small>
                </td>
                <td><%= row.source_query %></td>
                <td><%= truncate(row.target_customer, length: 60) %></td>
                <td><%= truncate(row.revenue_model, length: 60) %></td>
                <td>
                  <%= number_to_currency(row.expected_profit_yen, unit: "¥", precision: 0) %><br>
                  <small>時給 <%= number_to_currency(row.expected_hourly_value_yen, unit: "¥", precision: 0) %></small>
                </td>
                <td><%= truncate(row.validation_step, length: 80) %></td>
                <td><span class="pill"><%= row.status %></span></td>
                <td>
                  <div class="actions compact-actions">
                    <% publication = candidate.metadata.to_h["auto_new_business_publication"].to_h %>
                    <% published_slug = publication["published_slug"] %>
                    <% if publication["completed"] %>
                      <%= link_to "事業を見る", candidate.business, class: "button" if candidate.business %>
                      <%= link_to "LPを見る", public_lp_path(published_slug), class: "button secondary" if published_slug.present? %>
                    <% else %>
                      <%= button_to "今すぐ事業化",
                                    approve_action_candidate_path(candidate),
                                    method: :patch,
                                    params: { return_to: businesses_path(tab: "businesses") },
                                    class: "button",
                                    data: { turbo_confirm: "この候補をBusiness化します。" } %>
                      <%= button_to "却下",
                                    reject_action_candidate_path(candidate),
                                    method: :patch,
                                    params: { return_to: businesses_path(tab: "serp_candidates") },
                                    class: "button secondary",
                                    data: { turbo_confirm: "この候補を却下します。" } %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        <h3>表示できるSERP新規事業候補はありません</h3>
        <ul>
          <% @serp_new_business_board.zero_reasons.each do |reason| %>
            <li><%= reason %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </section>
</div>
<% else %>
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>事業名</th>
        <th>状態</th>
        <th>Type</th>
        <th>Lifecycle</th>
        <th>Resource</th>
        <th>Health</th>
        <th>最終期待値</th>
        <th>Last Sync</th>
        <th>GSC 7日 / 30日</th>
        <th>GA4 7日 / 30日</th>
        <th>接続状態</th>
        <th>Engagement</th>
        <th>Revenue 7日 / 30日</th>
        <th>Data Source Cost</th>
        <th>Pending Actions</th>
        <th>Warning</th>
        <th>Execution Profile</th>
        <th>Auto Revision</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @businesses.each do |business| %>
        <% summary = @business_analytics_summaries.fetch(business) %>
        <% expected_value = @business_expected_values.fetch(business) %>
        <% period_7d = summary.periods.fetch(7) %>
        <% period_30d = summary.periods.fetch(30) %>
        <tr>
          <td><%= link_to business.name, business %></td>
          <td><span class="pill"><%= business.status %></span></td>
          <td><span class="pill"><%= business_type_label(business.business_type) %></span></td>
          <td>
            <span class="pill"><%= lifecycle_stage_label(business.lifecycle_stage) %></span><br>
            <small><%= lifecycle_stage_description(business.lifecycle_stage) %></small>
          </td>
          <td>
            <span class="pill"><%= resource_status_label(business.resource_status) %></span><br>
            <small><%= business.next_review_on ? "次回 #{business.next_review_on}" : resource_status_description(business.resource_status) %></small>
          </td>
          <td class="number"><%= number_with_precision(summary.health&.health_score.to_d, precision: 1) %></td>
          <td>
            <strong><%= number_to_currency(expected_value.expected_total_value_yen, unit: "¥", precision: 0) %></strong><br>
            <small>
              raw <%= number_to_currency(expected_value.raw_candidate_sum_yen, unit: "¥", precision: 0) %> /
              流入制約 <%= number_to_currency(expected_value.market_limit_adjustment_yen, unit: "¥", precision: 0) %>
            </small><br>
            <small>opp <%= expected_value.unique_opportunity_count %> / cost <%= number_to_currency(expected_value.cost_yen, unit: "¥", precision: 0) %></small>
          </td>
          <td><%= summary.last_sync_at ? l(summary.last_sync_at, format: :short) : "未接続 / データ不足" %></td>
          <td>
            clicks <%= number_with_delimiter(period_7d.gsc_clicks) %> / <%= number_with_delimiter(period_30d.gsc_clicks) %><br>
            <small>impressions <%= number_with_delimiter(period_7d.gsc_impressions) %> / <%= number_with_delimiter(period_30d.gsc_impressions) %></small>
          </td>
          <td>
            sessions <%= number_with_delimiter(period_7d.ga4_sessions) %> / <%= number_with_delimiter(period_30d.ga4_sessions) %><br>
            <small>pageviews <%= number_with_delimiter(period_7d.ga4_pageviews) %> / <%= number_with_delimiter(period_30d.ga4_pageviews) %></small>
          </td>
          <td>
            <% @data_source_settings_presenter.business_statuses(business, source_keys: %w[gsc ga4 serp x]).each do |status| %>
              <span class="pill status-<%= status.status_level %>"><%= status.source_key.upcase %> <%= status.status_label %></span><br>
            <% end %>
            <%= link_to "Google設定", google_settings_business_path(business), class: "button secondary" %><br>
            <% codex_status = @data_source_settings_presenter.codex_status(business) %>
            <span class="pill status-<%= codex_status.status_level %>">CODEX <%= codex_status.status_label %></span>
          </td>
          <td>
            score <%= number_with_precision(period_30d.engagement_score, precision: 1) %><br>
            <small>
              滞在 <%= number_with_precision(period_30d.average_engagement_time_seconds, precision: 0) %>秒 /
              回遊 <%= number_with_precision(period_30d.views_per_session, precision: 2) %>
            </small>
          </td>
          <td>
            <%= number_to_currency(period_7d.revenue_yen, unit: "¥", precision: 0) %> /
            <%= number_to_currency(period_30d.revenue_yen, unit: "¥", precision: 0) %>
          </td>
          <td>
            <% serp_estimate = summary.cost_estimates.find { |estimate| estimate.source_key == "serp" } %>
            <span class="pill cost-level-<%= serp_estimate.cost_level %>">SERP <%= serp_estimate.execution_mode %></span><br>
            <span class="pill status-<%= serp_estimate.connection_status_level %>"><%= serp_estimate.connection_label || "未紐付け" %></span><br>
            <small>
              <%= number_to_currency(serp_estimate.estimated_cost_yen, unit: "¥", precision: 0) %> /
              ROI <%= serp_estimate.roi ? number_with_precision(serp_estimate.roi, precision: 1) : "無料" %>
            </small>
          </td>
          <td class="number"><%= period_30d.pending_actions %></td>
          <td>
            <span class="pill"><%= summary.warning_count %>件</span>
            <% if summary.warnings.any? %>
              <small><%= summary.warnings.first %></small>
            <% end %>
          </td>
          <td>
            <% if business.aicoo_internal_codex? %>
              <span class="pill status-healthy">AICOO内部</span>
              <small>AICOO本体Repository</small>
            <% elsif (profile = business.business_execution_profile) %>
              <span class="pill"><%= AicooRepositoryTargetCoverageService::STATUS_LABELS.fetch(profile.coverage_status) %></span>
              <% if profile.coverage_status == "configured" %>
                <small><%= profile.display_repository_name %></small>
              <% else %>
                <small><%= profile.coverage_status == "inactive" ? "無効化" : "不足: #{profile.missing_required_fields.join(", ")}" %></small>
              <% end %>
            <% else %>
              <span class="pill">❌ missing</span>
              <small>Execution Profile未作成</small>
            <% end %>
          </td>
          <td>
            <span class="pill <%= business.auto_build_enabled? ? "status-warning" : "" %>">Build: <%= business.auto_build_enabled? ? "ON" : "OFF" %></span><br>
            <small><%= business.auto_build_requires_approval? ? "Owner確認あり" : "Owner確認なし" %> / risk <%= business.auto_build_risk_level %></small><br>
            <small>新規LP Deploy: <%= business.new_lp_auto_deploy_enabled? ? "ON" : "OFF" %><%= " / 停止中" if business.auto_deploy_suspended? %></small>
            <hr>
            <span class="pill <%= business.automatic_auto_revision? ? "status-warning" : "" %>"><%= auto_revision_mode_label(business.auto_revision_mode) %></span><br>
            <small><%= auto_revision_mode_description(business.auto_revision_mode) %></small>
            <hr>
            <span class="pill <%= business.automatic_auto_deploy? ? "status-warning" : "" %>">Deploy: <%= auto_deploy_mode_label(business.auto_deploy_mode) %></span><br>
            <small><%= auto_deploy_mode_description(business.auto_deploy_mode) %></small>
          </td>
          <td>
            <div class="actions compact-actions">
              <%= link_to "Analytics", business_path(business, anchor: "analytics"), class: "button secondary" %>
              <%= link_to "詳細", business, class: "button secondary" %>
              <%= link_to "編集", edit_business_path(business), class: "button secondary" %>
              <%= link_to "Data Source紐付け", edit_business_path(business, anchor: "data-source-link-settings"), class: "button secondary" %>
              <% if business.aicoo_internal_codex? %>
                <span class="pill status-healthy">AICOO内部</span>
              <% elsif business.business_execution_profile %>
                <%= link_to "Profile編集", edit_admin_business_execution_profile_path(business.business_execution_profile), class: "button secondary" %>
              <% else %>
                <%= link_to "Profile作成", new_admin_business_execution_profile_path(business_id: business.id), class: "button secondary" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>
<% end %>
