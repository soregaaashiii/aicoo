<% content_for :title, "事業フォルダ" %>

<% header_actions = capture do %>
  <%= link_to "事業を追加", new_business_path, class: "button" %>
  <%= link_to "収益記録", revenue_events_path, class: "button secondary" %>
  <%= link_to "代理指標", business_metric_dailies_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "事業フォルダ",
             description: "Business は行動候補を分類するためのフォルダです。判断の主役は行動候補です。",
             active_main: :revenue,
             actions: header_actions %>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>事業名</th>
        <th>状態</th>
        <th>行動候補数</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @businesses.each do |business| %>
        <tr>
          <td><%= link_to business.name, business %></td>
          <td><span class="pill"><%= business.status %></span></td>
          <td class="number"><%= business.action_candidates.count %></td>
          <td>
            <div class="actions compact-actions">
              <%= link_to "詳細", business, class: "button secondary" %>
              <%= link_to "編集", edit_business_path(business), class: "button secondary" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>
