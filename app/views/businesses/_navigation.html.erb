<% current_section ||= "概要" %>

<nav class="aicoo-card aicoo-card-compact" aria-label="Business navigation">
  <p class="aicoo-kicker">
    Business &gt; <%= link_to business.name, business_path(business) %> &gt; <%= current_section %>
  </p>
  <div class="actions compact-actions">
    <%= link_to "概要", business_path(business, anchor: "business-overview"), class: "button secondary" %>
    <%= link_to "LP", business_path(business, anchor: "business-lp"), class: "button secondary" %>
    <%= link_to "Service", business_path(business, anchor: "business-services"), class: "button secondary" %>
    <%= link_to "Analytics", business_path(business, anchor: "analytics"), class: "button secondary" %>
    <%= link_to "Timeline", business_path(business, anchor: "business-timeline"), class: "button secondary" %>
    <%= link_to "Learning", business_path(business, anchor: "business-learning"), class: "button secondary" %>
    <%= link_to "Source", business_path(business, anchor: "business-source-connections"), class: "button secondary" %>
    <%= link_to "設定", edit_business_path(business, return_to: business_path(business, anchor: "business-settings")), class: "button secondary" %>
  </div>
</nav>
