<% content_for :title, "#{@business.name} - Business設定" %>

<% header_actions = capture do %>
  <%= link_to "Business詳細へ戻る", @business, class: "button secondary" %>
  <%= link_to "事業一覧に戻る", businesses_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "#{@business.name} のBusiness設定",
             description: "このBusinessが使うGoogle / SERP / Codexなどの紐付けをここで管理します。保存後は元の画面へ戻ります。",
             active_main: :revenue,
             actions: header_actions %>
  <%= render "navigation", business: @business, current_section: "設定" %>

  <%= render "form", business: @business, return_to: @return_to %>

  <section class="dashboard-section" id="data-source-link-settings">
    <div class="section-heading">
      <div>
        <h2>Business個別紐付け設定</h2>
        <p>このBusinessがどのProperty / Account / Keyword / Handleを使うかを管理します。API KeyやOAuthはAICOO全体設定、ここでは事業固有の紐付けを設定します。</p>
      </div>
      <%= link_to "全体Data Source設定", aicoo_setting_path(anchor: "data-source-costs"), class: "button secondary" %>
    </div>

    <% data_source_policy = @data_source_policy || Aicoo::DataSourcePolicy.for(@business) %>
    <% visible_analysis_sources = data_source_policy.visible_source_states %>
    <div class="aicoo-card aicoo-card-compact" id="analysis-source-policy">
      <div class="section-heading">
        <div>
          <h3>分析ソース</h3>
          <p>既存Business改善で実際に使うデータソースです。外部データは検証済みになるまで既存改善には使いません。</p>
        </div>
      </div>
      <div class="metric-grid aicoo-owner-secondary">
        <div class="metric-card">
          <span>現在使用中</span>
          <strong><%= visible_analysis_sources.select(&:used?).map { |source| "✅ #{source.label}" }.join(" / ") %></strong>
          <small>ActionCandidate / 期待値 / 実行指示はこの範囲だけを参照</small>
        </div>
        <div class="metric-card">
          <span>未使用</span>
          <strong><%= visible_analysis_sources.select(&:unused?).map { |source| "⬜ #{source.label}" }.join(" / ") %></strong>
          <small>SERP・Reddit・X・Newsは新規事業探索または検証済み個別設定のみ</small>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ソース</th>
              <th>分析利用</th>
              <th>理由</th>
            </tr>
          </thead>
          <tbody>
            <% visible_analysis_sources.each do |source| %>
              <tr>
                <td><strong><%= source.label %></strong></td>
                <td><span class="pill status-<%= source.used? ? "healthy" : "attention" %>"><%= source.used? ? "使用中" : "未使用" %></span></td>
                <td><%= source.reason %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <% business_statuses = @data_source_settings_presenter.business_statuses(@business) %>
    <div class="metric-grid aicoo-owner-secondary">
      <% business_statuses.each do |status| %>
        <div class="metric-card">
          <span><%= status.source_key.upcase %></span>
          <strong><%= status.status_label %></strong>
          <small><%= status.connection_summary %></small>
        </div>
      <% end %>
      <% codex_status = @data_source_settings_presenter.codex_status(@business) %>
      <div class="metric-card">
        <span>CODEX</span>
        <strong><%= codex_status.status_label %></strong>
        <small><%= codex_status.summary %></small>
      </div>
    </div>

    <%= form_with url: update_data_source_settings_business_path(@business), method: :patch, class: "aicoo-form" do %>
      <%= hidden_field_tag :return_to, @return_to.presence || edit_business_path(@business, anchor: "data-source-link-settings") %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Data Source</th>
              <th>状態</th>
              <th>利用</th>
              <th>全体/個別</th>
              <th>実行/予算Override</th>
              <th>紐付け状態</th>
              <th>Property / Target</th>
              <th>Account / 外部ID</th>
              <th>URL / Endpoint</th>
              <th>Credential参照</th>
              <th>サービス別設定</th>
              <th>メモ</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @data_source_cost_profiles.each do |profile| %>
              <% setting = @business_data_source_settings_by_key[profile.source_key] || BusinessDataSourceSetting.new(business: @business, source_key: profile.source_key) %>
              <% source_binding = setting.metadata.to_h.fetch("source_binding", {}) %>
              <% use_global = ActiveModel::Type::Boolean.new.cast(source_binding.fetch("use_global", true)) %>
              <% status = @data_source_settings_presenter.business_status(@business, profile.source_key) %>
              <% google_source = profile.source_key.in?(%w[gsc ga4]) %>
              <% google_identifier_key = profile.source_key == "gsc" ? "site_url" : "property_id" %>
              <% google_options = profile.source_key == "gsc" ? @gsc_site_options : @ga4_property_options %>
              <% selected_google_identifier = setting.connection_field_value(google_identifier_key).presence || setting.property_identifier.presence %>
              <% google_options = google_options + [[selected_google_identifier, selected_google_identifier]] if google_source && selected_google_identifier.present? && google_options.none? { |_label, value| value == selected_google_identifier } %>
              <tr>
                <td>
                  <strong><%= profile.name %></strong><br>
                  <span class="pill cost-level-<%= profile.cost_level %>"><%= profile.execution_mode %></span>
                  <% if status&.manual_paid %>
                    <br><span class="pill cost-level-high">🔴 有料Manual</span>
                  <% end %>
                </td>
                <td>
                  <span class="pill status-<%= status.status_level %>"><%= status.status_label %></span><br>
                  <% if status.warning.present? %>
                    <small><%= status.warning %></small>
                  <% else %>
                    <small><%= google_source ? "保存値から自動判定" : (status.uses_global ? "AICOO全体設定を利用" : "Business個別設定") %></small>
                  <% end %>
                </td>
                <td>
                  <%= hidden_field_tag "business_data_source_settings[#{profile.source_key}][enabled]", "0" %>
                  <%= check_box_tag "business_data_source_settings[#{profile.source_key}][enabled]", "1", setting.enabled? %>
                </td>
                <td>
                  <% if google_source %>
                    <%= hidden_field_tag "business_data_source_settings[#{profile.source_key}][source_binding][use_global]", "1" %>
                    <small>OAuth取得済みGoogleアカウントを使用</small>
                  <% else %>
                    <label>
                      <%= hidden_field_tag "business_data_source_settings[#{profile.source_key}][source_binding][use_global]", "0" %>
                      <%= check_box_tag "business_data_source_settings[#{profile.source_key}][source_binding][use_global]", "1", use_global %>
                      AICOO全体設定を使う
                    </label>
                  <% end %>
                </td>
                <td>
                  <div class="field compact-field">
                    <label>Execution mode override</label>
                    <%= select_tag "business_data_source_settings[#{profile.source_key}][source_binding][execution_mode]",
                                   options_for_select([["全体設定", ""]] + DataSourceCostProfile::EXECUTION_MODES.map { |mode| [mode, mode] }, source_binding["execution_mode"]) %>
                  </div>
                  <div class="field compact-field">
                    <label>Budget override</label>
                    <%= number_field_tag "business_data_source_settings[#{profile.source_key}][source_binding][monthly_budget_yen]",
                                         source_binding["monthly_budget_yen"],
                                         min: 0,
                                         placeholder: profile.monthly_budget_yen %>
                  </div>
                </td>
                <td>
                  <% if google_source %>
                    <small>状態は保存後に自動判定されます。</small>
                  <% else %>
                    <%= select_tag "business_data_source_settings[#{profile.source_key}][connection_status]",
                                   options_for_select(BusinessDataSourceSetting::CONNECTION_STATUS_LABELS.map { |value, label| [label, value] }, setting.connection_status) %>
                  <% end %>
                </td>
                <td>
                  <% if google_source %>
                    <%= hidden_field_tag "business_data_source_settings[#{profile.source_key}][property_identifier]", selected_google_identifier %>
                    <%= select_tag "business_data_source_settings[#{profile.source_key}][connection_fields][#{google_identifier_key}]",
                                   options_for_select([[profile.source_key == "gsc" ? "GSC Siteを選択" : "GA4 Propertyを選択", ""]] + google_options, selected_google_identifier),
                                   class: "input" %>
                    <% if google_options.empty? %>
                      <small>OAuth取得済みの<%= profile.source_key == "gsc" ? "GSC Site" : "GA4 Property" %>がまだありません。先にGoogleと接続し、Analytics設定を作成してください。</small>
                    <% end %>
                  <% else %>
                    <%= text_field_tag "business_data_source_settings[#{profile.source_key}][property_identifier]",
                                       setting.property_identifier,
                                       placeholder: "例: sc-domain / GA4 property / KW group" %>
                  <% end %>
                </td>
                <td>
                  <%= text_field_tag "business_data_source_settings[#{profile.source_key}][external_account_id]",
                                     setting.external_account_id,
                                     placeholder: "例: account_id / channel_id" %>
                </td>
                <td>
                  <%= text_field_tag "business_data_source_settings[#{profile.source_key}][endpoint_url]",
                                     setting.endpoint_url,
                                     placeholder: "例: https://..." %>
                </td>
                <td>
                  <%= text_field_tag "business_data_source_settings[#{profile.source_key}][credential_reference]",
                                     setting.credential_reference,
                                     placeholder: "例: AICOO共通Google認証" %>
                </td>
                <td>
                  <% if google_source %>
                    <small><%= profile.source_key == "gsc" ? "GSC Siteは左の一覧から選択します。" : "GA4 Propertyは左の一覧から選択します。" %></small>
                  <% else %>
                    <% setting.connection_fields.each do |field| %>
                      <div class="field compact-field">
                        <label><%= field.label %></label>
                        <%= text_field_tag "business_data_source_settings[#{profile.source_key}][connection_fields][#{field.key}]",
                                           setting.connection_field_value(field.key),
                                           placeholder: field.placeholder %>
                      </div>
                    <% end %>
                    <% if setting.connection_fields.empty? %>
                      <small>追加必須項目なし</small>
                    <% end %>
                  <% end %>
                </td>
                <td>
                  <%= text_field_tag "business_data_source_settings[#{profile.source_key}][notes]",
                                     setting.notes,
                                     placeholder: "補足" %>
                </td>
                <td><button type="button" class="button secondary" disabled>Test connection</button></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="actions compact-actions">
        <%= submit_tag "Data Source紐付けを保存", class: "button" %>
      </div>
    <% end %>
  </section>
</div>
