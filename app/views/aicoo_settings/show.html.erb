<% content_for :title, "AICOO設定" %>

<% header_actions = capture do %>
  <%= link_to "操作盤に戻る", dashboard_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "AICOO設定",
             description: "Daily Run後の自動処理など、AICOO全体の運用設定を管理します。",
             active_main: :revenue,
             actions: header_actions %>
  <%= render "shared/aicoo_execution_tabs", active: :dashboard %>

  <section class="dashboard-section" id="data-source-costs">
    <div class="aicoo-card">
      <h2>Data Source Cost Engine</h2>
      <p class="aicoo-lab-help">
        無料APIと有料APIを分け、Auto / Smart / Manual、月間予算、平均コスト、期待利益、ROIを管理します。
        ManualのData SourceはOwnerが押した時だけ実行する前提です。
      </p>

      <div class="metric-grid">
        <div class="metric-card"><span>月間APIコスト</span><strong><%= number_to_currency(@cost_summary.monthly_api_cost_yen, unit: "¥", precision: 0) %></strong></div>
        <div class="metric-card"><span>月間予算</span><strong><%= number_to_currency(@cost_summary.monthly_budget_yen, unit: "¥", precision: 0) %></strong></div>
        <div class="metric-card"><span>ROI</span><strong><%= @cost_summary.roi ? number_with_precision(@cost_summary.roi, precision: 1) : "無料/未計算" %></strong></div>
        <div class="metric-card"><span>Auto</span><strong><%= @cost_summary.auto_count %></strong></div>
        <div class="metric-card"><span>Smart</span><strong><%= @cost_summary.smart_count %></strong></div>
        <div class="metric-card"><span>Manual</span><strong><%= @cost_summary.manual_count %></strong></div>
      </div>

      <%= form_with url: update_data_sources_aicoo_setting_path, method: :patch, class: "aicoo-form" do %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Data Source</th>
                <th>ON</th>
                <th>方式</th>
                <th>認証情報</th>
                <th>月間予算</th>
                <th>月間使用額</th>
                <th>今月実行</th>
                <th>平均コスト</th>
                <th>平均期待利益</th>
                <th>ROI</th>
              </tr>
            </thead>
            <tbody>
              <% @data_source_cost_profiles.each do |profile| %>
                <% estimate = Aicoo::CostEngine.new.estimate(profile.source_key) %>
                <tr>
                  <td>
                    <strong><%= profile.name %></strong><br>
                    <span class="pill cost-level-<%= estimate.cost_level %>"><%= estimate.cost_level %></span>
                    <%= hidden_field_tag "data_sources[#{profile.source_key}][name]", profile.name %>
                  </td>
                  <td>
                    <%= hidden_field_tag "data_sources[#{profile.source_key}][enabled]", "0" %>
                    <%= check_box_tag "data_sources[#{profile.source_key}][enabled]", "1", profile.enabled? %>
                  </td>
                  <td><%= select_tag "data_sources[#{profile.source_key}][execution_mode]", options_for_select(DataSourceCostProfile::EXECUTION_MODES, profile.execution_mode) %></td>
                  <td>
                    <% credential_fields = profile.credential_fields %>
                    <% if credential_fields.any? %>
                      <% credential_fields.each do |field| %>
                        <div class="field compact-field">
                          <label><%= field.label %></label>
                          <% input_name = field.key == "api_key" ? "data_sources[#{profile.source_key}][api_key]" : "data_sources[#{profile.source_key}][credentials][#{field.key}]" %>
                          <% if field.secret %>
                            <%= password_field_tag input_name, nil, placeholder: profile.credential_configured?(field.key) ? "設定済み" : field.placeholder %>
                          <% else %>
                            <%= text_field_tag input_name, profile.credential_value(field.key), placeholder: field.placeholder %>
                          <% end %>
                        </div>
                      <% end %>
                    <% else %>
                      <%= password_field_tag "data_sources[#{profile.source_key}][api_key]", nil, placeholder: profile.api_key_configured? ? "設定済み" : "未設定" %>
                    <% end %>
                  </td>
                  <td><%= number_field_tag "data_sources[#{profile.source_key}][monthly_budget_yen]", profile.monthly_budget_yen, min: 0 %></td>
                  <td><%= number_field_tag "data_sources[#{profile.source_key}][monthly_spend_yen]", profile.monthly_spend_yen, min: 0 %></td>
                  <td><%= number_field_tag "data_sources[#{profile.source_key}][monthly_run_count]", profile.monthly_run_count, min: 0 %></td>
                  <td><%= number_field_tag "data_sources[#{profile.source_key}][average_cost_yen]", profile.average_cost_yen, min: 0, step: 0.01 %></td>
                  <td><%= number_field_tag "data_sources[#{profile.source_key}][average_expected_profit_yen]", profile.average_expected_profit_yen, min: 0, step: 1 %></td>
                  <td><%= estimate.roi ? number_with_precision(estimate.roi, precision: 1) : "無料/未計算" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <h3>Businessごとの利用Data Source</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Business</th>
                <% @data_source_cost_profiles.each do |profile| %>
                  <th><%= profile.source_key %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% @businesses.each do |business| %>
                <tr>
                  <td>
                    <%= link_to business.name, business %><br>
                    <small><%= link_to "紐付け詳細", edit_business_path(business, anchor: "data-source-link-settings") %></small>
                  </td>
                  <% @data_source_cost_profiles.each do |profile| %>
                    <% setting = @business_data_source_settings[[business.id, profile.source_key]] %>
                    <% enabled = setting.nil? ? true : setting.enabled? %>
                    <td>
                      <% connection_setting = @business_data_source_settings[[business.id, profile.source_key]] || BusinessDataSourceSetting.new(business:, source_key: profile.source_key) %>
                      <%= hidden_field_tag "business_data_sources[#{business.id}][#{profile.source_key}][enabled]", "0" %>
                      <%= check_box_tag "business_data_sources[#{business.id}][#{profile.source_key}][enabled]", "1", enabled %>
                      <br>
                      <span class="pill status-<%= connection_setting.connection_status_level %>"><%= connection_setting.connection_status_label %></span>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="actions compact-actions">
          <%= submit_tag "Data Source設定を保存", class: "button" %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="aicoo-card">
      <h2>データ整備タスク自動キュー投入</h2>
      <p class="aicoo-lab-help">
        ONにすると、Daily Run後に生成されたデータ整備タスクをExecutorの実行承認待ちへ自動で積みます。
        自動実行は行わず、人間がExecutorで承認してから進めます。
      </p>

      <div class="metric-grid">
        <div class="metric-card">
          <span>現在の状態</span>
          <strong><%= @aicoo_setting.auto_queue_data_preparation_tasks? ? "自動投入ON" : "自動投入OFF" %></strong>
        </div>
      </div>

      <%= form_with model: @aicoo_setting, url: aicoo_setting_path, method: :patch, class: "aicoo-form" do |form| %>
        <% if @aicoo_setting.errors.any? %>
          <div class="aicoo-lab-help alert">
            <strong>保存できませんでした</strong>
            <ul>
              <% @aicoo_setting.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-row">
          <%= form.label :auto_queue_data_preparation_tasks, "Daily Run後にデータ整備タスクをExecutor承認待ちへ自動投入する" %>
          <%= form.check_box :auto_queue_data_preparation_tasks %>
        </div>

        <div class="actions compact-actions">
          <%= form.submit "AICOO設定を保存", class: "button" %>
          <%= link_to "キャンセル", dashboard_path, class: "button secondary" %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="aicoo-card">
      <h2>Owner Execution Queue</h2>
      <p class="aicoo-lab-help">
        Daily Run後に、Ownerが今日処理しやすい低〜中リスクの確認キューを作ります。
        Codex実行やデプロイは自動では行いません。
      </p>

      <%= form_with model: @aicoo_setting, url: aicoo_setting_path, method: :patch, class: "aicoo-form" do |form| %>
        <div class="form-row">
          <%= form.label :daily_owner_queue_limit, "1日の生成上限" %>
          <%= form.number_field :daily_owner_queue_limit, min: 1, max: 50 %>
        </div>
        <div class="form-row">
          <%= form.label :auto_queue_low_risk_enabled, "low riskをキューに入れる" %>
          <%= form.check_box :auto_queue_low_risk_enabled %>
        </div>
        <div class="form-row">
          <%= form.label :auto_queue_medium_risk_enabled, "medium riskをキューに入れる" %>
          <%= form.check_box :auto_queue_medium_risk_enabled %>
        </div>
        <div class="form-row">
          <%= form.label :auto_queue_high_risk_enabled, "high riskをキューに入れる" %>
          <%= form.check_box :auto_queue_high_risk_enabled %>
        </div>

        <div class="actions compact-actions">
          <%= form.submit "Owner Queue設定を保存", class: "button" %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="aicoo-card">
      <h2>Strategic Philosophy</h2>
      <p class="aicoo-lab-help">
        Decision Logだけで「よく承認される提案」に寄りすぎないよう、AICOOの経営思想を目的関数として設定します。
        Decision Logはこの思想を補正する材料として使います。
      </p>

      <div class="metric-grid">
        <div class="metric-card"><span>長期利益</span><strong><%= @aicoo_setting.long_term_profit_weight %></strong></div>
        <div class="metric-card"><span>短期利益</span><strong><%= @aicoo_setting.short_term_profit_weight %></strong></div>
        <div class="metric-card"><span>学習価値</span><strong><%= @aicoo_setting.learning_weight %></strong></div>
        <div class="metric-card"><span>自動化価値</span><strong><%= @aicoo_setting.automation_weight %></strong></div>
        <div class="metric-card"><span>探索価値</span><strong><%= @aicoo_setting.exploration_weight %></strong></div>
      </div>

      <%= form_with model: @aicoo_setting, url: aicoo_setting_path, method: :patch, class: "aicoo-form" do |form| %>
        <div class="form-row">
          <%= form.label :long_term_profit_weight, "長期利益重視" %>
          <%= form.number_field :long_term_profit_weight, min: 0, max: 100 %>
        </div>
        <div class="form-row">
          <%= form.label :short_term_profit_weight, "短期利益重視" %>
          <%= form.number_field :short_term_profit_weight, min: 0, max: 100 %>
        </div>
        <div class="form-row">
          <%= form.label :learning_weight, "学習価値重視" %>
          <%= form.number_field :learning_weight, min: 0, max: 100 %>
        </div>
        <div class="form-row">
          <%= form.label :automation_weight, "自動化価値重視" %>
          <%= form.number_field :automation_weight, min: 0, max: 100 %>
        </div>
        <div class="form-row">
          <%= form.label :exploration_weight, "探索価値重視" %>
          <%= form.number_field :exploration_weight, min: 0, max: 100 %>
        </div>

        <div class="actions compact-actions">
          <%= form.submit "Strategic Philosophyを保存", class: "button" %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="aicoo-card">
      <h2>Strategic Learning Guardrail</h2>
      <p class="aicoo-lab-help">
        思想補正とDecision Log補正が効きすぎないように、最大補正率と警告条件を管理します。
      </p>

      <div class="metric-grid">
        <div class="metric-card"><span>補正</span><strong><%= @aicoo_setting.strategic_learning_enabled? ? "ON" : "OFF" %></strong></div>
        <div class="metric-card"><span>最大Boost</span><strong><%= number_to_percentage(@aicoo_setting.strategic_learning_max_boost_rate.to_d * 100, precision: 0) %></strong></div>
        <div class="metric-card"><span>最大Penalty</span><strong><%= number_to_percentage(@aicoo_setting.strategic_learning_max_penalty_rate.to_d * 100, precision: 0) %></strong></div>
        <div class="metric-card"><span>Warning閾値</span><strong><%= number_to_percentage(@aicoo_setting.strategic_learning_warning_threshold_rate.to_d * 100, precision: 0) %></strong></div>
        <div class="metric-card"><span>Decision Log最小件数</span><strong><%= @aicoo_setting.strategic_learning_decision_log_min_count %>件</strong></div>
      </div>

      <%= form_with model: @aicoo_setting, url: aicoo_setting_path, method: :patch, class: "aicoo-form" do |form| %>
        <div class="form-row">
          <%= form.label :strategic_learning_enabled, "Strategic Learning補正を有効にする" %>
          <%= form.check_box :strategic_learning_enabled %>
        </div>
        <div class="form-row">
          <%= form.label :strategic_learning_max_boost_rate, "最大Boost率" %>
          <%= form.number_field :strategic_learning_max_boost_rate, min: 0, max: 1, step: 0.01 %>
        </div>
        <div class="form-row">
          <%= form.label :strategic_learning_max_penalty_rate, "最大Penalty率" %>
          <%= form.number_field :strategic_learning_max_penalty_rate, min: 0, max: 1, step: 0.01 %>
        </div>
        <div class="form-row">
          <%= form.label :strategic_learning_warning_threshold_rate, "Warning閾値" %>
          <%= form.number_field :strategic_learning_warning_threshold_rate, min: 0, max: 1, step: 0.01 %>
        </div>
        <div class="form-row">
          <%= form.label :strategic_learning_decision_log_min_count, "Decision Log最小件数" %>
          <%= form.number_field :strategic_learning_decision_log_min_count, min: 0, step: 1 %>
        </div>

        <div class="actions compact-actions">
          <%= form.submit "Guardrail設定を保存", class: "button" %>
        </div>
      <% end %>
    </div>
  </section>
</div>
