<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "AI COO / AI経営企画室" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="AI COO / AI経営企画室">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="robots" content="noindex,nofollow">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= render "shared/aicoo_submit_feedback_script" %>
  </head>

  <body>
    <header class="app-header aicoo-global-header">
      <div class="aicoo-brand-block">
        <%= link_to "AICOO", aicoo_mode_home_path, class: "brand" %>
        <p><%= aicoo_mode_label %> / <%= aicoo_mode_description %></p>
      </div>

      <nav class="aicoo-mode-nav" aria-label="Mode navigation">
        <%= link_to owner_focus_path, class: ["aicoo-mode-pill", ("active" if aicoo_ceo_mode?)] do %>
          CEO MODE<br><small>今日動く</small>
        <% end %>
        <%= link_to dashboard_path, class: ["aicoo-mode-pill", ("active" unless aicoo_ceo_mode?)] do %>
          SYSTEM MODE<br><small>監視室</small>
        <% end %>
        <%= link_to businesses_path, class: "aicoo-header-link" do %>
          Business<br><small>事業一覧</small>
        <% end %>
      </nav>

      <div class="aicoo-header-tools">
        <%= form_with url: action_candidates_path, method: :get, class: "aicoo-global-search", data: { turbo: false } do |form| %>
          <%= form.search_field :q, placeholder: "Search", aria: { label: "Search" } %>
        <% end %>
        <%= link_to "Notifications", owner_tasks_path, class: "aicoo-notification-chip" %>
        <span class="aicoo-profile-chip">Profile</span>
      </div>
    </header>

    <div class="aicoo-shell <%= aicoo_ceo_mode? ? "aicoo-shell-ceo" : "aicoo-shell-system" %>">
      <aside class="aicoo-sidebar" aria-label="<%= aicoo_mode_label %> navigation">
        <div class="aicoo-sidebar-mode">
          <strong><%= aicoo_mode_label %></strong>
          <span>目的から探す</span>
        </div>

        <nav class="aicoo-sidebar-nav">
          <% aicoo_sidebar_items.each do |category| %>
            <section class="aicoo-sidebar-group <%= 'active' if aicoo_sidebar_category_active?(category) %>">
              <%= link_to category[:path], class: ["aicoo-sidebar-link", "aicoo-sidebar-category", ("active" if aicoo_sidebar_category_active?(category))] do %>
                <strong><%= category[:label] %></strong>
                <span><%= category[:description] %></span>
              <% end %>
              <div class="aicoo-sidebar-children">
                <% category.fetch(:children, []).each do |item| %>
                  <%= link_to item[:path], class: ["aicoo-sidebar-link", "aicoo-sidebar-child", ("active" if aicoo_sidebar_child_active?(item))] do %>
                    <strong><%= item[:label] %></strong>
                    <span><%= item[:description] %></span>
                  <% end %>
                <% end %>
              </div>
            </section>
          <% end %>
        </nav>
      </aside>

      <main class="app-main aicoo-main">
        <nav class="aicoo-breadcrumb" aria-label="現在位置">
          <span>現在位置</span>
          <% aicoo_breadcrumb_items.each_with_index do |item, index| %>
            <span class="aicoo-breadcrumb-separator">›</span>
            <% if index == aicoo_breadcrumb_items.size - 1 %>
              <strong><%= item[:label] %></strong>
            <% else %>
              <%= link_to item[:label], item[:path] %>
            <% end %>
          <% end %>
        </nav>

        <div class="aicoo-flash-stack" aria-live="polite">
          <div id="aicoo-loading-feedback" class="flash-message flash-info is-hidden">
            <span class="aicoo-spinner" aria-hidden="true"></span>
            <span>実行中...</span>
          </div>
          <% flash.each do |type, message| %>
            <% next if message.blank? %>
            <% flash_level = case type.to_s
              when "notice", "success" then "success"
              when "alert", "error" then "error"
              else "info"
              end %>
            <div class="flash-message flash-<%= flash_level %>" role="<%= flash_level == "error" ? "alert" : "status" %>">
              <%= sanitize(message.to_s, tags: %w[a], attributes: %w[href]) %>
            </div>
          <% end %>
        </div>

        <%= render "shared/operation_status_panel", monitor: @long_running_operation_monitor %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
