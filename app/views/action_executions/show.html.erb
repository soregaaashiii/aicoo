<% content_for :title, "実行準備詳細" %>

<% action_candidate = @action_execution.action_candidate %>
<% expansion = action_candidate.metadata.to_h["action_expansion"].to_h %>
<% execution_tasks = Array(expansion["recommended_tasks"]).presence || Array(expansion["execution_steps"]).presence || [] %>
<% result_intake = @action_execution.metadata.to_h["execution_result_intake"].to_h %>
<% header_actions = capture do %>
  <% if @action_execution.status == "ready" %>
    <%= button_to "実行する", start_action_execution_path(@action_execution), method: :patch, class: "button" %>
  <% elsif @action_execution.status == "completed" && @action_execution.action_result.blank? %>
    <%= link_to "結果登録へ進む", new_action_result_path(action_execution_id: @action_execution.id), class: "button" %>
  <% end %>
  <%= link_to "詳細を見る", "#developer-mode", class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "実行準備詳細",
             description: "この作業の次の1手だけを判断します。",
             mode: :ceo,
             active_main: :revenue,
             actions: header_actions %>
  <%= render "shared/aicoo_execution_tabs", active: :today %>

  <% stop_reason =
       case @action_execution.status
       when "ready" then "作業開始待ちです。"
       when "running" then "実行中です。完了したら結果を登録してください。"
       when "completed" then @action_execution.action_result ? "結果登録済みです。" : "ActionResult登録待ちです。"
       when "failed" then @action_execution.result_summary.presence || "作業が途中で止まっています。"
       else "状態を確認してください。"
       end %>

  <section class="dashboard-section aicoo-decision-hero">
    <div class="aicoo-decision-card">
      <p><span class="pill"><%= action_candidate.business.name %></span> <span class="pill"><%= @action_execution.status %></span></p>
      <h2><%= action_candidate.title %></h2>
      <p class="aicoo-decision-reason"><%= stop_reason %></p>
      <div class="aicoo-decision-metrics">
        <div><span>期待利益</span><strong><%= number_to_currency(action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></strong></div>
        <div><span>成功率</span><strong><%= number_to_percentage(action_candidate.success_probability.to_d * 100, precision: 0) %></strong></div>
        <div><span>想定時間</span><strong><%= action_candidate.expected_hours || "-" %>h</strong></div>
        <div><span>実績時間</span><strong><%= @action_execution.actual_hours || "-" %>h</strong></div>
      </div>
      <div class="actions compact-actions">
        <% if @action_execution.status == "ready" %>
          <%= button_to "実行する", start_action_execution_path(@action_execution), method: :patch, class: "button" %>
        <% elsif @action_execution.status == "completed" && @action_execution.action_result.blank? %>
          <%= link_to "実行する", new_action_result_path(action_execution_id: @action_execution.id), class: "button" %>
        <% else %>
          <%= link_to "詳細を見る", "#developer-mode", class: "button secondary" %>
        <% end %>
      </div>
    </div>
  </section>

  <details class="aicoo-developer-mode" id="developer-mode">
    <summary>Developer Mode</summary>

  <% if @action_execution.status == "completed" && @action_execution.action_result.blank? %>
    <% elapsed_hours = @action_execution.completed_at ? ((Time.current - @action_execution.completed_at) / 1.hour).round(1) : nil %>
    <section class="dashboard-section danger">
      <div class="section-heading">
        <h2>実行結果未登録</h2>
        <p>この作業は完了していますが、実行結果が未登録です。</p>
      </div>
      <p>完了から <strong><%= elapsed_hours ? "#{elapsed_hours}時間" : "-" %></strong> 経過しています。予測と実績の補正に必要な学習データを登録してください。</p>
      <div class="actions">
        <%= link_to "結果登録へ進む", new_action_result_path(action_execution_id: @action_execution.id), class: "button" %>
      </div>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="metric-grid">
      <div class="metric-card"><span>状態</span><strong><%= @action_execution.status %></strong></div>
      <div class="metric-card"><span>実行種別</span><strong><%= @action_execution.execution_type %></strong></div>
      <div class="metric-card"><span>期待利益</span><strong><%= number_to_currency(action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>成功確率</span><strong><%= number_to_percentage(action_candidate.success_probability.to_d * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>想定時間</span><strong><%= action_candidate.expected_hours || "-" %>h</strong></div>
      <div class="metric-card"><span>実績時間</span><strong><%= @action_execution.actual_hours || "-" %>h</strong></div>
      <div class="metric-card"><span>実績コスト</span><strong><%= number_to_currency(@action_execution.actual_cost_yen.to_d, unit: "¥", precision: 0) %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Prediction Snapshot</h2>
      <p>ActionExecution生成時点の予測値です。ActionCandidateが後から変わっても保持します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>期待利益</span><strong><%= number_to_currency(@action_execution.predicted_profit_yen_snapshot.to_i, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>成功確率</span><strong><%= number_to_percentage(@action_execution.predicted_success_probability_snapshot.to_d * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>想定時間</span><strong><%= @action_execution.predicted_hours_snapshot || "-" %>h</strong></div>
      <div class="metric-card"><span>想定コスト</span><strong><%= number_to_currency(@action_execution.predicted_cost_yen_snapshot.to_i, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>スコア</span><strong><%= number_with_precision(@action_execution.action_score_snapshot.to_d, precision: 1) %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Execution Snapshot</h2>
      <p>実行完了時に登録された実績です。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>実績時間</span><strong><%= @action_execution.actual_hours || "-" %>h</strong></div>
      <div class="metric-card"><span>実績コスト</span><strong><%= number_to_currency(@action_execution.actual_cost_yen.to_d, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>完了日時</span><strong><%= @action_execution.completed_at ? l(@action_execution.completed_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>ActionResult</span><strong><%= @action_execution.action_result ? "結果登録済み" : "未登録" %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>改善案情報</h2>
      <p><%= link_to action_candidate.title, action_candidate %></p>
    </div>
    <dl class="detail-list">
      <dt>Business</dt>
      <dd><%= action_candidate.business.name %></dd>
      <dt>改善タイプ</dt>
      <dd><%= action_candidate.action_type %></dd>
      <dt>評価理由</dt>
      <dd><%= simple_format(action_candidate.evaluation_reason.presence || "-") %></dd>
    </dl>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>実行プロンプト</h2>
      <p>Codexや人間に渡せる実行単位として整形しています。</p>
    </div>
    <pre><%= @action_execution.execution_prompt %></pre>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>作業の進め方</h2>
      <p>作業開始は「作業中」にするだけです。完了時に、実際に何をしたかを下の入力欄へ残します。</p>
    </div>
    <div class="actions compact-actions">
      <% if @action_execution.status == "ready" %>
        <%= button_to "作業開始", start_action_execution_path(@action_execution), method: :patch, class: "button" %>
      <% end %>
      <% if @action_execution.status.in?(%w[ready running]) %>
        <%= link_to "実行結果を入力", action_execution_path(@action_execution, anchor: "execution-result-form"), class: "button secondary" %>
      <% end %>
    </div>

    <% if @action_execution.status.in?(%w[running ready]) %>
      <div id="execution-result-form" class="aicoo-card aicoo-card-compact">
        <h3>実行結果を入力</h3>
        <p>指示通りにできたか、途中で止まったか、指示以上に進んだかをここで残します。</p>
      </div>

      <%= form_with model: @action_execution, url: complete_action_execution_path(@action_execution), method: :patch, class: "form" do |form| %>
        <div class="field">
          <%= form.label :execution_outcome, "今回の結果" %>
          <div class="checkbox-list">
            <% [
              [ "as_planned", "指示通りにできた" ],
              [ "partial", "一部だけできた" ],
              [ "exceeded", "捗って指示以上にやった" ],
              [ "blocked", "できなくて途中で止まった" ]
            ].each do |value, label| %>
              <label>
                <%= form.radio_button :execution_outcome, value, checked: params[:outcome].presence == value || (params[:outcome].blank? && value == "as_planned") %>
                <%= label %>
              </label>
            <% end %>
          </div>
        </div>

        <% if execution_tasks.any? %>
          <div class="field">
            <%= form.label :completed_task_names, "実際にやった作業" %>
            <div class="checkbox-list">
              <% execution_tasks.first(10).each do |task_name| %>
                <label>
                  <%= check_box_tag "action_execution[completed_task_names][]", task_name, false, id: nil %>
                  <%= task_name %>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="grid">
          <div class="field">
            <%= form.label :actual_hours, "実績時間" %>
            <%= form.number_field :actual_hours, step: 0.1 %>
          </div>
          <div class="field">
            <%= form.label :actual_cost_yen, "実績コスト" %>
            <%= form.number_field :actual_cost_yen, step: 1 %>
          </div>
        </div>
        <div class="field">
          <%= form.label :result_summary, "実際にやったこと" %>
          <%= form.textarea :result_summary, rows: 4, placeholder: "例: SEOタイトルを変更し、内部リンクを3件追加した" %>
        </div>
        <div class="field">
          <%= form.label :extra_work, "指示以上にやったこと" %>
          <%= form.textarea :extra_work, rows: 3, placeholder: "例: 追加で関連記事を1本作成した" %>
        </div>
        <div class="field">
          <%= form.label :blocked_reason, "できなかったこと・止まった理由" %>
          <%= form.textarea :blocked_reason, rows: 3, placeholder: "例: 権限がなくページを更新できなかった" %>
        </div>
        <div class="actions compact-actions">
          <%= form.submit "完了として保存", class: "button" %>
        </div>
      <% end %>

      <%= form_with model: @action_execution, url: fail_action_execution_path(@action_execution), method: :patch, class: "form" do |form| %>
        <%= form.hidden_field :execution_outcome, value: "blocked" %>
        <div class="field">
          <%= form.label :result_summary, "途中で止まった理由" %>
          <%= form.textarea :result_summary, rows: 3, placeholder: "例: 必要な権限・素材・情報が不足していた" %>
        </div>
        <div class="field">
          <%= form.label :blocked_reason, "次に必要なもの" %>
          <%= form.textarea :blocked_reason, rows: 3, placeholder: "例: 管理画面の編集権限が必要" %>
        </div>
        <%= form.submit "途中で止まったとして保存", class: "button danger" %>
      <% end %>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>実行結果</h2>
    </div>
    <dl class="detail-list">
      <dt>started_at</dt>
      <dd><%= @action_execution.started_at ? l(@action_execution.started_at, format: :long) : "-" %></dd>
      <dt>completed_at</dt>
      <dd><%= @action_execution.completed_at ? l(@action_execution.completed_at, format: :long) : "-" %></dd>
      <dt>result_summary</dt>
      <dd><%= simple_format(@action_execution.result_summary.presence || "-") %></dd>
      <dt>今回の結果</dt>
      <dd><%= result_intake["execution_outcome_label"].presence || "-" %></dd>
      <dt>実施した作業</dt>
      <dd><%= Array(result_intake["completed_task_names"]).presence&.join(" / ") || "-" %></dd>
      <dt>指示以上にやったこと</dt>
      <dd><%= simple_format(result_intake["extra_work"].presence || "-") %></dd>
      <dt>止まった理由</dt>
      <dd><%= simple_format(result_intake["blocked_reason"].presence || "-") %></dd>
    </dl>
    <% if @action_execution.action_result %>
      <div class="actions">
        <%= link_to "結果登録済み", @action_execution.action_result, class: "button secondary" %>
      </div>
    <% elsif @action_execution.status == "completed" %>
      <div class="actions">
        <%= link_to "結果登録へ進む", new_action_result_path(action_execution_id: @action_execution.id), class: "button" %>
      </div>
    <% end %>
  </section>
  </details>
</div>
