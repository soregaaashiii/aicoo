<% content_for :title, "AICOO Daily Run詳細" %>

<% header_actions = capture do %>
  <%= link_to "Daily Run一覧", aicoo_daily_runs_path, class: "button secondary" %>
  <%= link_to "SERP設定", admin_serp_settings_path(anchor: "serp-execution"), class: "button secondary" %>
  <%= link_to "総合判断を見る", admin_integrated_decision_path, class: "button secondary" %>
  <%= link_to "SYSTEM MODE", aicoo_daily_runs_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "AICOO Daily Run詳細",
             description: "#{@daily_run.target_date} の日次処理結果です。",
             active_main: :revenue,
             actions: header_actions %>
  <%= render "shared/purpose_context_bar",
             parent_label: "AI活動",
             parent_path: aicoo_daily_runs_path,
             section_label: "AI日次実行",
             detail_label: "Daily Run詳細",
             list_path: aicoo_daily_runs_path %>
  <%= render "shared/aicoo_execution_tabs", active: :dashboard %>

  <% if @daily_run.running? %>
    <% current_step = @daily_run.current_step %>
    <section class="dashboard-section">
      <div class="aicoo-card">
        <p><span class="pill">現在実行中</span></p>
        <h2>Daily Runはまだ完了していません</h2>
        <p>
          開始: <%= @daily_run.started_at ? l(@daily_run.started_at, format: :long) : "-" %> /
          経過: <%= @daily_run.running_duration_label %> /
          現在step: <%= current_step&.step_name || "準備中" %>
        </p>
        <p>このRunが完了するまで、同じ対象日の再実行はスキップされます。</p>
      </div>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>基本情報</h2>
      <p>このRunの実行日時、source、retry、対象日を確認します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>Run ID</span><strong>#<%= @daily_run.id %></strong></div>
      <div class="metric-card"><span>実行日時</span><strong><%= @daily_run.created_at ? l(@daily_run.created_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>開始時刻</span><strong><%= @daily_run.started_at ? l(@daily_run.started_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>終了時刻</span><strong><%= @daily_run.finished_at ? l(@daily_run.finished_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>実行時間</span><strong><%= @daily_run_history.run_duration_label %></strong></div>
      <div class="metric-card"><span>status</span><strong><%= @daily_run.status %></strong></div>
      <div class="metric-card"><span>source</span><strong><%= @daily_run.source %></strong><small>manual / cron / retry</small></div>
      <div class="metric-card"><span>retry回数</span><strong><%= @daily_run.retry_count %></strong></div>
      <div class="metric-card"><span>target_date</span><strong><%= @daily_run.target_date %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <%= render "serp_run_card", serp_run: @latest_serp_run %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>同時間帯のSERP Run</h2>
      <p>このDaily Runの開始前後30分から終了後30分までに実行されたSERP Runです。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>実行日時</th>
            <th>Status</th>
            <th>実行者</th>
            <th>検索クエリ</th>
            <th>成功</th>
            <th>skip</th>
            <th>fail</th>
            <th>候補</th>
            <th>新規事業候補</th>
            <th>Business追加</th>
            <th>重複/失敗</th>
            <th>既存改善</th>
            <th>詳細</th>
          </tr>
        </thead>
        <tbody>
          <% @related_serp_runs.each do |serp_run| %>
            <tr>
              <td><%= serp_run.started_at ? l(serp_run.started_at, format: :short) : "-" %></td>
              <td><span class="pill"><%= serp_run.status %></span></td>
              <td><%= serp_run.executed_by %></td>
              <td class="number"><%= serp_run.query_count %></td>
              <td class="number"><%= serp_run.success_count %></td>
              <td class="number"><%= serp_run.skipped_plan_rows.size %></td>
              <td class="number"><%= serp_run.failure_count %></td>
              <td class="number"><%= serp_run.candidate_count %></td>
              <td class="number"><%= serp_run.metadata.to_h.dig("new_business_discovery", "new_business_candidate_count").to_i %></td>
              <td class="number">
                <% publication = serp_run.metadata.to_h["auto_new_business_publication"].to_h %>
                <% discovery = serp_run.metadata.to_h["new_business_discovery"].to_h %>
                <%= [ publication["business_created_count"].to_i + publication["business_linked_count"].to_i, discovery.fetch("business_ids", []).size ].max %>
              </td>
              <td class="number">
                <%= discovery["duplicate_count"].to_i + discovery["failed_count"].to_i + publication["failed_count"].to_i %>
              </td>
              <td class="number"><%= discovery["existing_business_improvement_count"].to_i %></td>
              <td><%= link_to "見る", admin_serp_run_path(serp_run), class: "button secondary" %></td>
            </tr>
          <% end %>
          <% if @related_serp_runs.empty? %>
            <tr><td colspan="13">同時間帯に実行されたSERP Runはありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>実行サマリー</h2>
      <p>主要カテゴリごとの件数、成功、warning、失敗を確認します。</p>
    </div>
    <div class="metric-grid">
      <% @daily_run_history.summary_cards.each do |card| %>
        <div class="metric-card">
          <span><%= card.label %></span>
          <strong><%= card.count %></strong>
          <small><span class="pill"><%= card.status %></span> <%= card.detail %></small>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="metric-grid">
      <div class="metric-card"><span>状態</span><strong><%= @daily_run.status %></strong></div>
      <div class="metric-card"><span>source</span><strong><%= @daily_run.source %></strong></div>
      <div class="metric-card"><span>retry</span><strong><%= @daily_run.retry_count %></strong></div>
      <div class="metric-card"><span>Analytics取得</span><strong><%= @daily_run.analytics_fetch_count %></strong></div>
      <div class="metric-card"><span>DataHub Snapshot</span><strong><%= @daily_run.snapshot_count %></strong></div>
      <div class="metric-card"><span>Insight生成</span><strong><%= @daily_run.insight_generated_count %></strong></div>
      <div class="metric-card"><span>代理指標取り込み</span><strong><%= @daily_run.business_metrics_imported_count %></strong></div>
      <div class="metric-card"><span>重み補正</span><strong><%= @daily_run.proxy_weights_adjusted_count %></strong></div>
      <div class="metric-card"><span>候補生成</span><strong><%= @daily_run.action_candidates_generated_count %></strong></div>
      <div class="metric-card"><span>結果評価</span><strong><%= @daily_run.action_results_evaluated_count %></strong></div>
      <div class="metric-card"><span>補正ログ作成</span><strong><%= @daily_run.score_snapshots_created_count %></strong></div>
      <div class="metric-card"><span>順位上昇</span><strong><%= @daily_run.score_snapshot_rank_up_count %></strong></div>
      <div class="metric-card"><span>順位低下</span><strong><%= @daily_run.score_snapshot_rank_down_count %></strong></div>
      <div class="metric-card"><span>補正なし</span><strong><%= @daily_run.score_snapshot_no_adjustment_count %></strong></div>
      <div class="metric-card"><span>データ整備候補</span><strong><%= @daily_run.data_preparation_candidates_count %></strong></div>
      <div class="metric-card"><span>自動投入</span><strong><%= @daily_run.data_preparation_auto_queued_count %></strong></div>
      <div class="metric-card"><span>評価関数補正</span><strong><%= @daily_run.calibration_ran? ? "実行済み" : "未実行" %></strong></div>
      <div class="metric-card"><span>補正更新</span><strong><%= @daily_run.updated_calibration_count %></strong></div>
      <div class="metric-card"><span>補正ログ</span><strong><%= @daily_run.calibration_log_count %></strong></div>
      <div class="metric-card"><span>反映待ち補正</span><strong><%= @daily_run.pending_calibration_count %></strong></div>
      <div class="metric-card"><span>Auto Revision Queue</span><strong><%= @auto_revision_queue_run ? "実行済み" : "未実行" %></strong></div>
      <div class="metric-card"><span>Auto Revision生成</span><strong><%= @auto_revision_queue_run&.generated_tasks_count.to_i %></strong></div>
      <div class="metric-card"><span>Auto Revision高risk</span><strong><%= @auto_revision_queue_run&.high_risk_candidates_count.to_i %></strong></div>
      <div class="metric-card"><span>Auto Revisionスキップ</span><strong><%= @auto_revision_queue_run&.skipped_candidates_count.to_i %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <dl class="detail-list">
      <dt>対象日</dt>
      <dd><%= @daily_run.target_date %></dd>
      <dt>開始</dt>
      <dd><%= @daily_run.started_at ? l(@daily_run.started_at, format: :long) : "-" %></dd>
      <dt>終了</dt>
      <dd><%= @daily_run.finished_at ? l(@daily_run.finished_at, format: :long) : "-" %></dd>
      <dt>calibration_ran</dt>
      <dd><%= @daily_run.calibration_ran? %></dd>
      <dt>calibration_started_at</dt>
      <dd><%= @daily_run.calibration_started_at ? l(@daily_run.calibration_started_at, format: :long) : "-" %></dd>
      <dt>calibration_finished_at</dt>
      <dd><%= @daily_run.calibration_finished_at ? l(@daily_run.calibration_finished_at, format: :long) : "-" %></dd>
      <dt>calibration_error</dt>
      <dd><%= @daily_run.calibration_error.present? ? "補正エラーあり。原因全文は実行履歴で確認してください。" : "-" %></dd>
      <dt>Auto Revision Queue</dt>
      <dd>
        <% if @auto_revision_queue_run %>
          自動実行済み:
          生成 <%= @auto_revision_queue_run.generated_tasks_count %>件 /
          high risk <%= @auto_revision_queue_run.high_risk_candidates_count %>件 /
          スキップ <%= @auto_revision_queue_run.skipped_candidates_count %>件
        <% else %>
          未実行
        <% end %>
      </dd>
      <dt>エラー</dt>
      <dd>
        <% if @daily_run.error_message.present? %>
          エラーあり。原因全文は<%= link_to "実行履歴", admin_execution_runs_path %>で確認してください。
        <% else %>
          -
        <% end %>
      </dd>
    </dl>
  </section>

  <% if @daily_run_history.warning_rows.any? || @daily_run_history.skipped_rows.any? %>
    <section class="dashboard-section">
      <div class="section-heading">
        <h2>skipped / warning理由</h2>
        <p>SERP Optional、Google OAuth期限切れ、No Metricsなど、止めずに進めた理由を見える化します。</p>
      </div>
      <div class="aicoo-card-grid">
        <% (@daily_run_history.warning_rows + @daily_run_history.skipped_rows).uniq.each do |row| %>
          <div class="aicoo-card aicoo-card-compact">
            <p><span class="pill"><%= row.visual_status %></span></p>
            <h3><%= row.reason %></h3>
            <p><%= row.name %></p>
            <% if row.metadata["message"].present? %>
              <p><%= row.metadata["message"] %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Error Log</h2>
      <p>failed stepだけを一覧表示します。全文・metadataはStep Timelineで確認できます。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Step</th>
            <th>Exception</th>
            <th>message</th>
            <th>backtrace</th>
            <th>再実行</th>
          </tr>
        </thead>
        <tbody>
          <% @daily_run_history.error_rows.each do |row| %>
            <% exception, message = row.error_message.to_s.split(": ", 2) %>
            <tr>
              <td><%= row.name %></td>
              <td><%= message.present? ? exception : "-" %></td>
              <td><%= truncate(message.presence || row.error_message.to_s, length: 120) %></td>
              <td>保存なし</td>
              <td>
                <% if row.record.recovery_available? %>
                  <%= button_to "再実行", recover_aicoo_daily_run_step_path(@daily_run, row.record), method: :post, class: "button secondary", data: { turbo_confirm: "#{row.name} stepを再実行しますか？" } %>
                <% else %>
                  <span class="pill"><%= row.record.recovery_state_label %></span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @daily_run_history.error_rows.empty? %>
            <tr><td colspan="5">failed stepはありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%= render "shared/correction_readiness",
             readiness: @correction_readiness,
             show_action_button: true %>

  <%= render "shared/learning_loop_summary",
             summary: @learning_loop_summary,
             action_center: @learning_loop_action_center %>

  <%= render "shared/learning_loop_action_center",
             action_center: @learning_loop_action_center,
             compact: true %>

  <section class="dashboard-section" id="step-breakdown">
    <div class="section-heading">
      <h2>Step Timeline</h2>
      <p>Daily Runの各Stepを時系列で確認します。metadataは整形JSONで表示します。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Step名</th>
            <th>Status</th>
            <th>開始時刻</th>
            <th>終了時刻</th>
            <th>実行時間</th>
            <th>メモリ</th>
            <th>理由</th>
            <th>error_message</th>
            <th>metadata</th>
            <th>再実行</th>
          </tr>
        </thead>
        <tbody>
          <% @daily_run_history.step_rows.each do |row| %>
            <% step = row.record %>
            <tr>
              <td><%= row.name %></td>
              <td><span class="pill"><%= row.visual_status %></span></td>
              <td><%= row.started_at ? l(row.started_at, format: :short) : "-" %></td>
              <td><%= row.finished_at ? l(row.finished_at, format: :short) : "-" %></td>
              <td class="number"><%= row.duration_label %></td>
              <td class="number"><%= row.memory_label %></td>
              <td><%= row.reason %></td>
              <td><%= truncate(row.error_message.to_s.presence || "-", length: 120) %></td>
              <td>
                <% if row.metadata.present? %>
                  <details>
                    <summary>JSON</summary>
                    <pre><%= JSON.pretty_generate(row.metadata) %></pre>
                  </details>
                <% else %>
                  -
                <% end %>
              </td>
              <td>
                <% if step.recovery_needed? %>
                  <% if step.recovery_available? %>
                    <%= button_to "Recovery", recover_aicoo_daily_run_step_path(@daily_run, step), method: :post, class: "button secondary", data: { turbo_confirm: "#{step.step_name} stepを再実行しますか？" } %>
                  <% else %>
                    <span class="pill"><%= step.recovery_state_label %></span>
                    <br><small><%= step.recovery_unavailable_reason %></small>
                  <% end %>
                <% elsif step.recoverable? %>
                  <span class="pill">再実行可能</span>
                <% else %>
                  <span class="pill">再実行不可</span>
                <% end %>
                <% if step.last_recovery_at %>
                  <br><small><%= step.last_recovery_status %> / <%= l(step.last_recovery_at, format: :short) %></small>
                <% end %>
                <% if step.recovery_attempt_count.positive? %>
                  <br><small>attempts: <%= step.recovery_attempt_count %></small>
                <% end %>
                <% if step.last_recovery_message.present? %>
                  <br><small><%= truncate(step.last_recovery_message, length: 80) %></small>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @daily_run_history.step_rows.empty? %>
            <tr><td colspan="10">このDaily RunにはStep Timelineがまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>自動改修タスク候補</h2>
      <p>このDaily Run対象日に生成され、Codex投入用タスク化できるActionCandidateです。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>タイトル</th>
            <th>事業</th>
            <th>action_type</th>
            <th>score</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @auto_revision_candidates.each do |candidate| %>
            <tr>
              <td><%= link_to candidate.title, candidate %></td>
              <td><%= candidate.business.name %></td>
              <td><%= candidate.action_type %></td>
              <td class="number"><%= number_with_precision(candidate.final_score, precision: 1) %></td>
              <td>
                <% if (task = candidate.auto_revision_tasks.active.first) %>
                  <%= link_to "タスクを見る", task, class: "button secondary" %>
                <% else %>
                  <%= button_to "自動改修タスク化", auto_revision_tasks_path(action_candidate_id: candidate.id), method: :post, class: "button secondary" %>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @auto_revision_candidates.empty? %>
            <tr><td colspan="5">この対象日の自動改修タスク候補はありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>最近作成されたAuto Revision Task</h2>
      <p>Daily Runとの直接紐づきがない場合も、直近のCodex準備前タスクを確認できます。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>タイトル</th>
            <th>事業</th>
            <th>risk</th>
            <th>status</th>
            <th>作成</th>
            <th>詳細</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_auto_revision_tasks.each do |task| %>
            <tr>
              <td><%= task.title %></td>
              <td><%= task.business.name %></td>
              <td><span class="pill"><%= task.risk_level %></span></td>
              <td><span class="pill"><%= task.status %></span></td>
              <td><%= l(task.created_at, format: :short) %></td>
              <td><%= link_to "詳細", task, class: "button secondary" %></td>
            </tr>
          <% end %>
          <% if @recent_auto_revision_tasks.empty? %>
            <tr><td colspan="6">最近作成されたAuto Revision Taskはありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%= render "shared/execution_feasibility_insight",
             execution_feasibility: @execution_feasibility_insight %>

  <%= render "shared/execution_feasibility_correction_overview",
             overview: @execution_feasibility_correction_overview %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Run Log</h2>
    </div>
    <pre><%= @daily_run.run_log.presence || "-" %></pre>
  </section>
</div>
