<% content_for :title, "AICOO Daily Run" %>

<% header_actions = capture do %>
  <%= link_to "Daily Runヘルス", admin_aicoo_daily_run_health_path, class: "button secondary" %>
  <%= link_to "操作盤に戻る", dashboard_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "AICOO Daily Run",
             description: "代理指標更新、重み補正、行動候補生成、実行結果評価を日次でまとめて実行します。",
             active_main: :revenue,
             actions: header_actions %>
  <%= render "shared/aicoo_execution_tabs", active: :dashboard %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>現在の実行状態</h2>
      <p>Daily Runが実行中の場合、対象日・現在のstep・経過時間を表示します。</p>
    </div>

    <% if @running_daily_runs.any? %>
      <div class="aicoo-card-grid">
        <% @running_daily_runs.each do |daily_run| %>
          <% current_step = daily_run.current_step %>
          <div class="aicoo-card">
            <p><span class="pill">実行中</span></p>
            <h2><%= daily_run.target_date %> のDaily Run</h2>
            <div class="metric-grid">
              <div class="metric-card"><span>開始</span><strong><%= daily_run.started_at ? l(daily_run.started_at, format: :short) : "-" %></strong></div>
              <div class="metric-card"><span>経過</span><strong><%= daily_run.running_duration_label %></strong></div>
              <div class="metric-card"><span>現在step</span><strong><%= current_step&.step_name || "準備中" %></strong></div>
              <div class="metric-card"><span>source</span><strong><%= daily_run.source %></strong></div>
            </div>
            <div class="actions compact-actions">
              <%= link_to "詳細を見る", daily_run, class: "button" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="aicoo-card aicoo-card-compact">
        <strong>Daily Runは現在実行されていません。</strong>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <%= render "serp_run_card", serp_run: @latest_serp_run %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>手動実行</h2>
      <p>対象日を指定して、AICOOの日次処理をまとめて実行します。</p>
    </div>
    <%= form_with url: aicoo_daily_runs_path, scope: :aicoo_daily_run, class: "filters" do |form| %>
      <div class="field compact-field">
        <%= form.label :target_date, "対象日" %>
        <%= form.date_field :target_date, value: Date.yesterday %>
      </div>
      <%= form.submit "AICOO Daily Runを実行", class: "button" %>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>検索・絞り込み</h2>
      <p>夜中に何が起きたかを、status・source・warning・failed・SERP/Analytics有無で絞り込みます。</p>
    </div>
    <%= form_with url: aicoo_daily_runs_path, method: :get, class: "filters" do |form| %>
      <div class="field compact-field">
        <%= form.label :status, "status" %>
        <%= form.select :status, options_for_select([ [ "すべて", "" ] ] + AicooDailyRun::STATUSES.map { |status| [ status, status ] }, params[:status]), {}, class: "input" %>
      </div>
      <div class="field compact-field">
        <%= form.label :source, "source" %>
        <%= form.select :source, options_for_select([ [ "すべて", "" ] ] + AicooDailyRun::SOURCES.map { |source| [ source, source ] }, params[:source]), {}, class: "input" %>
      </div>
      <div class="field compact-field">
        <%= form.label :date, "target_date" %>
        <%= form.date_field :date, value: params[:date] %>
      </div>
      <label class="checkbox-label"><%= check_box_tag :warning, "1", params[:warning].present? %> warningあり</label>
      <label class="checkbox-label"><%= check_box_tag :failed, "1", params[:failed].present? %> failedあり</label>
      <label class="checkbox-label"><%= check_box_tag :serp, "1", params[:serp].present? %> SERPあり</label>
      <label class="checkbox-label"><%= check_box_tag :analytics, "1", params[:analytics].present? %> Analyticsあり</label>
      <div class="field compact-field">
        <%= form.label :business_id, "Business ID" %>
        <%= form.number_field :business_id, value: params[:business_id], min: 1 %>
      </div>
      <%= form.submit "絞り込む", class: "button" %>
      <%= link_to "解除", aicoo_daily_runs_path, class: "button secondary" %>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Daily Run調査履歴</h2>
      <p>最新50件のDaily Run結果です。詳細でStep Timeline、Error Log、metadataを確認できます。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>実行日時</th>
            <th>対象日</th>
            <th>source</th>
            <th>状態</th>
            <th>retry</th>
            <th>Analytics</th>
            <th>Snapshot</th>
            <th>Insight</th>
            <th>候補生成</th>
            <th>結果評価</th>
            <th>関連SERP Run</th>
            <th>詳細</th>
          </tr>
        </thead>
        <tbody>
          <% @daily_runs.each do |daily_run| %>
            <% related_serp_runs = @serp_runs_by_daily_run_id[daily_run.id].to_a %>
            <tr>
              <td><%= daily_run.started_at ? l(daily_run.started_at, format: :short) : "-" %></td>
              <td><%= daily_run.target_date %></td>
              <td><span class="pill"><%= daily_run.source %></span></td>
              <td><span class="pill"><%= daily_run.status %></span></td>
              <td class="number"><%= daily_run.retry_count %></td>
              <td class="number"><%= daily_run.analytics_fetch_count %></td>
              <td class="number"><%= daily_run.snapshot_count %></td>
              <td class="number"><%= daily_run.insight_generated_count %></td>
              <td class="number"><%= daily_run.action_candidates_generated_count %></td>
              <td class="number"><%= daily_run.action_results_evaluated_count %></td>
              <td>
                <% if related_serp_runs.any? %>
                  <% related_serp_runs.first(2).each do |serp_run| %>
                    <div>
                      <small>
                        <%= serp_run.started_at ? l(serp_run.started_at, format: :short) : "-" %>
                        SERP Run
                        <%= link_to "##{serp_run.id}", admin_serp_run_path(serp_run) %>
                        <span class="pill"><%= serp_run.status %></span>
                      </small>
                    </div>
                  <% end %>
                <% else %>
                  <span class="muted">-</span>
                <% end %>
              </td>
              <td><%= link_to "詳細", daily_run, class: "button secondary" %></td>
            </tr>
          <% end %>
          <% if @daily_runs.empty? %>
            <tr><td colspan="12">まだDaily Runはありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
