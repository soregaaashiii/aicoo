<% active_main = local_assigns.fetch(:active_main, nil).to_s %>
<% main_tabs = [
  { key: "daily_run", label: "日次実行", description: "実行履歴と停止原因", path: aicoo_daily_runs_path },
  { key: "datahub", label: "実績データ", description: "PV・CV・収益などの事実", path: admin_aicoo_datahub_path },
  { key: "judge", label: "判断精度", description: "予測精度を確認する", path: admin_aicoo_judge_path },
  { key: "settings", label: "全体設定", description: "連携・予算・実行設定", path: aicoo_setting_path }
] %>

<header class="aicoo-header aicoo-system-header">
  <div class="aicoo-header-main">
    <div>
      <p class="aicoo-mode-eyebrow">AICOO システムモード</p>
      <h1><%= title %></h1>
      <p>分析・運用・設定</p>
      <p class="aicoo-header-description"><%= description %></p>
    </div>
    <div class="aicoo-page-actions">
      <% if local_assigns[:actions].present? %>
        <%= actions %>
      <% end %>
    </div>
  </div>

  <%= render "shared/aicoo_mode_switcher", current_mode: :system %>

  <nav class="aicoo-tabs" aria-label="AICOOシステムナビゲーション">
    <% main_tabs.each do |tab| %>
      <% active = active_main == tab[:key] %>
      <%= link_to tab[:path], class: "aicoo-tab#{' active' if active}", aria: (active ? { current: "page" } : nil) do %>
        <strong><%= tab[:label] %></strong>
        <span><%= tab[:description] %></span>
      <% end %>
    <% end %>
  </nav>
</header>
