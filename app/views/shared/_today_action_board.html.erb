<% today_board = local_assigns.fetch(:today_board) %>
<% empty_message = local_assigns.fetch(:empty_message, "Todayに表示するActionはありません") %>

<section class="dashboard-section">
  <div class="section-heading">
    <div>
      <h2>今日処理するAction</h2>
      <p>緊急障害、Owner判断が必要な自動改修、Codexでは実行できない作業を同じ優先順位で表示します。</p>
    </div>
  </div>

  <% if today_board.items.any? %>
    <%= render "shared/action_expected_value_ranking", board: today_board %>
  <% else %>
    <div class="aicoo-lab-help">
      <strong><%= empty_message %></strong>
      <p>緊急障害、判断待ちの自動改修、またはCodexでは実行できない具体作業だけがここに表示されます。</p>
    </div>
  <% end %>
</section>
