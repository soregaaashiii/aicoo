<% board = local_assigns.fetch(:board) %>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>順位</th>
        <th>Business名</th>
        <th>具体的な作業名</th>
        <th>施策期待値</th>
        <th>反実仮想</th>
        <th>想定時間</th>
        <th>期待時給</th>
        <th>成功率</th>
        <th>実行方法</th>
        <th>利用データ</th>
        <th>承認が必要か</th>
        <th>Codex対象か</th>
        <th>詳細を見る</th>
      </tr>
    </thead>
    <tbody>
      <% board.items.each do |item| %>
        <tr data-today-item-id="<%= item.stable_id %>">
          <td class="number"><%= item.rank %></td>
          <td><%= item.business_name.presence || "-" %></td>
          <td>
            <strong><%= item.concrete_task %></strong><br>
            <small>対象: <%= item.target %></small><br>
            <small>次: <%= item.owner_next_step %></small>
            <% if item.reason.present? %>
              <br><small>理由: <%= item.reason %></small>
            <% end %>
            <% if item.group_summary.present? %>
              <br><small><%= item.group_summary %></small>
            <% end %>
            <% if item.stopped_reason.present? %>
              <br><small>停止理由: <%= item.stopped_reason %></small>
            <% end %>
          </td>
          <td class="number">
            <% delta = item.action_expected_value_delta_yen.to_i %>
            <strong><%= delta.positive? ? "+" : "" %><%= number_to_currency(delta, unit: "¥", precision: 0) %></strong><br>
            <small><%= item.valuation_status %> / <%= item.valuation_period_days %>日</small>
          </td>
          <td>
            <small>何もしない: <%= number_to_currency(item.expected_value_if_no_action_yen, unit: "¥", precision: 0) %></small><br>
            <small>実行後: <%= number_to_currency(item.expected_value_if_action_yen, unit: "¥", precision: 0) %></small><br>
            <small>実行コスト: <%= number_to_currency(item.execution_cost_yen, unit: "¥", precision: 0) %></small><br>
            <small>算定: <%= item.calculation_method %> / 信頼度 <%= number_to_percentage(item.confidence.to_d * 100, precision: 0) %></small>
          </td>
          <td class="number"><%= number_with_precision(item.expected_hours, precision: 1, strip_insignificant_zeros: true) %>時間</td>
          <td class="number"><%= number_to_currency(item.expected_hourly_value_yen, unit: "¥", precision: 0) %></td>
          <td class="number"><%= number_to_percentage(item.success_probability.to_d * 100, precision: 1) %></td>
          <td><span class="pill"><%= item.execution_mode_label %></span></td>
          <td><%= item.data_sources_label %></td>
          <td><%= item.approval_required ? "必要" : "不要" %></td>
          <td><%= item.codex_target ? "はい" : "いいえ" %></td>
          <td><%= link_to "詳細を見る", item.detail_url, class: "button secondary" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= render "shared/pagination",
           current_page: board.current_page,
           total_pages: board.total_pages,
           total_count: board.total_count,
           per_page: board.per_page,
           page_param: board.page_param %>
