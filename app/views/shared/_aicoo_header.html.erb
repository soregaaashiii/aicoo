<% header_mode = local_assigns[:mode].presence || (request.path.start_with?("/owner") ? :ceo : :system) %>
<% if header_mode.to_sym == :ceo %>
  <%= render "shared/aicoo_ceo_header",
             title: local_assigns.fetch(:title),
             description: local_assigns.fetch(:description),
             actions: local_assigns[:actions] %>
<% else %>
  <%= render "shared/aicoo_system_header",
             title: local_assigns.fetch(:title),
             description: local_assigns.fetch(:description),
             active_main: local_assigns.fetch(:active_main, nil),
             actions: local_assigns[:actions] %>
<% end %>
