<% monitor = local_assigns[:monitor] %>
<% if monitor&.visible? %>
  <section
    id="aicoo-operation-status-panel"
    class="operation-status-panel"
    data-aicoo-operation-panel="true"
    data-aicoo-auto-refresh="<%= monitor.running? ? 5000 : nil %>">
    <% if monitor.running_operations.any? %>
      <div class="status-banner status-banner-running">
        <span class="aicoo-spinner" aria-hidden="true"></span>
        <div>
          <strong>実行中の処理があります</strong>
          <p>画面を閉じても処理は継続します。完了後、このカードに結果が表示されます。</p>
        </div>
      </div>

      <div class="execution-card-grid">
        <% monitor.running_operations.each do |operation| %>
          <%= render "shared/operation_status_card", operation: operation, emphasized: true %>
        <% end %>
      </div>
    <% end %>

    <% if monitor.recent_operations.any? %>
      <details class="operation-history" <%= "open" if monitor.running_operations.empty? && monitor.recent_operations.any?(&:failed?) %>>
        <summary>直近の実行結果</summary>
        <div class="execution-card-grid">
          <% monitor.recent_operations.each do |operation| %>
            <%= render "shared/operation_status_card", operation: operation, emphasized: false %>
          <% end %>
        </div>
      </details>
    <% end %>
  </section>
<% else %>
  <section id="aicoo-operation-status-panel" class="operation-status-panel is-empty" data-aicoo-operation-panel="true"></section>
<% end %>
