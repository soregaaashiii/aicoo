<% monitor = local_assigns[:monitor] %>
<% if monitor&.running? %>
  <section
    id="aicoo-operation-status-panel"
    class="operation-status-panel"
    data-aicoo-operation-panel="true"
    data-aicoo-auto-refresh="<%= monitor.running? ? 5000 : nil %>">
    <% if monitor.running_operations.any? %>
      <div class="status-banner status-banner-running">
        <span class="aicoo-spinner" aria-hidden="true"></span>
        <div>
          <strong>実行中の処理があります</strong>
          <p>画面を閉じても処理は継続します。完了後の詳細は実行履歴で確認できます。</p>
        </div>
      </div>

      <div class="table-wrap operation-table-wrap">
        <table class="operation-table">
          <thead>
            <tr>
              <th>状態</th>
              <th>処理名</th>
              <th>対象</th>
              <th>開始時刻</th>
              <th>実行時間</th>
              <th>進捗</th>
              <th>簡易メッセージ</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% monitor.running_operations.each do |operation| %>
              <%= render "shared/operation_status", operation:, mode: :compact %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <div class="actions compact-actions">
      <%= link_to "実行履歴を見る", admin_execution_runs_path, class: "button secondary" %>
    </div>
  </section>
<% else %>
  <section id="aicoo-operation-status-panel" class="operation-status-panel is-empty" data-aicoo-operation-panel="true"></section>
<% end %>
