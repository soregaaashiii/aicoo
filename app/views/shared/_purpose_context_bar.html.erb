<% business = local_assigns[:business] || aicoo_context_business %>
<% parent_label = local_assigns[:parent_label].presence || "事業" %>
<% parent_path = local_assigns[:parent_path] || businesses_path %>
<% section_label = local_assigns[:section_label].presence || aicoo_context_objective_label %>
<% detail_label = local_assigns[:detail_label].presence || aicoo_context_detail_label %>
<% business_path_value = business ? business_path(business) : nil %>

<section class="aicoo-card aicoo-card-compact purpose-context-bar">
  <p class="aicoo-kicker">
    <%= link_to parent_label, parent_path %>
    <% if business %>
      &gt; <%= link_to business.name, business_path_value %>
    <% end %>
    &gt; <%= section_label %>
    &gt; <%= detail_label %>
  </p>

  <div class="section-heading">
    <div>
      <h2><%= business ? business.name : parent_label %></h2>
      <p>
        親カテゴリ: <strong><%= parent_label %></strong> /
        見ている内容: <strong><%= section_label %></strong>
      </p>
    </div>
    <div class="actions compact-actions">
      <% if business %>
        <%= link_to "この事業へ戻る", business_path_value, class: "button secondary" %>
      <% end %>
      <span class="pill"><%= detail_label %></span>
    </div>
  </div>
</section>
