<% status = local_assigns[:status] %>
<% mode = local_assigns[:mode] || :full %>

<% if status&.running? %>
  <% if mode == :compact %>
    <% row = status.rows.first %>
    <%= render "shared/daily_run_progress",
               progress: row.progress,
               compact: true,
               refresh_key: "operation-#{row.run_id}" %>
    <div class="actions compact-actions">
      <%= link_to "進行状況を見る", row.path, class: "button secondary" %>
    </div>
  <% else %>
    <div class="aicoo-card <%= 'danger' if status.rows.any?(&:stuck?) %>">
      <div class="section-heading">
        <div>
          <h2>現在の実行状態</h2>
          <p>Daily Runの現在Step、Business進捗、ETAを表示します。</p>
        </div>
        <span class="pill"><%= status.status_label %></span>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Run ID</th>
              <th>status</th>
              <th>進捗</th>
              <th>現在step</th>
              <th>Business</th>
              <th>ETA</th>
              <th>started_at</th>
              <th>経過時間</th>
              <th>stuck判定</th>
              <th>最終ログ</th>
              <th>詳細</th>
            </tr>
          </thead>
          <tbody>
            <% status.rows.each do |row| %>
              <tr>
                <td>#<%= row.run_id %></td>
                <td><span class="pill"><%= row.status_label %></span><br><small><%= row.status %> / <%= row.source %></small></td>
                <td>
                  <div data-daily-run-progress-key="status-<%= row.run_id %>">
                    <strong><%= row.progress.progress_percent %>%</strong>
                    <div class="daily-run-progress-track daily-run-progress-track-small" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="<%= row.progress.progress_percent %>">
                      <span style="width: <%= row.progress.progress_percent %>%"></span>
                    </div>
                  </div>
                </td>
                <td><%= row.current_step_name %><br><small><%= row.progress.current_step_name %></small></td>
                <td><%= row.progress.business_label %></td>
                <td><%= row.progress.remaining_label %></td>
                <td><%= row.started_at ? l(row.started_at, format: :short) : "-" %></td>
                <td><%= row.elapsed_label %></td>
                <td><%= row.stuck? ? "stuckの可能性あり" : "通常実行中" %></td>
                <td><%= row.last_log.presence || "-" %></td>
                <td><%= link_to "詳細を見る", row.path, class: "button secondary" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

<% else %>
  <div class="aicoo-card aicoo-card-compact">
    <strong>Daily Runは現在実行されていません。</strong>
    <% if status&.latest_run %>
      <p class="muted">
        最終実行:
        #<%= status.latest_run.id %>
        <span class="pill"><%= status.latest_run.status %></span>
        <%= status.latest_run.finished_at ? l(status.latest_run.finished_at, format: :short) : l(status.latest_run.created_at, format: :short) %>
      </p>
    <% end %>
  </div>
<% end %>
