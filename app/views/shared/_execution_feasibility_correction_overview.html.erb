<section class="dashboard-section">
  <div class="section-heading">
    <h2>Execution Correction Overview</h2>
    <p>ActionCandidateの実行可能性補正を集計し、過大提案になりやすい領域を確認します。</p>
  </div>

  <% overall = overview.fetch(:overall) %>
  <div class="metric-grid">
    <div class="metric-card"><span>候補数</span><strong><%= overall.total_candidates %></strong></div>
    <div class="metric-card"><span>補正あり</span><strong><%= overall.corrected_count %></strong></div>
    <div class="metric-card"><span>補正率</span><strong><%= number_to_percentage(overall.correction_rate * 100, precision: 1) %></strong></div>
    <div class="metric-card"><span>hard_to_execute</span><strong><%= overall.labels_count.fetch("hard_to_execute") %></strong></div>
  </div>

  <div class="aicoo-card-grid">
    <div class="aicoo-card aicoo-card-compact">
      <h3>補正率が高い action_type</h3>
      <% overview.fetch(:by_action_type).first(5).each do |summary| %>
        <p><strong><%= summary.label %></strong> <%= number_to_percentage(summary.correction_rate * 100, precision: 1) %> / <%= summary.corrected_count %>件</p>
      <% end %>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>hard_to_execute が多い action_type</h3>
      <% overview.fetch(:by_action_type).sort_by { |summary| -summary.labels_count.fetch("hard_to_execute") }.first(5).each do |summary| %>
        <p><strong><%= summary.label %></strong> <%= summary.labels_count.fetch("hard_to_execute") %>件</p>
      <% end %>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>over_sized が多い action_type</h3>
      <% overview.fetch(:by_action_type).sort_by { |summary| -summary.labels_count.fetch("over_sized") }.first(5).each do |summary| %>
        <p><strong><%= summary.label %></strong> <%= summary.labels_count.fetch("over_sized") %>件</p>
      <% end %>
    </div>
  </div>

  <h3>Business別補正率</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Business</th>
          <th>候補数</th>
          <th>補正数</th>
          <th>補正率</th>
          <th>成功確率差分</th>
          <th>工数差分</th>
          <th>Insight</th>
        </tr>
      </thead>
      <tbody>
        <% overview.fetch(:by_business).first(8).each do |summary| %>
          <tr>
            <td><%= summary.label %></td>
            <td class="number"><%= summary.total_candidates %></td>
            <td class="number"><%= summary.corrected_count %></td>
            <td class="number"><%= number_to_percentage(summary.correction_rate * 100, precision: 1) %></td>
            <td class="number"><%= summary.average_success_probability_delta ? number_to_percentage(summary.average_success_probability_delta * 100, precision: 1) : "-" %></td>
            <td class="number"><%= summary.average_expected_hours_delta ? number_with_precision(summary.average_expected_hours_delta, precision: 2) : "-" %></td>
            <td><%= summary.insight_text %></td>
          </tr>
        <% end %>
        <% if overview.fetch(:by_business).empty? %>
          <tr><td colspan="7">ActionCandidateがまだありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <h3>最近補正された候補</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>候補</th>
          <th>Business</th>
          <th>action_type</th>
          <th>ラベル</th>
          <th>理由</th>
        </tr>
      </thead>
      <tbody>
        <% overview.fetch(:recent_corrected).each do |candidate| %>
          <% metadata = candidate.metadata.to_h.fetch("execution_feasibility_correction", {}) %>
          <tr>
            <td><%= link_to candidate.title, candidate %></td>
            <td><%= candidate.business.name %></td>
            <td><%= candidate.action_type %></td>
            <td><span class="pill"><%= metadata["feasibility_label"] %></span></td>
            <td><%= truncate(metadata["reason"].to_s, length: 80) %></td>
          </tr>
        <% end %>
        <% if overview.fetch(:recent_corrected).empty? %>
          <tr><td colspan="5">まだ実行可能性補正された候補はありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
