<% content_for :title, "収益記録" %>

<% header_actions = capture do %>
    <%= link_to "収益記録を追加", new_revenue_event_path, class: "button" %>
    <%= link_to "事業一覧", businesses_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "収益記録",
             description: "事業評価用の簡易な売上・費用記録です。会計ではなく、AICOOが収益性を見るための材料です。",
             active_main: :revenue,
             actions: header_actions %>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>日付</th>
        <th>事業名</th>
        <th>区分</th>
        <th>金額</th>
        <th>紐づき</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @revenue_events.each do |revenue_event| %>
        <tr>
          <td><%= l(revenue_event.occurred_on) %></td>
          <td><%= link_to revenue_event.business.name, revenue_event.business %></td>
          <td><span class="pill"><%= revenue_event.revenue? ? "売上" : "費用" %></span></td>
          <td class="number"><%= number_to_currency(revenue_event.amount, unit: "¥", precision: 0) %></td>
          <td>
            <% if revenue_event.action_candidate %>
              <%= link_to truncate(revenue_event.action_candidate.title, length: 24), revenue_event.action_candidate %>
            <% elsif revenue_event.action_result %>
              <%= link_to "ActionResult ##{revenue_event.action_result.id}", revenue_event.action_result %>
            <% elsif revenue_event.action_execution_log %>
              <%= link_to "ActionExecutionLog ##{revenue_event.action_execution_log.id}", revenue_event.action_execution_log %>
            <% else %>
              -
            <% end %>
          </td>
          <td>
            <%= link_to "詳細", revenue_event %>
            <%= link_to "編集", edit_revenue_event_path(revenue_event) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>
