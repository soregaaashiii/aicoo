<% content_for :title, "収益記録" %>

<% header_actions = capture do %>
    <%= link_to "編集", edit_revenue_event_path(@revenue_event), class: "button secondary" %>
    <%= link_to "一覧へ戻る", revenue_events_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "収益記録",
             description: "#{@revenue_event.business.name} の収益イベントです。",
             active_main: :revenue,
             actions: header_actions %>
  <%= render "shared/purpose_context_bar",
             business: @revenue_event.business,
             section_label: "売上",
             detail_label: "売上履歴詳細",
             list_path: revenue_events_path %>

<dl class="detail-list">
  <dt>日付</dt>
  <dd><%= l(@revenue_event.occurred_on) %></dd>
  <dt>事業</dt>
  <dd><%= link_to @revenue_event.business.name, @revenue_event.business %></dd>
  <dt>区分</dt>
  <dd><%= @revenue_event.revenue? ? "売上" : "費用" %></dd>
  <dt>金額</dt>
  <dd><%= number_to_currency(@revenue_event.amount, unit: "¥", precision: 0) %></dd>
  <dt>ActionCandidate</dt>
  <dd><%= @revenue_event.action_candidate ? link_to(@revenue_event.action_candidate.title, @revenue_event.action_candidate) : "-" %></dd>
  <dt>ActionResult</dt>
  <dd><%= @revenue_event.action_result ? link_to("ActionResult ##{@revenue_event.action_result.id}", @revenue_event.action_result) : "-" %></dd>
  <dt>ActionExecutionLog</dt>
  <dd><%= @revenue_event.action_execution_log ? link_to("ActionExecutionLog ##{@revenue_event.action_execution_log.id}", @revenue_event.action_execution_log) : "-" %></dd>
</dl>

<div class="actions">
  <%= button_to "削除", @revenue_event, method: :delete, class: "danger" %>
</div>
</div>
