<% display_action_title = @evidence_presenter.summary.presence || @action_candidate.title %>
<% content_for :title, display_action_title %>

<% today_return_params = @action_workspace ? { return_to: owner_focus_path } : {} %>
<% executed_at = @action_candidate.action_execution&.completed_at || @action_candidate.action_result&.created_at || @action_candidate.metadata.to_h["executed_at"].presence %>

<% header_actions = capture do %>
  <% if @action_workspace %>
    <%= link_to "戻る", owner_focus_path, class: "button secondary" %>
  <% end %>
  <% if @action_candidate.executed? %>
    <span class="pill">実行済み<%= executed_at.present? ? " #{l(Time.zone.parse(executed_at.to_s), format: :short) rescue ""}" : "" %></span>
  <% elsif !%w[rejected archived].include?(@action_candidate.status) %>
    <%= button_to "実行済みにする",
                  mark_executed_action_candidate_path(@action_candidate),
                  method: :patch,
                  class: "button",
                  data: { turbo_confirm: "この施策を実行済みにしますか？\n実行済みにすると、今日処理するActionから除外されます。" } %>
  <% end %>
  <% unless %w[rejected archived completed done].include?(@action_candidate.status) %>
    <%= button_to "却下する", reject_action_candidate_path(@action_candidate, today_return_params), method: :patch, class: "button danger" %>
  <% end %>
  <%= link_to "詳細を見る", "#developer-mode", class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: display_action_title,
             description: @action_workspace ? "Todayから開いた1つの仕事です。完了したらTodayへ戻ります。" : "今日やるかどうかだけを判断します。",
             mode: :ceo,
             active_main: :revenue,
             actions: header_actions %>
  <%= render "shared/aicoo_execution_tabs", active: :today %>
  <% unless @action_workspace %>
    <%= render "shared/purpose_context_bar",
               business: @action_candidate.business,
               section_label: "改善履歴",
               detail_label: "改善案詳細" %>
  <% end %>

<% metadata = @action_candidate.metadata.to_h %>
<% action_plan = metadata["action_plan"].to_h %>
<% article_plan = @action_candidate.execution_mode == "content_creation" ? @execution_brief.article_plan : {} %>
<% expansion = metadata.fetch("action_expansion", {}) %>
<% execution_steps = Array(action_plan["execution_steps"]).presence || Array(expansion["execution_steps"]).presence || @execution_brief.completion_criteria.first(4) %>
<% reason_text = @evidence_presenter&.reason.presence || metadata.dig("evidence", "reason").presence || @action_candidate.evaluation_reason.presence || @action_candidate.description %>
<% target_text = @evidence_presenter&.target_label.presence || @execution_brief.target[:url].presence || expansion["target"].presence || metadata["target"].presence || "対象はこの施策内の作業内容を確認してください。" %>
<% concrete_task_text = metadata["concrete_task"].presence || metadata.dig("decision", "selected", "concrete_task").presence %>
<% next_action_text = action_plan["owner_output"].presence || action_plan["summary"].presence || concrete_task_text || display_action_title %>

<section class="dashboard-section aicoo-decision-hero">
  <div class="aicoo-decision-card">
    <p>
      <span class="pill"><%= @action_candidate.business.name %></span>
      <span class="pill"><%= action_candidate_type_label(@action_candidate) %></span>
      <span class="pill"><%= @evidence_presenter.execution_mode_label %></span>
    </p>
    <h2><%= display_action_title %></h2>
    <div class="aicoo-decision-subcard">
      <strong>次にやること</strong>
      <p class="aicoo-decision-reason"><%= next_action_text %></p>
    </div>
  </div>
</section>

<section class="dashboard-section" id="why-action">
  <div class="section-heading">
    <div>
      <h2>なぜやるのか</h2>
      <p>現在の問題、根拠、期待される改善です。</p>
    </div>
  </div>
  <div class="aicoo-grid aicoo-grid-2">
    <div class="aicoo-card aicoo-card-compact">
      <h3>現在の問題</h3>
      <p><%= reason_text %></p>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>根拠</h3>
      <p>
        <%= @evidence_presenter.source_label.presence || @action_candidate.generation_source %> のデータから、
        <%= target_text %> に対する改善余地があります。
      </p>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>期待される改善</h3>
      <p><%= @execution_brief.expected_effects[:profit] %> の期待利益、成功率 <%= number_to_percentage(@action_candidate.success_probability.to_d * 100, precision: 0) %> を見込んでいます。</p>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>対象</h3>
      <p><%= target_text %></p>
    </div>
  </div>
</section>

<section class="dashboard-section" id="work-plan">
  <div class="section-heading">
    <div>
      <h2>やること</h2>
      <p>ユーザーが実際に進める作業です。</p>
    </div>
  </div>
  <div class="aicoo-card aicoo-card-compact">
    <ol class="compact-list">
      <% execution_steps.each do |step| %>
        <li><%= step %></li>
      <% end %>
      <% if execution_steps.empty? %>
        <li><%= next_action_text %></li>
      <% end %>
    </ol>
  </div>
</section>

<section class="dashboard-section" id="deliverables">
  <div class="section-heading">
    <div>
      <h2>成果物</h2>
      <p>実行に必要な具体情報です。</p>
    </div>
  </div>
  <% if @action_candidate.execution_mode == "content_creation" %>
    <div class="table-wrap">
      <table>
        <tbody>
          <tr><td><strong>タイトル候補</strong></td><td class="wide-text"><%= article_plan[:title].presence || metadata["recommended_title"].presence || @action_candidate.title %></td></tr>
          <tr><td><strong>URL</strong></td><td class="wide-text"><%= metadata["recommended_url"].presence || metadata["recommended_slug"].presence || @execution_brief.target[:url] %></td></tr>
          <tr><td><strong>目的</strong></td><td class="wide-text"><%= article_plan[:reason].presence || action_plan["goal"].presence || reason_text %></td></tr>
          <tr><td><strong>対象キーワード</strong></td><td class="wide-text"><%= article_plan[:keyword].presence || metadata["keyword"].presence || metadata["source_query"].presence || "-" %></td></tr>
          <tr><td><strong>検索意図</strong></td><td class="wide-text"><%= article_plan[:search_intent].presence || metadata["search_intent"].presence || "-" %></td></tr>
          <tr><td><strong>見出し</strong></td><td class="wide-text"><%= Array(article_plan[:recommended_sections]).presence&.join(" / ") || Array(metadata["recommended_sections"]).join(" / ").presence || "-" %></td></tr>
        </tbody>
      </table>
    </div>
  <% elsif @action_candidate.code_revision_execution_mode? %>
    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card aicoo-card-compact">
        <h3>修正対象</h3>
        <ul class="compact-list">
          <% @execution_brief.file_changes.each do |path| %>
            <li><code><%= path %></code></li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>修正内容</h3>
        <p><%= @action_candidate.execution_prompt.presence || @action_candidate.description.presence || next_action_text %></p>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>期待する結果</h3>
        <ul class="compact-list">
          <% @execution_brief.completion_criteria.each do |criterion| %>
            <li><%= criterion %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% else %>
    <div class="aicoo-card aicoo-card-compact">
      <p><%= @action_candidate.description.presence || next_action_text %></p>
      <% if @evidence_presenter&.execution_units? %>
        <ol class="compact-list">
          <% @evidence_presenter.execution_units.first(5).each do |unit| %>
            <li><%= unit["label"] %><%= unit["estimated_minutes"].present? ? "（#{unit['estimated_minutes']}分）" : "" %></li>
          <% end %>
        </ol>
      <% end %>
    </div>
  <% end %>
</section>

<section class="dashboard-section" id="expected-effect">
  <div class="section-heading">
    <div>
      <h2>期待効果</h2>
      <p>実行判断に必要な最小限の数字です。</p>
    </div>
  </div>
  <div class="metric-grid">
    <div class="metric-card"><span>期待利益</span><strong><%= number_to_currency(@action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></strong></div>
    <div class="metric-card"><span>成功率</span><strong><%= number_to_percentage(@action_candidate.success_probability.to_d * 100, precision: 0) %></strong></div>
    <div class="metric-card"><span>予想時間</span><strong><%= @action_candidate.expected_hours.present? ? "#{@action_candidate.expected_hours.to_f.round(1)}h" : "-" %></strong></div>
    <div class="metric-card"><span>期待時給</span><strong><%= @action_candidate.expected_hourly_value_yen.present? ? number_to_currency(@action_candidate.expected_hourly_value_yen, unit: "¥", precision: 0) : "-" %></strong></div>
  </div>
</section>

<section class="dashboard-section" id="execute-action">
  <div class="section-heading">
    <div>
      <h2>実行</h2>
      <p>完了したら実行済みにします。不要なら却下します。</p>
    </div>
  </div>
  <div class="actions compact-actions">
    <% if @action_candidate.executed? %>
      <span class="pill">実行済み</span>
      <% if executed_at.present? %>
        <span class="muted">実行日時: <%= l(Time.zone.parse(executed_at.to_s), format: :short) rescue executed_at %></span>
      <% end %>
    <% elsif !%w[rejected archived].include?(@action_candidate.status) %>
      <%= button_to "実行済みにする",
                    mark_executed_action_candidate_path(@action_candidate),
                    method: :patch,
                    class: "button",
                    data: { turbo_confirm: "この施策を実行済みにしますか？\n実行済みにすると、今日処理するActionから除外されます。" } %>
    <% end %>
    <% unless %w[rejected archived completed done].include?(@action_candidate.status) %>
      <%= button_to "却下する", reject_action_candidate_path(@action_candidate, today_return_params), method: :patch, class: "button danger" %>
    <% end %>
  </div>
</section>

<details class="aicoo-developer-mode" id="developer-mode">
  <summary>開発者向け情報</summary>
  <p class="muted">raw value、confidence補正、Opportunity、異常値、流入制約などの内部計算ログです。通常の実行判断では上の「なぜやるのか」「やること」「成果物」を見れば十分です。</p>

<%= render @action_candidate %>

<% if @evidence_presenter.analyzer_evidence? %>
  <section class="dashboard-section" id="analyzer-evidence">
    <div class="section-heading">
      <div>
        <h2>Analyzer根拠</h2>
        <p>この候補を生成したBusiness Analyzerが見たデータです。</p>
      </div>
      <span class="pill">Business Analyzer</span>
    </div>

    <div class="metric-grid">
      <div class="metric-card"><span>根拠</span><strong><%= @evidence_presenter.source_label %></strong></div>
      <div class="metric-card"><span>対象</span><strong><%= @evidence_presenter.target_label %></strong></div>
      <div class="metric-card"><span>現在</span><strong><%= @evidence_presenter.current_label %></strong></div>
      <div class="metric-card"><span>目標</span><strong><%= @evidence_presenter.benchmark_label %></strong></div>
      <div class="metric-card"><span>実施量</span><strong><%= @evidence_presenter.amount_label %></strong></div>
      <div class="metric-card"><span>期待効果</span><strong><%= @evidence_presenter.expected_effect_label %></strong></div>
    </div>

    <div class="aicoo-card aicoo-card-compact">
      <strong>理由</strong>
      <p><%= @evidence_presenter.reason %></p>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>項目</th>
            <th>内容</th>
          </tr>
        </thead>
        <tbody>
          <% @evidence_presenter.table_rows.each do |label, value| %>
            <tr>
              <td><strong><%= label %></strong></td>
              <td class="wide-text"><%= value %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<% if @evidence_presenter.execution_units? || @evidence_presenter.execution_units_warning? %>
  <section class="dashboard-section" id="execution-units">
    <div class="section-heading">
      <div>
        <h2>今日やる単位</h2>
        <p>候補全体を、Ownerがそのまま着手できる作業単位に分解しています。</p>
      </div>
      <% if @evidence_presenter.seo_action_type? %>
        <span class="pill"><%= @evidence_presenter.seo_action_type_label %></span>
      <% end %>
    </div>

    <% if @evidence_presenter.execution_units? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>作業</th>
              <th>対象</th>
              <th>件数</th>
              <th>時間</th>
              <th>理由</th>
            </tr>
          </thead>
          <tbody>
            <% @evidence_presenter.execution_units.each_with_index do |unit, index| %>
              <tr>
                <td><span class="pill">#<%= index + 1 %></span></td>
                <td class="wide-text"><strong><%= unit["label"] %></strong></td>
                <td><%= [unit["area"], unit["genre"], unit["page_path"], unit["query"]].compact_blank.join(" / ").presence || "-" %></td>
                <td class="number"><%= unit["target_amount"].presence || "-" %></td>
                <td class="number"><%= unit["estimated_minutes"].present? ? "#{unit['estimated_minutes']}分" : "-" %></td>
                <td class="wide-text"><%= unit["reason"].presence || "-" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="flash-message flash-warning">このAnalyzer候補には、今日やる単位がまだ生成されていません。</div>
    <% end %>
  </section>
<% end %>

<section class="dashboard-section" id="execution-brief">
  <div class="section-heading">
    <div>
      <h2>実行指示書</h2>
      <p>AICOOは何をやるべきかを判断します。本文・コード・データ登録は別コンポーネントへ渡します。</p>
    </div>
    <div class="actions compact-actions">
      <% @execution_brief.open_links.each do |link| %>
        <%= link_to link[:label], link[:url], class: "button secondary", target: "_blank", rel: "noopener" %>
      <% end %>
      <% if @action_candidate.code_revision_execution_mode? %>
        <% if @codex_prompt_draft %>
          <%= link_to "Codex用プロンプト確認", owner_codex_prompt_draft_path(@codex_prompt_draft), class: "button" %>
        <% else %>
          <%= button_to "Codex用プロンプト生成", generate_codex_prompt_draft_action_candidate_path(@action_candidate), method: :post, class: "button" %>
        <% end %>
      <% end %>
      <%= link_to "完了 / 実行結果を記録", new_action_result_path(action_result: { action_candidate_id: @action_candidate.id }), class: "button secondary" %>
    </div>
  </div>

  <% target = @execution_brief.target %>
  <div class="metric-grid">
    <div class="metric-card"><span>Business</span><strong><%= target[:business] %></strong></div>
    <div class="metric-card"><span>対象</span><strong><%= target[:resource_type] %></strong><small><%= target[:resource_name] %></small></div>
    <div class="metric-card"><span>対象ページURL</span><strong><%= target[:url] %></strong></div>
    <div class="metric-card"><span>候補ページ</span><strong><%= Array(target[:candidate_pages]).presence&.join(" / ") || "未特定" %></strong></div>
    <div class="metric-card"><span>管理画面URL</span><strong><%= target[:admin_url] %></strong></div>
    <div class="metric-card"><span>予想作業時間</span><strong><%= @execution_brief.expected_minutes %>分</strong></div>
    <div class="metric-card"><span>期待CTR</span><strong><%= @execution_brief.expected_effects[:ctr] %></strong></div>
    <div class="metric-card"><span>期待順位</span><strong><%= @execution_brief.expected_effects[:rank] %></strong></div>
    <div class="metric-card"><span>期待利益</span><strong><%= @execution_brief.expected_effects[:profit] %></strong><small>期待時給 <%= @execution_brief.expected_effects[:hourly] %></small></div>
  </div>

  <% if @action_candidate.execution_mode == "content_creation" %>
    <% plan = @execution_brief.article_plan %>
    <div class="table-wrap">
      <h3>記事計画</h3>
      <table>
        <tbody>
          <tr><td><strong>記事タイトル</strong></td><td class="wide-text"><%= plan[:title] %></td></tr>
          <tr><td><strong>検索キーワード</strong></td><td class="wide-text"><%= plan[:keyword] %></td></tr>
          <tr><td><strong>記事タイプ</strong></td><td><%= plan[:article_type] %></td></tr>
          <tr><td><strong>ターゲット</strong></td><td class="wide-text"><%= plan[:target_user] %></td></tr>
          <tr><td><strong>検索意図</strong></td><td class="wide-text"><%= plan[:search_intent] %></td></tr>
          <tr><td><strong>理由</strong></td><td class="wide-text"><%= plan[:reason] %></td></tr>
          <tr><td><strong>推奨構成</strong></td><td class="wide-text"><%= plan[:recommended_sections].join(" / ") %></td></tr>
          <tr><td><strong>関連ページ</strong></td><td class="wide-text"><%= plan[:related_pages].join(" / ") %></td></tr>
          <tr><td><strong>内部リンク候補</strong></td><td class="wide-text"><%= plan[:internal_links].join(" / ") %></td></tr>
        </tbody>
      </table>
    </div>
  <% elsif @execution_brief.before_after_items.any? %>
    <div class="table-wrap">
      <h3>変更概要</h3>
      <table>
        <thead>
          <tr>
            <th>項目</th>
            <th>現在</th>
            <th>変更後</th>
          </tr>
        </thead>
        <tbody>
          <% @execution_brief.before_after_items.each do |row| %>
            <tr>
              <td><strong><%= row[:label] %></strong></td>
              <td class="wide-text"><%= simple_format(row[:current]) %></td>
              <td class="wide-text"><%= simple_format(row[:after]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>

<section class="dashboard-section" id="serp-gap">
  <% serp = @execution_brief.serp_comparison %>
  <div class="section-heading">
    <div>
      <h2>SERPとの差分</h2>
      <p>競合上位ページに共通する要素と、現在不足している要素です。</p>
    </div>
    <span class="pill">検索クエリ: <%= serp[:query] %></span>
  </div>

  <div class="metric-grid">
    <div class="metric-card"><span>共通ワード</span><strong><%= serp[:common_words].join(" / ") %></strong></div>
    <div class="metric-card"><span>共通構成</span><strong><%= serp[:common_structure].join(" / ") %></strong></div>
    <div class="metric-card"><span>不足要素</span><strong><%= serp[:missing_elements].join(" / ") %></strong></div>
  </div>
  <div class="aicoo-inline-panel">
    <strong>修正理由</strong>
    <p><%= serp[:reason] %></p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>順位</th>
          <th>競合タイトル</th>
          <th>URL</th>
          <th>snippet</th>
        </tr>
      </thead>
      <tbody>
        <% serp[:top_results].each do |result| %>
          <tr>
            <td class="number"><%= result["position"] || result[:position] %></td>
            <td class="wide-text"><%= result["title"] || result[:title] %></td>
            <td class="wide-text"><%= result["url"] || result[:url] %></td>
            <td class="wide-text"><%= truncate((result["snippet"] || result[:snippet]).to_s, length: 120) %></td>
          </tr>
        <% end %>
        <% if serp[:top_results].empty? %>
          <tr><td colspan="4">SERP上位5件はまだ保存されていません。共通要素は既定テンプレートから補完しています。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<% if @action_candidate.code_revision_execution_mode? %>
<section class="dashboard-section" id="implementation-files">
  <div class="section-heading">
    <h2>変更ファイルと完了条件</h2>
    <p>Codexまたは人間が触るべきファイルと、作業完了の判定条件です。</p>
  </div>
  <div class="aicoo-grid aicoo-grid-2">
    <div>
      <h3>変更ファイル</h3>
      <ul class="compact-list">
        <% @execution_brief.file_changes.each do |path| %>
          <li><code><%= path %></code></li>
        <% end %>
      </ul>
    </div>
    <div>
      <h3>完了条件</h3>
      <ul class="compact-list">
        <% @execution_brief.completion_criteria.each do |criterion| %>
          <li><%= criterion %></li>
        <% end %>
      </ul>
    </div>
  </div>
</section>
<% end %>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>提案理由</h2>
    <p>この提案を支えている根拠です。根拠が足りない場合は不足として扱います。</p>
  </div>
  <% evidence = @action_candidate.metadata.to_h.fetch("evidence", {}) %>
  <% evidence_items = Array(evidence["items"]) %>
  <div class="metric-grid">
    <div class="metric-card"><span>Evidence Score</span><strong><%= evidence["score"].present? ? number_with_precision(evidence["score"].to_d, precision: 1) : "未評価" %></strong></div>
    <div class="metric-card"><span>根拠数</span><strong><%= evidence_items.size %>件</strong></div>
    <div class="metric-card"><span>状態</span><strong><%= evidence["warning"] ? "根拠不足" : "根拠あり" %></strong></div>
  </div>
  <div class="aicoo-card aicoo-card-compact">
    <h3>Evidence Summary</h3>
    <ul class="compact-list">
      <% Array(evidence["summary"]).each do |line| %>
        <li><%= line.to_s.sub(/\A・/, "") %></li>
      <% end %>
      <% if Array(evidence["summary"]).empty? %>
        <li>Evidence不足: 判断に使える根拠データがまだありません。</li>
      <% end %>
    </ul>
    <% if evidence["missing_sources"].present? %>
      <p><strong>不足:</strong> <%= evidence["missing_sources"].join(", ") %></p>
    <% end %>
  </div>
  <% if evidence_items.any? %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>source</th><th>title</th><th>metric</th><th>current</th><th>change</th><th>confidence</th></tr>
        </thead>
        <tbody>
          <% evidence_items.each do |item| %>
            <tr>
              <td><span class="pill"><%= item["source"] %></span></td>
              <td><%= item["title"] %></td>
              <td><%= item["metric_name"].presence || "-" %></td>
              <td><%= item["current_value"].presence || "-" %></td>
              <td><%= item["change_rate"].present? ? "#{item["change_rate"]}%" : "-" %></td>
              <td><%= number_with_precision(item["confidence"].to_d, precision: 1) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>Execution Guide</h2>
    <p>抽象的な提案を、今日そのまま実行できる手順に展開します。</p>
  </div>
  <% expansion = @action_candidate.metadata.to_h.fetch("action_expansion", {}) %>
  <div class="metric-grid">
    <div class="metric-card"><span>状態</span><strong><%= expansion["expanded"] ? "具体化済み" : "具体化不足" %></strong></div>
    <div class="metric-card"><span>対象</span><strong><%= expansion["target"].presence || "未特定" %></strong></div>
    <div class="metric-card"><span>対象KW</span><strong><%= expansion["target_keyword"].presence || "未特定" %></strong></div>
    <div class="metric-card"><span>所要時間</span><strong><%= expansion["expected_minutes"].present? ? "#{expansion["expected_minutes"]}分" : "未算出" %></strong></div>
    <div class="metric-card"><span>信頼度</span><strong><%= expansion["confidence"].present? ? number_with_precision(expansion["confidence"].to_d, precision: 1) : "未評価" %></strong></div>
  </div>
  <div class="aicoo-card aicoo-card-compact">
    <% if expansion["warning"] %>
      <strong>Warning</strong>
      <p><%= expansion["warning_reason"].presence || "具体化に必要な根拠が不足しています。" %></p>
      <% if expansion["missing_data_sources"].present? %>
        <p><strong>不足データ:</strong> <%= expansion["missing_data_sources"].join(", ") %></p>
      <% end %>
    <% else %>
      <h3>実行手順</h3>
      <ol class="compact-list">
        <% Array(expansion["execution_steps"]).each do |step| %>
          <li><%= step %></li>
        <% end %>
      </ol>
      <h3>完了条件</h3>
      <ul class="compact-list">
        <% Array(expansion["completion_criteria"]).each do |criterion| %>
          <li><%= criterion %></li>
        <% end %>
      </ul>
    <% end %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>Business Playbook</h2>
    <p>このBusinessでの過去実績から、弱めに補正した結果です。</p>
  </div>
  <% playbook = @action_candidate.metadata.to_h.fetch("business_playbook", {}) %>
  <div class="metric-grid">
    <div class="metric-card"><span>Playbook Score</span><strong><%= number_with_precision(@action_candidate.business_playbook_score.to_d, precision: 1) %></strong></div>
    <div class="metric-card"><span>Confidence</span><strong><%= number_with_precision(playbook["confidence"].to_s.to_d, precision: 1) %></strong></div>
    <div class="metric-card"><span>係数</span><strong><%= number_with_precision(playbook["coefficient"].presence || 1, precision: 4) %></strong></div>
  </div>
  <div class="aicoo-card aicoo-card-compact">
    <p><%= playbook["reason"].presence || "Business Playbook未学習のため汎用ルールで評価しています。" %></p>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>Practicality</h2>
    <p>今日すぐ着手できる具体度を確認します。</p>
  </div>
  <% practicality = @action_candidate.metadata.to_h.fetch("practicality", {}) %>
  <% subscores = practicality.fetch("subscores", {}) %>
  <div class="metric-grid">
    <div class="metric-card"><span>実行可能性</span><strong><%= @action_candidate.practicality_score ? number_with_precision(@action_candidate.practicality_score, precision: 1) : "未評価" %></strong></div>
    <div class="metric-card"><span>対象の明確さ</span><strong><%= number_with_precision(subscores["target_clarity_score"].to_d, precision: 1) %></strong></div>
    <div class="metric-card"><span>やる内容</span><strong><%= number_with_precision(subscores["action_clarity_score"].to_d, precision: 1) %></strong></div>
    <div class="metric-card"><span>成果物</span><strong><%= number_with_precision(subscores["deliverable_score"].to_d, precision: 1) %></strong></div>
    <div class="metric-card"><span>今日着手可能</span><strong><%= number_with_precision(subscores["execution_ready_score"].to_d, precision: 1) %></strong></div>
    <div class="metric-card"><span>依存関係</span><strong><%= number_with_precision(subscores["dependency_score"].to_d, precision: 1) %></strong></div>
    <div class="metric-card"><span>自動化余地</span><strong><%= number_with_precision(subscores["automation_score"].to_d, precision: 1) %></strong></div>
  </div>
  <div class="aicoo-card aicoo-card-compact">
    <strong><%= @action_candidate.practicality_warning? ? "不足情報あり" : "実行準備OK" %></strong>
    <p><%= @action_candidate.practicality_reason.presence || practicality["reason"].presence || "Practicality情報はまだありません。" %></p>
    <% if practicality["missing_items"].present? %>
      <ul class="compact-list">
        <% practicality["missing_items"].each do |item| %>
          <li><%= item %></li>
        <% end %>
      </ul>
    <% end %>
  </div>
</section>

<% if @action_execution %>
  <section class="dashboard-section">
    <div class="section-heading">
      <h2>実行管理</h2>
      <p>改修開始後の実行準備・実行・結果登録を管理します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>状態</span><strong><%= @action_execution.status %></strong></div>
      <div class="metric-card"><span>実行タイプ</span><strong><%= @action_execution.execution_type %></strong></div>
      <div class="metric-card"><span>開始</span><strong><%= @action_execution.started_at ? l(@action_execution.started_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>完了</span><strong><%= @action_execution.completed_at ? l(@action_execution.completed_at, format: :short) : "-" %></strong></div>
    </div>
    <div class="actions">
      <%= link_to "実行管理へ", @action_execution, class: "button" %>
    </div>
  </section>
<% end %>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>提案と実行の差分</h2>
    <p>AICOOの提案に対して、人間が実際に何をどれだけ行ったかを記録します。</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>完了日時</th>
          <th>状態</th>
          <th>実行内容</th>
          <th>完了率</th>
          <th>差分</th>
          <th>理由</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @action_execution_logs.each do |log| %>
          <tr>
            <td><%= log.finished_at ? l(log.finished_at, format: :short) : "-" %></td>
            <td><%= log.status %></td>
            <td><%= truncate(log.actual_action, length: 48) %></td>
            <td class="number"><%= log.completion_rate ? number_to_percentage(log.completion_rate * 100, precision: 1) : "-" %></td>
            <td class="number"><%= log.variance_quantity || "-" %></td>
            <td><%= truncate(log.variance_reason.to_s, length: 48) %></td>
            <td><%= link_to "詳細", log %></td>
          </tr>
        <% end %>
        <% if @action_execution_logs.empty? %>
          <tr><td colspan="7">まだ実行差分は記録されていません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="actions">
    <%= link_to "実行差分を記録", new_action_execution_log_path(action_candidate_id: @action_candidate.id), class: "button" %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>紐づいた売上/費用</h2>
    <p>この提案から発生したRevenueEventを確認します。</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>日付</th>
          <th>区分</th>
          <th>金額</th>
          <th>結果</th>
          <th>詳細</th>
        </tr>
      </thead>
      <tbody>
        <% @action_candidate.revenue_events.order(occurred_on: :desc, created_at: :desc).each do |event| %>
          <tr>
            <td><%= l(event.occurred_on) %></td>
            <td><span class="pill"><%= event.revenue? ? "売上" : "費用" %></span></td>
            <td class="number"><%= number_to_currency(event.amount, unit: "¥", precision: 0) %></td>
            <td><%= event.action_result ? link_to("ActionResult ##{event.action_result.id}", event.action_result) : "-" %></td>
            <td><%= link_to "詳細", event %></td>
          </tr>
        <% end %>
        <% if @action_candidate.revenue_events.empty? %>
          <tr><td colspan="5">まだ売上/費用は紐づいていません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="actions">
    <%= link_to "売上/費用を登録", new_revenue_event_path(revenue_event: { action_candidate_id: @action_candidate.id }), class: "button" %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>開始履歴</h2>
    <p>Owner操作からExecutor投入までの状態を確認します。</p>
  </div>
  <dl class="detail-list">
    <dt>開始日時</dt>
    <dd><%= @action_candidate.approved_at ? l(@action_candidate.approved_at, format: :short) : "-" %></dd>
    <dt>開始者</dt>
    <dd><%= @action_candidate.approved_by.presence || "-" %></dd>
    <dt>executor_queued_at</dt>
    <dd><%= @action_candidate.executor_queued_at ? l(@action_candidate.executor_queued_at, format: :short) : "-" %></dd>
  </dl>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>信頼度ベース評価</h2>
    <p>GA4/GSC/Judge/Revenue/Learningの評価を、各信頼度で加重して統合します。</p>
  </div>
  <div class="metric-grid">
    <div class="metric-card"><span>最終期待値</span><strong><%= number_to_currency(@action_candidate.final_expected_value_yen, unit: "¥", precision: 0) %></strong></div>
    <div class="metric-card"><span>最終信頼度</span><strong><%= @action_candidate.final_confidence_score.to_i %></strong></div>
    <% primary_evaluator = @action_candidate.metadata.to_h.fetch("evaluator_breakdown", []).max_by { |entry| entry["confidence_score"].to_i } %>
    <div class="metric-card"><span>主な根拠</span><strong><%= primary_evaluator ? primary_evaluator["evaluator_type"].to_s.upcase : "-" %></strong><small><%= primary_evaluator ? primary_evaluator["reason"] : "評価内訳はまだありません。" %></small></div>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>評価器</th>
          <th>期待値</th>
          <th>信頼度</th>
          <th>理由</th>
        </tr>
      </thead>
      <tbody>
        <% @action_candidate.metadata.to_h.fetch("evaluator_breakdown", []).each do |entry| %>
          <tr>
            <td><%= entry["evaluator_type"].to_s.upcase %></td>
            <td class="number"><%= number_to_currency(entry["expected_value_yen"].to_i, unit: "¥", precision: 0) %></td>
            <td class="number"><%= entry["confidence_score"].to_i %></td>
            <td><%= entry["reason"] %></td>
          </tr>
        <% end %>
        <% if @action_candidate.metadata.to_h.fetch("evaluator_breakdown", []).empty? %>
          <tr><td colspan="4">評価内訳はまだありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>実行可能性補正</h2>
    <p>ActionExecutionLogをもとに、過大提案や実行されにくい提案を保守的に補正します。</p>
  </div>
  <% feasibility_correction = @action_candidate.metadata.to_h.fetch("execution_feasibility_correction", {}) %>
  <div class="metric-grid">
    <div class="metric-card"><span>補正</span><strong><%= feasibility_correction["applied"] ? "あり" : "なし" %></strong></div>
    <div class="metric-card"><span>補正ラベル</span><strong><%= feasibility_correction["feasibility_label"].presence || "データ不足" %></strong></div>
    <div class="metric-card"><span>補正前 success_probability</span><strong><%= feasibility_correction["base_success_probability"].present? ? number_to_percentage(feasibility_correction["base_success_probability"].to_d * 100, precision: 1) : "-" %></strong></div>
    <div class="metric-card"><span>補正後 success_probability</span><strong><%= feasibility_correction["adjusted_success_probability"].present? ? number_to_percentage(feasibility_correction["adjusted_success_probability"].to_d * 100, precision: 1) : "-" %></strong></div>
  </div>
  <div class="aicoo-card aicoo-card-compact">
    <strong>補正理由</strong>
    <p><%= feasibility_correction["reason"].presence || "ActionExecutionLogが不足しているため、実行可能性補正はまだありません。" %></p>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>評価関数補正</h2>
    <p>同じaction_typeの予測誤差から、期待利益と成功確率を保守的に補正します。</p>
  </div>
  <% prediction_calibration = @action_candidate.metadata.to_h.fetch("prediction_calibration", {}) %>
  <div class="metric-grid">
    <div class="metric-card"><span>補正</span><strong><%= prediction_calibration["active"] ? "適用中" : "未適用" %></strong></div>
    <div class="metric-card"><span>sample</span><strong><%= prediction_calibration["sample_count"].to_i %>件</strong></div>
    <div class="metric-card"><span>利益補正係数</span><strong><%= prediction_calibration["profit_calibration_factor"].presence || "1.0" %></strong></div>
    <div class="metric-card"><span>確率補正係数</span><strong><%= prediction_calibration["probability_calibration_factor"].presence || "1.0" %></strong></div>
    <div class="metric-card">
      <span>補正前期待利益</span>
      <strong><%= number_to_currency(prediction_calibration["raw_expected_profit_yen"].to_i, unit: "¥", precision: 0) %></strong>
    </div>
    <div class="metric-card">
      <span>補正後期待利益</span>
      <strong><%= number_to_currency(prediction_calibration["adjusted_expected_profit_yen"].to_i, unit: "¥", precision: 0) %></strong>
    </div>
  </div>
  <div class="actions compact-actions">
    <%= link_to "補正係数を見る", admin_aicoo_calibration_path, class: "button secondary" %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>Judge補正</h2>
    <p>同じ生成元・行動タイプの過去的中率を使って、最終スコアを軽く補正します。</p>
  </div>
  <div class="metric-grid">
    <div class="metric-card"><span>generation_source過去的中率</span><strong><%= @action_candidate_judge_score.generation_source_accuracy ? number_to_percentage(@action_candidate_judge_score.generation_source_accuracy * 100, precision: 1) : "データ不足" %></strong></div>
    <div class="metric-card"><span>action_type過去的中率</span><strong><%= @action_candidate_judge_score.action_type_accuracy ? number_to_percentage(@action_candidate_judge_score.action_type_accuracy * 100, precision: 1) : "データ不足" %></strong></div>
    <div class="metric-card"><span>Business平均prediction_error_rate</span><strong><%= @action_candidate_judge_score.business_average_prediction_error_rate ? number_to_percentage(@action_candidate_judge_score.business_average_prediction_error_rate * 100, precision: 1) : "データ不足" %></strong></div>
    <div class="metric-card"><span>judge_adjusted_score</span><strong><%= number_with_precision(@action_candidate_judge_score.judge_adjusted_score, precision: 1) %></strong></div>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>この候補に近い過去精度</h2>
    <p>同じ生成元・行動タイプ・Businessで、過去のActionResultがどれくらい当たったかを表示します。</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>軸</th>
          <th>評価済み件数</th>
          <th>的中率</th>
          <th>平均prediction_error</th>
          <th>平均誤差率</th>
        </tr>
      </thead>
      <tbody>
        <% {
          "このgeneration_source" => @action_prediction_precision[:generation_source],
          "このaction_type" => @action_prediction_precision[:action_type],
          "このBusiness" => @action_prediction_precision[:business]
        }.each do |label, summary| %>
          <tr>
            <td><%= label %></td>
            <td class="number"><%= summary.evaluated_count %></td>
            <td class="number"><%= summary.hit_rate ? number_to_percentage(summary.hit_rate * 100, precision: 1) : "データ不足" %></td>
            <td class="number"><%= summary.average_prediction_error_yen ? number_to_currency(summary.average_prediction_error_yen, unit: "¥", precision: 0) : "データ不足" %></td>
            <td class="number"><%= summary.average_prediction_error_rate ? number_to_percentage(summary.average_prediction_error_rate * 100, precision: 1) : "データ不足" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<% if @action_candidate.action_result %>
  <section class="dashboard-section">
    <div class="section-heading">
      <h2>実行結果サマリー</h2>
      <p>予測した期待利益と実績のズレを確認します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>評価状態</span><strong><%= @action_candidate.action_result.evaluation_status %></strong></div>
      <div class="metric-card"><span>予測期待利益</span><strong><%= number_to_currency(@action_candidate.action_result.predicted_expected_profit_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>実績利益</span><strong><%= number_to_currency(@action_candidate.action_result.actual_profit_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>予測誤差</span><strong><%= number_to_currency(@action_candidate.action_result.prediction_error_yen, unit: "¥", precision: 0) %></strong></div>
    </div>
  </section>
<% end %>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>Judge補正スコア履歴</h2>
    <p>この候補がJudge補正でどの順位に動いたかを日別に確認します。</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>recorded_on</th>
          <th>raw_score</th>
          <th>judge_adjusted_score</th>
          <th>raw_rank</th>
          <th>adjusted_rank</th>
          <th>rank_delta</th>
          <th>倍率</th>
          <th>理由</th>
        </tr>
      </thead>
      <tbody>
        <% @score_snapshots.each do |snapshot| %>
          <tr>
            <td><%= snapshot.recorded_on %></td>
            <td class="number"><%= number_with_precision(snapshot.raw_score, precision: 1) %></td>
            <td class="number"><%= number_with_precision(snapshot.judge_adjusted_score, precision: 1) %></td>
            <td class="number"><%= snapshot.raw_rank %></td>
            <td class="number"><%= snapshot.adjusted_rank %></td>
            <td class="number"><%= snapshot.rank_delta %></td>
            <td class="number"><%= number_with_precision(snapshot.adjustment_multiplier, precision: 2) %></td>
            <td><%= snapshot.reason %></td>
          </tr>
        <% end %>
        <% if @score_snapshots.empty? %>
          <tr><td colspan="8">まだScoreSnapshot履歴はありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<div class="actions">
  <%= link_to "行動候補一覧に戻る", action_candidates_path, class: "button secondary" %>
  <%= button_to "Destroy", @action_candidate, method: :delete, class: "danger" %>
</div>
</details>
</div>
