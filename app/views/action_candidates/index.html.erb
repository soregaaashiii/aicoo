<% content_for :title, "行動候補" %>

<% header_actions = capture do %>
  <%= link_to "行動候補を追加", new_action_candidate_path, class: "button" %>
  <%= button_to "generalのみdepartment一括分類",
                classify_department_rankings_path,
                method: :post,
                class: "button secondary",
                form: { data: { turbo_confirm: "departmentがgeneralの候補だけを一括分類します。実行しますか？" } } %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "行動候補",
             description: "事業フォルダをまたいで比較する、行動単位の候補一覧です。",
             active_main: :revenue,
             actions: header_actions %>
  <%= render "shared/aicoo_execution_tabs", active: :today %>

<%= form_with url: action_candidates_path, method: :get, class: "filters" do |form| %>
  <div class="field compact-field">
    <%= form.label :business_id, "Business" %>
    <%= form.select :business_id, options_from_collection_for_select(@businesses, :id, :name, params[:business_id]), include_blank: "All" %>
  </div>
  <div class="field compact-field">
    <%= form.label :action_type, "Action type" %>
    <%= form.select :action_type, options_for_select(ActionCandidate::ACTION_TYPES, params[:action_type]), include_blank: "All" %>
  </div>
  <div class="field compact-field">
    <%= form.label :department, "部門" %>
    <%= form.select :department, options_for_select(ActionCandidate::DEPARTMENTS.map { |department| [ActionCandidateDepartmentRanking::DEPARTMENTS.fetch(department), department] }, params[:department]), include_blank: "All" %>
  </div>
  <div class="field compact-field">
    <%= form.label :status, "Status" %>
    <%= form.select :status, options_for_select(ActionCandidate::STATUSES, params[:status]), include_blank: "All" %>
  </div>
  <div class="field compact-field">
    <%= form.label :data_confidence_score, "Data confidence min" %>
    <%= form.number_field :data_confidence_score, min: 0, max: 100, value: params[:data_confidence_score] %>
  </div>
  <%= form.submit "Filter", class: "button" %>
  <%= link_to "Clear", action_candidates_path, class: "button secondary" %>
<% end %>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>行動タイトル</th>
        <th>事業</th>
        <th>部門</th>
        <th>種別</th>
        <th>期待利益</th>
        <th>Judge補正後</th>
        <th>状態</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @action_candidates.each do |action_candidate| %>
        <% judge_score = @action_candidate_judge_scores.fetch(action_candidate) %>
        <% executor_task = action_candidate.unfinished_executor_task %>
        <tr>
          <td><%= link_to action_candidate.title, action_candidate %></td>
          <td><%= action_candidate.business.name %></td>
          <td><span class="pill"><%= ActionCandidateDepartmentRanking::DEPARTMENTS.fetch(action_candidate.department, action_candidate.department) %></span></td>
          <td><span class="pill"><%= action_candidate.action_type %></span></td>
          <td class="number"><%= number_to_currency(action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></td>
          <td class="number"><%= number_with_precision(judge_score.judge_adjusted_score, precision: 1) %></td>
          <td>
            <span class="pill"><%= action_candidate.status %></span>
            <% feasibility_correction = action_candidate.metadata.to_h.fetch("execution_feasibility_correction", {}) %>
            <% if feasibility_correction["applied"] %>
              <br><span class="pill">実行補正あり</span>
              <span class="pill"><%= feasibility_correction["feasibility_label"] %></span>
            <% end %>
          </td>
          <td>
            <div class="actions compact-actions">
              <%= link_to "詳細", action_candidate, class: "button secondary" %>
              <%= link_to "編集", edit_action_candidate_path(action_candidate), class: "button secondary" %>
              <% if action_candidate.data_preparation? %>
                <% if executor_task %>
                  <%= link_to "Executor送信済み", admin_aicoo_executor_task_path(executor_task), class: "button secondary" %>
                <% else %>
                  <%= button_to "Executorへ送る", send_to_executor_action_candidate_path(action_candidate), method: :post, class: "button" %>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>
