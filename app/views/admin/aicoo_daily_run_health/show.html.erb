<% content_for :title, "Daily Run Health" %>

<% header_actions = capture do %>
  <%= link_to "Daily Run履歴", aicoo_daily_runs_path, class: "button secondary" %>
  <%= link_to "Daily Run設定", admin_aicoo_daily_run_settings_path, class: "button secondary" %>
  <%= link_to "SYSTEM MODE", aicoo_daily_runs_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Daily Run Health",
             description: "Render Cronで実行されたDaily Runが本当に動いたか、AICOO内のDB記録だけで確認します。",
             active_main: :dashboard,
             actions: header_actions %>
  <%= render "shared/aicoo_execution_tabs", active: :dashboard %>

  <% if @cron_health.warnings.any? %>
    <section class="dashboard-section danger">
      <div class="section-heading">
        <div>
          <h2>異常検知</h2>
          <p>Renderログを開かずに、Daily Runの詰まり・認証・ENV・APIエラー兆候を確認します。</p>
        </div>
      </div>
      <div class="aicoo-card-grid">
        <% @cron_health.warnings.each do |warning| %>
          <div class="system-status-card status-<%= warning.severity == "critical" ? "critical" : "warning" %>">
            <p><span class="system-status-pill status-<%= warning.severity == "critical" ? "critical" : "warning" %>"><%= warning.severity %></span></p>
            <h3><%= warning.title %></h3>
            <p><%= warning.message %></p>
          </div>
        <% end %>
      </div>

      <div class="actions compact-actions">
        <%= button_to "Daily Run再実行", aicoo_daily_runs_path,
                      method: :post,
                      params: { aicoo_daily_run: { target_date: @scheduler_status.target_date.to_s } },
                      class: "button",
                      data: { turbo_confirm: "#{@scheduler_status.target_date} のDaily Runを再実行しますか？" } %>
        <%= link_to "Scheduler診断", admin_aicoo_daily_run_settings_path, class: "button secondary" %>
        <%= link_to "ENV診断", aicoo_setting_path, class: "button secondary" %>
      </div>

      <% if @cron_health.warnings.any? { |warning| warning.title.to_s.match?(/Google|OAuth|API/) || warning.message.to_s.match?(/Google|OAuth|GA4|GSC|invalid_grant/i) } %>
        <div class="aicoo-card aicoo-card-compact">
          <h3>Google APIエラーの復旧</h3>
          <p>Google OAuth / GA4 / GSC の失敗は、ここから再認証できます。</p>
          <%= render "shared/google_reauth_actions", credential: @google_credential, compact: true %>
        </div>
      <% end %>

      <% if @cron_health.recoverable_steps.any? %>
        <div class="aicoo-card aicoo-card-compact">
          <h3>安全に再実行できるStep</h3>
          <div class="actions compact-actions">
            <% @cron_health.recoverable_steps.each do |step| %>
              <%= button_to "#{step.step_name} 再実行",
                            recover_aicoo_daily_run_step_path(@cron_health.latest_run, step),
                            method: :post,
                            class: "button secondary",
                            data: { turbo_confirm: "#{step.step_name} stepを再実行しますか？" } %>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>Daily Run Health</h2>
        <p>毎朝最初に見る要約です。Cronの状態、今日の回数、最新Runの成否を確認します。</p>
      </div>
    </div>
    <%= render "shared/daily_run_cron_mode", status: @cron_status %>
    <div class="metric-grid">
      <div class="metric-card"><span>最終Cron開始</span><strong><%= @cron_health.last_cron_started_at ? l(@cron_health.last_cron_started_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>最終Cron終了</span><strong><%= @cron_health.last_cron_finished_at ? l(@cron_health.last_cron_finished_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>最終成功</span><strong><%= @cron_health.last_success_at ? l(@cron_health.last_success_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>最終失敗</span><strong><%= @cron_health.last_failure_at ? l(@cron_health.last_failure_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>実行時間</span><strong><%= @cron_health.duration_label_for_latest %></strong></div>
      <div class="metric-card"><span>Status</span><strong><%= @cron_health.status %></strong></div>
      <div class="metric-card"><span>今日の実行</span><strong><%= @cron_health.today_run_count %>回</strong></div>
      <div class="metric-card"><span>今日の成功</span><strong><%= @cron_health.today_success_count %>回</strong></div>
      <div class="metric-card"><span>今日の失敗</span><strong><%= @cron_health.today_failure_count %>回</strong></div>
      <div class="metric-card"><span>今日のSkip</span><strong><%= @cron_health.today_skip_count %>回</strong></div>
      <div class="metric-card"><span>Retry</span><strong><%= @cron_health.retry_count %>回</strong></div>
      <div class="metric-card"><span>Stuck検知</span><strong><%= @cron_health.stuck_count %>件</strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>最新Run</h2>
        <p>最新のAicooDailyRunを確認します。エラー全文やmetadataはRun詳細画面に集約しています。</p>
      </div>
      <% if @cron_health.latest_run %>
        <%= link_to "Run詳細", aicoo_daily_run_path(@cron_health.latest_run), class: "button secondary" %>
      <% end %>
    </div>

    <% if @cron_health.latest_run %>
      <% latest = @cron_health.latest_run %>
      <div class="metric-grid">
        <div class="metric-card"><span>Run ID</span><strong>#<%= latest.id %></strong></div>
        <div class="metric-card"><span>開始日時</span><strong><%= latest.started_at ? l(latest.started_at, format: :short) : "-" %></strong></div>
        <div class="metric-card"><span>終了日時</span><strong><%= latest.finished_at ? l(latest.finished_at, format: :short) : "-" %></strong></div>
        <div class="metric-card"><span>Status</span><strong><%= latest.status %></strong></div>
        <div class="metric-card"><span>実行時間</span><strong><%= @cron_health.duration_label_for_latest %></strong></div>
        <div class="metric-card"><span>実行環境</span><strong><%= @cron_health.latest_run_environment %></strong></div>
        <div class="metric-card"><span>実行理由</span><strong><%= @cron_health.latest_run_reason %></strong></div>
        <div class="metric-card"><span>エラー</span><strong><%= latest.error_message.presence || "-" %></strong></div>
      </div>
    <% else %>
      <div class="aicoo-card aicoo-empty-state">
        <h2>Daily Run履歴がまだありません。</h2>
      </div>
    <% end %>
  </section>

  <% if @cron_health.latest_run %>
    <section class="dashboard-section">
      <div class="section-heading">
        <div>
          <h2>Step一覧</h2>
          <p>最新RunのStep状態です。Warningは黄色、Failureは赤で表示します。</p>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Step名</th>
              <th>Status</th>
              <th>開始</th>
              <th>終了</th>
              <th>実行時間</th>
              <th>Warning</th>
              <th>Error Message</th>
            </tr>
          </thead>
          <tbody>
            <% @cron_health.latest_step_rows.each do |row| %>
              <tr class="status-<%= row.severity %>">
                <td><%= row.name %></td>
                <td><span class="system-status-pill status-<%= row.severity %>"><%= row.status %></span></td>
                <td><%= row.started_at ? l(row.started_at, format: :short) : "-" %></td>
                <td><%= row.finished_at ? l(row.finished_at, format: :short) : "-" %></td>
                <td><%= row.duration_label %></td>
                <td><%= row.warning %></td>
                <td class="wide-text"><%= row.error_message %></td>
              </tr>
            <% end %>
            <% if @cron_health.latest_step_rows.empty? %>
              <tr><td colspan="7">このRunにはStepがまだありません。</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>過去30件のDaily Run</h2>
        <p>Render Cron / Manualを横断して、実行時間・Step成功数・Step失敗数を確認します。</p>
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>日時</th>
            <th>Status</th>
            <th>実行時間</th>
            <th>Step成功</th>
            <th>Step失敗</th>
            <th>Retry</th>
            <th>Trigger</th>
            <th>詳細</th>
          </tr>
        </thead>
        <tbody>
          <% @cron_health.history_rows.each do |row| %>
            <tr>
              <td><%= row.run.started_at ? l(row.run.started_at, format: :short) : l(row.run.created_at, format: :short) %></td>
              <td><span class="pill"><%= row.run.status %></span></td>
              <td><%= row.duration_label %></td>
              <td class="number"><%= row.success_count %></td>
              <td class="number"><%= row.failed_count %></td>
              <td class="number"><%= row.retry_count %></td>
              <td><%= row.trigger_label %></td>
              <td><%= link_to "詳細", aicoo_daily_run_path(row.run), class: "button secondary" %></td>
            </tr>
          <% end %>
          <% if @cron_health.history_rows.empty? %>
            <tr><td colspan="8">まだDaily Runはありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
