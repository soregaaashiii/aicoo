<% content_for :title, "Codex投入一覧" %>

<% header_actions = capture do %>
  <%= link_to "改修キュー", codex_queue_auto_revision_tasks_path, class: "button secondary" %>
  <%= link_to "Execution Profile", admin_business_execution_profiles_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Codex投入一覧",
             description: "AutoRevisionTask、GitHub Issue、PR URL、失敗理由を一画面で追跡します。",
             active_main: :dashboard,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>絞り込み</h2>
      <p>status、Business、作業フォルダ、riskでCodex投入状態を確認します。</p>
    </div>
    <%= form_with url: admin_codex_submissions_path, method: :get, class: "inline-form", data: { turbo: false } do |form| %>
      <div class="field compact-field">
        <%= form.label :status, "状態" %>
        <%= form.select :status, options_for_select([ [ "すべて", "" ] ] + CodexSubmission::STATUSES.map { |status| [ status, status ] }, @status_filter) %>
      </div>
      <div class="field compact-field">
        <%= form.label :business_id, "Business" %>
        <%= form.collection_select :business_id, Business.real_businesses.order(:name), :id, :name, { include_blank: "すべて" }, selected: @business_id %>
      </div>
      <div class="field compact-field">
        <%= form.label :project_folder, "Codex作業フォルダ" %>
        <%= form.text_field :project_folder, value: @project_folder, placeholder: "例: suelog" %>
      </div>
      <div class="field compact-field">
        <%= form.label :risk, "Risk" %>
        <%= form.select :risk, options_for_select([ [ "すべて", "" ] ] + AutoRevisionTask::RISK_LEVELS.map { |risk| [ risk, risk ] }, @risk_filter) %>
      </div>
      <%= form.submit "絞り込む", class: "button secondary" %>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>状態</th>
            <th>Business</th>
            <th>作業フォルダ</th>
            <th>Repository</th>
            <th>Task</th>
            <th>Risk</th>
            <th>GitHub Issue</th>
            <th>PR</th>
            <th>作成</th>
            <th>Codex実行</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @codex_submissions.each do |submission| %>
            <tr>
              <td><span class="pill"><%= submission.workflow_status_label %></span></td>
              <td><%= link_to submission.business.name, submission.business %></td>
              <td><%= submission.project_folder %></td>
              <td class="wide-text"><%= submission.repository_url %></td>
              <td class="wide-text"><%= link_to submission.auto_revision_task.title, submission.auto_revision_task %></td>
              <td><span class="pill"><%= submission.auto_revision_task.risk_level %></span></td>
              <td>
                <% if submission.github_issue_url.present? %>
                  <%= link_to "Issue ##{submission.github_issue_number}", submission.github_issue_url, target: "_blank", rel: "noopener" %>
                <% else %>
                  -
                <% end %>
              </td>
              <td>
                <% if submission.pr_url.present? %>
                  <%= link_to "PR", submission.pr_url, target: "_blank", rel: "noopener" %>
                <% else %>
                  -
                <% end %>
              </td>
              <td><%= l(submission.created_at, format: :short) %></td>
              <td><%= submission.submitted_at ? l(submission.submitted_at, format: :short) : "-" %></td>
              <td class="actions compact-actions">
                <%= link_to "詳細", admin_codex_submission_path(submission), class: "button secondary" %>
                <% if submission.external_handoff_url.present? %>
                  <%= link_to submission.external_handoff_label, submission.external_handoff_url, class: "button", target: "_blank", rel: "noopener" %>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @codex_submissions.empty? %>
            <tr><td colspan="11">Codex投入Taskはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
