<% content_for :title, "Google API直取得" %>

<% header_actions = capture do %>
    <%= link_to "分析設定", admin_analytics_connections_path, class: "button secondary" %>
    <%= link_to "サイト別分析設定", admin_analytics_sites_path, class: "button secondary" %>
    <%= link_to "CSV貼り付け取込", admin_analytics_imports_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Google API直取得",
             description: "Google OAuthのRefresh Tokenを使い、BusinessごとのGA4 / GSCから直接取得してBusinessMetricDailyへ保存します。",
             active_main: :datahub,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="aicoo-lab-help">
      <strong>この画面でやること</strong>
      <p>CSV貼り付けは使いません。GSC site_url / GA4 property_id とGoogle OAuth接続済みのRefresh Tokenを使って、Google APIから日次KPIを直接取得します。</p>
    </div>
    <%= render "shared/google_oauth_client_status", credential: @google_credential %>
  </section>
</div>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>Business別 Google API取得</h2>
    <p>取得結果はBusinessMetricDailyに保存され、Business Analytics / Evidence / Learning の材料になります。</p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Business</th>
          <th>GSC</th>
          <th>GA4</th>
          <th>最終同期</th>
          <th>使用Credential</th>
          <th>取得状態</th>
          <th>Warning</th>
          <th>取得</th>
          <th>設定</th>
        </tr>
      </thead>
      <tbody>
        <% @businesses.each do |business| %>
          <% analytics = @business_analytics_summaries.fetch(business) %>
          <% health = analytics.health %>
          <% gsc_site_url = analytics.settings[:gsc_site_url] %>
          <% ga4_property_id = analytics.settings[:ga4_property_id] %>
          <% import_run = @google_api_import_runs_by_business_id[business.id] %>
          <% credential_snapshot = import_run&.metadata&.dig("google_credential_at_enqueue") || import_run&.metadata&.dig("google_credential_at_success") %>
          <tr>
            <td><%= link_to business.name, business_path(business) %></td>
            <td>
              <span class="pill"><%= health&.gsc&.connected ? "接続済み" : "未接続" %></span><br>
              <small><%= gsc_site_url.presence || "site_url未設定" %></small>
            </td>
            <td>
              <span class="pill"><%= health&.ga4&.connected ? "接続済み" : "未接続" %></span><br>
              <small><%= ga4_property_id.presence || "property_id未設定" %></small>
            </td>
            <td><%= analytics.last_sync_at ? l(analytics.last_sync_at, format: :short) : "-" %></td>
            <td>
              <% if credential_snapshot.present? %>
                #<%= credential_snapshot["record_id"] || "-" %><br>
                <small><%= credential_snapshot["client_id"].presence || "client_id未記録" %></small><br>
                <small><%= credential_snapshot["google_cloud_project_id"].presence || "project_id未記録" %></small>
              <% else %>
                <span class="pill"><%= @google_credential.present? ? "現在使用中 ##{@google_credential.id}" : "未設定" %></span>
              <% end %>
            </td>
            <td>
              <span class="pill"><%= import_run ? import_run.status_label : "未実行" %></span><br>
              <small>
                最終実行:
                <%= import_run&.started_at ? l(import_run.started_at, format: :short) : "-" %>
                / 更新 <%= import_run&.updated_metric_count.to_i %>件
              </small>
              <% if import_run&.failed? %>
                <br><small class="text-danger"><%= import_run.error_message %></small>
              <% end %>
            </td>
            <td>
              <% warnings = [health&.gsc&.warning, health&.ga4&.warning].compact %>
              <%= warnings.presence&.join(" / ") || "-" %>
            </td>
            <td>
              <%= button_to "Google APIから取得",
                            admin_google_api_imports_path,
                            method: :post,
                            params: { business_id: business.id },
                            class: "button",
                            data: { aicoo_loading_label: "Google API取得中..." },
                            form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "Google API取得中..." } },
                            disabled: gsc_site_url.blank? && ga4_property_id.blank? %>
            </td>
            <td><%= link_to "紐付け設定", edit_business_path(business, anchor: "data-source-link-settings"), class: "button secondary" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
