<% content_for :title, "新規事業探索" %>

<% current_run = @current_serp_run %>
<% current_candidates = Array(@current_run_candidates) %>
<% publication = current_run&.metadata.to_h["auto_new_business_publication"].to_h %>
<% businessized_count = publication["business_created_count"].to_i + publication["business_linked_count"].to_i %>
<% result_count = current_run&.metadata.to_h["result_count"].to_i %>
<% settings = @serp_settings.to_h %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "新規事業探索",
             description: "市場・検索需要・競合・未充足ニーズから新規事業候補を発見します。既存事業改善には使用しません。",
             mode: :ceo %>

  <section class="dashboard-section" id="serp-settings">
    <div class="section-heading">
      <div>
        <h2>設定</h2>
        <p>一度保存した設定を、次回以降の新規事業探索にも使います。</p>
      </div>
    </div>

    <div class="metric-grid">
      <div class="metric-card">
        <span>提供元</span>
        <strong><%= @current_provider %></strong>
      </div>
      <div class="metric-card">
        <span>APIキー</span>
        <strong><%= @api_key_configured ? "設定済み" : "未設定" %></strong>
        <small><%= @serp_optional_mode.reason %></small>
      </div>
      <div class="metric-card">
        <span>用途</span>
        <strong>新規事業探索専用</strong>
        <small>既存事業改善には使いません</small>
      </div>
      <div class="metric-card">
        <span>1日の探索件数</span>
        <strong><%= settings["daily_query_limit"].to_i %>件</strong>
      </div>
    </div>

    <div class="aicoo-card aicoo-card-compact">
      <%= form_with url: update_scheduler_admin_serp_settings_path, scope: :serp_exploration, method: :patch, class: "form" do |form| %>
        <div class="form-grid">
          <div>
            <%= form.label :mode, "探索方法" %>
            <%= form.select :mode,
                            options_for_select([
                              [ "AI自動探索", "ai_auto" ],
                              [ "業界指定", "industry" ],
                              [ "キーワード指定", "keyword" ]
                            ], settings["exploration_mode"]) %>
          </div>

          <div>
            <%= form.label :query, "業界・キーワード（任意）" %>
            <%= form.text_field :query,
                                value: settings["exploration_query"],
                                placeholder: "例: フリーランス 請求、飲食店 予約、士業 顧客管理" %>
          </div>

          <div>
            <%= form.label :country, "対象地域" %>
            <%= form.select :country, options_for_select([ "日本" ], settings["exploration_country"].presence || "日本") %>
          </div>

          <div>
            <%= form.label :region, "地域指定" %>
            <%= form.text_field :region, value: settings["exploration_region"], placeholder: "例: 東京、大阪、福岡。空欄なら全国" %>
          </div>

          <div>
            <%= form.label :daily_query_limit, "1日の探索件数" %>
            <%= form.number_field :daily_query_limit, value: settings["daily_query_limit"], min: 1, max: 100 %>
          </div>

          <div>
            <%= form.label :learning_enabled, "学習" %>
            <%= form.select :learning_enabled,
                            options_for_select([ [ "ON", "1" ], [ "OFF", "0" ] ], ActiveModel::Type::Boolean.new.cast(settings["learning_enabled"]) ? "1" : "0") %>
          </div>

          <div>
            <%= form.label :new_field_ratio, "新しい分野を探す割合" %>
            <%= form.number_field :new_field_ratio, value: settings["new_field_ratio"], min: 0, max: 100 %>
          </div>

          <div>
            <%= form.label :proven_field_ratio, "実績のある分野を深掘りする割合" %>
            <%= form.number_field :proven_field_ratio, value: settings["proven_field_ratio"], min: 0, max: 100 %>
          </div>
        </div>

        <fieldset class="aicoo-card aicoo-card-compact">
          <legend>除外</legend>
          <% exclusion_rules = Array(settings["exclusion_rules"]) %>
          <label class="checkbox-label">
            <%= check_box_tag "serp_exploration[exclusion_rules][]", "existing_businesses", exclusion_rules.include?("existing_businesses") %>
            既存事業
          </label>
          <label class="checkbox-label">
            <%= check_box_tag "serp_exploration[exclusion_rules][]", "deleted_businesses", exclusion_rules.include?("deleted_businesses") %>
            削除済み事業
          </label>
          <label class="checkbox-label">
            <%= check_box_tag "serp_exploration[exclusion_rules][]", "duplicate_markets", exclusion_rules.include?("duplicate_markets") %>
            重複市場
          </label>
        </fieldset>

        <div class="actions compact-actions">
          <%= form.submit "設定を保存", class: "button secondary" %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section" id="serp-scan">
    <div class="aicoo-card aicoo-card-compact">
      <div class="section-heading">
        <div>
          <h2>探索実行</h2>
          <p>市場探索、需要発見、競合分析、新規事業候補生成、事業化までを自動で進めます。</p>
        </div>
      </div>

      <%= form_with url: run_now_admin_serp_settings_path, method: :post, class: "form" do %>
        <% settings.slice("exploration_mode", "exploration_query", "exploration_country", "exploration_region", "daily_query_limit", "learning_enabled", "new_field_ratio", "proven_field_ratio").each do |key, value| %>
          <%= hidden_field_tag "serp_exploration[#{key.sub('exploration_', '')}]", value %>
        <% end %>
        <% Array(settings["exclusion_rules"]).each do |rule| %>
          <%= hidden_field_tag "serp_exploration[exclusion_rules][]", rule %>
        <% end %>
        <div class="actions compact-actions">
          <%= submit_tag "新規事業探索を実行", class: "button", data: { aicoo_loading_label: "新規事業探索中..." } %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section" id="serp-run-result">
    <div class="section-heading">
      <div>
        <h2>今回の走査結果</h2>
        <p>Rawデータや順位一覧は表示しません。新規事業化に必要な結果だけ表示します。</p>
      </div>
      <% if current_run %>
        <span class="pill"><%= current_run.status %></span>
      <% end %>
    </div>

    <% if current_run %>
      <div class="metric-grid">
        <div class="metric-card"><span>取得件数</span><strong><%= current_run.query_count %>件</strong></div>
        <div class="metric-card"><span>解析完了</span><strong><%= current_run.success_count %>件</strong></div>
        <div class="metric-card"><span>今回発見した新規事業候補</span><strong><%= current_candidates.size %>件</strong></div>
        <div class="metric-card"><span>新しくActionへ反映</span><strong><%= current_run.candidate_count %>件</strong></div>
        <div class="metric-card"><span>事業化</span><strong><%= businessized_count %>件</strong></div>
        <div class="metric-card"><span>保存結果</span><strong><%= result_count %>件</strong></div>
      </div>

      <% if current_candidates.any? %>
        <div class="aicoo-card">
          <div class="section-heading">
            <h3>期待値TOP5</h3>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>順位</th>
                  <th>事業名（仮）</th>
                  <th>理由</th>
                  <th>期待利益</th>
                  <th>成功率</th>
                  <th>学習価値</th>
                  <th>状態</th>
                </tr>
              </thead>
              <tbody>
                <% current_candidates.first(5).each.with_index(1) do |candidate, index| %>
                  <% candidate_metadata = candidate.metadata.to_h %>
                  <% publication_metadata = candidate_metadata["auto_new_business_publication"].to_h %>
                  <tr>
                    <td><span class="pill">#<%= index %></span></td>
                    <td class="wide-text">
                      <strong><%= candidate_metadata["business_name"].presence || candidate_metadata["service_name"].presence || candidate.title %></strong><br>
                      <small><%= candidate_metadata["source_query"].presence || candidate_metadata["serp_keyword"].presence || "根拠検索クエリ未記録" %></small>
                    </td>
                    <td><%= truncate(candidate_metadata["recommendation_reason"].presence || candidate.evaluation_reason.presence || candidate.description.to_s, length: 90) %></td>
                    <td><%= number_to_currency(candidate.expected_profit_yen, unit: "¥", precision: 0) %></td>
                    <td><%= number_to_percentage(candidate.success_probability.to_d * 100, precision: 0) %></td>
                    <td><%= number_to_currency(candidate.expected_learning_value_yen.to_i, unit: "¥", precision: 0) %></td>
                    <td>
                      <% if publication_metadata["completed"] || candidate.business_id.present? %>
                        <span class="pill">事業化済み</span>
                      <% else %>
                        <span class="pill">自動追加待ち</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% else %>
        <div class="aicoo-card aicoo-empty-state">
          <h3>今回の新規事業候補は0件です。</h3>
          <p>保存済み結果から新規事業候補を生成できませんでした。既存事業改善候補はここには表示しません。</p>
        </div>
      <% end %>
    <% else %>
      <div class="aicoo-card aicoo-empty-state">
        <h3>まだ新規事業探索はありません。</h3>
        <p>上の「新規事業探索を実行」を押すと、今回の探索結果がここに表示されます。</p>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section" id="serp-created-businesses">
    <div class="section-heading">
      <div>
        <h2>事業化した一覧</h2>
        <p>SERP経由で事業化したものだけを表示します。</p>
      </div>
    </div>

    <% if @serp_businessized_businesses.any? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>事業名</th>
              <th>作成日</th>
              <th>状態</th>
              <th>期待利益</th>
              <th>現在利益</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @serp_businessized_businesses.each do |business| %>
              <% metadata = business.metadata.to_h %>
              <tr>
                <td><strong><%= business.name %></strong></td>
                <td><%= l(business.created_at, format: :short) %></td>
                <td><%= business.lifecycle_stage.presence || business.status %></td>
                <td><%= number_to_currency(metadata["expected_profit_yen"].to_i, unit: "¥", precision: 0) %></td>
                <td><%= number_to_currency(business.revenue_amount(30.days.ago..Time.current), unit: "¥", precision: 0) %></td>
                <td><%= link_to "事業を見る", business_path(business), class: "button secondary" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="aicoo-card aicoo-empty-state">
        <h3>SERP経由で事業化したものはまだありません。</h3>
        <p>探索で候補が見つかると、自動で事業としてここに追加されます。</p>
      </div>
    <% end %>
  </section>
</div>
