<% content_for :title, "SERP設定" %>

<% header_actions = capture do %>
  <%= link_to "AICOO全体設定", aicoo_setting_path, class: "button secondary" %>
  <%= link_to "実績データ", admin_aicoo_datahub_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "SERP設定",
             description: "SERP ProviderをAdapter経由でテストします。AICOO本体はProvider固有JSONを直接読みません。",
             active_main: :system,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Provider状態</h2>
      <p>Providerは <code>AICOO_SERP_PROVIDER</code> で切り替えできます。初期ProviderはSerperです。</p>
    </div>

    <div class="metric-grid">
      <div class="metric-card">
        <span>現在のProvider</span>
        <strong><%= @current_provider %></strong>
      </div>
      <div class="metric-card">
        <span>API Key</span>
        <strong><%= @api_key_configured ? "設定済み" : "未設定" %></strong>
      </div>
      <div class="metric-card">
        <span>実行モード</span>
        <strong><%= @serp_profile.execution_mode %></strong>
      </div>
      <div class="metric-card">
        <span>月間予算</span>
        <strong><%= number_to_currency(@serp_profile.monthly_budget_yen, unit: "¥", precision: 0) %></strong>
      </div>
      <div class="metric-card">
        <span>Optional Mode</span>
        <strong><%= @serp_optional_mode.status %></strong>
        <small><%= @serp_optional_mode.reason %></small>
      </div>
    </div>

    <% unless @api_key_configured %>
      <div class="error-toast">
        <%= @serp_optional_mode.message %>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>SERP Optional Mode</h2>
      <p>SERPは任意データソースです。未設定でも既存データによる改善・Learning・Lifecycle評価は継続します。</p>
    </div>
    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card aicoo-card-compact">
        <h3>SERP依存step</h3>
        <p>API Key未設定時は skipped / warning として扱います。</p>
        <ul class="compact-list">
          <% @serp_optional_mode.dependent_steps.each do |step| %>
            <li><%= step %></li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>SERPなしで実行可能なstep</h3>
        <p>Daily Run全体と改善ループは継続します。</p>
        <ul class="compact-list">
          <% @serp_optional_mode.independent_steps.each do |step| %>
            <li><%= step %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>SERP月予算</h2>
      <p>CEO MODEの実行前コストと月予算警告に使います。</p>
    </div>

    <%= form_with url: admin_serp_settings_path, scope: :serp_settings, method: :patch, class: "form" do |form| %>
      <div class="form-grid">
        <div>
          <%= form.label :monthly_budget_yen, "月予算" %>
          <%= form.number_field :monthly_budget_yen, value: @serp_profile.monthly_budget_yen, min: 0 %>
        </div>
        <div>
          <%= form.label :monthly_spend_yen, "今月使用額" %>
          <%= form.number_field :monthly_spend_yen, value: @serp_profile.monthly_spend_yen, min: 0 %>
        </div>
        <div>
          <%= form.label :unit_result_cost_yen, "1取得あたり概算単価" %>
          <%= form.number_field :unit_result_cost_yen,
                                value: @serp_profile.metadata.to_h.fetch(Aicoo::Serp::ScanPlan::METADATA_UNIT_COST_KEY, Aicoo::Serp::ScanPlan::DEFAULT_UNIT_RESULT_COST_YEN),
                                min: 0,
                                step: 0.01 %>
        </div>
      </div>
      <div class="actions">
        <%= form.submit "SERP予算を保存", class: "button" %>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>テスト検索</h2>
      <p>Google Searchのみ実装済みです。Maps / News / Shopping / AI Overview / Images / Videos は未実装Providerとしてエラー表示します。</p>
    </div>

    <%= form_with url: test_search_admin_serp_settings_path, scope: :serp_test, method: :post, class: "form" do |form| %>
      <div class="form-grid">
        <div>
          <%= form.label :provider, "Provider" %>
          <%= form.select :provider, @provider_keys.map { |key| [key.to_s, key.to_s] }, selected: @test_params[:provider] %>
        </div>
        <div>
          <%= form.label :type, "検索タイプ" %>
          <%= form.select :type,
                          Aicoo::Serp::Adapter::TYPES.map { |type| [type.to_s, type.to_s] },
                          selected: @test_params[:type] %>
        </div>
        <div>
          <%= form.label :query, "query" %>
          <%= form.text_field :query, value: @test_params[:query], required: true %>
        </div>
        <div>
          <%= form.label :location, "location" %>
          <%= form.text_field :location, value: @test_params[:location] %>
        </div>
        <div>
          <%= form.label :language, "language" %>
          <%= form.text_field :language, value: @test_params[:language] %>
        </div>
        <div>
          <%= form.label :limit, "limit" %>
          <%= form.number_field :limit, value: @test_params[:limit], min: 1, max: 100 %>
        </div>
      </div>

      <div class="actions">
        <%= form.submit "SERP Adapterでテスト検索",
                        class: "button",
                        data: { aicoo_loading_label: "SERP検索中..." } %>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>取得結果</h2>
      <p>Daily RunまたはCEO MODEのSERP走査で保存された直近結果です。</p>
    </div>

    <div class="metric-grid">
      <div class="metric-card"><span>保存済み分析</span><strong><%= @serp_analysis_count %>件</strong></div>
      <div class="metric-card"><span>保存済み結果</span><strong><%= @serp_result_count %>件</strong></div>
      <div class="metric-card"><span>最終取得</span><strong><%= @recent_serp_analyses.first ? l(@recent_serp_analyses.first.analyzed_at, format: :short) : "未取得" %></strong></div>
      <div class="metric-card"><span>最終エラー</span><strong><%= @last_serp_error ? l(@last_serp_error.updated_at, format: :short) : "なし" %></strong></div>
    </div>

    <% if @last_serp_error %>
      <div class="error-toast">
        <strong><%= @last_serp_error.business.name %> / <%= @last_serp_error.keyword %></strong>
        <p><%= @last_serp_error.error_message %></p>
      </div>
    <% end %>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>取得日時</th>
            <th>Business</th>
            <th>Keyword</th>
            <th>Status</th>
            <th>Provider</th>
            <th>結果</th>
            <th>競合</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_serp_analyses.each do |analysis| %>
            <tr>
              <td><%= l(analysis.analyzed_at, format: :short) %></td>
              <td><%= link_to analysis.business.name, business_path(analysis.business, anchor: "business-serp") %></td>
              <td><%= analysis.keyword %></td>
              <td><span class="pill"><%= analysis.status %></span></td>
              <td><%= analysis.provider %></td>
              <td><%= analysis.result_count.to_i %>件</td>
              <td><%= analysis.competition_score || "-" %></td>
              <td><%= truncate(analysis.error_message, length: 80) if analysis.error_message.present? %></td>
            </tr>
          <% end %>
          <% if @recent_serp_analyses.empty? %>
            <tr><td colspan="8">SERP取得結果はまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <% if @error_message.present? %>
    <section class="dashboard-section">
      <div class="error-toast">SERPテスト検索に失敗しました。原因全文は実行履歴で確認してください。</div>
    </section>
  <% end %>

  <% if @result.present? %>
    <% payload = @result.to_h %>
    <section class="dashboard-section">
      <div class="section-heading">
        <h2>実行結果</h2>
        <p>Provider非依存の共通形式へ正規化済みです。</p>
      </div>

      <div class="metric-grid">
        <div class="metric-card"><span>Provider</span><strong><%= payload["provider"] %></strong></div>
        <div class="metric-card"><span>Type</span><strong><%= payload["type"] %></strong></div>
        <div class="metric-card"><span>Query</span><strong><%= payload["query"] %></strong></div>
        <div class="metric-card"><span>Organic</span><strong><%= payload["organic_results"].size %>件</strong></div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>順位</th>
              <th>タイトル</th>
              <th>URL</th>
              <th>Snippet</th>
            </tr>
          </thead>
          <tbody>
            <% payload["organic_results"].each do |row| %>
              <tr>
                <td><%= row["position"] %></td>
                <td><%= row["title"] %></td>
                <td><%= link_to row["displayed_url"].presence || row["url"], row["url"], target: "_blank", rel: "noopener" if row["url"].present? %></td>
                <td><%= truncate(row["snippet"], length: 140) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</div>
