<% content_for :title, "Codex Cloud Connection Center" %>

<% header_actions = capture do %>
  <%= link_to "Execution Profile", admin_business_execution_profiles_path, class: "button secondary" %>
  <%= link_to "Codex手動送信一覧", admin_codex_submissions_path, class: "button secondary" %>
  <%= link_to "Codex Rules", admin_codex_prompt_rules_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Codex Cloud Connection Center",
             description: "Codex Cloud接続、対象Repository、タスク送信、PR追跡を一元管理します。",
             active_main: :dashboard,
             actions: header_actions %>

  <nav class="aicoo-sub-tabs" aria-label="Codex Connection navigation">
    <%= link_to "全体設定", "#codex-global" %>
    <%= link_to "Business別接続", "#codex-businesses" %>
    <%= link_to "Codexタスク", "#codex-tasks" %>
    <%= link_to "PR追跡", "#codex-prs" %>
    <%= link_to "E2E診断", "#codex-e2e" %>
  </nav>

  <section class="dashboard-section" id="codex-global">
    <div class="section-heading">
      <h2>全体設定</h2>
      <p>初期値は安全側です。自動merge / 自動deployはBusiness別Execution Profileで明示ONにしたものだけ有効です。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card">
        <span>Codex利用</span>
        <strong><%= @summary.global_settings.codex_enabled_count.positive? ? "ON" : "OFF" %></strong>
        <small><%= @summary.global_settings.codex_enabled_count %>/<%= @summary.global_settings.profile_count %>件が有効</small>
      </div>
      <div class="metric-card">
        <span>GitHub接続状態</span>
        <strong><%= @summary.global_settings.github_configured_count.positive? ? "Repository設定あり" : "未設定" %></strong>
        <small>GitHub token: <%= @summary.global_settings.github_token_configured ? "設定済み" : "未設定" %></small>
      </div>
      <div class="metric-card"><span>デフォルトbase branch</span><strong><%= @summary.global_settings.default_base_branch %></strong></div>
      <div class="metric-card"><span>working branch prefix</span><strong><%= @summary.global_settings.default_working_branch %></strong></div>
      <div class="metric-card"><span>PR作成ルール</span><strong>Profile基準</strong><small><%= @summary.global_settings.pr_rule %></small></div>
      <div class="metric-card"><span>Codex自動実行</span><strong><%= @summary.global_settings.auto_submit_enabled_count.positive? ? "一部ON" : "OFF" %></strong><small>v1はOwner確認を優先</small></div>
      <div class="metric-card"><span>自動review</span><strong>ON</strong><small><%= @summary.global_settings.auto_review_label %></small></div>
      <div class="metric-card"><span>自動merge</span><strong><%= @summary.global_settings.auto_merge_enabled_count.positive? ? "一部ON" : "OFF" %></strong><small>high riskは禁止</small></div>
      <div class="metric-card"><span>自動deploy</span><strong><%= @summary.global_settings.auto_deploy_enabled_count.positive? ? "一部ON" : "OFF" %></strong><small>初期OFF</small></div>
      <div class="metric-card"><span>失敗時の停止ルール</span><strong>Business単位で停止</strong><small>failedはOwner確認へ</small></div>
      <div class="metric-card"><span>最終接続確認</span><strong><%= @summary.global_settings.last_connection_checked_at ? l(@summary.global_settings.last_connection_checked_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>最終エラー</span><strong><%= @summary.global_settings.last_error.present? ? "あり" : "なし" %></strong><small><%= truncate(@summary.global_settings.last_error.to_s, length: 80) %></small></div>
    </div>
  </section>

  <section class="dashboard-section" id="codex-businesses">
    <div class="section-heading">
      <h2>Business別接続</h2>
      <p>Business詳細では編集せず、この画面からExecution Profileへ移動します。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Business</th>
            <th>Codex</th>
            <th>GitHub repository</th>
            <th>base branch</th>
            <th>working prefix</th>
            <th>deploy target</th>
            <th>deploy command</th>
            <th>test command</th>
            <th>最終Codex実行</th>
            <th>最終PR</th>
            <th>Health</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @summary.business_rows.each do |row| %>
            <tr>
              <td><%= link_to row.business.name, row.business %></td>
              <td><span class="pill"><%= row.codex_enabled ? "ON" : "OFF" %></span></td>
              <td class="wide-text"><%= row.github_repo %></td>
              <td><%= row.base_branch %></td>
              <td><%= row.working_branch_prefix %></td>
              <td><%= row.deploy_target %></td>
              <td class="wide-text"><%= row.deploy_command %></td>
              <td class="wide-text"><%= row.test_command %></td>
              <td><%= row.last_codex_run_at ? l(row.last_codex_run_at, format: :short) : "-" %></td>
              <td class="wide-text">
                <% if row.last_pr_url.present? %>
                  <%= link_to "PR", row.last_pr_url, target: "_blank", rel: "noopener" %>
                <% else %>
                  -
                <% end %>
              </td>
              <td>
                <span class="pill"><%= row.health %></span>
                <% if row.missing_fields.present? %>
                  <div class="muted"><%= row.missing_fields.join(" / ") %></div>
                <% end %>
              </td>
              <td>
                <% if row.profile %>
                  <%= link_to "設定", edit_admin_business_execution_profile_path(row.profile), class: "button secondary" %>
                <% else %>
                  <%= link_to "作成", new_admin_business_execution_profile_path(business_id: row.business.id), class: "button secondary" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section" id="codex-tasks">
    <div class="section-heading">
      <h2>Codexタスク</h2>
      <p>AutoRevisionTaskからCodexへ渡す作業単位です。v1では完全プロンプト確認と手動PR追跡を優先します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>Codex送信待ち</span><strong><%= @summary.task_summary.waiting_count %></strong></div>
      <div class="metric-card"><span>送信済み</span><strong><%= @summary.task_summary.submitted_count %></strong></div>
      <div class="metric-card"><span>PR作成済み</span><strong><%= @summary.task_summary.pr_created_count %></strong></div>
      <div class="metric-card"><span>レビュー待ち</span><strong><%= @summary.task_summary.review_waiting_count %></strong></div>
      <div class="metric-card"><span>merge待ち</span><strong><%= @summary.task_summary.merge_waiting_count %></strong></div>
      <div class="metric-card"><span>deploy待ち</span><strong><%= @summary.task_summary.deploy_waiting_count %></strong></div>
      <div class="metric-card"><span>失敗</span><strong><%= @summary.task_summary.failed_count %></strong></div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>status</th>
            <th>Task名</th>
            <th>Business</th>
            <th>risk</th>
            <th>priority</th>
            <th>target repo</th>
            <th>base branch</th>
            <th>expected files</th>
            <th>last error</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @summary.task_rows.each do |row| %>
            <tr>
              <td><span class="pill"><%= row.status %></span></td>
              <td class="wide-text"><%= link_to row.title, row.task %></td>
              <td><%= link_to row.business.name, row.business %></td>
              <td><span class="pill"><%= row.risk %></span></td>
              <td><%= number_with_delimiter(row.priority.to_i) %></td>
              <td class="wide-text"><%= row.target_repo %></td>
              <td><%= row.base_branch %></td>
              <td class="wide-text"><%= row.expected_files.join(", ") %></td>
              <td class="wide-text"><%= truncate(row.last_error.to_s, length: 70) %></td>
              <td class="actions compact-actions">
                <% if row.submission %>
                  <%= link_to "Prompt確認", admin_codex_submission_path(row.submission), class: "button secondary" %>
                  <%= button_to "手動送信済みにする", mark_submitted_admin_codex_submission_path(row.submission), method: :patch, class: "button secondary" unless row.submission.status == "submitted" %>
                  <%= button_to "再試行", retry_admin_codex_submission_path(row.submission), method: :patch, class: "button secondary" if row.submission.status == "failed" %>
                <% else %>
                  <%= button_to "Codex手動送信準備", build_codex_submission_auto_revision_task_path(row.task), method: :post, class: "button" %>
                  <%= link_to "Prompt確認", row.task, class: "button secondary" %>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @summary.task_rows.empty? %>
            <tr><td colspan="10">Codex対象Taskはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section" id="codex-prs">
    <div class="section-heading">
      <h2>PR追跡</h2>
      <p>Codexが作成したPRをAICOO側で追跡します。GitHub API未連携でも手動更新できます。</p>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>PR</th>
            <th>Business</th>
            <th>repo</th>
            <th>branch</th>
            <th>status</th>
            <th>review</th>
            <th>CI</th>
            <th>merge</th>
            <th>deploy</th>
            <th>last checked</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @summary.pr_rows.each do |row| %>
            <tr>
              <td><%= link_to "PR", row.pr_url, target: "_blank", rel: "noopener" %></td>
              <td><%= link_to row.business.name, row.business %></td>
              <td class="wide-text"><%= row.github_repo %></td>
              <td><%= row.branch %></td>
              <td><span class="pill"><%= row.status %></span></td>
              <td><%= row.review_status %></td>
              <td><%= row.ci_status %></td>
              <td><%= row.merge_status %></td>
              <td><%= row.deploy_status %></td>
              <td><%= row.last_checked_at ? l(Time.zone.parse(row.last_checked_at.to_s), format: :short) : "-" %></td>
              <td class="actions compact-actions">
                <%= link_to "詳細", admin_codex_submission_path(row.submission), class: "button secondary" %>
                <%= button_to "merge済み", mark_merged_admin_codex_submission_path(row.submission), method: :patch, class: "button secondary" %>
                <%= button_to "deploy済み", mark_deployed_admin_codex_submission_path(row.submission), method: :patch, class: "button secondary" %>
              </td>
            </tr>
          <% end %>
          <% if @summary.pr_rows.empty? %>
            <tr><td colspan="11">追跡中のPRはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <section class="aicoo-card">
      <h3>PR URL登録 / ステータス更新</h3>
      <p class="muted">Codex手動送信済みTaskにPR URLを登録すると、上のPR追跡に表示されます。</p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Task</th>
              <th>PR URL</th>
              <th>review</th>
              <th>CI</th>
              <th>merge</th>
              <th>deploy</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @summary.task_rows.select(&:submission).each do |row| %>
              <% payload = row.submission.response_payload.to_h %>
              <tr>
                <td class="wide-text"><%= link_to row.title, admin_codex_submission_path(row.submission) %></td>
                <%= form_with model: row.submission, url: update_tracking_admin_codex_submission_path(row.submission), method: :patch, data: { turbo: false } do |form| %>
                  <td><%= form.url_field :pull_request_url, value: row.submission.pr_url, placeholder: "https://github.com/.../pull/1" %></td>
                  <td><%= form.select :review_status, options_for_select(%w[未確認 pending approved changes_requested failed], payload["review_status"]) %></td>
                  <td><%= form.select :ci_status, options_for_select(%w[未確認 pending success failed], payload["ci_status"]) %></td>
                  <td><%= form.select :merge_status, options_for_select(%w[未merge pending merged failed], payload["merge_status"]) %></td>
                  <td><%= form.select :deploy_status, options_for_select(%w[未deploy pending deployed failed], payload["deploy_status"]) %></td>
                  <td><%= form.submit "更新", class: "button secondary" %></td>
                <% end %>
              </tr>
            <% end %>
            <% if @summary.task_rows.select(&:submission).empty? %>
              <tr><td colspan="7">PR URLを登録できるCodexSubmissionはまだありません。</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </section>

  <section class="dashboard-section" id="codex-e2e">
    <div class="section-heading">
      <h2>E2E診断</h2>
      <p>Businessを選ぶだけで、Codex手動送信からPR追跡、deploy確認までの準備状態を診断します。</p>
    </div>

    <%= form_with url: admin_codex_connection_path(anchor: "codex-e2e"), method: :get, class: "inline-form", data: { turbo: false } do |form| %>
      <div class="field compact-field">
        <%= form.label :business_id, "Business" %>
        <%= form.collection_select :business_id, @summary.business_options, :id, :name, { selected: @summary.e2e.business&.id } %>
      </div>
      <%= form.submit "診断", class: "button secondary" %>
    <% end %>

    <div class="metric-grid">
      <div class="metric-card">
        <span>Codex Health</span>
        <strong><%= @summary.e2e.health %></strong>
        <small><%= @summary.e2e.business&.name || "-" %></small>
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>状態</th>
            <th>診断</th>
            <th>結果</th>
          </tr>
        </thead>
        <tbody>
          <% @summary.e2e.checks.each do |check| %>
            <tr>
              <td>
                <% label = { "pass" => "PASS", "warning" => "WARNING", "fail" => "FAIL" }.fetch(check.status, check.status.upcase) %>
                <span class="pill"><%= label %></span>
              </td>
              <td><%= check.label %></td>
              <td><%= check.message %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
