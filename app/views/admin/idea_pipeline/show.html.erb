<% content_for :title, @item.title %>

<% header_actions = capture do %>
  <%= link_to "Pipeline一覧", admin_idea_pipeline_index_path, class: "button secondary" %>
  <% if @item.aicoo_lab_landing_page %>
    <%= link_to "LP編集", admin_aicoo_lab_edit_public_landing_page_path(@item.aicoo_lab_landing_page), class: "button secondary" %>
  <% end %>
  <% if @item.business %>
    <%= link_to "Business詳細", business_path(@item.business), class: "button secondary" %>
  <% elsif @item.aicoo_lab_landing_page&.publicly_visible? || @item.mvp_decided_at.present? %>
    <%= button_to "Businessを作成して紐付け", recover_business_admin_idea_pipeline_path(@item), method: :post, class: "button" %>
  <% end %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: @item.title,
             description: @item.short_description,
             active_main: :system,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Pipeline状態遷移</h2>
      <p>DiscoveryからContinue / Pivot / Endまでを、Gate・Waiting・Budget込みで管理します。</p>
    </div>
    <div class="idea-pipeline-flow">
      <% AicooPipelineRun::STAGES.each do |stage| %>
        <% state = @pipeline_run.stage_state(stage) %>
        <div class="idea-stage-node <%= 'done' if state['status'].in?(%w[done skipped]) %> <%= 'active' if @pipeline_run.current_stage == stage %>">
          <span><%= stage_label(stage) %></span>
          <strong><%= state["status"].presence || "pending" %></strong>
          <% if @pipeline_run.current_stage == stage && state["message"].present? %>
            <small><%= state["message"] %></small>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>Pipeline</span><strong><%= @pipeline_run.status %></strong></div>
      <div class="metric-card"><span>現在位置</span><strong><%= stage_label(@pipeline_run.current_stage) %></strong></div>
      <div class="metric-card"><span>次</span><strong><%= @pipeline_run.next_stage ? stage_label(@pipeline_run.next_stage) : "-" %></strong></div>
      <div class="metric-card"><span>詰まり</span><strong><%= @pipeline_run.stuck? ? @pipeline_run.stuck_reason : "なし" %></strong></div>
      <div class="metric-card"><span>Pivot判断</span><strong><%= @pipeline_run.pivot_decision.presence || "-" %></strong></div>
      <div class="metric-card"><span>予想コスト</span><strong><%= number_to_currency(@pipeline_run.estimated_cost_yen || 0, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>実コスト</span><strong><%= number_to_currency(@pipeline_run.actual_cost_yen || 0, unit: "¥", precision: 0) %></strong></div>
    </div>
    <% if @pipeline_run.stuck? %>
      <div class="notice-toast">
        <strong>Pipelineが停止しています。</strong>
        <p><%= @pipeline_run.recovery_message.presence || "原因を確認して復旧操作を選んでください。" %></p>
        <div class="actions compact-actions">
          <%= button_to "再試行", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "retry" }, class: "button secondary" %>
          <%= button_to "スキップ", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "skip" }, class: "button secondary" %>
          <%= button_to "承認して進む", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "approve" }, class: "button secondary" %>
          <%= button_to "停止", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "stop" }, class: "button secondary" %>
          <%= button_to "終了", admin_pipeline_recovery_path(@pipeline_run), method: :post, params: { recovery_action: "end" }, class: "button secondary", data: { turbo_confirm: "このPipelineを終了しますか？" } %>
          <a href="#pipeline-recovery-logs" class="button secondary">復旧ログを見る</a>
        </div>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section" id="pipeline-recovery-logs">
    <div class="section-heading">
      <h2>復旧ログ</h2>
      <p>自動復旧と手動復旧の履歴です。詳細エラーはここだけに表示します。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>日時</th>
            <th>Stage</th>
            <th>理由</th>
            <th>操作</th>
            <th>結果</th>
            <th>前</th>
            <th>後</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          <% @pipeline_recovery_logs.each do |log| %>
            <tr>
              <td><%= l(log.executed_at, format: :short) %></td>
              <td><%= stage_label(log.stage) %></td>
              <td><%= log.stuck_reason %></td>
              <td><%= log.action %></td>
              <td><%= log.success? ? "成功" : "失敗" %></td>
              <td><%= log.before_status.presence || "-" %></td>
              <td><%= log.after_status.presence || "-" %></td>
              <td><%= simple_format(log.error_message.presence || "-") %></td>
            </tr>
          <% end %>
          <% if @pipeline_recovery_logs.empty? %>
            <tr><td colspan="8">復旧ログはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Idea</h2>
      <p>サービス化前に、まずLPで反応を見るための仮説です。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>状態</span><strong><%= @item.status %></strong></div>
      <div class="metric-card"><span>Score</span><strong><%= number_with_precision(@item.final_score, precision: 1) || "-" %></strong></div>
      <div class="metric-card"><span>期待利益</span><strong><%= @item.expected_profit_yen ? number_to_currency(@item.expected_profit_yen, unit: "¥", precision: 0) : "-" %></strong></div>
      <div class="metric-card"><span>MVP判断</span><strong><%= @item.mvp_decision.presence || "-" %></strong></div>
      <div class="metric-card">
        <span>Business化</span>
        <strong>
          <% if @item.business %>
            作成済み / <%= link_to "Business詳細へ", business_path(@item.business) %>
          <% else %>
            未作成
          <% end %>
        </strong>
      </div>
    </div>
    <div class="aicoo-card">
      <p><strong>解決課題:</strong> <%= @item.problem %></p>
      <p><strong>想定ユーザー:</strong> <%= @item.target_user %></p>
      <p><strong>収益モデル:</strong> <%= @item.revenue_model %></p>
      <p><strong>MVP案:</strong> <%= @item.mvp_concept %></p>
      <p><strong>LP案:</strong> <%= @item.lp_concept %></p>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Stage操作</h2>
      <p>SERPやLP公開は高コスト/公開操作なので、必要な段階だけ進められます。</p>
    </div>
    <div class="actions">
      <%= button_to "期待値評価", score_admin_idea_pipeline_path(@item), method: :post, class: "button secondary" %>
      <%= button_to "SERP判定", run_serp_admin_idea_pipeline_path(@item), method: :post, class: "button secondary" %>
      <% if @item.serp_passed? %>
        <%= button_to "SERP後に生成", generate_lp_admin_idea_pipeline_path(@item), method: :post, class: "button secondary" %>
      <% else %>
        <%= button_to "SERPなしでLP生成", generate_lp_admin_idea_pipeline_path(@item), method: :post, class: "button secondary" unless @item.lp_generation_blocked? %>
      <% end %>
      <%= button_to "公開", publish_lp_admin_idea_pipeline_path(@item), method: :post, class: "button secondary" %>
      <%= button_to "反応評価", evaluate_learning_admin_idea_pipeline_path(@item), method: :post, class: "button secondary" %>
      <%= button_to "MVP仕様書", build_mvp_spec_admin_idea_pipeline_path(@item), method: :post, class: "button" %>
      <%= button_to "まとめて次へ", run_pipeline_admin_idea_pipeline_path(@item), method: :post, class: "button" %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Score</h2>
      <p>AI評価だけで絞り、上位IdeaだけSERPへ進めます。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>市場</span><strong><%= @item.market_score || "-" %></strong></div>
      <div class="metric-card"><span>競合</span><strong><%= @item.competition_score || "-" %></strong></div>
      <div class="metric-card"><span>収益性</span><strong><%= @item.monetization_score || "-" %></strong></div>
      <div class="metric-card"><span>自動化率</span><strong><%= @item.automation_score || "-" %></strong></div>
      <div class="metric-card"><span>SERP難易度</span><strong><%= @item.serp_difficulty_score || "-" %></strong></div>
      <div class="metric-card"><span>維持コスト</span><strong><%= @item.maintenance_cost_score || "-" %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>SERP結果評価</h2>
      <p>Organic / Related / PAAから競合強度・市場性・差別化を評価します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>SERP状態</span><strong><%= @item.serp_status_label %></strong></div>
      <div class="metric-card"><span>合格</span><strong><%= @item.serp_passed? ? "はい" : "いいえ" %></strong></div>
      <div class="metric-card"><span>Organic</span><strong><%= @item.serp_snapshot.to_h["organic_count"] || 0 %>件</strong></div>
      <div class="metric-card"><span>競合強度</span><strong><%= @item.serp_snapshot.to_h["competition_strength"] || "-" %></strong></div>
      <div class="metric-card"><span>市場性</span><strong><%= @item.serp_snapshot.to_h["market_signal"] || "-" %></strong></div>
      <div class="metric-card"><span>差別化</span><strong><%= @item.serp_snapshot.to_h["differentiation_score"] || "-" %></strong></div>
    </div>
    <% if @item.serp_snapshot.to_h["reason"].present? %>
      <div class="error-toast"><%= @item.serp_snapshot.to_h["reason"] %></div>
    <% end %>
    <% if @item.serp_warning_for_lp_generation.present? && @item.lp_generation_allowed? %>
      <div class="notice-toast">
        <%= @item.serp_warning_for_lp_generation %>
        <div class="actions compact-actions">
          <%= link_to "SERP設定へ", admin_serp_settings_path, class: "button secondary" %>
          <%= button_to "SERPなしでLP生成", generate_lp_admin_idea_pipeline_path(@item), method: :post, class: "button" unless @item.aicoo_lab_landing_page %>
        </div>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>LP / 公開 / Learning</h2>
      <p>公開後は既存LP基盤のGA4/GSC/robots/sitemap対象になります。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>LP</span><strong><%= @item.aicoo_lab_landing_page ? @item.aicoo_lab_landing_page.public_status : "未生成" %></strong></div>
      <div class="metric-card"><span>PV</span><strong><%= @item.learning_snapshot.to_h["pv"] || 0 %></strong></div>
      <div class="metric-card"><span>CTA</span><strong><%= @item.learning_snapshot.to_h["cta_clicks"] || 0 %></strong></div>
      <div class="metric-card"><span>Signup</span><strong><%= @item.learning_snapshot.to_h["signups"] || 0 %></strong></div>
    </div>
    <% if @item.aicoo_lab_landing_page&.published_slug.present? %>
      <p><%= link_to "公開LPを見る", public_lp_path(@item.aicoo_lab_landing_page.published_slug), class: "button secondary", target: "_blank", rel: "noopener" %></p>
    <% end %>
  </section>

  <% if @item.mvp_specification.present? %>
    <section class="dashboard-section">
      <div class="section-heading">
        <h2>Codex向けMVP仕様書</h2>
        <p>MVP化決定時だけ生成します。まだ実装は行いません。</p>
      </div>
      <pre><%= @item.mvp_specification %></pre>
    </section>
  <% end %>
</div>
