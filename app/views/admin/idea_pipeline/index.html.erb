<% content_for :title, "Idea Pipeline" %>

<% header_actions = capture do %>
  <%= button_to "Ideaを生成", generate_admin_idea_pipeline_index_path,
                method: :post,
                params: { count: 3 },
                class: "button",
                data: { aicoo_loading_label: "Idea生成中..." },
                form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "Idea生成中..." } } %>
  <%= link_to "公開LP管理", admin_aicoo_lab_public_landing_pages_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Idea Pipeline",
             description: "Ideaから期待値評価、SERP検証、LP公開、反応計測、MVP仕様書生成まで段階的に進めます。",
             active_main: :system,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Pipeline状態</h2>
      <p>DiscoveryからLearningまでを統一Pipelineとして同期します。</p>
    </div>
    <div class="idea-pipeline-flow">
      <% AicooPipelineRun::STAGES.each do |stage| %>
        <div class="idea-stage-node">
          <span><%= stage_label(stage) %></span>
          <strong><%= @pipeline_runs_by_item.values.count { |run| run.current_stage == stage } %></strong>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Idea一覧</h2>
      <p>期待値が高いものだけSERPへ進み、SERP合格後に公開LPへ進めます。</p>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Stage</th>
            <th>Idea</th>
            <th>Score</th>
            <th>期待利益</th>
            <th>SERP</th>
            <th>LP</th>
            <th>Pipeline</th>
            <th>MVP判断</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @latest_items.each do |item| %>
            <tr>
              <td><span class="pill"><%= stage_label(item.current_stage) %></span></td>
              <td class="wide-text">
                <strong><%= link_to item.title, admin_idea_pipeline_path(item) %></strong><br>
                <small><%= item.short_description %></small>
              </td>
              <td class="number"><%= number_with_precision(item.final_score, precision: 1) || "-" %></td>
              <td class="number"><%= item.expected_profit_yen ? number_to_currency(item.expected_profit_yen, unit: "¥", precision: 0) : "-" %></td>
              <td><%= item.serp_snapshot.to_h["status"].presence || "-" %></td>
              <td>
                <% if item.aicoo_lab_landing_page %>
                  <%= link_to item.aicoo_lab_landing_page.public_status, admin_aicoo_lab_edit_public_landing_page_path(item.aicoo_lab_landing_page) %>
                <% else %>
                  -
                <% end %>
              </td>
              <% run = @pipeline_runs_by_item[item] %>
              <td>
                <span class="pill"><%= run&.status || "-" %></span><br>
                <small><%= run ? stage_label(run.current_stage) : "-" %></small>
              </td>
              <td><%= item.mvp_decision.presence || "-" %></td>
              <td>
                <%= button_to "次へ進める", run_pipeline_admin_idea_pipeline_path(item),
                              method: :post,
                              class: "button secondary",
                              data: { aicoo_loading_label: "Pipeline実行中..." },
                              form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "Pipeline実行中..." } } %>
              </td>
            </tr>
          <% end %>
          <% if @latest_items.empty? %>
            <tr><td colspan="9">Ideaはまだありません。まず「Ideaを生成」を押してください。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
