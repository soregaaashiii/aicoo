<% content_for :title, "SERP検索クエリ" %>

<% header_actions = capture do %>
  <%= link_to "SERP設定", admin_serp_settings_path, class: "button secondary" %>
  <%= link_to "SERP E2E診断", admin_serp_e2e_check_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "SERP検索クエリ",
             description: "BusinessごとのSERP検索クエリを優先順位順に管理します。追加しただけでは検索は実行されません。",
             active_main: :dashboard,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>絞り込み</h2>
      <p>SERP Schedulerはactiveの検索クエリをpriority順に実行します。</p>
    </div>
    <%= form_with url: admin_serp_queries_path, method: :get, class: "inline-form", data: { turbo: false } do |form| %>
      <div class="field compact-field">
        <%= form.label :business_id, "Business" %>
        <%= form.collection_select :business_id, @businesses, :id, :name, { include_blank: "すべて" }, selected: @business_id %>
      </div>
      <div class="field compact-field">
        <%= form.label :category, "Category" %>
        <%= form.select :category, options_for_select([ [ "すべて", "" ] ] + SerpQuery::CATEGORIES.map { |category| [ category, category ] }, @category) %>
      </div>
      <div class="field compact-field">
        <%= form.label :status, "Status" %>
        <%= form.select :status, options_for_select([ [ "すべて", "" ] ] + SerpQuery::STATUSES.map { |status| [ status, status ] }, @status) %>
      </div>
      <div class="field compact-field">
        <%= form.label :enabled, "Enabled" %>
        <%= form.select :enabled, options_for_select([ [ "すべて", "" ], [ "ON", "true" ], [ "OFF", "false" ] ], @enabled) %>
      </div>
      <div class="field compact-field">
        <%= form.label :q, "検索クエリ検索" %>
        <%= form.search_field :q, value: @q, placeholder: "警備 AI" %>
      </div>
      <%= form.submit "絞り込む", class: "button secondary" %>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>SERP検索クエリを追加</h2>
      <p>追加ボタンを押した時点でDB保存されます。追加後に再度保存する必要はありません。</p>
    </div>
    <%= form_with model: [ :admin, @serp_query ], class: "inline-form", data: { turbo: false } do |form| %>
      <div class="field compact-field">
        <%= form.label :business_id, "Business" %>
        <%= form.collection_select :business_id, @businesses, :id, :name, { include_blank: "選択" } %>
      </div>
      <div class="field compact-field">
        <%= form.label :query, "検索クエリ" %>
        <%= form.text_field :query, placeholder: "大阪 喫煙 カフェ" %>
      </div>
      <div class="field compact-field">
        <%= form.label :category, "Category" %>
        <%= form.select :category, SerpQuery::CATEGORIES.map { |category| [ category, category ] } %>
      </div>
      <div class="field compact-field">
        <%= form.label :priority, "Priority" %>
        <%= form.number_field :priority, min: 0, step: 1 %>
      </div>
      <div class="field compact-field">
        <%= form.label :daily_limit, "Daily Limit" %>
        <%= form.number_field :daily_limit, min: 0, step: 1 %>
      </div>
      <%= form.submit "検索クエリを追加", class: "button" %>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>SERP検索クエリ一覧</h2>
      <p>Priorityが小さいほど先に実行されます。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Priority</th>
            <th>検索クエリ</th>
            <th>Status</th>
            <th>Business</th>
            <th>Category</th>
            <th>Enabled</th>
            <th>Daily Limit</th>
            <th>最終取得</th>
            <th>次回実行予定</th>
            <th>Success</th>
            <th>Failure</th>
            <th>Candidate</th>
            <th>Revenue</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @serp_queries.each do |query| %>
            <tr id="serp-query-<%= query.id %>">
              <td><%= query.priority %></td>
              <td class="wide-text"><%= query.query %></td>
              <td><span class="pill"><%= query.status %></span></td>
              <td><%= link_to query.business.name, query.business %></td>
              <td><span class="pill"><%= query.category %></span></td>
              <td><span class="pill"><%= query.enabled? ? "ON" : "OFF" %></span></td>
              <td><%= query.daily_limit %></td>
              <td><%= query.last_run_at ? l(query.last_run_at, format: :short) : "-" %></td>
              <td><%= query.next_run_label %></td>
              <td><%= query.success_count %></td>
              <td><%= query.failure_count %></td>
              <td><%= query.total_candidates_generated %> / 採用 <%= query.total_candidates_approved %></td>
              <td>¥<%= number_with_delimiter(query.total_revenue_yen) %></td>
              <td class="actions compact-actions">
                <%= link_to "編集", edit_admin_serp_query_path(query), class: "button secondary" %>
                <%= button_to "この検索クエリだけ実行", run_now_admin_serp_query_path(query), method: :post, class: "button secondary" %>
                <%= button_to query.enabled? ? "OFF" : "ON", toggle_admin_serp_query_path(query), method: :patch, class: "button secondary" %>
                <%= button_to "Pause", pause_admin_serp_query_path(query), method: :patch, class: "button secondary" %>
                <%= button_to "Archive", archive_admin_serp_query_path(query), method: :patch, class: "button secondary" %>
                <%= link_to "最終結果を見る", admin_serp_settings_path(business_id: query.business_id, anchor: "serp-market-results"), class: "button secondary" %>
                <% if query.failure_count.to_i.positive? %>
                  <%= link_to "エラーを見る", admin_serp_settings_path(business_id: query.business_id, anchor: "serp-market-results"), class: "button secondary" %>
                <% end %>
                <%= button_to "削除", admin_serp_query_path(query), method: :delete, class: "button danger", form: { data: { turbo_confirm: "このSERP検索クエリを削除しますか？" } } %>
              </td>
            </tr>
          <% end %>
          <% if @serp_queries.empty? %>
            <tr><td colspan="14">SERP検索クエリはまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
