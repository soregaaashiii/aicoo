<% content_for :title, "SERP検索クエリ編集" %>

<% header_actions = capture do %>
  <%= link_to "一覧へ戻る", admin_serp_queries_path(business_id: @serp_query.business_id), class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "SERP検索クエリ編集",
             description: @serp_query.query,
             active_main: :dashboard,
             actions: header_actions %>

  <section class="dashboard-section">
    <%= form_with model: [ :admin, @serp_query ], class: "form", data: { turbo: false } do |form| %>
      <% if @serp_query.errors.any? %>
        <div class="error-toast"><%= @serp_query.errors.full_messages.to_sentence %></div>
      <% end %>

      <div class="grid">
        <div class="field">
          <%= form.label :business_id, "Business" %>
          <%= form.collection_select :business_id, @businesses, :id, :name %>
        </div>
        <div class="field">
          <%= form.label :query, "検索クエリ" %>
          <%= form.text_field :query %>
        </div>
        <div class="field">
          <%= form.label :status, "Status" %>
          <%= form.select :status, SerpQuery::STATUSES.map { |status| [ status, status ] } %>
        </div>
        <div class="field">
          <%= form.label :category, "Category" %>
          <%= form.select :category, SerpQuery::CATEGORIES.map { |category| [ category, category ] } %>
        </div>
        <div class="field">
          <%= form.label :priority, "Priority" %>
          <%= form.number_field :priority, min: 0, step: 1 %>
        </div>
        <div class="field">
          <%= form.label :daily_limit, "Daily Limit" %>
          <%= form.number_field :daily_limit, min: 0, step: 1 %>
        </div>
        <div class="field">
          <%= form.label :country, "Country" %>
          <%= form.text_field :country %>
        </div>
        <div class="field">
          <%= form.label :language, "Language" %>
          <%= form.text_field :language %>
        </div>
        <div class="field">
          <%= form.label :enabled, "Enabled" %>
          <%= form.check_box :enabled %>
        </div>
      </div>

      <%= form.submit "保存", class: "button" %>
    <% end %>
  </section>
</div>
