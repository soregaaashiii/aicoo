<% content_for :title, "SERP E2E診断" %>

<% header_actions = capture do %>
  <%= link_to "SERP設定", admin_serp_settings_path, class: "button secondary" %>
  <%= link_to "Daily Run", aicoo_daily_runs_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "SERP E2E診断",
             description: "API、検索クエリ、Scan Plan、SERP Run、取得結果、Learning、Action Candidateまで一画面で確認します。",
             active_main: :system,
             actions: header_actions %>

  <section class="dashboard-section">
    <%= form_with url: admin_serp_e2e_check_path, method: :get, local: true, class: "inline-form" do |form| %>
      <%= form.collection_select :business_id, @businesses, :id, :name, { selected: @business&.id } %>
      <%= form.submit "診断", class: "button" %>
    <% end %>
  </section>

  <% if @serp_e2e_check %>
    <% health_icon = { "healthy" => "✅", "warning" => "⚠", "broken" => "❌" }.fetch(@serp_e2e_check.overall_status) %>
    <section class="dashboard-section">
      <div class="section-heading">
        <div>
          <h2>SERP Health</h2>
          <p><%= @business.name %> のSERP運用状態です。</p>
        </div>
        <span class="pill"><%= health_icon %> <%= @serp_e2e_check.health_label %></span>
      </div>
      <div class="metric-grid">
        <div class="metric-card"><span>Business</span><strong><%= @business.name %></strong></div>
        <div class="metric-card"><span>総合判定</span><strong><%= @serp_e2e_check.health_label %></strong></div>
        <div class="metric-card"><span>Scan予定クエリ</span><strong><%= @serp_e2e_check.scan_plan_keywords.size %>件</strong></div>
        <div class="metric-card"><span>SERP候補</span><strong><%= @serp_e2e_check.serp_candidates.count %>件</strong></div>
      </div>
      <% metrics = @serp_e2e_check.pipeline_metrics %>
      <div class="metric-grid">
        <div class="metric-card"><span>取得件数</span><strong><%= metrics[:fetched_query_count] %></strong><small>SerpRun.query_count</small></div>
        <div class="metric-card"><span>保存件数</span><strong><%= metrics[:saved_result_count] %></strong><small>SerpResult全体</small></div>
        <div class="metric-card"><span>解析件数</span><strong><%= metrics[:saved_analysis_count] %></strong><small>SerpAnalysis全体</small></div>
        <div class="metric-card"><span>Business解析</span><strong><%= metrics[:business_analysis_count] %></strong><small><%= @business.name %></small></div>
        <div class="metric-card"><span>Business保存</span><strong><%= metrics[:business_result_count] %></strong><small>Business紐付け済みSerpResult</small></div>
        <div class="metric-card"><span>Candidate生成件数</span><strong><%= metrics[:candidate_count] %></strong><small>SERP由来</small></div>
      </div>
      <% if (problem = @serp_e2e_check.first_problem) %>
        <div class="<%= problem.status == "fail" ? "error-toast" : "notice-toast" %>">
          最優先: <strong><%= problem.label %></strong> - <%= problem.message %>
          <% if problem.details.to_h[:fail_reason].present? %>
            <br><small>FAIL理由: <%= problem.details[:fail_reason] %></small>
          <% end %>
        </div>
      <% end %>
    </section>

    <section class="dashboard-section">
      <div class="section-heading">
        <h2>取得からCandidate生成まで</h2>
        <p>どの段階で止まっているかを件数で確認します。</p>
      </div>
      <% metrics = @serp_e2e_check.pipeline_metrics %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>段階</th>
              <th>参照モデル</th>
              <th>件数</th>
              <th>見る場所</th>
              <th>0件時の主な原因</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>取得</td>
              <td>SerpRun</td>
              <td><%= metrics[:fetched_query_count] %></td>
              <td>latest run #<%= metrics[:latest_serp_run_id] || "-" %> / <%= metrics[:latest_serp_run_status] || "-" %></td>
              <td>Scheduler OFF、API Key未設定、実行対象クエリなし</td>
            </tr>
            <tr>
              <td>保存</td>
              <td>SerpResult</td>
              <td><%= metrics[:saved_result_count] %></td>
              <td>最新SerpRunに紐づく検索結果全体</td>
              <td>Providerレスポンス空、保存処理失敗、SerpAnalysisのみ作成</td>
            </tr>
            <tr>
              <td>解析</td>
              <td>SerpAnalysis</td>
              <td><%= metrics[:saved_analysis_count] %></td>
              <td>最新SerpRunに紐づく解析</td>
              <td>RunはあるがScanRunnerが解析保存まで到達していない</td>
            </tr>
            <tr>
              <td>Business紐付け</td>
              <td>SerpAnalysis / SerpResult</td>
              <td><%= metrics[:business_analysis_count] %> / <%= metrics[:business_result_count] %></td>
              <td><%= @business.name %> に紐づく結果</td>
              <td>選択Business以外のクエリが実行された、business_id紐付けなし</td>
            </tr>
            <tr>
              <td>Candidate生成</td>
              <td>ActionCandidate</td>
              <td><%= metrics[:candidate_count] %></td>
              <td>generation_source=serp</td>
              <td>候補生成ルール未達、OpenAI失敗、ActionCandidate化未実行</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="dashboard-section">
      <div class="section-heading">
        <h2>診断一覧</h2>
        <p>FAILは停止箇所、WARNINGは確認推奨です。</p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>状態</th>
              <th>項目</th>
              <th>診断</th>
              <th>安全な復旧</th>
            </tr>
          </thead>
          <tbody>
            <% @serp_e2e_check.checks.each do |check| %>
              <tr>
                <td>
                  <% icon = { "pass" => "✅ PASS", "warning" => "⚠ WARNING", "fail" => "❌ FAIL" }.fetch(check.status) %>
                  <span class="pill"><%= icon %></span>
                </td>
                <td><strong><%= check.label %></strong></td>
                <td>
                  <%= check.message %>
                  <% if check.details.present? %>
                    <br><small><%= check.details.to_json %></small>
                  <% end %>
                </td>
                <td>
                  <% if check.repair_action.present? %>
                    <%= button_to "復旧する",
                                  admin_serp_e2e_check_repair_path,
                                  method: :post,
                                  params: {
                                    business_id: @business.id,
                                    repair_action: check.repair_action
                                  },
                                  class: "button secondary",
                                  data: { aicoo_loading_label: "復旧中..." },
                                  form: { data: { aicoo_submit_lock: true, aicoo_loading_label: "復旧中..." } } %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="dashboard-section">
      <div class="section-heading">
        <h2>Scan Plan</h2>
        <p>SERP Schedulerで実際に取得予定の検索クエリです。</p>
      </div>
      <div class="metric-grid">
        <% @serp_e2e_check.scan_plan_keywords.each_with_index do |keyword, index| %>
          <div class="metric-card">
            <span>#<%= index + 1 %></span>
            <strong><%= keyword %></strong>
          </div>
        <% end %>
        <% if @serp_e2e_check.scan_plan_keywords.empty? %>
          <div class="metric-card"><span>検索クエリ</span><strong>なし</strong></div>
        <% end %>
      </div>
    </section>

    <section class="dashboard-section">
      <div class="section-heading">
        <h2>Scan実行結果</h2>
        <p>最新SERP取得の保存状況です。</p>
      </div>
      <% if @serp_e2e_check.latest_analysis %>
        <% analysis = @serp_e2e_check.latest_analysis %>
        <div class="metric-grid">
          <div class="metric-card"><span>実行日時</span><strong><%= l(analysis.analyzed_at, format: :short) %></strong></div>
          <div class="metric-card"><span>Status</span><strong><%= analysis.status %></strong></div>
          <div class="metric-card"><span>検索クエリ</span><strong><%= analysis.keyword %></strong></div>
          <div class="metric-card"><span>Result</span><strong><%= analysis.result_count.to_i %>件</strong></div>
        </div>
        <% if analysis.error_message.present? %>
          <div class="error-toast">
            <strong>原因</strong>
            <p><%= analysis.error_message %></p>
            <small><%= analysis.raw_summary.to_h.slice("error_class", "error_message").to_json %></small>
          </div>
        <% end %>
      <% else %>
        <div class="aicoo-card aicoo-empty-state">SERP取得はまだありません。</div>
      <% end %>
    </section>

    <section class="dashboard-section">
      <div class="section-heading">
        <h2>Action Candidate</h2>
        <p>SERP由来の改善候補です。</p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>タイトル</th>
              <th>状態</th>
              <th>作成日時</th>
              <th>詳細</th>
            </tr>
          </thead>
          <tbody>
            <% @serp_e2e_check.serp_candidates.limit(10).each do |candidate| %>
              <tr>
                <td><%= candidate.title %></td>
                <td><span class="pill"><%= candidate.status %></span></td>
                <td><%= l(candidate.created_at, format: :short) %></td>
                <td><%= link_to "開く", action_candidate_path(candidate), class: "button secondary" %></td>
              </tr>
            <% end %>
            <% if @serp_e2e_check.serp_candidates.empty? %>
              <tr><td colspan="4">SERP由来候補はまだありません。</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="dashboard-section">
      <div class="section-heading">
        <h2>SERP Run</h2>
        <p>Daily Runから分離されたSERP専用Runの履歴です。</p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Run</th>
              <th>Status</th>
              <th>実行者</th>
              <th>Query</th>
              <th>成功</th>
              <th>失敗</th>
              <th>Message</th>
            </tr>
          </thead>
          <tbody>
            <% @serp_e2e_check.serp_runs.each do |run| %>
              <tr>
                <td>#<%= run.id %></td>
                <td><span class="pill"><%= run.status %></span></td>
                <td><%= run.executed_by %></td>
                <td><%= run.query_count %></td>
                <td><%= run.success_count %></td>
                <td><%= run.failure_count %></td>
                <td><%= truncate(run.error_message.to_s, length: 120) %></td>
              </tr>
            <% end %>
            <% if @serp_e2e_check.serp_runs.empty? %>
              <tr><td colspan="7">SERP Run履歴はまだありません。</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% else %>
    <section class="dashboard-section">
      <div class="aicoo-card aicoo-empty-state">
        <h2>Businessがありません。</h2>
        <p>SERP E2E診断には実事業のBusinessが必要です。</p>
      </div>
    </section>
  <% end %>
</div>
