<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "サイト別分析設定を追加",
             description: "サイトごとにGSC/GA4の解析対象を設定します。",
             active_main: :datahub,
             actions: header_actions %>

<section class="dashboard-section">
  <%= render "form", site: @site %>
</section>
</div>
