<%= form_with model: business_execution_profile,
              url: business_execution_profile.persisted? ? admin_business_execution_profile_path(business_execution_profile) : admin_business_execution_profiles_path,
              class: "form" do |form| %>
  <% if business_execution_profile.errors.any? %>
    <div class="alert">
      <p>保存できませんでした。</p>
      <ul>
        <% business_execution_profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid">
    <div class="field">
      <%= form.label :business_id, "Business" %>
      <%= form.collection_select :business_id, Business.real_businesses.order(:name), :id, :name, prompt: "選択してください" %>
    </div>
    <div class="field">
      <%= form.label :execution_type, "execution_type" %>
      <%= form.select :execution_type, [
        [ "AICOO本体のLP/Business/設定を対象にする", "aicoo_internal" ],
        [ "別サービスの外部リポジトリを対象にする", "external_repo" ]
      ] %>
    </div>
    <div class="field">
      <%= form.label :repository_type, "Repository Type" %>
      <%= form.select :repository_type, BusinessExecutionProfile::REPOSITORY_TYPES.map { |type| [type, type] } %>
    </div>
    <div class="field">
      <%= form.label :repository_name, "Repository Name" %>
      <%= form.text_field :repository_name, placeholder: "例: suelog" %>
    </div>
    <div class="field">
      <%= form.label :github_repository, "github_repo" %>
      <%= form.text_field :github_repository, placeholder: "例: owner/suelog" %>
    </div>
    <div class="field">
      <%= form.label :repository_path, "local_project_path" %>
      <%= form.text_field :repository_path, placeholder: "例: /Users/.../suelog" %>
    </div>
    <div class="field">
      <%= form.label :target_slug, "target_slug" %>
      <%= form.text_field :target_slug, placeholder: "例: suelog / public-lp-slug" %>
    </div>
    <div class="field">
      <%= form.label :default_branch, "Default Branch" %>
      <%= form.text_field :default_branch, placeholder: "main" %>
    </div>
    <div class="field">
      <%= form.label :working_branch_prefix, "Working Branch Prefix" %>
      <%= form.text_field :working_branch_prefix, placeholder: "codex/auto-revision" %>
    </div>
  </div>

  <div class="grid">
    <div class="field">
      <%= form.label :test_command, "Test Command" %>
      <%= form.text_field :test_command, placeholder: "bin/rails test" %>
    </div>
    <div class="field">
      <%= form.label :lint_command, "Lint Command" %>
      <%= form.text_field :lint_command, placeholder: "RUBOCOP_CACHE_ROOT=tmp/rubocop_cache bundle exec rubocop" %>
    </div>
    <div class="field">
      <%= form.label :deploy_command, "Deploy Command" %>
      <%= form.text_field :deploy_command, placeholder: "必要な場合だけ入力" %>
    </div>
    <div class="field">
      <%= form.label :deploy_target, "Deploy Target" %>
      <%= form.select :deploy_target, BusinessExecutionProfile::DEPLOY_TARGETS.map { |target| [ target, target ] } %>
    </div>
    <div class="field">
      <%= form.label :render_service_name, "Render Service Name" %>
      <%= form.text_field :render_service_name, placeholder: "例: suelog-web" %>
    </div>
    <div class="field">
      <%= form.label :production_url, "Production URL" %>
      <%= form.url_field :production_url, placeholder: "https://example.com" %>
    </div>
    <div class="field">
      <%= form.label :health_check_url, "Health Check URL" %>
      <%= form.url_field :health_check_url, placeholder: "https://example.com/health" %>
    </div>
  </div>

  <div class="field">
    <%= form.label :target_paths_text, "target_paths" %>
    <%= form.text_area :target_paths_text, rows: 4, placeholder: "1行に1つずつ入力\n例: app/views/public_landing_pages\n例: app/services/aicoo" %>
  </div>

  <div class="field">
    <%= form.label :codex_instructions, "Codex Instructions" %>
    <%= form.text_area :codex_instructions, rows: 5, placeholder: "この事業の改修時にCodexへ必ず伝える指示" %>
  </div>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Codex連携設定</h2>
      <p>Codex Cloudで個別サービスを改修するための作業スペース、フォルダ、PR方針です。初期はAuto Submit OFFのままにします。</p>
    </div>

    <label class="checkbox">
      <%= form.check_box :codex_enabled %>
      Codex連携 ON
    </label>

    <div class="grid">
      <div class="field">
        <%= form.label :codex_workspace_name, "Codex Workspace" %>
        <%= form.text_field :codex_workspace_name, placeholder: "例: AICOO" %>
      </div>
      <div class="field">
        <%= form.label :codex_project_folder, "Codex作業フォルダ" %>
        <%= form.text_field :codex_project_folder, placeholder: "例: suelog / aicoo / vault" %>
      </div>
      <div class="field">
        <%= form.label :codex_repository_url, "Repository URL" %>
        <%= form.text_field :codex_repository_url, placeholder: "例: https://github.com/owner/suelog" %>
      </div>
      <div class="field">
        <%= form.label :codex_base_branch, "Base Branch" %>
        <%= form.text_field :codex_base_branch, placeholder: "main" %>
      </div>
      <div class="field">
        <%= form.label :codex_working_branch_prefix, "Working Branch Prefix" %>
        <%= form.text_field :codex_working_branch_prefix, placeholder: "aicoo/" %>
      </div>
      <div class="field">
        <%= form.label :codex_risk_limit, "Codex Risk Limit" %>
        <%= form.select :codex_risk_limit, BusinessExecutionProfile::RISK_LIMITS.map { |risk| [ risk, risk ] } %>
      </div>
    </div>

    <label class="checkbox">
      <%= form.check_box :codex_auto_submit_enabled %>
      Auto Submit
    </label>

    <label class="checkbox">
      <%= form.check_box :codex_auto_pr_enabled %>
      Auto PR
    </label>

    <label class="checkbox">
      <%= form.check_box :codex_auto_merge_enabled %>
      Auto Merge
    </label>

    <label class="checkbox">
      <%= form.check_box :codex_auto_deploy_enabled %>
      Auto Deploy
    </label>

    <div class="field">
      <%= form.label :codex_notes, "Codex Notes" %>
      <%= form.text_area :codex_notes, rows: 4, placeholder: "Codex Cloud連携時の補足。外部API送信が未接続なら運用メモを残します。" %>
    </div>
  </section>

  <div class="field">
    <%= form.label :forbidden_patterns, "Forbidden Patterns" %>
    <%= form.text_area :forbidden_patterns, rows: 5, placeholder: "db:drop\ndb:reset\ndrop database" %>
  </div>

  <label class="checkbox">
    <%= form.check_box :active %>
    有効
  </label>

  <label class="checkbox">
    <%= form.check_box :auto_deploy_enabled %>
    auto_deploy_enabled
  </label>

  <label class="checkbox">
    <%= form.check_box :auto_merge_enabled %>
    auto_merge_enabled
  </label>

  <label class="checkbox">
    <%= form.check_box :require_manual_approval %>
    require_manual_approval
  </label>

  <div class="field">
    <%= form.label :auto_deploy_risk_limit, "Auto Deploy Risk Limit" %>
    <%= form.select :auto_deploy_risk_limit, BusinessExecutionProfile::RISK_LIMITS.map { |risk| [ risk, risk ] } %>
  </div>

  <div class="actions">
    <%= form.submit "保存", class: "button" %>
    <%= link_to "一覧へ戻る", admin_business_execution_profiles_path, class: "button secondary" %>
  </div>
<% end %>
