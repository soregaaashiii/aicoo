<% content_for :title, "Today" %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Today",
             description: @today_board.description,
             active_main: :revenue %>
  <%= render "shared/aicoo_execution_tabs", active: :today %>

  <nav class="aicoo-sub-tabs" aria-label="Today ranking mode">
    <% @today_board.tabs.each do |tab| %>
      <%= link_to tab.label,
                  tab.path,
                  class: "aicoo-sub-tab#{' active' if tab.active}",
                  aria: (tab.active ? { current: "page" } : nil) %>
    <% end %>
  </nav>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>今日処理するAction</h2>
      <p>自動改修の判断待ち、またはCodexでは実行できない作業だけを表示します。</p>
    </div>

    <% if @today_board.items.any? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>順位</th>
              <th>Business名</th>
              <th>具体的な作業名</th>
              <th>期待利益</th>
              <th>想定時間</th>
              <th>期待時給</th>
              <th>成功率</th>
              <th>実行方法</th>
              <th>承認が必要か</th>
              <th>Codex対象か</th>
              <th>詳細を見る</th>
            </tr>
          </thead>
          <tbody>
            <% @today_board.items.each do |item| %>
              <tr>
                <td class="number"><%= item.rank %></td>
                <td><%= item.business_name.presence || "-" %></td>
                <td>
                  <strong><%= item.concrete_task %></strong><br>
                  <small>対象: <%= item.target %></small><br>
                  <small>次: <%= item.owner_next_step %></small>
                  <% if item.stopped_reason.present? %>
                    <br><small>停止理由: <%= item.stopped_reason %></small>
                  <% end %>
                </td>
                <td class="number"><%= number_to_currency(item.expected_value_yen, unit: "¥", precision: 0) %></td>
                <td class="number"><%= number_with_precision(item.expected_hours, precision: 1, strip_insignificant_zeros: true) %>時間</td>
                <td class="number"><%= number_to_currency(item.expected_hourly_value_yen, unit: "¥", precision: 0) %></td>
                <td class="number"><%= number_to_percentage(item.success_probability.to_d * 100, precision: 1) %></td>
                <td><span class="pill"><%= item.execution_mode_label %></span></td>
                <td><%= item.approval_required ? "必要" : "不要" %></td>
                <td><%= item.codex_target ? "はい" : "いいえ" %></td>
                <td><%= link_to "詳細を見る", item.detail_url, class: "button secondary" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="aicoo-lab-help">
        <strong>Todayに表示するActionはありません</strong>
        <p>承認待ちで止まっている自動改修、またはCodexでは実行できない具体作業だけがここに表示されます。</p>
      </div>
    <% end %>
  </section>
</div>
