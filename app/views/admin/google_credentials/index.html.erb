<% content_for :title, "Google認証" %>

<% header_actions = capture do %>
  <% if @current_credential.present? %>
    <%= link_to "GA4/GSCまとめて再認証", admin_analytics_oauth_connect_path(google_credential_id: @current_credential.id), class: "button" %>
  <% end %>
  <%= link_to "サイト別分析設定", admin_analytics_sites_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Google認証",
             description: "GSC/GA4取得に使うAICOO共通のGoogle認証を管理します。各サイトにはsite_url / property_idだけを設定します。",
             active_main: :datahub,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>Google連携の復旧</h2>
        <p>Google認証が切れた時はここから再認証します。履歴からOAuth URLを探す必要はありません。</p>
      </div>
    </div>

    <%= render "shared/google_reauth_actions", credential: @current_credential %>

    <div class="aicoo-card-grid">
      <% @google_oauth_recovery_statuses.each do |status| %>
        <div class="system-status-card status-<%= status.invalid_grant? || status.status == "missing" ? "critical" : (status.status == "expired" ? "warning" : "healthy") %>">
          <p><span class="system-status-pill status-<%= status.invalid_grant? || status.status == "missing" ? "critical" : (status.status == "expired" ? "warning" : "success") %>"><%= status.status %></span></p>
          <h3><%= status.label %></h3>
          <p>last_success_at: <%= status.last_success_at ? l(status.last_success_at, format: :short) : "-" %></p>
          <p>last_error: <%= status.last_error.present? ? status.last_error.truncate(120) : "-" %></p>
          <p>latest_run: <%= status.latest_run ? "##{status.latest_run.id} #{status.latest_run.status}" : "-" %></p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Google認証一覧</h2>
      <p>通常は接続済みの共通Google認証を1つだけ使います。必要な場合だけサイト設定側で個別認証を上書きできます。</p>
    </div>
    <%= render "shared/google_oauth_client_status", credential: @current_credential %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Record ID</th>
            <th>名前</th>
            <th>状態</th>
            <th>有効</th>
            <th>Googleアカウント</th>
            <th>Project ID</th>
            <th>OAuth Client</th>
            <th>Project番号</th>
            <th>Access Token</th>
            <th>Refresh Token</th>
            <th>Token Expiry</th>
            <th>最終接続日時</th>
            <th>last_oauth_success_at</th>
            <th>updated_at</th>
            <th>利用設定数</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @credentials.each do |credential| %>
            <tr>
              <td>
                #<%= credential.id %>
                <% if @current_credential&.id == credential.id %>
                  <br><span class="pill">現在使用中</span>
                <% end %>
              </td>
              <td><%= credential.name %></td>
              <td><span class="pill"><%= credential.connected? ? "接続済み" : "未接続" %></span></td>
              <td><span class="pill"><%= credential.enabled? ? "有効" : "無効" %></span></td>
              <td><%= credential.google_account_email.presence || "-" %></td>
              <td><%= credential.effective_google_cloud_project_id.presence || "未設定" %></td>
              <td><%= credential.client_id.presence || "-" %></td>
              <td><%= credential.oauth_project_number.presence || "不明" %></td>
              <td><span class="pill"><%= credential.access_token.present? ? "保存済み" : "未保存" %></span></td>
              <td><span class="pill"><%= credential.refresh_token.present? ? "保存済み" : "未保存" %></span></td>
              <td>
                <% if credential.token_expires_at.present? %>
                  <%= l(credential.token_expires_at, format: :short) %>
                  <span class="pill"><%= credential.token_expired? ? "期限切れ" : "有効" %></span>
                <% else %>
                  -
                <% end %>
              </td>
              <td><%= credential.connected_at ? l(credential.connected_at, format: :short) : "-" %></td>
              <td><%= credential.last_oauth_success_at ? l(credential.last_oauth_success_at, format: :short) : "-" %></td>
              <td><%= credential.updated_at ? l(credential.updated_at, format: :short) : "-" %></td>
              <td class="number"><%= credential.analytics_source_settings.count %></td>
              <td>
                <div class="actions compact-actions">
                  <%= link_to "Googleと接続", connect_admin_google_credential_path(credential), class: "button" %>
                  <%= link_to "編集", edit_admin_google_credential_path(credential), class: "button secondary" %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @credentials.empty? %>
            <tr><td colspan="16">Google認証はまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Google認証を追加</h2>
      <p>Client ID / Secret を保存してから「Googleと接続」を押すと、refresh token / access token / token expiry / Googleアカウントを自動保存できます。</p>
    </div>
    <%= render "form", credential: @credential %>
  </section>
</div>
