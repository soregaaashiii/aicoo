<% content_for :title, "実行指示" %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "実行指示",
             description: "今日やることや新規事業の候補を、Codexへ渡せる実行タスクとして整理します。まだ自動実行はしません。",
             active_main: :executor %>

<section class="dashboard-section">
  <div class="aicoo-lab-help">
    <strong>この画面でやること</strong>
    <p>今日やることや新規事業の候補を、Codexへ貼れる実行指示に変換し、承認してから実行に進めます。</p>
  </div>
</section>

<section class="dashboard-section">
  <div class="metric-grid">
    <div class="metric-card"><span>実行待ち</span><strong><%= @summary.waiting_count %></strong></div>
    <div class="metric-card"><span>承認待ち</span><strong><%= @summary.approval_pending_count %></strong></div>
    <div class="metric-card"><span>データ整備タスク</span><strong><%= @summary.data_preparation_count %></strong></div>
    <div class="metric-card"><span>完了</span><strong><%= @summary.done_count %></strong></div>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>実行タスク</h2>
    <p>Codex実行指示を確認し、人間が承認してから実行に進めます。</p>
  </div>

  <%= form_with url: admin_aicoo_executor_path, method: :get, class: "filters" do |form| %>
    <div class="field compact-field">
      <%= form.label :execution_type, "タスク種別" %>
      <%= form.select :execution_type,
                      options_for_select([ [ "すべて", "" ], [ "データ整備タスク", "data_preparation" ] ] + AicooExecutorTask::EXECUTION_TYPES.reject { |type| type == "data_preparation" }.map { |type| [ type, type ] }, params[:execution_type]) %>
    </div>
    <%= form.submit "絞り込み", class: "button" %>
    <%= link_to "解除", admin_aicoo_executor_path, class: "button secondary" %>
  <% end %>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>タイトル</th>
          <th>実行タイプ</th>
          <th>見積時間</th>
          <th>状態</th>
          <th>作成日時</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @tasks.each do |task| %>
          <tr>
            <td><%= link_to task.title, admin_aicoo_executor_task_path(task) %></td>
            <td><span class="pill"><%= task.execution_type %></span></td>
            <td class="number"><%= task.estimated_minutes || "-" %>分</td>
            <td><%= aicoo_executor_status_label(task.status) %></td>
            <td><%= l(task.created_at, format: :short) %></td>
            <td><%= link_to "詳細", admin_aicoo_executor_task_path(task), class: "button secondary" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
</div>
