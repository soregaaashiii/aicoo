<% form_url = admin_aicoo_lab_experiment_landing_page_path(experiment) %>

<%= form_with(model: landing_page, url: form_url, class: "form") do |form| %>
  <% if landing_page.errors.any? %>
    <div class="errors">
      <h2><%= pluralize(landing_page.errors.count, "error") %> prohibited this landing page from being saved:</h2>
      <ul>
        <% landing_page.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section>
    <h2>LP本文</h2>
    <div class="field">
      <%= form.label :headline %>
      <%= form.text_field :headline %>
    </div>
    <div class="field">
      <%= form.label :subheadline %>
      <%= form.text_field :subheadline %>
    </div>
    <div class="field">
      <%= form.label :body %>
      <%= form.textarea :body, rows: 10 %>
    </div>
    <div class="grid">
      <div class="field">
        <%= form.label :cta_text %>
        <%= form.text_field :cta_text %>
      </div>
      <div class="field">
        <%= form.label :assumed_price_yen %>
        <%= form.number_field :assumed_price_yen, min: 0 %>
      </div>
      <div class="field">
        <%= form.label :status %>
        <%= form.select :status, AicooLabLandingPage::STATUSES %>
      </div>
      <div class="field">
        <%= form.label :public_status, "公開状態" %>
        <%= form.select :public_status, AicooLabLandingPage::PUBLIC_STATUSES %>
      </div>
      <div class="field">
        <%= form.label :preview_slug %>
        <%= form.text_field :preview_slug %>
      </div>
      <div class="field">
        <%= form.label :published_slug, "公開slug" %>
        <%= form.text_field :published_slug %>
      </div>
      <div class="field">
        <%= form.label :scheduled_publish_at, "予約公開日時" %>
        <%= form.datetime_field :scheduled_publish_at %>
      </div>
    </div>
    <div class="field">
      <%= form.label :notes %>
      <%= form.textarea :notes, rows: 4 %>
    </div>
  </section>

  <section>
    <h2>SEO / SNS</h2>
    <div class="grid">
      <div class="field">
        <%= form.label :seo_title, "SEO title" %>
        <%= form.text_field :seo_title %>
      </div>
      <div class="field">
        <%= form.label :canonical_url, "canonical URL" %>
        <%= form.url_field :canonical_url %>
      </div>
    </div>
    <div class="field">
      <%= form.label :seo_description, "SEO description" %>
      <%= form.textarea :seo_description, rows: 3 %>
    </div>
    <div class="grid">
      <div class="field">
        <%= form.label :og_title, "OG title" %>
        <%= form.text_field :og_title %>
      </div>
      <div class="field">
        <%= form.label :og_image_url, "OG image URL" %>
        <%= form.url_field :og_image_url %>
      </div>
    </div>
    <div class="field">
      <%= form.label :og_description, "OG description" %>
      <%= form.textarea :og_description, rows: 3 %>
    </div>
  </section>

  <div class="actions">
    <%= form.submit class: "button" %>
  </div>
<% end %>
