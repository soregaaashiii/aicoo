<% content_for :title, "LP作成" %>

<% header_actions = capture do %>
  <%= link_to "検証詳細に戻る", admin_aicoo_lab_experiment_path(@experiment), class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "LP作成",
             description: "#{@experiment.title} の確認用プレビューを作ります。",
             active_main: :lab,
             actions: header_actions %>
  <%= render "form", experiment: @experiment, landing_page: @landing_page %>
</div>
