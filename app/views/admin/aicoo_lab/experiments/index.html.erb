<% content_for :title, "新規事業" %>

<% header_actions = capture do %>
    <%= link_to "事業アイデア", admin_aicoo_lab_candidates_path, class: "button secondary" %>
    <%= link_to "レビュー待ち", admin_aicoo_lab_review_queue_path, class: "button secondary" %>
    <%= link_to "承認済み未開始", admin_aicoo_lab_approved_experiments_path, class: "button secondary" %>
    <%= link_to "採点待ち", admin_aicoo_lab_scoring_queue_path, class: "button secondary" %>
    <%= link_to "承認待ち", admin_aicoo_lab_approvals_path, class: "button secondary" %>
    <%= link_to "アイデア生成履歴", admin_aicoo_lab_generation_runs_path, class: "button secondary" %>
    <%= link_to "AI提案", admin_aicoo_lab_ai_drafts_path, class: "button secondary" %>
    <%= link_to "SERPからLP候補生成", admin_aicoo_lab_serp_landing_page_candidates_path, class: "button secondary" %>
    <%= link_to "設定", admin_aicoo_lab_setting_path, class: "button secondary" %>
    <%= link_to "検証を作成", new_admin_aicoo_lab_experiment_path, class: "button" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "新規事業",
             description: "アイデアをLP化し、市場の反応を検証してください。",
             active_main: :lab,
             actions: header_actions %>

<section class="dashboard-section">
  <div class="aicoo-lab-help">
    <strong>この画面でやること</strong>
    <p>アイデアをLP化し、市場の反応を検証してください。レビュー、承認、検証開始、採点までの詰まりもここから確認できます。</p>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>今やること</h2>
    <p>上から順に処理すると、候補生成から採点まで詰まらず進みます。</p>
  </div>
  <div class="aicoo-lab-inbox-grid">
    <% aicoo_lab_inbox_items.each do |item| %>
      <article class="aicoo-lab-card aicoo-lab-next-action">
        <span class="aicoo-lab-status-badge"><%= item.state %></span>
        <strong><%= item.count.positive? ? "#{item.state}が#{item.count}件あります" : item.state %></strong>
        <p><%= item.description %></p>
        <%= link_to item.button_label, item.path, class: "button" %>
      </article>
    <% end %>
  </div>
</section>

<section class="dashboard-section">
  <div class="aicoo-lab-help">
    <strong>用語メモ</strong>
    <p><b>事業アイデア</b>: まだ検証ではありません。</p>
    <p><b>LP作成済み</b>: 公開前の下書きLPを確認する段階です。</p>
    <p><b>承認待ち</b>: 検証として進めるか判断する段階です。</p>
    <p><b>承認済み</b>: まだ検証開始前です。</p>
    <p><b>検証中</b>: LP URLに人を流すとPV/CTA/Signupが記録されます。</p>
    <p><b>採点待ち</b>: 結果を記録して予測精度を改善する段階です。</p>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>次アクション</h2>
    <p>迷ったらDashboardで、候補生成から採点までの次の詰まりを確認します。</p>
  </div>
  <div class="notice-panel">
    <strong>今の状態説明</strong>
    <ul>
      <% aicoo_lab_current_state_sentence.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
  <div class="actions compact-actions">
    <%= link_to "操作盤", dashboard_path, class: "button" %>
    <%= button_to "候補を自動生成", generate_admin_aicoo_lab_candidates_path, method: :post, class: "button secondary" %>
    <%= link_to "候補を一括LP化", admin_aicoo_lab_candidates_path, class: "button secondary" %>
    <%= link_to "レビュー待ち", admin_aicoo_lab_review_queue_path, class: "button secondary" %>
    <%= link_to "検証開始", admin_aicoo_lab_approved_experiments_path, class: "button secondary" %>
    <%= link_to "採点待ち", admin_aicoo_lab_scoring_queue_path, class: "button secondary" %>
  </div>
</section>

<%= form_with url: admin_aicoo_lab_experiments_path, method: :get, class: "filters" do |form| %>
  <div class="field compact-field">
    <%= form.label :status, "状態" %>
    <%= form.select :status, options_for_select(AicooLabExperiment::STATUSES.map { |status| [aicoo_lab_status_label(status), status] }, params[:status]), include_blank: "すべて" %>
  </div>
  <div class="field compact-field">
    <%= form.label :approval_status, "承認" %>
    <%= form.select :approval_status, options_for_select(AicooLabExperiment::APPROVAL_STATUSES.map { |status| [aicoo_lab_approval_status_label(status), status] }, params[:approval_status]), include_blank: "すべて" %>
  </div>
  <div class="field compact-field">
    <%= form.label :experiment_type, "種類" %>
    <%= form.select :experiment_type, options_for_select(AicooLabExperiment::EXPERIMENT_TYPES, params[:experiment_type]), include_blank: "すべて" %>
  </div>
  <div class="field compact-field">
    <%= form.label :market_category, "市場" %>
    <%= form.text_field :market_category, value: params[:market_category] %>
  </div>
  <div class="field compact-field">
    <%= form.label :acquisition_channel, "流入経路" %>
    <%= form.select :acquisition_channel, options_for_select(AicooLabExperiment::ACQUISITION_CHANNELS, params[:acquisition_channel]), include_blank: "すべて" %>
  </div>
  <%= form.submit "絞り込む", class: "button" %>
  <%= link_to "クリア", admin_aicoo_lab_experiments_path, class: "button secondary" %>
<% end %>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>検証名</th>
        <th>種類</th>
        <th>市場</th>
        <th>状態</th>
        <th>承認</th>
        <th>LP公開</th>
        <th>次にやる操作</th>
        <th>90日期待利益</th>
        <th>成功確率</th>
        <th>期待値</th>
        <th>学習価値</th>
        <th>採点速度</th>
        <th>新規事業優先度</th>
        <th>PV</th>
        <th>開始日</th>
        <th>7日採点</th>
        <th>30日採点</th>
        <th>90日採点</th>
      </tr>
    </thead>
    <tbody>
      <% @experiments.each do |experiment| %>
        <tr>
          <td><%= link_to experiment.title, admin_aicoo_lab_experiment_path(experiment) %></td>
          <td><%= experiment.experiment_type %></td>
          <td><%= experiment.market_category.presence || "-" %></td>
          <td><span class="pill"><%= aicoo_lab_status_label(experiment.status) %></span></td>
          <td><span class="pill"><%= aicoo_lab_approval_status_label(experiment.approval_status) %></span></td>
          <td>
            <% if experiment.aicoo_lab_landing_page %>
              <span class="pill"><%= aicoo_lab_status_label(experiment.aicoo_lab_landing_page.status) %></span>
            <% else %>
              -
            <% end %>
          </td>
          <td>
            <div class="aicoo-lab-table-action">
              <strong><%= aicoo_lab_next_operation_label(experiment) %></strong>
              <%= link_to "開く", aicoo_lab_next_operation_path(experiment), class: "button secondary" %>
            </div>
          </td>
          <td class="number"><%= number_to_currency(experiment.expected_90d_profit_yen, unit: "¥", precision: 0) %></td>
          <td class="number"><%= number_to_percentage(experiment.success_probability.to_d * 100, precision: 1) %></td>
          <td class="number"><%= number_with_precision(experiment.expected_value_score, precision: 3) || "-" %></td>
          <td class="number"><%= number_with_precision(experiment.learning_value_score, precision: 2) %></td>
          <td class="number"><%= number_with_precision(experiment.scoring_speed_score, precision: 4) || "-" %></td>
          <td class="number"><%= number_with_precision(experiment.lab_priority_score, precision: 4) || "-" %></td>
          <td class="number"><%= experiment.current_pv %> / <%= experiment.sample_pv_threshold %></td>
          <td><%= experiment.published_at ? l(experiment.published_at, format: :short) : "-" %></td>
          <td><%= experiment.score_due_7d_at ? l(experiment.score_due_7d_at, format: :short) : "-" %></td>
          <td><%= experiment.score_due_30d_at ? l(experiment.score_due_30d_at, format: :short) : "-" %></td>
          <td><%= experiment.score_due_90d_at ? l(experiment.score_due_90d_at, format: :short) : "-" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>
