<% content_for :title, "レビュー待ち" %>

<div class="page-title">
  <div>
    <h1>レビュー待ち</h1>
    <p>LP作成済みまたは検証判断待ちの検証を、高速に検証開始・却下します。</p>
  </div>
  <div class="actions compact-actions">
    <%= link_to "新規事業", admin_aicoo_lab_experiments_path, class: "button secondary" %>
    <%= link_to "事業アイデア", admin_aicoo_lab_candidates_path, class: "button secondary" %>
  </div>
</div>

<section class="dashboard-section">
  <div class="aicoo-lab-help">
    <strong>この画面でやること</strong>
    <p>ここではLPプレビューを見ることで、検証として進めるか判断します。検証へ進めても本番公開や課金は発生しません。</p>
  </div>
</section>

<%= form_with url: admin_aicoo_lab_review_queue_bulk_update_path, method: :post, id: "review-bulk-form", class: "filters" do |form| %>
  <div class="field compact-field">
    <%= form.label :bulk_action, "一括操作" %>
    <%= form.select :bulk_action, options_for_select([
      [ "検証判断待ちにする", "approval_pending" ],
      [ "検証へ進める", "approve" ],
      [ "却下する", "reject" ],
      [ "一時停止にする", "paused" ]
    ]) %>
  </div>
  <%= form.submit "選択した実験に適用", class: "button" %>
<% end %>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>選択</th>
        <th>検証名</th>
        <th>種類</th>
        <th>市場</th>
        <th>90日期待利益</th>
        <th>成功確率</th>
        <th>期待値</th>
        <th>新規事業優先度</th>
        <th>学習価値</th>
        <th>LP確認</th>
        <th>LP headline</th>
        <th>LP CTA</th>
        <th>予算</th>
        <th>工数</th>
        <th>生成元</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @experiments.each do |experiment| %>
        <% landing_page = experiment.aicoo_lab_landing_page %>
        <tr>
          <td><%= check_box_tag "experiment_ids[]", experiment.id, false, form: "review-bulk-form" %></td>
          <td><%= link_to experiment.title, admin_aicoo_lab_review_queue_experiment_path(experiment) %></td>
          <td><%= experiment.experiment_type %></td>
          <td><%= experiment.market_category.presence || "-" %></td>
          <td class="number"><%= number_to_currency(experiment.expected_90d_profit_yen, unit: "¥", precision: 0) %></td>
          <td class="number"><%= number_to_percentage(experiment.success_probability.to_d * 100, precision: 1) %></td>
          <td class="number"><%= number_with_precision(experiment.expected_value_score, precision: 3) || "-" %></td>
          <td class="number"><%= number_with_precision(experiment.lab_priority_score, precision: 4) || "-" %></td>
          <td class="number"><%= number_with_precision(experiment.learning_value_score, precision: 2) || "-" %></td>
          <td>
            <% if landing_page %>
              <%= link_to "LPプレビューを見る", aicoo_lab_preview_path(landing_page.preview_slug), target: "_blank", rel: "noopener", class: "button secondary" %>
            <% else %>
              -
            <% end %>
          </td>
          <td><%= landing_page&.headline || "-" %></td>
          <td><%= landing_page&.cta_text || "-" %></td>
          <td class="number"><%= number_to_currency(experiment.budget_yen, unit: "¥", precision: 0) %></td>
          <td class="number"><%= experiment.estimated_work_minutes %></td>
          <td><%= landing_page&.generation_source || "-" %></td>
          <td>
            <div class="actions compact-actions">
              <%= link_to "詳細", admin_aicoo_lab_experiment_path(experiment), class: "button secondary" %>
              <%= link_to "レビュー", admin_aicoo_lab_review_queue_experiment_path(experiment), class: "button" %>
              <%= button_to "検証へ進める", admin_aicoo_lab_review_queue_approve_path(experiment), method: :patch, class: "button" %>
              <%= button_to "却下", admin_aicoo_lab_review_queue_reject_path(experiment), method: :patch, class: "danger" %>
              <%= button_to "一時停止", admin_aicoo_lab_review_queue_paused_path(experiment), method: :patch, class: "button secondary" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
