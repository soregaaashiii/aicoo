<% content_for :title, "Codex Executor Queue" %>

<% header_actions = capture do %>
  <%= link_to "Auto Revision Tasks", auto_revision_tasks_path, class: "button secondary" %>
  <%= link_to "Todayへ戻る", owner_focus_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Codex Executor Queue",
             description: "準備完了したAutoRevisionTaskをCodex手動送信待ち・手動送信済み・実装中として管理します。",
             active_main: :dashboard,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="actions compact-actions">
      <% [
        [ "すべて", nil ],
        [ "実行待ち", "queued" ],
        [ "手動送信待ち", "ready_for_codex" ],
        [ "手動送信済み", "sent_to_codex" ],
        [ "実装中", "running" ],
        [ "放置", "stale" ]
      ].each do |label, status| %>
        <%= link_to label,
                    codex_queue_auto_revision_tasks_path(status:),
                    class: "button #{(@status_filter == status || (@status_filter.blank? && status.blank?)) ? "" : "secondary"}" %>
      <% end %>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>タイトル</th>
            <th>事業</th>
            <th>Repository</th>
            <th>Type</th>
            <th>Target</th>
            <th>risk</th>
            <th>status</th>
            <th>優先度</th>
            <th>Codex手動送信</th>
            <th>実装開始</th>
            <th>最終確認</th>
            <th>Codexスレッド</th>
            <th>作成</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @auto_revision_tasks.each do |task| %>
            <% target_validation = task.codex_prompt_target_validation %>
            <tr>
              <td><%= link_to task.title, task %></td>
              <td><%= task.business.name %></td>
              <td><%= task.target_repository_display %></td>
              <td><span class="pill"><%= task.target_repository_type.presence || "-" %></span></td>
              <td>
                <span class="pill"><%= task.repository_target_status_label %></span>
                <% if task.repository_target_warning? %>
                  <small>不足: <%= task.repository_target_missing_fields_label %></small>
                <% end %>
                <br>
                <span class="pill"><%= target_validation.target_status %></span>
                <% if target_validation.invalid? %>
                  <small><%= target_validation.missing_items.join(", ") %></small>
                <% elsif target_validation.warning? %>
                  <small>warning</small>
                <% end %>
              </td>
              <td><span class="pill"><%= task.risk_level %></span></td>
              <td><span class="pill"><%= task.status %></span></td>
              <td class="number"><%= number_with_precision(task.priority_score, precision: 1) %></td>
              <td><%= task.sent_to_codex_at ? l(task.sent_to_codex_at, format: :short) : "-" %></td>
              <td><%= task.started_running_at ? l(task.started_running_at, format: :short) : "-" %></td>
              <td>
                <%= task.last_checked_at ? l(task.last_checked_at, format: :short) : "-" %>
                <% if task.stale_codex_task? %>
                  <span class="pill danger">stale</span>
                <% end %>
              </td>
              <td>
                <% if task.codex_thread_url.present? %>
                  <%= link_to "開く", task.codex_thread_url, class: "button secondary", target: "_blank", rel: "noopener" %>
                <% else %>
                  -
                <% end %>
              </td>
              <td><%= l(task.created_at, format: :short) %></td>
              <td>
                <div class="actions compact-actions">
                  <button type="button"
                          class="button secondary"
                          onclick="navigator.clipboard.writeText(this.dataset.prompt)"
                          data-prompt="<%= h(task.codex_prompt_markdown) %>"
                          <%= "disabled" if target_validation.invalid? %>>
                    プロンプトをコピー
                  </button>
                  <% if target_validation.invalid? %>
                    <button class="button secondary" disabled>プロンプト確認不可</button>
                  <% else %>
                    <%= link_to "プロンプト確認", export_codex_prompt_auto_revision_task_path(task), class: "button secondary" %>
                  <% end %>
                  <%= link_to "詳細", task, class: "button secondary" %>
                  <% if %w[ready_for_codex approved].include?(task.status) && task.risk_level != "high" %>
                    <%= button_to "実行キューへ追加", enqueue_auto_revision_task_path(task), method: :patch, class: "button secondary" %>
                  <% elsif task.status == "queued" %>
                    <% if target_validation.invalid? %>
                      <button class="button" disabled>手動送信不可</button>
                      <% if task.business.business_execution_profile %>
                        <%= link_to "Execution Profileを修正", edit_admin_business_execution_profile_path(task.business.business_execution_profile), class: "button secondary" %>
                      <% else %>
                        <%= link_to "Execution Profileを作成", new_admin_business_execution_profile_path(business_id: task.business_id), class: "button secondary" %>
                      <% end %>
                    <% else %>
                      <%= button_to "手動送信済みにする", mark_sent_to_codex_auto_revision_task_path(task), method: :patch, class: "button" %>
                    <% end %>
                  <% elsif task.status == "sent_to_codex" %>
                    <%= button_to "実装開始", start_implementation_auto_revision_task_path(task), method: :patch, class: "button" %>
                  <% elsif task.status == "running" %>
                    <%= link_to "結果登録", task, class: "button" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @auto_revision_tasks.empty? %>
            <tr><td colspan="14">Codex手動送信待ちのAuto Revision Taskはありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
