<% content_for :title, "Auto Revision Tasks" %>

<% header_actions = capture do %>
  <%= link_to "Codex Queue", codex_queue_auto_revision_tasks_path, class: "button" %>
  <%= link_to "外部commitを取り込む", new_admin_external_commit_import_path, class: "button secondary" %>
  <%= link_to "操作盤に戻る", dashboard_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Auto Revision Tasks",
             description: "ActionCandidateをCodexへ渡せる改修タスクとして管理します。",
             active_main: :dashboard,
             actions: header_actions %>

  <% status_counts = AutoRevisionTask.group(:status).count %>
  <section class="dashboard-section">
    <div class="section-heading">
      <h2>改訂フロー</h2>
      <p>改善案から承認、Codexキュー、実行中、完了、失敗までの状態を管理します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>承認待ち</span><strong><%= status_counts.fetch("waiting_approval", 0) %>件</strong></div>
      <div class="metric-card"><span>実行待ち</span><strong><%= status_counts.fetch("queued", 0) + status_counts.fetch("ready_for_codex", 0) %>件</strong></div>
      <div class="metric-card"><span>実行中</span><strong><%= status_counts.fetch("running", 0) %>件</strong></div>
      <div class="metric-card"><span>完了</span><strong><%= status_counts.fetch("completed", 0) + status_counts.fetch("succeeded", 0) + status_counts.fetch("partial_succeeded", 0) %>件</strong></div>
      <div class="metric-card"><span>失敗</span><strong><%= status_counts.fetch("failed", 0) %>件</strong></div>
    </div>
  </section>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>タイトル</th>
          <th>事業</th>
          <th>Repository</th>
          <th>Type</th>
          <th>risk</th>
          <th>status</th>
          <th>優先度</th>
          <th>作成</th>
          <th>詳細</th>
        </tr>
      </thead>
      <tbody>
        <% @auto_revision_tasks.each do |task| %>
          <tr>
            <td><%= task.title %></td>
            <td><%= task.business.name %></td>
            <td><%= task.target_repository_display %></td>
            <td><span class="pill"><%= task.target_repository_type.presence || "-" %></span></td>
            <td><span class="pill"><%= task.risk_level %></span></td>
            <td><span class="pill"><%= task.status %></span></td>
            <td class="number"><%= number_with_precision(task.priority_score, precision: 1) %></td>
            <td><%= l(task.created_at, format: :short) %></td>
            <td><%= link_to "詳細", task, class: "button secondary" %></td>
          </tr>
        <% end %>
        <% if @auto_revision_tasks.empty? %>
          <tr><td colspan="9">まだAuto Revision Taskはありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
