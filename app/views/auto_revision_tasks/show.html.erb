<% content_for :title, @auto_revision_task.title %>

<% header_actions = capture do %>
  <%= link_to "一覧", auto_revision_tasks_path, class: "button secondary" %>
  <%= link_to "Codex Queue", codex_queue_auto_revision_tasks_path, class: "button secondary" %>
  <%= link_to "ActionCandidate", @auto_revision_task.action_candidate, class: "button secondary" %>
  <% if %w[draft waiting_approval].include?(@auto_revision_task.status) %>
    <%= button_to "承認", approve_auto_revision_task_path(@auto_revision_task), method: :patch, class: "button", data: { turbo_confirm: "#{@auto_revision_task.risk_level} riskの改修タスクを承認しますか？" } %>
  <% end %>
  <% if @auto_revision_task.status == "ready_for_codex" %>
    <%= button_to "Codex投入済みにする", mark_sent_to_codex_auto_revision_task_path(@auto_revision_task), method: :patch, class: "button" %>
  <% elsif @auto_revision_task.status == "sent_to_codex" %>
    <%= button_to "実装開始", start_implementation_auto_revision_task_path(@auto_revision_task), method: :patch, class: "button" %>
  <% end %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: @auto_revision_task.title,
             description: "Codexへ渡す前の改修タスクです。まだ自動実行はしません。",
             active_main: :dashboard,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="metric-grid">
      <div class="metric-card"><span>status</span><strong><%= @auto_revision_task.status %></strong></div>
      <div class="metric-card"><span>risk</span><strong><%= @auto_revision_task.risk_level %></strong></div>
      <div class="metric-card"><span>優先度</span><strong><%= number_with_precision(@auto_revision_task.priority_score, precision: 1) %></strong></div>
      <div class="metric-card"><span>generated_by</span><strong><%= @auto_revision_task.generated_by %></strong></div>
      <div class="metric-card"><span>Repository</span><strong><%= @auto_revision_task.target_repository_display %></strong></div>
      <div class="metric-card"><span>Repository Type</span><strong><%= @auto_revision_task.target_repository_type.presence || "-" %></strong></div>
      <div class="metric-card"><span>Codex投入</span><strong><%= @auto_revision_task.sent_to_codex_at ? l(@auto_revision_task.sent_to_codex_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>実装開始</span><strong><%= @auto_revision_task.started_running_at ? l(@auto_revision_task.started_running_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>最終確認</span><strong><%= @auto_revision_task.last_checked_at ? l(@auto_revision_task.last_checked_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>放置判定</span><strong><%= @auto_revision_task.stale_codex_task? ? "要確認" : "正常" %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Target Repository</h2>
      <p>このタスクをCodexへ渡すときの対象事業・リポジトリ・実行コマンドです。</p>
    </div>
    <% if @auto_revision_task.repository_target_warning? %>
      <p class="aicoo-empty-state">
        ⚠ この事業はExecution Profileが<%= @auto_revision_task.repository_target_status %>です。
        Codex投入前に設定してください。不足: <%= @auto_revision_task.repository_target_missing_fields_label %>
      </p>
      <div class="actions compact-actions">
        <% if @auto_revision_task.business.business_execution_profile %>
          <%= link_to "Execution Profileを編集", edit_admin_business_execution_profile_path(@auto_revision_task.business.business_execution_profile), class: "button" %>
        <% else %>
          <%= link_to "Execution Profileを作成", new_admin_business_execution_profile_path(business_id: @auto_revision_task.business_id), class: "button" %>
        <% end %>
      </div>
    <% end %>
    <% profile = @auto_revision_task.execution_profile %>
    <dl class="detail-list">
      <dt>対象事業</dt>
      <dd><%= @auto_revision_task.target_business&.name || @auto_revision_task.business.name %></dd>
      <dt>Repository</dt>
      <dd><%= @auto_revision_task.target_repository_display %></dd>
      <dt>Repository Type</dt>
      <dd><%= @auto_revision_task.target_repository_type.presence || "-" %></dd>
      <dt>Coverage Status</dt>
      <dd><%= @auto_revision_task.repository_target_status_label %></dd>
      <dt>GitHub Repository</dt>
      <dd><%= profile&.github_repository.presence || "-" %></dd>
      <dt>Repository Path</dt>
      <dd><%= profile&.repository_path.presence || "-" %></dd>
      <dt>Test Command</dt>
      <dd><%= profile&.test_command.presence || "bin/rails test" %></dd>
      <dt>Lint Command</dt>
      <dd><%= profile&.lint_command.presence || "RUBOCOP_CACHE_ROOT=tmp/rubocop_cache bundle exec rubocop" %></dd>
      <dt>Deploy Command</dt>
      <dd><%= profile&.deploy_command.presence || "-" %></dd>
      <dt>Forbidden Patterns</dt>
      <dd><%= simple_format(profile&.forbidden_pattern_lines&.join("\n").presence || "db:drop\ndb:reset\ndrop database") %></dd>
    </dl>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Codex Execution Tracking</h2>
      <p>Codexへ投入した日時、実行スレッド、最終確認日時を記録します。</p>
    </div>
    <dl class="detail-list">
      <dt>status</dt>
      <dd><%= @auto_revision_task.status %></dd>
      <dt>sent_to_codex_at</dt>
      <dd><%= @auto_revision_task.sent_to_codex_at ? l(@auto_revision_task.sent_to_codex_at, format: :long) : "-" %></dd>
      <dt>started_running_at</dt>
      <dd><%= @auto_revision_task.started_running_at ? l(@auto_revision_task.started_running_at, format: :long) : "-" %></dd>
      <dt>last_checked_at</dt>
      <dd><%= @auto_revision_task.last_checked_at ? l(@auto_revision_task.last_checked_at, format: :long) : "-" %></dd>
      <dt>codex_thread_url</dt>
      <dd>
        <% if @auto_revision_task.codex_thread_url.present? %>
          <%= link_to @auto_revision_task.codex_thread_url, @auto_revision_task.codex_thread_url, target: "_blank", rel: "noopener" %>
        <% else %>
          -
        <% end %>
      </dd>
      <dt>codex_session_label</dt>
      <dd><%= @auto_revision_task.codex_session_label.presence || "-" %></dd>
    </dl>

    <%= form_with model: @auto_revision_task,
                  url: update_codex_tracking_auto_revision_task_path(@auto_revision_task),
                  method: :patch,
                  class: "aicoo-form" do |form| %>
      <div class="field">
        <%= form.label :codex_thread_url, "CodexスレッドURL" %>
        <%= form.url_field :codex_thread_url, placeholder: "https://chatgpt.com/..." %>
      </div>
      <div class="field">
        <%= form.label :codex_session_label, "Codexセッション名" %>
        <%= form.text_field :codex_session_label, placeholder: "SUELOG-SEO-001" %>
      </div>
      <div class="field">
        <%= form.label :last_checked_at, "最終確認日時" %>
        <%= form.datetime_field :last_checked_at,
                                value: (@auto_revision_task.last_checked_at&.strftime("%Y-%m-%dT%H:%M")) %>
      </div>
      <div class="actions compact-actions">
        <%= form.submit "追跡情報を保存", class: "button" %>
        <%= button_tag "最終確認を今に更新", type: "submit", name: "mark_checked", value: "1", class: "button secondary" %>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Codex用プロンプト</h2>
      <p>この内容をCodexに貼って、承認済みタスクとして実行できます。</p>
    </div>
    <div class="actions compact-actions">
      <button type="button"
              class="button secondary"
              onclick="navigator.clipboard.writeText(document.getElementById('auto-revision-codex-prompt').value)">
        Codexプロンプトをコピー
      </button>
    </div>
    <div class="field">
      <textarea id="auto-revision-codex-prompt" readonly rows="30" class="code-textarea"><%= @auto_revision_task.codex_prompt %></textarea>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Codex Quality Check</h2>
      <p>Codex実装結果の安全性、テスト状況、リスクを自動評価します。</p>
    </div>
    <% if (quality_check = @auto_revision_task.codex_quality_check) %>
      <div class="metric-grid">
        <div class="metric-card"><span>品質スコア</span><strong><%= quality_check.quality_score %></strong></div>
        <div class="metric-card"><span>リスクスコア</span><strong><%= quality_check.risk_score %></strong></div>
        <div class="metric-card"><span>test_status</span><strong><%= quality_check.test_status %></strong></div>
        <div class="metric-card"><span>判定結果</span><strong><%= quality_check.result %></strong></div>
        <div class="metric-card"><span>Quality Gate Status</span><strong><%= quality_check.quality_gate_label %></strong></div>
        <div class="metric-card"><span>migration検知</span><strong><%= quality_check.migration_detected? ? "あり" : "なし" %></strong></div>
        <div class="metric-card"><span>high risk検知</span><strong><%= quality_check.high_risk_change_detected? ? "あり" : "なし" %></strong></div>
        <div class="metric-card"><span>変更ファイル</span><strong><%= quality_check.changed_files_count %></strong></div>
        <div class="metric-card"><span>warning</span><strong><%= quality_check.warning_count %></strong></div>
      </div>
      <% if quality_check.warnings.present? %>
        <ul>
          <% quality_check.warnings.each do |warning| %>
            <li><%= warning %></li>
          <% end %>
        </ul>
      <% else %>
        <p class="aicoo-empty-state">品質警告はありません。</p>
      <% end %>
      <div class="actions compact-actions">
        <%= link_to "Quality Gate詳細", quality_check, class: "button secondary" %>
        <% if quality_check.approval_status == "pending" %>
          <%= button_to "Quality Gate承認", approve_codex_quality_check_path(quality_check), method: :patch, class: "button" %>
          <%= button_to "Quality Gate却下", reject_codex_quality_check_path(quality_check), method: :patch, class: "button danger" %>
        <% end %>
      </div>
    <% else %>
      <p class="aicoo-empty-state">実装結果を登録すると、Codex Quality Checkが自動作成されます。</p>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>実装結果を登録</h2>
      <p>Codexで実装した結果を戻し、ActionExecutionLogやActionResultへつなげます。</p>
    </div>

    <%= form_with model: @auto_revision_task, url: record_result_auto_revision_task_path(@auto_revision_task), method: :patch, class: "aicoo-form" do |form| %>
      <div class="field">
        <%= form.label :status, "status" %>
        <%= form.select :status, options_for_select(%w[succeeded partial_succeeded failed canceled], @auto_revision_task.status) %>
      </div>
      <div class="field">
        <%= form.label :result_summary, "result_summary" %>
        <%= form.text_area :result_summary, rows: 4 %>
      </div>
      <div class="field">
        <%= form.label :error_message, "error_message" %>
        <%= form.text_area :error_message, rows: 3 %>
      </div>
      <div class="field">
        <%= form.label :changed_files, "changed_files" %>
        <%= form.text_area :changed_files, rows: 4, placeholder: "app/models/example.rb\napp/views/example.html.erb" %>
      </div>
      <div class="field">
        <%= form.label :test_result, "test_result" %>
        <%= form.text_area :test_result, rows: 4 %>
      </div>
      <div class="field">
        <%= form.label :codex_output, "codex_output" %>
        <%= form.text_area :codex_output, rows: 6 %>
      </div>
      <div class="field">
        <%= form.label :finished_at, "finished_at" %>
        <%= form.datetime_field :finished_at, value: (@auto_revision_task.finished_at || Time.current).strftime("%Y-%m-%dT%H:%M") %>
      </div>
      <label class="checkbox">
        <%= check_box_tag :create_action_execution_log, "1", true %>
        ActionExecutionLogを作成する
      </label>
      <%= form.submit "実装結果を登録", class: "button" %>
    <% end %>
  </section>

  <% if @auto_revision_task.successful_result? %>
    <section class="dashboard-section">
      <div class="section-heading">
        <h2>次の学習登録</h2>
        <p>成功または部分成功した改修は、ActionResultへつなげて予測精度を学習できます。</p>
      </div>
      <div class="actions compact-actions">
        <%= link_to "ActionResultを登録", new_action_result_path(action_result: { action_candidate_id: @auto_revision_task.action_candidate_id }), class: "button" %>
      </div>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>元データ</h2>
      <p>ActionCandidateからコピーした内容です。</p>
    </div>
    <dl class="detail-list">
      <dt>事業</dt>
      <dd><%= @auto_revision_task.business.name %></dd>
      <dt>ActionCandidate</dt>
      <dd><%= link_to @auto_revision_task.action_candidate.title, @auto_revision_task.action_candidate %></dd>
      <dt>execution_prompt</dt>
      <dd><%= simple_format(@auto_revision_task.execution_prompt.presence || "-") %></dd>
      <dt>result_summary</dt>
      <dd><%= simple_format(@auto_revision_task.result_summary.presence || "-") %></dd>
      <dt>error_message</dt>
      <dd><%= simple_format(@auto_revision_task.error_message.presence || "-") %></dd>
      <dt>changed_files</dt>
      <dd><%= simple_format(@auto_revision_task.changed_files.presence || "-") %></dd>
      <dt>test_result</dt>
      <dd><%= simple_format(@auto_revision_task.test_result.presence || "-") %></dd>
      <dt>codex_output</dt>
      <dd><%= simple_format(@auto_revision_task.codex_output.presence || "-") %></dd>
    </dl>
  </section>
</div>
