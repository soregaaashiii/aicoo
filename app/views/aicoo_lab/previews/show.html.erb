<% public_lp = local_assigns.fetch(:public_lp, @public_lp_rendering) %>
<% headline = public_lp ? @landing_page.public_headline : @landing_page.headline %>
<% subheadline = public_lp ? @landing_page.public_subheadline : @landing_page.subheadline %>
<% body = public_lp ? @landing_page.public_body : @landing_page.body %>
<% cta_text = public_lp ? @landing_page.public_cta_text : @landing_page.cta_text %>
<% content_for :title, public_lp ? @landing_page.public_seo_title : @landing_page.effective_seo_title %>
<% content_for :meta_description, public_lp ? @landing_page.public_seo_description : @landing_page.effective_seo_description %>
<% content_for :canonical_url, @canonical_url if @canonical_url.present? %>
<% content_for :og_title, public_lp ? @landing_page.public_og_title : @landing_page.effective_og_title %>
<% content_for :og_description, public_lp ? @landing_page.public_og_description : @landing_page.effective_og_description %>
<% if @landing_page.effective_og_image_url.present? %>
  <% content_for :og_image, @landing_page.effective_og_image_url %>
  <% content_for :twitter_card, "summary_large_image" %>
<% end %>

<main class="lp-preview">
  <section class="lp-hero">
    <% unless public_lp %>
      <p class="lp-eyebrow"><%= @lp_mode_label || "確認用" %></p>
    <% end %>
    <h1><%= headline %></h1>
    <p class="lp-subheadline"><%= subheadline %></p>
    <% if @lp_mode_description.present? %>
      <p class="lp-subheadline"><%= @lp_mode_description %></p>
    <% end %>
    <div class="lp-actions">
      <%= button_to cta_text, @cta_click_path || aicoo_lab_preview_cta_click_path(@landing_page.preview_slug), method: :post, class: "button" %>
      <% if @landing_page.assumed_price_yen.present? %>
        <span class="lp-price"><%= number_to_currency(@landing_page.assumed_price_yen, unit: "¥", precision: 0) %></span>
      <% end %>
    </div>
  </section>

  <section class="lp-content">
    <%= simple_format(body) %>
  </section>

  <section id="cta" class="lp-cta">
    <h2><%= cta_text %></h2>
    <p><%= public_lp ? "登録後、準備ができ次第ご案内します。" : "興味があれば事前登録に進んでください。登録内容は管理画面で確認できます。" %></p>
    <%= button_to cta_text, @cta_click_path || aicoo_lab_preview_cta_click_path(@landing_page.preview_slug), method: :post, class: "button" %>
  </section>
</main>

<% if @scroll_event_path.present? %>
  <script>
    (() => {
      const thresholds = [25, 50, 75, 100];
      const sent = new Set();
      const csrfToken = document.querySelector("meta[name='csrf-token']")?.content;

      const sendScrollDepth = (depth) => {
        if (sent.has(depth)) return;
        sent.add(depth);

        fetch("<%= j @scroll_event_path %>", {
          method: "POST",
          credentials: "same-origin",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": csrfToken
          },
          body: JSON.stringify({ depth })
        }).catch(() => {});

        if (window.gtag) {
          window.gtag("event", "lp_scroll_depth", {
            landing_page_slug: "<%= j @landing_page.published_slug %>",
            scroll_depth: depth
          });
        }
      };

      const checkScrollDepth = () => {
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const percent = scrollable <= 0 ? 100 : Math.round((window.scrollY / scrollable) * 100);
        thresholds.forEach((threshold) => {
          if (percent >= threshold) sendScrollDepth(threshold);
        });
      };

      window.addEventListener("scroll", checkScrollDepth, { passive: true });
      window.addEventListener("load", checkScrollDepth);
    })();
  </script>
<% end %>
