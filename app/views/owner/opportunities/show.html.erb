<% content_for :title, @opportunity.title %>

<% candidate = @opportunity.action_candidate %>
<% execution = candidate&.action_execution %>
<% result = candidate&.action_result %>

<% header_actions = capture do %>
  <%= link_to "Opportunity一覧", owner_opportunities_path, class: "button secondary" %>
  <% unless candidate %>
    <% if @opportunity.status == "pending" %>
      <%= button_to "Approve", approve_owner_opportunity_path(@opportunity), method: :patch, class: "button secondary" %>
    <% end %>
    <% if @opportunity.new_service_candidate? %>
      <%= button_to "新規サービス下書きを作成", create_business_owner_opportunity_path(@opportunity), method: :post, class: "button" %>
    <% else %>
      <%= button_to "Convert to Candidate", convert_to_candidate_owner_opportunity_path(@opportunity), method: :post, class: "button" %>
    <% end %>
  <% end %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: @opportunity.title,
             description: "OpportunityからActionCandidate、Execution、Resultまで追跡します。",
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>source</span><strong><%= @opportunity.source_type %></strong></div>
      <div class="metric-card"><span>status</span><strong><%= @opportunity.status %></strong></div>
      <div class="metric-card"><span>score</span><strong><%= @opportunity.opportunity_score.to_i %></strong></div>
      <div class="metric-card"><span>expected value</span><strong><%= number_to_currency(@opportunity.expected_value_yen.to_i, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>confidence</span><strong><%= @opportunity.confidence.to_i %></strong></div>
      <div class="metric-card"><span>type</span><strong><%= @opportunity.opportunity_type %></strong></div>
      <div class="metric-card"><span>discovered</span><strong><%= @opportunity.discovered_at ? l(@opportunity.discovered_at, format: :short) : "-" %></strong></div>
    </div>
  </section>

  <% if @opportunity.new_service_candidate? %>
    <section class="dashboard-section">
      <div class="aicoo-card aicoo-card-compact">
        <h2>新規サービス候補</h2>
        <p>このOpportunityは既存Businessに紐づいていません。ActionCandidate化する前に、新規サービスのBusiness下書きを作成してください。</p>
        <div class="actions compact-actions">
          <%= button_to "新規サービス下書きを作成", create_business_owner_opportunity_path(@opportunity), method: :post, class: "button" %>
        </div>
      </div>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>評価スコア</h2>
      <p>Explore ObservationをOpportunityとして評価した内訳です。</p>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>market signal</span><strong><%= @opportunity.market_signal_score.to_i %></strong></div>
      <div class="metric-card"><span>urgency</span><strong><%= @opportunity.urgency_score.to_i %></strong></div>
      <div class="metric-card"><span>monetization</span><strong><%= @opportunity.monetization_score.to_i %></strong></div>
      <div class="metric-card"><span>feasibility</span><strong><%= @opportunity.feasibility_score.to_i %></strong></div>
      <div class="metric-card"><span>competition</span><strong><%= @opportunity.competition_score.to_i %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>提案理由</h2>
      <p>Opportunityを支えているExplore・実績・判断ログの根拠です。</p>
    </div>
    <% evidence = @opportunity.metadata.to_h.fetch("evidence", {}) %>
    <% evidence_items = Array(evidence["items"]) %>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>Evidence Score</span><strong><%= evidence["score"].present? ? number_with_precision(evidence["score"].to_d, precision: 1) : "未評価" %></strong></div>
      <div class="metric-card"><span>根拠数</span><strong><%= evidence_items.size %>件</strong></div>
      <div class="metric-card"><span>状態</span><strong><%= evidence["warning"] ? "根拠不足" : "根拠あり" %></strong></div>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <ul class="compact-list">
        <% Array(evidence["summary"]).each do |line| %>
          <li><%= line.to_s.sub(/\A・/, "") %></li>
        <% end %>
        <% if Array(evidence["summary"]).empty? %>
          <li>Evidence不足: 判断に使える根拠データがまだありません。</li>
        <% end %>
      </ul>
      <% if evidence["missing_sources"].present? %>
        <p><strong>不足:</strong> <%= evidence["missing_sources"].join(", ") %></p>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Business Playbook</h2>
      <p>このBusinessの勝ちパターンから見たOpportunity評価です。</p>
    </div>
    <% playbook = @opportunity.metadata.to_h.fetch("business_playbook", {}) %>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>Playbook Score</span><strong><%= number_with_precision(@opportunity.business_playbook_score.to_d, precision: 1) %></strong></div>
      <div class="metric-card"><span>Confidence</span><strong><%= number_with_precision(playbook["confidence"].to_s.to_d, precision: 1) %></strong></div>
      <div class="metric-card"><span>係数</span><strong><%= number_with_precision(playbook["coefficient"].presence || 1, precision: 4) %></strong></div>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <p><%= playbook["reason"].presence || "Business Playbook未学習のため汎用ルールで評価しています。" %></p>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Practicality</h2>
      <p>ActionCandidate化できるほど具体的かを確認します。</p>
    </div>
    <% practicality = @opportunity.metadata.to_h.fetch("practicality", {}) %>
    <% subscores = practicality.fetch("subscores", {}) %>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>実行可能性</span><strong><%= @opportunity.practicality_score ? number_with_precision(@opportunity.practicality_score, precision: 1) : "未評価" %></strong></div>
      <div class="metric-card"><span>対象</span><strong><%= number_with_precision(subscores["target_clarity_score"].to_d, precision: 1) %></strong></div>
      <div class="metric-card"><span>行動</span><strong><%= number_with_precision(subscores["action_clarity_score"].to_d, precision: 1) %></strong></div>
      <div class="metric-card"><span>成果物</span><strong><%= number_with_precision(subscores["deliverable_score"].to_d, precision: 1) %></strong></div>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <p><%= @opportunity.practicality_reason.presence || practicality["reason"].presence || "Practicality情報はまだありません。" %></p>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>内容</h2>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <%= simple_format(@opportunity.description.presence || "-") %>
    </div>
    <div class="actions compact-actions">
      <% if @opportunity.status == "new" %>
        <%= button_to "Reviewedにする", review_owner_opportunity_path(@opportunity), method: :patch, class: "button secondary" %>
      <% end %>
      <% if @opportunity.status == "pending" %>
        <%= button_to "Approve", approve_owner_opportunity_path(@opportunity), method: :patch, class: "button secondary" %>
      <% end %>
      <% unless @opportunity.status == "rejected" %>
        <%= button_to "Reject", reject_owner_opportunity_path(@opportunity), method: :patch, class: "button danger", data: { turbo_confirm: "このOpportunityを却下しますか？" } %>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Opportunity Learning</h2>
      <p>このOpportunityから発生した実行と結果です。</p>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>Candidate</span><strong><%= candidate ? 1 : 0 %>件</strong></div>
      <div class="metric-card"><span>Execution</span><strong><%= @opportunity.execution_count %>件</strong></div>
      <div class="metric-card"><span>Result</span><strong><%= @opportunity.result_count %>件</strong></div>
      <div class="metric-card"><span>Success</span><strong><%= @opportunity.success_count %>件</strong></div>
      <div class="metric-card"><span>Failure</span><strong><%= @opportunity.failure_count %>件</strong></div>
    </div>
    <dl class="detail-list">
      <dt>ActionCandidate</dt>
      <dd><%= candidate ? link_to(candidate.title, candidate) : "-" %></dd>
      <dt>ActionExecution</dt>
      <dd><%= execution ? link_to("Execution ##{execution.id}", execution) : "-" %></dd>
      <dt>ActionResult</dt>
      <dd><%= result ? link_to("Result ##{result.id}", result) : "-" %></dd>
    </dl>
  </section>

  <% if @discovery_source_summary %>
    <section class="dashboard-section">
      <div class="section-heading">
        <h2>Source Performance</h2>
        <p>この発見源の過去実績です。</p>
      </div>
      <div class="metric-grid aicoo-owner-secondary">
        <div class="metric-card"><span>Opportunity</span><strong><%= @discovery_source_summary.opportunities_count %>件</strong></div>
        <div class="metric-card"><span>Candidate</span><strong><%= @discovery_source_summary.candidates_count %>件</strong></div>
        <div class="metric-card"><span>Execution</span><strong><%= @discovery_source_summary.executions_count %>件</strong></div>
        <div class="metric-card"><span>Result</span><strong><%= @discovery_source_summary.results_count %>件</strong></div>
        <div class="metric-card"><span>Success Rate</span><strong><%= number_to_percentage(@discovery_source_summary.overall_success_rate * 100, precision: 1) %></strong></div>
        <div class="metric-card"><span>Actual Profit</span><strong><%= number_to_currency(@discovery_source_summary.total_actual_profit, unit: "¥", precision: 0) %></strong></div>
      </div>
    </section>
  <% end %>
</div>
