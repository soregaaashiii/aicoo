<% content_for :title, "自動改修ループ" %>

<section class="page-header">
  <div>
    <p class="eyebrow">CEO MODE</p>
    <h1>自動改修ループ</h1>
    <p class="muted">改善案、Codex用プロンプト、PR、実装結果、ActionResult、Learningをこの1ページで進めます。</p>
  </div>
  <div class="button-row">
    <%= link_to "Owner Home", owner_focus_path, class: "button secondary" %>
  </div>
</section>

<% if @board.next_action %>
  <section class="panel">
    <p class="eyebrow">次に押すボタン</p>
    <h2><%= @board.next_action.next_action_label %></h2>
    <p><%= @board.next_action.next_action_reason %></p>
    <% if @board.next_action.next_action_path.present? %>
      <%= button_to @board.next_action.next_action_label,
                    @board.next_action.next_action_path,
                    method: @board.next_action.next_action_method,
                    class: "button primary" %>
    <% else %>
      <a href="#selected-task" class="button primary"><%= @board.next_action.next_action_label %></a>
    <% end %>
  </section>
<% end %>

<section class="metrics-grid">
  <div class="metric-card"><span>送信待ち</span><strong><%= @board.summary.waiting_to_copy_count %></strong></div>
  <div class="metric-card"><span>Codex作業中</span><strong><%= @board.summary.codex_running_count %></strong></div>
  <div class="metric-card"><span>PR待ち</span><strong><%= @board.summary.pr_waiting_count %></strong></div>
  <div class="metric-card"><span>確認待ち</span><strong><%= @board.summary.confirmation_waiting_count %></strong></div>
  <div class="metric-card"><span>結果登録待ち</span><strong><%= @board.summary.result_waiting_count %></strong></div>
  <div class="metric-card"><span>失敗</span><strong><%= @board.summary.failed_count %></strong></div>
  <div class="metric-card"><span>最近完了</span><strong><%= @board.summary.completed_count %></strong></div>
</section>

<div class="two-column-layout">
  <section class="panel">
    <h2>改修キュー</h2>
    <div class="stack-list">
      <% @board.rows.each_with_index do |row, index| %>
        <article class="task-card <%= "is-selected" if row == @board.selected %>">
          <div class="task-card__head">
            <div>
              <p class="eyebrow">#<%= index + 1 %> <%= row.business&.name || "Business未設定" %></p>
              <h3><%= link_to row.title, owner_auto_revision_loop_path(selected: row.key, anchor: "selected-task") %></h3>
            </div>
            <span class="pill"><%= row.current_state %></span>
          </div>
          <div class="progress-line" aria-label="<%= row.progress_label %> <%= row.progress_percent %>%">
            <span style="width: <%= row.progress_percent %>%"></span>
          </div>
          <dl class="compact-definition">
            <dt>期待利益</dt><dd>¥<%= number_with_delimiter(row.expected_profit_yen) %></dd>
            <dt>期待時給</dt><dd>¥<%= number_with_delimiter(row.expected_hourly_value_yen) %></dd>
            <dt>止まっている理由</dt><dd><%= row.stuck_reason %></dd>
          </dl>
          <div class="button-row">
            <% if row.next_action_path.present? %>
              <%= button_to row.next_action_label, row.next_action_path, method: row.next_action_method, class: "button small" %>
            <% else %>
              <%= link_to row.next_action_label, owner_auto_revision_loop_path(selected: row.key, anchor: "selected-task"), class: "button small" %>
            <% end %>
          </div>
        </article>
      <% end %>
      <% if @board.rows.empty? %>
        <p>改修キューはありません。</p>
      <% end %>
    </div>
  </section>

  <section class="panel" id="selected-task">
    <h2>選択中タスク</h2>
    <% if (row = @board.selected) %>
      <p class="eyebrow"><%= row.current_state %> / <%= row.progress_label %> <%= row.progress_percent %>%</p>
      <h3><%= row.title %></h3>
      <p><strong>Business:</strong> <%= row.business&.name || "未設定" %></p>
      <p><strong>止まっている理由:</strong> <%= row.stuck_reason %></p>
      <div class="progress-line"><span style="width: <%= row.progress_percent %>%"></span></div>

      <details open>
        <summary>実装指示書 / Codex Prompt</summary>
        <p><strong>対象URL:</strong> <%= row.detail[:target_url].presence || "未特定" %></p>
        <p><strong>期待効果:</strong>
          CTR <%= row.detail.dig(:expected_effects, :ctr) || "-" %> /
          順位 <%= row.detail.dig(:expected_effects, :rank) || "-" %> /
          利益 <%= row.detail.dig(:expected_effects, :profit) || "-" %>
        </p>
        <h4>変更ファイル</h4>
        <ul>
          <% Array(row.detail[:changed_files]).each do |path| %>
            <li><code><%= path %></code></li>
          <% end %>
        </ul>
        <h4>完成条件</h4>
        <ul>
          <% Array(row.detail[:completion_criteria]).each do |criterion| %>
            <li><%= criterion %></li>
          <% end %>
        </ul>
        <textarea id="codex-prompt" class="prompt-preview" rows="14" readonly><%= row.detail[:prompt] %></textarea>
      </details>

      <details open>
        <summary>Codex / PR操作</summary>
        <div class="button-row">
          <% if row.auto_revision_task %>
            <% submission = row.auto_revision_task.codex_submission %>
            <button type="button" class="button secondary" onclick="navigator.clipboard && navigator.clipboard.writeText(document.getElementById('codex-prompt').value)">Codex用プロンプトをコピー</button>
            <%= link_to "Cloud Codexで開く", "https://chatgpt.com/codex", class: "button secondary", target: "_blank", rel: "noopener" %>
            <% if submission&.github_issue_url.present? %>
              <%= link_to "GitHub Issueを開く", submission.github_issue_url, class: "button", target: "_blank", rel: "noopener" %>
            <% else %>
              <%= button_to "GitHub Issueを作成", create_github_issue_owner_auto_revision_loop_task_path(row.auto_revision_task), method: :post, class: "button" %>
            <% end %>
          <% elsif row.action_candidate %>
            <%= button_to "自動改修タスク化", create_task_owner_auto_revision_loop_candidate_path(row.action_candidate), method: :post, class: "button" %>
          <% end %>
        </div>

        <% if row.auto_revision_task %>
          <%= form_with url: record_result_owner_auto_revision_loop_task_path(row.auto_revision_task), method: :patch, scope: :auto_revision_task, local: true do |form| %>
            <div class="form-grid">
              <label>状態 <%= form.select :status, AutoRevisionTask::STATUSES, selected: "completed" %></label>
              <label>PR URL <%= form.url_field :pull_request_url, value: row.detail[:pr_url] %></label>
              <label>Deploy URL <%= form.url_field :deploy_url %></label>
              <label>Deploy状態 <%= form.text_field :deploy_status, value: row.detail[:deploy_status] %></label>
              <label>変更ファイル <%= form.text_area :changed_files, rows: 3 %></label>
              <label>テスト結果 <%= form.text_area :test_result, rows: 3 %></label>
              <label>実装内容 <%= form.text_area :result_summary, rows: 3, value: row.detail[:result_summary] %></label>
            </div>
            <label><%= check_box_tag :create_action_execution_log, "1", true %> ActionExecutionLogも作成する</label>
            <%= form.submit "実装結果を登録", class: "button primary" %>
          <% end %>
        <% end %>
      </details>

      <details open>
        <summary>ActionResult / Learning</summary>
        <% if row.action_candidate && row.action_candidate.action_result.blank? %>
          <%= form_with url: owner_auto_revision_loop_action_results_path, scope: :action_result, local: true do |form| %>
            <%= hidden_field_tag :action_candidate_id, row.action_candidate.id %>
            <div class="form-grid">
              <label>実行日 <%= form.date_field :executed_on, value: Date.current %></label>
              <label>評価日 <%= form.date_field :evaluated_on, value: Date.current %></label>
              <label>売上 <%= form.number_field :actual_revenue_yen, value: 0 %></label>
              <label>利益 <%= form.number_field :actual_profit_yen, value: 0 %></label>
              <label>メモ <%= form.text_area :note, rows: 3, value: row.detail[:result_summary] %></label>
            </div>
            <%= form.submit "ActionResultを登録", class: "button primary" %>
          <% end %>
        <% elsif row.action_candidate&.action_result %>
          <p class="notice">ActionResult登録済み: <%= row.action_candidate.action_result.evaluation_status %></p>
          <p class="muted">Learning評価は7日/14日/30日の実績で更新されます。</p>
        <% else %>
          <p>ActionResult登録はAutoRevisionTask作成後に利用できます。</p>
        <% end %>
      </details>
    <% else %>
      <p>選択中タスクはありません。</p>
    <% end %>
  </section>
</div>
