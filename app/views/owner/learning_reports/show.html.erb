<% content_for :title, "Learning Loop Quality Report" %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "学習品質レポート",
             description: "AICOOの予測がどれだけ実績に近づいているかを確認します。",
             active_main: :scoreboard %>

  <% report = @learning_loop_quality_report %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Summary</h2>
      <p>予測、実績、補正の全体状態です。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>Accuracy Score</span><strong><%= report.prediction_accuracy_score || "N/A" %></strong></div>
      <div class="metric-card"><span>Evaluated Count</span><strong><%= report.total_evaluated %>件</strong></div>
      <div class="metric-card"><span>Profit Error</span><strong><%= report.profit_error_rate ? number_to_percentage(report.profit_error_rate * 100, precision: 1) : "N/A" %></strong></div>
      <div class="metric-card"><span>Success Probability Error</span><strong><%= report.success_probability_error ? number_to_percentage(report.success_probability_error * 100, precision: 1) : "N/A" %></strong></div>
      <div class="metric-card"><span>Calibration Effectiveness</span><strong><%= report.calibration_effectiveness_score %></strong></div>
      <div class="metric-card"><span>Learning Trend</span><strong><%= report.learning_trend %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Recommendations</h2>
      <p>予測精度を上げるための次アクションです。</p>
    </div>
    <div class="aicoo-card-grid">
      <% @learning_report_recommendations.recommendations.first(5).each do |recommendation| %>
        <div class="aicoo-card aicoo-card-compact">
          <p><span class="pill"><%= recommendation.priority %></span> <%= recommendation.category %></p>
          <h3><%= recommendation.title %></h3>
          <p><%= recommendation.reason %></p>
          <p><strong>次アクション:</strong> <%= recommendation.recommended_action %></p>
          <div class="actions compact-actions">
            <% if recommendation.target_path.present? %>
              <%= link_to "対象を見る", recommendation.target_path, class: "button secondary" %>
            <% end %>
            <%= button_to "ActionCandidate化",
                          create_action_candidate_owner_learning_recommendation_path,
                          method: :post,
                          params: {
                            title: recommendation.title,
                            reason: recommendation.reason,
                            recommended_action: recommendation.recommended_action,
                            category: recommendation.category,
                            priority: recommendation.priority
                          },
                          class: "button" %>
            <%= button_to "Create Opportunity",
                          create_opportunity_owner_learning_recommendation_path,
                          method: :post,
                          params: {
                            title: recommendation.title,
                            reason: recommendation.reason,
                            recommended_action: recommendation.recommended_action,
                            category: recommendation.category,
                            priority: recommendation.priority
                          },
                          class: "button secondary" %>
          </div>
        </div>
      <% end %>
      <% if @learning_report_recommendations.recommendations.empty? %>
        <div class="aicoo-card aicoo-card-compact">
          <p>現時点で追加の改善提案はありません。</p>
        </div>
      <% end %>
    </div>
  </section>

  <% decision_summary = @owner_decision_summary %>
  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Decision Log Summary</h2>
      <p>Ownerの承認・却下・変換・実行判断を学習データとして集計します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>Today</span><strong><%= decision_summary.today_count %>件</strong></div>
      <div class="metric-card"><span>7 Days</span><strong><%= decision_summary.last_7_days_count %>件</strong></div>
      <div class="metric-card"><span>30 Days</span><strong><%= decision_summary.last_30_days_count %>件</strong></div>
    </div>

    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card aicoo-card-compact">
        <h3>Decision Types</h3>
        <ul class="compact-list">
          <% decision_summary.counts_by_decision_type.each do |decision_type, count| %>
            <li><strong><%= decision_type %></strong> / <%= count %>件</li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>Risk Execution Rate</h3>
        <ul class="compact-list">
          <% decision_summary.risk_level_execution_rates.each do |summary| %>
            <li><strong><%= summary.label %></strong> / <%= number_to_percentage(summary.rate * 100, precision: 1) %> / <%= summary.positive_count %>/<%= summary.total_count %>件</li>
          <% end %>
          <% if decision_summary.risk_level_execution_rates.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="aicoo-card aicoo-card-compact">
      <h3>Action Type Adoption</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>action_type</th><th>採用率</th><th>採用系</th><th>総数</th></tr>
          </thead>
          <tbody>
            <% decision_summary.action_type_adoption_rates.each do |summary| %>
              <tr>
                <td><%= summary.label %></td>
                <td><%= number_to_percentage(summary.rate * 100, precision: 1) %></td>
                <td><%= summary.positive_count %>件</td>
                <td><%= summary.total_count %>件</td>
              </tr>
            <% end %>
            <% if decision_summary.action_type_adoption_rates.empty? %>
              <tr><td colspan="4">データ不足</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="aicoo-card aicoo-card-compact">
      <h3>Recent Decision Logs</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>日時</th><th>判断</th><th>対象</th><th>Business</th><th>期待値</th><th>Risk</th></tr>
          </thead>
          <tbody>
            <% decision_summary.recent_logs.each do |log| %>
              <tr>
                <td><%= l(log.decided_at, format: :short) %></td>
                <td><%= log.decision_type %></td>
                <td><%= log.title %></td>
                <td><%= log.business&.name || "-" %></td>
                <td><%= number_to_currency(log.expected_value_yen.to_i, unit: "¥", precision: 0) %></td>
                <td><%= log.risk_level.presence || "-" %></td>
              </tr>
            <% end %>
            <% if decision_summary.recent_logs.empty? %>
              <tr><td colspan="6">まだDecision Logはありません。</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <% strategic_report = @strategic_learning_report %>
  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Strategic Learning</h2>
      <p>経営思想を主目的関数にし、Decision Logは補正として扱います。</p>
    </div>
    <div class="metric-grid">
      <% strategic_report.philosophy_weights.each do |weight, value| %>
        <div class="metric-card"><span><%= weight.to_s.sub("_weight", "").humanize %></span><strong><%= value %></strong></div>
      <% end %>
      <div class="metric-card"><span>思想一致率</span><strong><%= number_to_percentage(strategic_report.strategic_alignment_rate * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>学習補正率</span><strong><%= number_to_percentage(strategic_report.learning_correction_rate * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>Decision補正率</span><strong><%= number_to_percentage(strategic_report.decision_correction_rate * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>逆方向判断</span><strong><%= strategic_report.contrary_decision_count %>件</strong></div>
    </div>

    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card aicoo-card-compact">
        <h3>Top Approved ActionType</h3>
        <ul class="compact-list">
          <% strategic_report.top_approved_action_types.each do |action_type, count| %>
            <li><strong><%= action_type %></strong> / <%= count %>件</li>
          <% end %>
          <% if strategic_report.top_approved_action_types.empty? %><li>データ不足</li><% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>Top Rejected / Skipped ActionType</h3>
        <ul class="compact-list">
          <% (strategic_report.top_rejected_action_types + strategic_report.top_skipped_action_types).first(5).each do |action_type, count| %>
            <li><strong><%= action_type %></strong> / <%= count %>件</li>
          <% end %>
          <% if strategic_report.top_rejected_action_types.empty? && strategic_report.top_skipped_action_types.empty? %><li>データ不足</li><% end %>
        </ul>
      </div>
    </div>

    <div class="aicoo-card aicoo-card-compact">
      <h3>Decision補正係数</h3>
      <ul class="compact-list">
        <% strategic_report.decision_coefficients.each do |coefficient| %>
          <li><strong><%= coefficient.label %></strong> / coefficient <%= coefficient.coefficient %> / rate <%= number_to_percentage(coefficient.rate * 100, precision: 1) %> / <%= coefficient.count %>件</li>
        <% end %>
        <% if strategic_report.decision_coefficients.empty? %><li>データ不足</li><% end %>
      </ul>
    </div>

    <div class="aicoo-card aicoo-card-compact">
      <h3>高期待値なのにSkip/Reject</h3>
      <ul class="compact-list">
        <% strategic_report.high_value_skipped_logs.each do |log| %>
          <li><%= log.title %> / <%= log.decision_type %> / <%= number_to_currency(log.expected_value_yen.to_i, unit: "¥", precision: 0) %></li>
        <% end %>
        <% if strategic_report.high_value_skipped_logs.empty? %><li>該当なし</li><% end %>
      </ul>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Strategic Learning Guardrail</h2>
      <p>補正が効きすぎていないかを確認します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>補正</span><strong><%= strategic_report.guardrail_settings.fetch(:enabled) ? "ON" : "OFF" %></strong></div>
      <div class="metric-card"><span>最大Boost</span><strong><%= number_to_percentage(strategic_report.guardrail_settings.fetch(:max_boost_rate).to_d * 100, precision: 0) %></strong></div>
      <div class="metric-card"><span>最大Penalty</span><strong><%= number_to_percentage(strategic_report.guardrail_settings.fetch(:max_penalty_rate).to_d * 100, precision: 0) %></strong></div>
      <div class="metric-card"><span>Warning閾値</span><strong><%= number_to_percentage(strategic_report.guardrail_settings.fetch(:warning_threshold_rate).to_d * 100, precision: 0) %></strong></div>
      <div class="metric-card"><span>Decision Log最小件数</span><strong><%= strategic_report.guardrail_settings.fetch(:decision_log_min_count) %>件</strong></div>
      <div class="metric-card"><span>今日warning</span><strong><%= strategic_report.guardrail_warning_today_count %>件</strong></div>
      <div class="metric-card"><span>7日warning</span><strong><%= strategic_report.guardrail_warning_7_days_count %>件</strong></div>
      <div class="metric-card"><span>30日warning</span><strong><%= strategic_report.guardrail_warning_30_days_count %>件</strong></div>
      <div class="metric-card"><span>最大補正率</span><strong><%= number_to_percentage(strategic_report.max_adjustment_rate * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>補正弱化</span><strong><%= strategic_report.weakened_decision_log_count %>件</strong></div>
    </div>

    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card aicoo-card-compact">
        <h3>補正率が大きい候補</h3>
        <ul class="compact-list">
          <% strategic_report.largest_adjustments.each do |candidate| %>
            <% guardrail = candidate.metadata.to_h["strategic_learning_guardrail"].to_h %>
            <li><%= link_to candidate.title, action_candidate_path(candidate) %> / <%= number_to_percentage(guardrail.fetch("adjustment_rate", 0).to_d * 100, precision: 1) %></li>
          <% end %>
          <% if strategic_report.largest_adjustments.empty? %><li>データ不足</li><% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>high riskなのにboost</h3>
        <ul class="compact-list">
          <% strategic_report.high_risk_boosted.each do |candidate| %>
            <li><%= link_to candidate.title, action_candidate_path(candidate) %></li>
          <% end %>
          <% if strategic_report.high_risk_boosted.empty? %><li>該当なし</li><% end %>
        </ul>
      </div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Practicality分析</h2>
      <p>具体的な提案ほど採用・完了・実行されているかを確認します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>平均Practicality</span><strong><%= number_with_precision(@practicality_summary.average_practicality_score, precision: 1) %></strong></div>
      <div class="metric-card"><span>Practicality30未満</span><strong><%= @practicality_summary.low_practicality_count %>件</strong></div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Practicality</th><th>採用率</th><th>完了率</th><th>実行率</th></tr>
        </thead>
        <tbody>
          <% @practicality_summary.adoption_rates.each do |rate| %>
            <% completion = @practicality_summary.completion_rates.find { |item| item.bucket == rate.bucket } %>
            <% execution = @practicality_summary.execution_rates.find { |item| item.bucket == rate.bucket } %>
            <tr>
              <td><%= rate.bucket %></td>
              <td><%= number_to_percentage(rate.rate * 100, precision: 1) %> <small><%= rate.positive_count %>/<%= rate.total_count %></small></td>
              <td><%= number_to_percentage(completion.rate * 100, precision: 1) %> <small><%= completion.positive_count %>/<%= completion.total_count %></small></td>
              <td><%= number_to_percentage(execution.rate * 100, precision: 1) %> <small><%= execution.positive_count %>/<%= execution.total_count %></small></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Evidence分析</h2>
      <p>根拠が強い提案ほど採用・完了・実行されているかを確認します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>Evidence付きCandidate率</span><strong><%= number_to_percentage(@evidence_summary.evidence_attached_rate * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>Evidence不足</span><strong><%= @evidence_summary.insufficient_evidence_count %>件</strong></div>
      <div class="metric-card"><span>平均Evidence Score</span><strong><%= number_with_precision(@evidence_summary.average_evidence_score, precision: 1) %></strong></div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Evidence</th><th>採用率</th><th>完了率</th><th>実行率</th></tr>
        </thead>
        <tbody>
          <% @evidence_summary.adoption_rates.each do |rate| %>
            <% completion = @evidence_summary.completion_rates.find { |item| item.bucket == rate.bucket } %>
            <% execution = @evidence_summary.execution_rates.find { |item| item.bucket == rate.bucket } %>
            <tr>
              <td><%= rate.bucket %></td>
              <td><%= number_to_percentage(rate.rate * 100, precision: 1) %> <small><%= rate.positive_count %>/<%= rate.total_count %></small></td>
              <td><%= number_to_percentage(completion.rate * 100, precision: 1) %> <small><%= completion.positive_count %>/<%= completion.total_count %></small></td>
              <td><%= number_to_percentage(execution.rate * 100, precision: 1) %> <small><%= execution.positive_count %>/<%= execution.total_count %></small></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Business Playbook</h2>
      <p>Business別に成功しやすいActionTypeと学習Confidenceを確認します。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>学習済Business</span><strong><%= @business_playbook_summary.learned_businesses_count %>/<%= @business_playbook_summary.total_businesses %></strong></div>
      <div class="metric-card"><span>平均Confidence</span><strong><%= number_with_precision(@business_playbook_summary.average_confidence, precision: 1) %></strong></div>
      <div class="metric-card"><span>学習不足</span><strong><%= @business_playbook_summary.low_confidence_businesses.size %>件</strong></div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Business</th><th>Top ActionType</th><th>Worst ActionType</th><th>平均ROI</th><th>平均収益</th><th>平均Practicality</th><th>平均Evidence</th><th>Confidence</th></tr>
        </thead>
        <tbody>
          <% @business_playbook_summary.top_playbooks.each do |playbook| %>
            <tr>
              <td><%= link_to playbook.business.name, playbook.business %></td>
              <td><%= playbook.top_action_type.presence || "-" %></td>
              <td><%= playbook.worst_action_type.presence || "-" %></td>
              <td><%= playbook.average_roi ? number_with_precision(playbook.average_roi, precision: 2) : "-" %></td>
              <td><%= number_to_currency(playbook.average_actual_profit_yen.to_d, unit: "¥", precision: 0) %></td>
              <td><%= number_with_precision(playbook.average_practicality_score.to_d, precision: 1) %></td>
              <td><%= number_with_precision(playbook.average_evidence_score.to_d, precision: 1) %></td>
              <td><%= number_with_precision(playbook.confidence_score, precision: 1) %></td>
            </tr>
          <% end %>
          <% if @business_playbook_summary.top_playbooks.empty? %>
            <tr><td colspan="8">Business Playbookはまだ学習不足です。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Action Types</h2>
      <p>得意な行動タイプと、外れやすい行動タイプです。</p>
    </div>
    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card">
        <h3>Strongest</h3>
        <ul class="compact-list">
          <% report.strongest_action_types.each do |summary| %>
            <li><strong><%= summary.action_type %></strong> / <%= summary.sample_count %>件 / 誤差 <%= number_to_percentage(summary.avg_error_rate * 100, precision: 1) %></li>
          <% end %>
          <% if report.strongest_action_types.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card">
        <h3>Weakest</h3>
        <ul class="compact-list">
          <% report.weakest_action_types.each do |summary| %>
            <li><strong><%= summary.action_type %></strong> / <%= summary.sample_count %>件 / 誤差 <%= number_to_percentage(summary.avg_error_rate * 100, precision: 1) %></li>
          <% end %>
          <% if report.weakest_action_types.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Discovery Source Recommendations</h2>
      <p>どの発見源を増やすべきか、見直すべきかを確認します。</p>
    </div>
    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card aicoo-card-compact">
        <h3>Strongest Sources</h3>
        <ul class="compact-list">
          <% @discovery_source_performance_report.strongest_sources.each do |source| %>
            <li><strong><%= source.source_type %></strong> / 実績 <%= number_to_currency(source.total_actual_profit, unit: "¥", precision: 0) %> / 成功率 <%= number_to_percentage(source.overall_success_rate * 100, precision: 1) %></li>
          <% end %>
          <% if @discovery_source_performance_report.strongest_sources.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>Weakest Sources</h3>
        <ul class="compact-list">
          <% @discovery_source_performance_report.weakest_sources.each do |source| %>
            <li><strong><%= source.source_type %></strong> / 実績 <%= number_to_currency(source.total_actual_profit, unit: "¥", precision: 0) %> / 成功率 <%= number_to_percentage(source.overall_success_rate * 100, precision: 1) %></li>
          <% end %>
          <% if @discovery_source_performance_report.weakest_sources.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
    </div>
    <div class="actions compact-actions">
      <%= link_to "Discovery Reportを見る", owner_discovery_report_path, class: "button secondary" %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Overestimated</h2>
      <p>予測より実績が低かった行動です。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>タイトル</th><th>予測利益</th><th>実績利益</th><th>誤差率</th></tr>
        </thead>
        <tbody>
          <% report.most_overestimated_actions.each do |item| %>
            <tr>
              <td><%= link_to item.title, action_result_path(item.action_result) %></td>
              <td><%= number_to_currency(item.predicted_profit, unit: "¥", precision: 0) %></td>
              <td><%= number_to_currency(item.actual_profit, unit: "¥", precision: 0) %></td>
              <td><%= number_to_percentage(item.error_rate * 100, precision: 1) %></td>
            </tr>
          <% end %>
          <% if report.most_overestimated_actions.empty? %>
            <tr><td colspan="4">データ不足</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Underestimated</h2>
      <p>予測より実績が高かった行動です。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>タイトル</th><th>予測利益</th><th>実績利益</th><th>誤差率</th></tr>
        </thead>
        <tbody>
          <% report.most_underestimated_actions.each do |item| %>
            <tr>
              <td><%= link_to item.title, action_result_path(item.action_result) %></td>
              <td><%= number_to_currency(item.predicted_profit, unit: "¥", precision: 0) %></td>
              <td><%= number_to_currency(item.actual_profit, unit: "¥", precision: 0) %></td>
              <td><%= number_to_percentage(item.error_rate * 100, precision: 1) %></td>
            </tr>
          <% end %>
          <% if report.most_underestimated_actions.empty? %>
            <tr><td colspan="4">データ不足</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Warnings</h2>
      <p>精度改善のために確認すべきことです。</p>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <% if report.warnings.any? %>
        <ul class="compact-list">
          <% report.warnings.each do |warning| %>
            <li><%= warning %></li>
          <% end %>
        </ul>
      <% else %>
        <p>大きな警告はありません。</p>
      <% end %>
    </div>
  </section>
</div>
