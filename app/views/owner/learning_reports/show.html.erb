<% content_for :title, "Learning Loop Quality Report" %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "学習品質レポート",
             description: "AICOOの予測がどれだけ実績に近づいているかを確認します。",
             active_main: :scoreboard %>

  <% report = @learning_loop_quality_report %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Summary</h2>
      <p>予測、実績、補正の全体状態です。</p>
    </div>
    <div class="metric-grid">
      <div class="metric-card"><span>Accuracy Score</span><strong><%= report.prediction_accuracy_score || "N/A" %></strong></div>
      <div class="metric-card"><span>Evaluated Count</span><strong><%= report.total_evaluated %>件</strong></div>
      <div class="metric-card"><span>Profit Error</span><strong><%= report.profit_error_rate ? number_to_percentage(report.profit_error_rate * 100, precision: 1) : "N/A" %></strong></div>
      <div class="metric-card"><span>Success Probability Error</span><strong><%= report.success_probability_error ? number_to_percentage(report.success_probability_error * 100, precision: 1) : "N/A" %></strong></div>
      <div class="metric-card"><span>Calibration Effectiveness</span><strong><%= report.calibration_effectiveness_score %></strong></div>
      <div class="metric-card"><span>Learning Trend</span><strong><%= report.learning_trend %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Recommendations</h2>
      <p>予測精度を上げるための次アクションです。</p>
    </div>
    <div class="aicoo-card-grid">
      <% @learning_report_recommendations.recommendations.first(5).each do |recommendation| %>
        <div class="aicoo-card aicoo-card-compact">
          <p><span class="pill"><%= recommendation.priority %></span> <%= recommendation.category %></p>
          <h3><%= recommendation.title %></h3>
          <p><%= recommendation.reason %></p>
          <p><strong>次アクション:</strong> <%= recommendation.recommended_action %></p>
          <div class="actions compact-actions">
            <% if recommendation.target_path.present? %>
              <%= link_to "対象を見る", recommendation.target_path, class: "button secondary" %>
            <% end %>
            <%= button_to "ActionCandidate化",
                          create_action_candidate_owner_learning_recommendation_path,
                          method: :post,
                          params: {
                            title: recommendation.title,
                            reason: recommendation.reason,
                            recommended_action: recommendation.recommended_action,
                            category: recommendation.category,
                            priority: recommendation.priority
                          },
                          class: "button" %>
            <%= button_to "Create Opportunity",
                          create_opportunity_owner_learning_recommendation_path,
                          method: :post,
                          params: {
                            title: recommendation.title,
                            reason: recommendation.reason,
                            recommended_action: recommendation.recommended_action,
                            category: recommendation.category,
                            priority: recommendation.priority
                          },
                          class: "button secondary" %>
          </div>
        </div>
      <% end %>
      <% if @learning_report_recommendations.recommendations.empty? %>
        <div class="aicoo-card aicoo-card-compact">
          <p>現時点で追加の改善提案はありません。</p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Action Types</h2>
      <p>得意な行動タイプと、外れやすい行動タイプです。</p>
    </div>
    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card">
        <h3>Strongest</h3>
        <ul class="compact-list">
          <% report.strongest_action_types.each do |summary| %>
            <li><strong><%= summary.action_type %></strong> / <%= summary.sample_count %>件 / 誤差 <%= number_to_percentage(summary.avg_error_rate * 100, precision: 1) %></li>
          <% end %>
          <% if report.strongest_action_types.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card">
        <h3>Weakest</h3>
        <ul class="compact-list">
          <% report.weakest_action_types.each do |summary| %>
            <li><strong><%= summary.action_type %></strong> / <%= summary.sample_count %>件 / 誤差 <%= number_to_percentage(summary.avg_error_rate * 100, precision: 1) %></li>
          <% end %>
          <% if report.weakest_action_types.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Discovery Source Recommendations</h2>
      <p>どの発見源を増やすべきか、見直すべきかを確認します。</p>
    </div>
    <div class="aicoo-grid aicoo-grid-2">
      <div class="aicoo-card aicoo-card-compact">
        <h3>Strongest Sources</h3>
        <ul class="compact-list">
          <% @discovery_source_performance_report.strongest_sources.each do |source| %>
            <li><strong><%= source.source_type %></strong> / 実績 <%= number_to_currency(source.total_actual_profit, unit: "¥", precision: 0) %> / 成功率 <%= number_to_percentage(source.overall_success_rate * 100, precision: 1) %></li>
          <% end %>
          <% if @discovery_source_performance_report.strongest_sources.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
      <div class="aicoo-card aicoo-card-compact">
        <h3>Weakest Sources</h3>
        <ul class="compact-list">
          <% @discovery_source_performance_report.weakest_sources.each do |source| %>
            <li><strong><%= source.source_type %></strong> / 実績 <%= number_to_currency(source.total_actual_profit, unit: "¥", precision: 0) %> / 成功率 <%= number_to_percentage(source.overall_success_rate * 100, precision: 1) %></li>
          <% end %>
          <% if @discovery_source_performance_report.weakest_sources.empty? %>
            <li>データ不足</li>
          <% end %>
        </ul>
      </div>
    </div>
    <div class="actions compact-actions">
      <%= link_to "Discovery Reportを見る", owner_discovery_report_path, class: "button secondary" %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Overestimated</h2>
      <p>予測より実績が低かった行動です。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>タイトル</th><th>予測利益</th><th>実績利益</th><th>誤差率</th></tr>
        </thead>
        <tbody>
          <% report.most_overestimated_actions.each do |item| %>
            <tr>
              <td><%= link_to item.title, action_result_path(item.action_result) %></td>
              <td><%= number_to_currency(item.predicted_profit, unit: "¥", precision: 0) %></td>
              <td><%= number_to_currency(item.actual_profit, unit: "¥", precision: 0) %></td>
              <td><%= number_to_percentage(item.error_rate * 100, precision: 1) %></td>
            </tr>
          <% end %>
          <% if report.most_overestimated_actions.empty? %>
            <tr><td colspan="4">データ不足</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Underestimated</h2>
      <p>予測より実績が高かった行動です。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>タイトル</th><th>予測利益</th><th>実績利益</th><th>誤差率</th></tr>
        </thead>
        <tbody>
          <% report.most_underestimated_actions.each do |item| %>
            <tr>
              <td><%= link_to item.title, action_result_path(item.action_result) %></td>
              <td><%= number_to_currency(item.predicted_profit, unit: "¥", precision: 0) %></td>
              <td><%= number_to_currency(item.actual_profit, unit: "¥", precision: 0) %></td>
              <td><%= number_to_percentage(item.error_rate * 100, precision: 1) %></td>
            </tr>
          <% end %>
          <% if report.most_underestimated_actions.empty? %>
            <tr><td colspan="4">データ不足</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Warnings</h2>
      <p>精度改善のために確認すべきことです。</p>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <% if report.warnings.any? %>
        <ul class="compact-list">
          <% report.warnings.each do |warning| %>
            <li><%= warning %></li>
          <% end %>
        </ul>
      <% else %>
        <p>大きな警告はありません。</p>
      <% end %>
    </div>
  </section>
</div>
