<% content_for :title, "オーナーモード" %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "オーナーモード",
             description: "今日やること、期待値、収益価値、学習価値だけを見る意思決定画面です。",
             active_main: :revenue %>

  <section class="dashboard-section aicoo-ceo-intro" data-ceo-intro>
    <div class="aicoo-card">
      <div class="section-heading">
        <h2>CEO MODEでは意思決定だけに集中します</h2>
        <p>今日やること、承認、事業判断だけを表示します。詳細分析・設定・運用はSYSTEM MODEから確認できます。</p>
      </div>
      <button type="button" class="button secondary" onclick="localStorage.setItem('aicoo_ceo_intro_closed', '1'); this.closest('[data-ceo-intro]').hidden = true;">次回から表示しない</button>
    </div>
    <script>
      if (localStorage.getItem("aicoo_ceo_intro_closed") === "1") {
        document.querySelector("[data-ceo-intro]").hidden = true;
      }
    </script>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Focus Home</h2>
      <p>迷ったら、次に押すべき1件だけを処理します。</p>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <% if @owner_focus_home.top_task %>
        <p><span class="pill"><%= @owner_focus_home.top_task.priority %></span> <%= @owner_focus_home.top_task.task_type_label %></p>
        <h3><%= @owner_focus_home.top_task.title %></h3>
        <p><%= @owner_focus_home.top_task.reason %></p>
      <% else %>
        <p>今すぐ処理すべきタスクはありません。</p>
      <% end %>
      <div class="actions compact-actions">
        <%= link_to "Focusで処理", owner_focus_path, class: "button" %>
        <%= link_to "すべてのタスクを見る", owner_tasks_path, class: "button secondary" %>
      </div>
    </div>
  </section>

  <%= render "shared/owner_task_inbox",
             owner_task_inbox: @owner_task_inbox,
             limit: 10 %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>今日やる分析</h2>
      <p>分析も期待値とコストで優先順位を付けます。</p>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>候補</span><strong><%= @analysis_monitor.today_count %>件</strong></div>
      <div class="metric-card"><span>Auto / Smart / Manual</span><strong><%= @analysis_monitor.auto_count %> / <%= @analysis_monitor.smart_count %> / <%= @analysis_monitor.manual_count %></strong></div>
      <div class="metric-card"><span>推定コスト</span><strong><%= number_to_currency(@analysis_monitor.estimated_cost_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>期待値</span><strong><%= number_to_currency(@analysis_monitor.expected_value_yen, unit: "¥", precision: 0) %></strong></div>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <ul class="compact-list">
        <% @analysis_monitor.top_candidates.first(5).each do |candidate| %>
          <li>
            <%= link_to "#{candidate.business.name} / #{candidate.display_name}", candidate.business %>
            / <%= candidate.execution_mode %>
            / ROI <%= candidate.roi_label %>
          </li>
        <% end %>
        <% if @analysis_monitor.top_candidates.empty? %>
          <li>今日の分析候補はまだありません。</li>
        <% end %>
      </ul>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>今日やること TOP10</h2>
      <p>モードに応じて、収益と学習のどちらを重視するかを切り替えます。</p>
    </div>

    <nav class="aicoo-sub-tabs" aria-label="オーナーモード">
      <%= link_to "バランス", owner_dashboard_path(mode: "balanced"), class: "aicoo-sub-tab#{' active' if @mode == 'balanced'}" %>
      <%= link_to "収益重視", owner_dashboard_path(mode: "revenue"), class: "aicoo-sub-tab#{' active' if @mode == 'revenue'}" %>
      <%= link_to "学習重視", owner_dashboard_path(mode: "learning"), class: "aicoo-sub-tab#{' active' if @mode == 'learning'}" %>
    </nav>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>順位</th>
            <th>タイトル</th>
            <th>事業</th>
            <th>期待値</th>
            <th>収益</th>
            <th>学習</th>
            <th>信頼度</th>
            <th>承認</th>
          </tr>
        </thead>
        <tbody>
          <% @dashboard_summary.today_tasks.each.with_index(1) do |action_candidate, index| %>
            <tr>
              <td><%= index %></td>
              <td><%= link_to action_candidate.title, action_candidate_path(action_candidate) %></td>
              <td><%= action_candidate.business.name %></td>
              <td>
                <strong><%= number_to_currency(action_candidate.final_expected_value_yen, unit: "¥", precision: 0) %></strong>
                <br>
                <small>
                  <% action_candidate.metadata.to_h.fetch("evaluator_breakdown", []).each do |entry| %>
                    <%= owner_evaluator_label(entry["evaluator_type"]) %>: <%= entry["confidence_score"].to_i %>
                  <% end %>
                </small>
              </td>
              <td>
                <%= number_to_currency(action_candidate.expected_revenue_value_yen, unit: "¥", precision: 0) %>
                <br>
                <small><%= action_candidate.revenue_ratio %>%</small>
              </td>
              <td>
                <%= number_to_currency(action_candidate.expected_learning_value_yen, unit: "¥", precision: 0) %>
                <br>
                <small><%= action_candidate.learning_ratio %>%</small>
              </td>
              <td><%= action_candidate.final_confidence_score.to_i %></td>
              <td>
                <% if action_candidate.status == "approved" %>
                  承認済み
                <% else %>
                  <%= button_to "承認", approve_action_candidate_path(action_candidate), method: :patch, class: "button" %>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @dashboard_summary.today_tasks.empty? %>
            <tr><td colspan="8">今日やる候補はまだありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @dashboard_summary.owner_fallback_tasks.any? %>
      <div class="aicoo-card">
        <h3>AICOO推奨タスク</h3>
        <p>収益候補が少ないため、予測精度や成長スコアを改善するための学習準備タスクを補完しています。</p>
        <ol>
          <% @dashboard_summary.owner_fallback_tasks.first(3).each do |task| %>
            <li>
              <strong><%= link_to task.title, action_candidate_path(task) %></strong>
              <br>
              <small><%= task.evaluation_reason.presence || task.description %></small>
            </li>
          <% end %>
        </ol>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Top Opportunities</h2>
      <p>日々の気づきから、まだActionCandidate化できる可能性です。</p>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>New</span><strong><%= @opportunity_discovery_summary.status_counts.fetch("new") %>件</strong></div>
      <div class="metric-card"><span>Reviewed</span><strong><%= @opportunity_discovery_summary.status_counts.fetch("reviewed") %>件</strong></div>
      <div class="metric-card"><span>Converted</span><strong><%= @opportunity_discovery_summary.status_counts.fetch("converted") %>件</strong></div>
      <div class="metric-card"><span>Rejected</span><strong><%= @opportunity_discovery_summary.status_counts.fetch("rejected") %>件</strong></div>
      <div class="metric-card"><span>Focus Queue</span><strong><%= @opportunity_focus_queue.total_count %>件</strong></div>
      <div class="metric-card"><span>High Priority</span><strong><%= @opportunity_focus_queue.high_priority_count %>件</strong></div>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>最優先Opportunity</h3>
      <% if @opportunity_focus_queue.top_item %>
        <p><%= link_to @opportunity_focus_queue.top_item.opportunity.title, owner_opportunity_path(@opportunity_focus_queue.top_item.opportunity) %></p>
        <p>focus score <%= @opportunity_focus_queue.top_item.focus_score.to_i %> / <%= @opportunity_focus_queue.top_item.priority %></p>
      <% else %>
        <p>レビュー待ちOpportunityはありません。</p>
      <% end %>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>新着Opportunity</h3>
      <ul class="compact-list">
        <% @opportunity_discovery_summary.unconverted_opportunities.each do |opportunity| %>
          <li><%= link_to opportunity.title, owner_opportunity_path(opportunity) %> / score <%= opportunity.opportunity_score.to_i %></li>
        <% end %>
        <% if @opportunity_discovery_summary.unconverted_opportunities.empty? %>
          <li>未変換Opportunityはありません。</li>
        <% end %>
      </ul>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Top Discovery Sources</h3>
      <ul class="compact-list">
        <% @discovery_source_performance_report.strongest_sources.first(5).each do |source| %>
          <li>
            <strong><%= source.source_type %></strong>
            / 実績 <%= number_to_currency(source.total_actual_profit, unit: "¥", precision: 0) %>
            / 成功率 <%= number_to_percentage(source.overall_success_rate * 100, precision: 1) %>
          </li>
        <% end %>
        <% if @discovery_source_performance_report.strongest_sources.empty? %>
          <li>データ不足</li>
        <% end %>
      </ul>
    </div>
    <div class="actions compact-actions">
      <%= link_to "Opportunityを追加", new_owner_opportunity_path, class: "button" %>
      <%= link_to "Opportunitiesを見る", owner_opportunities_path, class: "button secondary" %>
      <%= link_to "Focusで処理", focus_owner_opportunities_path, class: "button" %>
      <%= link_to "Discovery Reportを見る", owner_discovery_report_path, class: "button secondary" %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Top Explore Signals</h2>
      <p>外部の兆しから見つかった新しい機会です。</p>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Explore Daily Routine</h3>
      <p><span class="pill"><%= @explore_daily_routine.routine_status %></span> <%= @explore_daily_routine.import_message %></p>
      <p><%= @explore_daily_routine.recommended_next_step.reason %></p>
      <div class="actions compact-actions">
        <%= link_to @explore_daily_routine.recommended_next_step.label, @explore_daily_routine.recommended_next_step.path, class: "button" %>
      </div>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>新規観測</span><strong><%= @explore_summary.new_observation_count %>件</strong></div>
      <div class="metric-card"><span>Opportunity変換</span><strong><%= @explore_summary.converted_opportunity_count %>件</strong></div>
      <div class="metric-card"><span>新規Import</span><strong><%= @explore_summary.imported_today_count %>件</strong></div>
      <div class="metric-card"><span>Focus待ち</span><strong><%= @explore_summary.new_status_observation_count %>件</strong></div>
      <div class="metric-card"><span>高score</span><strong><%= @explore_summary.high_score_observation_count %>件</strong></div>
      <div class="metric-card"><span>高優先Opportunity</span><strong><%= @explore_daily_routine.high_priority_opportunity_count %>件</strong></div>
      <div class="metric-card"><span>Explore Opportunity pending</span><strong><%= @explore_summary.pending_opportunity_count %>件</strong></div>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <ul class="compact-list">
        <% @explore_summary.top_opportunities.each do |observation| %>
          <li><%= observation.title %> / score <%= observation.score.to_i %> / <%= observation.explore_data_source.source_type %></li>
        <% end %>
        <% if @explore_summary.top_opportunities.empty? %>
          <li>Explore Signalはまだありません。</li>
        <% end %>
      </ul>
    </div>
    <div class="actions compact-actions">
      <%= link_to "Observation Focus", admin_explore_observations_focus_path, class: "button secondary" %>
      <%= link_to "Explore Data Hubを見る", admin_explore_path, class: "button secondary" %>
      <%= link_to "ExploreをImport", admin_explore_import_path, class: "button secondary" %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>改訂待ち</h2>
      <p>承認後のCodex Prompt確認・実行待ちはAutoRevisionTaskで管理します。</p>
    </div>
    <% approval = @dashboard_summary.approval_queue %>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>行動候補</span><strong><%= approval.action_candidate_count %>件</strong></div>
      <%= link_to auto_revision_tasks_path(status: "waiting_approval"), class: "metric-card" do %>
        <span>改訂承認待ち</span><strong><%= approval.approved_remaining_count %>件</strong>
      <% end %>
      <div class="metric-card"><span>今日承認</span><strong><%= approval.today_approved_count %>件</strong></div>
      <div class="metric-card"><span>今日Codex送信待ちへ</span><strong><%= approval.today_executor_queued_count %>件</strong></div>
      <div class="metric-card"><span>AutoRevision承認待ち</span><strong><%= approval.executor_task_count %>件</strong></div>
      <div class="metric-card"><span>学習準備</span><strong><%= approval.data_preparation_count %>件</strong></div>
    </div>
    <div class="actions compact-actions">
      <%= link_to "確認タスクを見る", owner_tasks_path, class: "button secondary" %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>危険アラート</h2>
      <p>学習や収益判断が止まりそうな原因です。</p>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <% if @dashboard_summary.owner_alerts.any? %>
        <ul class="compact-list">
          <% @dashboard_summary.owner_alerts.each do |alert| %>
            <li><%= alert %></li>
          <% end %>
        </ul>
      <% else %>
        <p>重大な不足はありません。</p>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>学習状況</h2>
      <p>予測精度と成長スコアを改善するための準備状況です。</p>
    </div>
    <% progress = @dashboard_summary.learning_progress %>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>AICOO成熟度</span><strong><%= @dashboard_summary.aicoo_maturity_score %>/100</strong><small><%= @dashboard_summary.aicoo_maturity_label %></small></div>
      <div class="metric-card"><span>実行結果</span><strong><%= progress.action_result_current %>/<%= progress.action_result_required %>件</strong></div>
      <div class="metric-card"><span>予測補正</span><strong><%= progress.judge_status %></strong><small><%= progress.evaluated_current %>/<%= progress.evaluated_required %>件 評価済み</small></div>
      <div class="metric-card"><span>日次指標</span><strong><%= progress.business_metric_current %>/<%= progress.business_metric_required %>日</strong></div>
      <div class="metric-card"><span>売上記録</span><strong><%= progress.revenue_event_current %>/<%= progress.revenue_event_required %>件</strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>予測精度</h2>
      <p>AICOOの提案が実績に近づいているかを確認します。</p>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>Accuracy Score</span><strong><%= @learning_loop_quality_report.prediction_accuracy_score || "N/A" %></strong></div>
      <div class="metric-card"><span>今週改善</span><strong><%= @learning_loop_quality_report.learning_trend %></strong></div>
      <div class="metric-card"><span>得意</span><strong><%= @learning_loop_quality_report.strongest_action_types.first&.action_type || "データ不足" %></strong></div>
      <div class="metric-card"><span>苦手</span><strong><%= @learning_loop_quality_report.weakest_action_types.first&.action_type || "データ不足" %></strong></div>
    </div>
    <% if @learning_loop_quality_report.warnings.any? %>
      <div class="aicoo-card aicoo-card-compact">
        <ul class="compact-list">
          <% @learning_loop_quality_report.warnings.first(3).each do |warning| %>
            <li><%= warning %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <% if @learning_report_recommendations.recommendations.first %>
      <% recommendation = @learning_report_recommendations.recommendations.first %>
      <div class="aicoo-card aicoo-card-compact">
        <p><span class="pill"><%= recommendation.priority %></span> 改善提案</p>
        <strong><%= recommendation.title %></strong>
        <p><%= recommendation.recommended_action %></p>
      </div>
    <% end %>
    <div class="actions compact-actions">
      <%= link_to "学習品質レポートを見る", owner_learning_report_path, class: "button secondary" %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>今日の数字</h2>
      <p>経営判断に必要な数字だけを表示します。</p>
    </div>
    <% metrics = @dashboard_summary.owner_metrics %>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>売上</span><strong><%= number_to_currency(metrics.revenue_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>利益</span><strong><%= number_to_currency(metrics.profit_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>成長スコア</span><strong><%= number_with_precision(metrics.proxy_score, precision: 1) %></strong></div>
      <div class="metric-card"><span>新規候補数</span><strong><%= metrics.new_candidate_count %>件</strong></div>
      <div class="metric-card"><span>評価完了数</span><strong><%= metrics.evaluated_count %>件</strong></div>
      <div class="metric-card"><span>LP公開数</span><strong><%= metrics.published_lp_count %>件</strong></div>
      <div class="metric-card"><span>日次処理</span><strong><%= metrics.daily_run_status %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>事業ランキング</h2>
      <p>事業別に、収益価値と学習価値を合算して見ます。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>事業</th>
            <th>総期待値</th>
            <th>収益価値</th>
            <th>学習価値</th>
          </tr>
        </thead>
        <tbody>
          <% @dashboard_summary.business_rankings.each do |ranking| %>
            <tr>
              <td><%= ranking.business.name %></td>
              <td><%= number_to_currency(ranking.expected_total_value_yen, unit: "¥", precision: 0) %></td>
              <td><%= number_to_currency(ranking.expected_revenue_value_yen, unit: "¥", precision: 0) %></td>
              <td><%= number_to_currency(ranking.expected_learning_value_yen, unit: "¥", precision: 0) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>判断材料の推移</h2>
      <p>検索流入・サイト行動・予測精度・売上記録・学習準備のうち、今どれを信じているかを表示します。</p>
    </div>
    <div class="actions compact-actions">
      <%= link_to "詳しく見る", owner_evaluator_trends_path, class: "button secondary" %>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <% @dashboard_summary.evaluator_confidence_summary.each do |entry| %>
        <div class="metric-card aicoo-card-compact">
          <span><%= owner_evaluator_label(entry.evaluator_type) %></span>
          <strong>信頼度 <%= entry.confidence_score %></strong>
          <small>判断への影響 <%= number_with_precision(entry.weighted_contribution_score, precision: 1) %></small>
          <small>前回比 <%= entry.confidence_delta.nil? ? "-" : "%+d" % entry.confidence_delta %></small>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="aicoo-card">
      <% learning = @dashboard_summary.learning_value_summary %>
      <h2>学習価値</h2>
      <p>AICOO自身の予測精度を上げる行動を円換算した値です。</p>
      <div class="metric-grid">
        <div class="metric-card"><span>学習価値合計</span><strong><%= number_to_currency(learning.total_learning_value_yen, unit: "¥", precision: 0) %></strong></div>
        <div class="metric-card"><span>学習候補数</span><strong><%= learning.learning_candidate_count %>件</strong></div>
      </div>
      <div class="actions compact-actions">
        <%= link_to "詳細を見る", dashboard_path, class: "button secondary" %>
      </div>
    </div>
  </section>
</div>
