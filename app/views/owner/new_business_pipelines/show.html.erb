<% content_for :title, "新規事業作成" %>

<section class="page-header">
  <div>
    <p class="eyebrow">CEO MODE</p>
    <h1>新規事業作成</h1>
    <p class="muted">品質不足の候補だけを編集し、Business化、LPまたはSaaS叩き台作成へ進めます。品質十分な候補は自動で事業化されます。</p>
  </div>
  <div class="button-row">
    <%= link_to "Owner Home", owner_focus_path, class: "button secondary" %>
  </div>
</section>

<% if @board.next_action %>
  <section class="panel">
    <p class="eyebrow">次に押すボタン</p>
    <h2><%= @board.next_action.next_action_label %></h2>
    <p><%= @board.next_action.next_action_reason %></p>
    <% if @board.next_action.next_action_path.present? %>
      <%= button_to @board.next_action.next_action_label,
                    @board.next_action.next_action_path,
                    method: @board.next_action.next_action_method,
                    class: "button primary" %>
    <% else %>
      <a href="#selected-candidate" class="button primary"><%= @board.next_action.next_action_label %></a>
    <% end %>
  </section>
<% end %>

<section class="metrics-grid">
  <div class="metric-card"><span>SERP由来候補</span><strong><%= @board.summary.serp_count %></strong></div>
  <div class="metric-card"><span>総合判断候補</span><strong><%= @board.summary.integrated_decision_count %></strong></div>
  <div class="metric-card"><span>Business作成待ち</span><strong><%= @board.summary.pending_count %></strong></div>
  <div class="metric-card"><span>自動Business化済み</span><strong><%= @board.summary.business_created_count %></strong></div>
  <div class="metric-card"><span>LP作成待ち</span><strong><%= @board.summary.lp_waiting_count %></strong></div>
  <div class="metric-card"><span>LP公開済み</span><strong><%= @board.summary.lp_published_count %></strong></div>
  <div class="metric-card"><span>検証中</span><strong><%= @board.summary.validating_count %></strong></div>
  <div class="metric-card"><span>撤退候補</span><strong><%= @board.summary.withdrawal_candidate_count %></strong></div>
</section>

<nav class="tab-nav" aria-label="新規事業候補タブ">
  <%= link_to "要編集の候補",
              owner_new_business_pipeline_path(tab: "needs_edit"),
              class: "tab-nav__item #{'is-active' if @board.active_tab == 'needs_edit'}" %>
  <%= link_to "事業化済み",
              owner_new_business_pipeline_path(tab: "businessized"),
              class: "tab-nav__item #{'is-active' if @board.active_tab == 'businessized'}" %>
</nav>

<div class="two-column-layout">
  <section class="panel">
    <h2><%= @board.active_tab == "businessized" ? "事業化済み" : "要編集の候補" %></h2>
    <div class="stack-list">
      <% @board.rows.each_with_index do |row, index| %>
        <article class="task-card <%= "is-selected" if row == @board.selected %>">
          <div class="task-card__head">
            <div>
              <p class="eyebrow">#<%= index + 1 %> <%= row.action_candidate.generation_source %></p>
              <h3><%= link_to row.title, owner_new_business_pipeline_path(selected_id: row.action_candidate.id, anchor: "selected-candidate") %></h3>
            </div>
            <span class="pill"><%= row.current_state %></span>
          </div>
          <div class="progress-line" aria-label="<%= row.progress_label %> <%= row.progress_percent %>%">
            <span style="width: <%= row.progress_percent %>%"></span>
          </div>
          <dl class="compact-definition">
            <dt>期待利益</dt><dd>¥<%= number_with_delimiter(row.expected_profit_yen) %></dd>
            <dt>期待時給</dt><dd>¥<%= number_with_delimiter(row.expected_hourly_value_yen) %></dd>
            <dt>止まっている理由</dt><dd><%= row.stuck_reason %></dd>
          </dl>
          <p class="muted"><%= truncate(row.problem, length: 90) %></p>
          <div class="button-row">
            <% if row.next_action_path.present? %>
              <%= button_to row.next_action_label, row.next_action_path, method: row.next_action_method, class: "button small" %>
            <% else %>
              <%= link_to row.next_action_label, owner_new_business_pipeline_path(selected_id: row.action_candidate.id, anchor: "selected-candidate"), class: "button small" %>
            <% end %>
          </div>
        </article>
      <% end %>
      <% if @board.rows.empty? %>
        <p>新規事業候補はありません。</p>
        <% @board.zero_reasons.each do |reason| %>
          <p class="muted"><%= reason %></p>
        <% end %>
      <% end %>
    </div>
  </section>

  <section class="panel" id="selected-candidate">
    <h2>選択中候補</h2>
    <% if (row = @board.selected) %>
      <p class="eyebrow"><%= row.current_state %> / <%= row.progress_label %> <%= row.progress_percent %>%</p>
      <h3><%= row.title %></h3>
      <p><strong>止まっている理由:</strong> <%= row.stuck_reason %></p>
      <p><strong>品質判定:</strong> <%= row.quality_status == "auto_publishable" ? "Business化できます" : "編集が必要" %></p>
      <% if row.quality_reasons.any? %>
        <ul class="compact-list">
          <% row.quality_reasons.each do |reason| %>
            <li><%= reason %></li>
          <% end %>
        </ul>
      <% end %>
      <div class="progress-line"><span style="width: <%= row.progress_percent %>%"></span></div>

      <div class="button-row">
        <% if row.next_action_path.present? && row.quality_status == "auto_publishable" %>
          <%= button_to row.next_action_label, row.next_action_path, method: row.next_action_method, class: "button primary" %>
        <% end %>
        <% if row.action_candidate.status.in?(%w[idea pending]) %>
          <%= button_to "却下", reject_owner_new_business_pipeline_candidate_path(row.action_candidate), method: :patch, class: "button danger" %>
        <% end %>
      </div>

      <details open>
        <summary>候補詳細</summary>
        <dl class="definition-list">
          <dt>Business化</dt><dd><%= row.business ? "作成済み: #{row.business.name}" : "未作成" %></dd>
          <dt>解決する課題</dt><dd><%= row.problem %></dd>
          <dt>想定顧客</dt><dd><%= row.target_customer %></dd>
          <dt>収益モデル</dt><dd><%= row.revenue_model %></dd>
          <dt>LP案</dt><dd><%= row.lp_idea %></dd>
          <dt>作成するもの</dt><dd><%= row.launch_asset_type == "saas" ? "SaaS仕様書" : "LP叩き台" %></dd>
          <dt>検証方法</dt><dd><%= row.validation_method %></dd>
          <dt>SERP根拠</dt><dd><%= row.serp_evidence %></dd>
          <dt>競合</dt><dd><%= row.competitors.any? ? row.competitors.join(" / ") : "未整理" %></dd>
          <dt>初期コスト</dt><dd>¥<%= number_with_delimiter(row.initial_cost_yen) %></dd>
          <dt>想定作業時間</dt><dd><%= row.expected_hours %>h</dd>
          <dt>成功条件</dt><dd><%= row.success_condition %></dd>
          <dt>撤退条件</dt><dd><%= row.rejection_condition %></dd>
        </dl>
      </details>

      <details open>
        <summary>候補を編集</summary>
        <% metadata = row.action_candidate.metadata.to_h %>
        <%= form_with url: update_owner_new_business_pipeline_candidate_path(row.action_candidate), method: :patch, scope: :action_candidate, local: true do |form| %>
          <div class="form-grid">
            <label>事業名 <%= form.text_field :business_name, value: metadata["business_name"].presence || row.title %></label>
            <label>顧客 <%= form.text_field :target_customer, value: metadata["target_customer"].presence || row.target_customer %></label>
            <label>課題 <%= form.text_area :problem, rows: 2, value: metadata["problem"].presence || row.problem %></label>
            <label>提供サービス <%= form.text_field :offering, value: metadata["offering"].presence || metadata["solution"] %></label>
            <label>提供価値 <%= form.text_area :value_proposition, rows: 2, value: metadata["value_proposition"].presence || metadata["differentiation"] %></label>
            <label>収益モデル <%= form.text_area :revenue_model, rows: 2, value: metadata["revenue_model"].presence || row.revenue_model %></label>
            <label>検証方法 <%= form.text_area :validation_method, rows: 2, value: metadata["validation_method"].presence || row.validation_method %></label>
            <label>市場 <%= form.text_field :market, value: metadata["market"] %></label>
            <label>カテゴリ <%= form.text_field :market_category, value: metadata["market_category"] %></label>
            <label>地域 <%= form.text_field :region, value: metadata["region"] %></label>
            <label>作成する叩き台
              <%= form.select :launch_asset_type,
                              options_for_select([["LP", "lp"], ["SaaS仕様書", "saas"]], row.launch_asset_type) %>
            </label>
          </div>
          <div class="button-row">
            <%= form.submit "候補を保存", class: "button" %>
          </div>
        <% end %>
        <% if row.quality_status == "auto_publishable" %>
          <%= button_to "Business作成", approve_owner_new_business_pipeline_candidate_path(row.action_candidate), method: :patch, class: "button primary" %>
        <% end %>
      </details>

      <details open>
        <summary>LP作成 / 公開 / 編集</summary>
        <% if row.business.blank? %>
          <p>Business化すると、LPまたはSaaS叩き台を自動作成します。</p>
        <% elsif row.landing_page.blank? %>
          <p>LP叩き台は未作成です。既存LP作成基盤で公開前の検証LPを作成します。</p>
          <%= button_to "LP作成", create_lp_owner_new_business_pipeline_candidate_path(row.action_candidate), method: :post, class: "button primary" %>
        <% else %>
          <p class="notice">
            LP: <%= row.landing_page.public_headline %>
            / 状態: <%= row.landing_page.public_status %>
            <% if row.public_lp_path %>
              / 公開URL: <%= row.public_lp_path %>
            <% end %>
          </p>
          <% unless row.landing_page.publicly_visible? %>
            <%= button_to "LP公開", publish_owner_new_business_pipeline_landing_page_path(row.landing_page), method: :patch, class: "button primary" %>
          <% end %>

          <%= form_with url: update_owner_new_business_pipeline_landing_page_path(row.landing_page), method: :patch, scope: :aicoo_lab_landing_page, local: true do |form| %>
            <div class="form-grid">
              <label>タイトル <%= form.text_field :headline, value: row.landing_page.headline %></label>
              <label>サブコピー <%= form.text_field :subheadline, value: row.landing_page.subheadline %></label>
              <label>SEO title <%= form.text_field :seo_title, value: row.landing_page.seo_title %></label>
              <label>meta description <%= form.text_area :seo_description, rows: 2, value: row.landing_page.seo_description %></label>
              <label>slug <%= form.text_field :published_slug, value: row.landing_page.published_slug %></label>
              <label>CTA <%= form.text_field :cta_text, value: row.landing_page.cta_text %></label>
              <label>本文 <%= form.text_area :body, rows: 8, value: row.landing_page.body %></label>
            </div>
            <%= form.submit "LP内容を保存", class: "button" %>
          <% end %>
        <% end %>
      </details>

      <details open>
        <summary>検証 / Learning</summary>
        <% if row.landing_page&.publicly_visible? %>
          <dl class="definition-list">
            <dt>公開日</dt><dd><%= l(row.landing_page.published_at, format: :short) if row.landing_page.published_at %></dd>
            <dt>PV</dt><dd><%= row.landing_page.view_count %></dd>
            <dt>CTAクリック</dt><dd><%= row.landing_page.cta_click_count %></dd>
            <dt>CV</dt><dd><%= row.landing_page.signup_count %></dd>
            <dt>次の評価</dt><dd>7日 / 14日 / 30日で継続・改善・撤退を判断</dd>
          </dl>
        <% else %>
          <p>LP公開後に計測とLearningの状態を表示します。</p>
        <% end %>
      </details>
    <% else %>
      <p>選択中候補はありません。</p>
    <% end %>
  </section>
</div>
