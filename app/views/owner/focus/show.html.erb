<% content_for :title, "Today" %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "Today",
             description: @today_board.description,
             active_main: :revenue %>

  <nav class="aicoo-sub-tabs" aria-label="Today ranking mode">
    <% @today_board.tabs.each do |tab| %>
      <%= link_to tab.label,
                  tab.path,
                  class: "aicoo-sub-tab#{' active' if tab.active}",
                  aria: (tab.active ? { current: "page" } : nil) %>
    <% end %>
  </nav>

  <%= render "shared/today_action_board", today_board: @today_board %>
</div>
