<% content_for :title, "今日の事業改善" %>

<% header_actions = capture do %>
  <%= link_to "事業一覧", businesses_path, class: "button secondary" %>
  <%= link_to "実行履歴", admin_execution_runs_path, class: "button secondary" %>
  <%= link_to "SYSTEM MODE", dashboard_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "今日の事業改善",
             description: "今日どの事業を改善すると一番利益が増えるかだけを判断します。",
             active_main: :revenue,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>今日おすすめの事業改善 TOP10</h2>
        <p>Business改善だけを、期待利益・ROI・成功率・必要時間・学習価値の順で並べています。</p>
      </div>
      <%= link_to "すべての改善候補", action_candidates_path, class: "button secondary" %>
    </div>

    <% if @ceo_improvement_board.improvements.any? %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>順位</th>
              <th>Business</th>
              <th>改善</th>
              <th>カテゴリ</th>
              <th>期待利益</th>
              <th>成功率</th>
              <th>時間</th>
              <th>学習価値</th>
              <th>生成元</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @ceo_improvement_board.improvements.each do |item| %>
              <tr>
                <td><span class="pill">#<%= item.rank %></span></td>
                <td><%= link_to item.business.name, item.business %></td>
                <td class="wide-text">
                  <strong><%= item.title %></strong>
                  <ul class="compact-list">
                    <% item.reason_lines.first(3).each do |line| %>
                      <li><%= line %></li>
                    <% end %>
                  </ul>
                </td>
                <td><span class="pill"><%= item.category %></span></td>
                <td class="number"><%= number_to_currency(item.expected_profit_yen, unit: "¥", precision: 0) %></td>
                <td class="number"><%= number_to_percentage(item.success_probability * 100, precision: 0) %></td>
                <td class="number"><%= item.required_minutes.positive? ? "#{item.required_minutes}分" : "-" %></td>
                <td class="number"><%= item.learning_value_yen.positive? ? number_to_currency(item.learning_value_yen, unit: "¥", precision: 0) : "-" %></td>
                <td><%= item.source_label %></td>
                <td class="actions compact-actions">
                  <%= link_to "詳細", item.detail_path, class: "button secondary" %>
                  <% if item.codex_method == :post %>
                    <%= button_to "Codex用プロンプト作成", item.codex_path, method: :post, class: "button secondary" %>
                  <% else %>
                    <%= link_to "Codex用プロンプト確認", item.codex_path, class: "button secondary" %>
                  <% end %>
                  <%= button_to "後で", item.defer_path, method: :patch, class: "button secondary" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="aicoo-card aicoo-empty-state">
        <h2>今日すぐ改善すべきBusiness候補はありません。</h2>
        <p>ActionCandidateやAutoRevisionTaskが作成されると、期待利益順にここへ表示されます。</p>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>新規事業候補</h2>
        <p>今すぐLP検証に進める候補だけを表示します。詳細分析は総合判断で確認します。</p>
      </div>
      <%= link_to "総合判断を見る", admin_integrated_decision_path, class: "button secondary" %>
    </div>

    <% if @new_business_candidate_board.candidates.any? %>
      <div class="aicoo-card-grid">
        <% @new_business_candidate_board.candidates.first(3).each do |row| %>
          <div class="aicoo-card">
            <p><span class="pill">#<%= row.rank %></span> <span class="pill"><%= row.status %></span></p>
            <h2><%= row.title %></h2>
            <p><%= row.reason %></p>
            <dl class="aicoo-definition-list">
              <dt>なぜ今やるべきか</dt>
              <dd><%= row.market_memo %></dd>
              <dt>最初の一手</dt>
              <dd><%= row.validation_step %></dd>
              <dt>根拠検索クエリ</dt>
              <dd><%= row.source_query %></dd>
            </dl>
            <div class="metric-grid aicoo-owner-secondary">
              <div class="metric-card"><span>期待利益</span><strong><%= number_to_currency(row.expected_profit_yen, unit: "¥", precision: 0) %></strong></div>
              <div class="metric-card"><span>必要作業時間</span><strong><%= row.expected_hours.positive? ? "#{row.expected_hours.to_f.round(1)}h" : "-" %></strong></div>
            </div>
            <%= render "shared/new_business_candidate_actions", row: row %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="aicoo-card aicoo-empty-state">
        <h3>今すぐ検証すべき新規事業候補はありません。</h3>
        <ul class="compact-list">
          <% @new_business_candidate_board.zero_reasons.each do |reason| %>
            <li><%= reason %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>Businessカード</h2>
        <p>事業ごとの今日の期待利益、Attention Score、改善候補数を一覧します。</p>
      </div>
      <%= link_to "Business一覧", businesses_path, class: "button secondary" %>
    </div>
    <div class="aicoo-card-grid">
      <% @ceo_improvement_board.business_cards.each do |row| %>
        <div class="aicoo-card">
          <p><span class="pill"><%= row.state_label %></span></p>
          <h2><%= row.business.name %></h2>
          <div class="metric-grid aicoo-owner-secondary">
            <div class="metric-card"><span>今日の期待利益</span><strong><%= number_to_currency(row.expected_profit_yen, unit: "¥", precision: 0) %></strong></div>
            <div class="metric-card"><span>Attention</span><strong><%= row.attention_score %></strong></div>
            <div class="metric-card"><span>ROI</span><strong><%= number_with_precision(row.roi, precision: 0) %></strong></div>
            <div class="metric-card"><span>おすすめ改善</span><strong><%= row.recommended_count %>件</strong></div>
            <div class="metric-card"><span>ActionCandidate</span><strong><%= row.action_candidate_count %>件</strong></div>
            <div class="metric-card"><span>AutoRevision</span><strong><%= row.auto_revision_task_count %>件</strong></div>
          </div>
          <p class="muted">最終改善: <%= row.last_improved_at ? l(row.last_improved_at, format: :short) : "未登録" %></p>
          <div class="actions compact-actions">
            <%= link_to "Business詳細", row.detail_path, class: "button secondary" %>
            <%= link_to "改善一覧", row.improvements_path, class: "button secondary" %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <% if @ceo_improvement_board.critical_business_blockers.any? %>
    <section class="dashboard-section danger">
      <div class="section-heading">
        <div>
          <h2>Business改善を止める重大障害</h2>
          <p>Google認証切れなど、改善判断そのものを止める障害だけ表示します。詳細復旧はSYSTEM MODEで行います。</p>
        </div>
        <%= link_to "SYSTEM MODE", dashboard_path, class: "button secondary" %>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Business</th>
              <th>内容</th>
              <th>次にやること</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @ceo_improvement_board.critical_business_blockers.each do |blocker| %>
              <tr>
                <td><%= blocker.business.name %></td>
                <td><%= blocker.title %></td>
                <td><%= blocker.message %></td>
                <td><%= link_to "確認", blocker.path, class: "button secondary" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>運用・実行管理</h2>
        <p>改修キュー、Codex送信、AI Resource、Daily Runなどは必要な時だけ開いて確認します。</p>
      </div>
      <%= link_to "SYSTEM MODE", dashboard_path, class: "button secondary" %>
    </div>

    <div class="aicoo-card <%= 'danger' if @traffic_channel_summary.health == 'Broken' %>">
      <div class="section-heading">
        <div>
          <h3>Traffic Channel</h3>
          <p>集客チャネル全体の要約です。詳細な設定・比較はTraffic Channel Centerで確認します。</p>
        </div>
        <span class="pill"><%= @traffic_channel_summary.health %></span>
      </div>
      <div class="metric-grid aicoo-owner-secondary">
        <div class="metric-card"><span>止まっているチャネル</span><strong><%= @traffic_channel_summary.stopped_channel_count %>件</strong></div>
        <div class="metric-card"><span>最も成果が良い</span><strong><%= @traffic_channel_summary.best_channel&.label || "未計測" %></strong></div>
        <div class="metric-card"><span>最も成果が悪い</span><strong><%= @traffic_channel_summary.worst_channel&.label || "未計測" %></strong></div>
        <div class="metric-card"><span>Traffic由来改善提案</span><strong><%= @traffic_channel_summary.today_traffic_action_candidate_count %>件</strong></div>
      </div>
      <div class="actions compact-actions">
        <%= link_to "Traffic Channel Center", admin_traffic_channels_path, class: "button secondary" %>
      </div>
    </div>

    <div class="aicoo-card <%= 'danger' if @serp_summary.health == 'Broken' %>">
      <div class="section-heading">
        <div>
          <h3>SERP</h3>
          <% if @serp_summary.health == "Healthy" %>
            <p>SERPは正常です。</p>
          <% else %>
            <p>今日確認すべきSERP項目があります。詳細はSERP運用センターで確認してください。</p>
          <% end %>
        </div>
        <span class="pill"><%= @serp_summary.health %></span>
      </div>

      <% if @serp_summary.pending_keyword_count.positive? || @serp_summary.failed_business_count.positive? || @serp_summary.stopped_business_count.positive? %>
        <ul class="compact-list">
          <% if @serp_summary.pending_keyword_count.positive? %>
            <li>承認待ち検索クエリが<%= @serp_summary.pending_keyword_count %>件あります。</li>
          <% end %>
          <% if @serp_summary.failed_business_count.positive? %>
            <li>SERP取得に失敗したBusinessが<%= @serp_summary.failed_business_count %>件あります。</li>
          <% end %>
          <% if @serp_summary.stopped_business_count.positive? %>
            <li>SERPが止まっているBusinessが<%= @serp_summary.stopped_business_count %>件あります。</li>
          <% end %>
        </ul>
      <% end %>

      <div class="metric-grid aicoo-owner-secondary">
        <div class="metric-card"><span>止まっているBusiness</span><strong><%= @serp_summary.stopped_business_count %>件</strong></div>
        <div class="metric-card"><span>Scheduler</span><strong><%= @serp_summary.scheduler_enabled ? "ON" : "OFF" %></strong></div>
        <div class="metric-card"><span>承認待ち検索クエリ</span><strong><%= @serp_summary.pending_keyword_count %>件</strong></div>
        <div class="metric-card"><span>今日実行Query</span><strong><%= @serp_summary.today_query_count %>件</strong></div>
        <div class="metric-card"><span>成功Query</span><strong><%= @serp_summary.today_success_query_count %>件</strong></div>
        <div class="metric-card"><span>失敗Query</span><strong><%= @serp_summary.today_failed_query_count %>件</strong></div>
        <div class="metric-card"><span>SERP由来改善提案</span><strong><%= @serp_summary.today_serp_action_candidate_count %>件</strong></div>
        <div class="metric-card"><span>取得失敗Business</span><strong><%= @serp_summary.failed_business_count %>件</strong></div>
        <div class="metric-card"><span>最優先Business</span><strong><%= @serp_summary.top_priority_business&.name || "未設定" %></strong></div>
        <div class="metric-card"><span>最終SERP実行</span><strong><%= @serp_summary.last_executed_at ? l(@serp_summary.last_executed_at, format: :short) : "未実行" %></strong></div>
        <div class="metric-card"><span>次回予定</span><strong><%= @serp_summary.next_scheduled_at ? l(@serp_summary.next_scheduled_at, format: :short) : "未設定" %></strong></div>
      </div>

      <% if @serp_summary.today_serp_action_candidate_count.positive? %>
        <p class="muted">今日SERPから<%= @serp_summary.today_serp_action_candidate_count %>件の改善提案が生成されています。</p>
      <% end %>

      <div class="actions compact-actions">
        <%= button_to "今すぐSERP実行", run_now_admin_serp_settings_path, method: :post, class: "button secondary" %>
        <%= link_to "SERP設定", admin_serp_settings_path, class: "button secondary" %>
        <%= link_to "SERP E2E診断", admin_serp_e2e_check_path, class: "button secondary" %>
        <%= link_to "総合判断を見る", admin_integrated_decision_path, class: "button secondary" %>
      </div>
    </div>

    <details class="aicoo-card">
      <summary><strong>改修・Codex管理</strong> <span class="muted">承認待ち改修、Codex手動送信待ち、PR/deploy前の作業単位</span></summary>
      <div class="metric-grid aicoo-owner-secondary">
        <div class="metric-card"><span>Codex送信待ち</span><strong><%= @codex_submission_summary&.ready_count.to_i %>件</strong></div>
        <div class="metric-card"><span>承認待ち改修</span><strong><%= @auto_revision_execution_summary&.waiting_approval_count.to_i %>件</strong></div>
        <div class="metric-card"><span>PR待ち</span><strong><%= @auto_revision_execution_summary&.pr_review_waiting_count.to_i %>件</strong></div>
      </div>
      <div class="actions compact-actions">
        <%= link_to "Codex送信待ちを見る", admin_aicoo_executor_path(codex_filter: "waiting"), class: "button" %>
        <%= link_to "Codex手動送信一覧", admin_codex_submissions_path(status: "ready"), class: "button secondary" %>
      </div>
      <%= render "shared/auto_revision_execution_summary", summary: @auto_revision_execution_summary %>
      <%= render "shared/codex_submission_summary", summary: @codex_submission_summary %>
    </details>

    <details class="aicoo-card">
      <summary><strong>AI Resource / Auto Build</strong> <span class="muted">Build Queue、AI予算、Auto Build状況</span></summary>
      <%= render "shared/resource_aware_auto_build_summary", summary: @auto_build_summary, show_learning_rank: false %>
    </details>

    <details class="aicoo-card">
      <summary><strong>システム状態</strong> <span class="muted">Daily Run Health、Cron Health、Google警告</span></summary>
      <%= render "shared/daily_run_health_summary", summary: @cron_health_summary %>
    </details>

    <details class="aicoo-card">
      <summary><strong>学習・履歴</strong> <span class="muted">Learning詳細、実行履歴、SYSTEM MODEへの導線</span></summary>
      <div class="actions compact-actions">
        <%= link_to "実行履歴を見る", admin_execution_runs_path, class: "button secondary" %>
        <%= link_to "SYSTEM MODEで確認", dashboard_path, class: "button secondary" %>
      </div>
    </details>
  </section>
</div>
