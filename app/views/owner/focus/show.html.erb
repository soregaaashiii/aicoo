<% content_for :title, "今日やること" %>

<% header_actions = capture do %>
  <%= link_to "全タスク", owner_tasks_path, class: "button secondary" %>
  <%= link_to "運用状態", dashboard_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "今日やること",
             description: "5秒で分かる作業指示だけを表示します。",
             active_main: :revenue,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>次にやる1件</h2>
      <p><%= @owner_home_summary.summary_message %></p>
    </div>

    <% if @top_task %>
      <% task = @top_task %>
      <div class="aicoo-card">
        <h2><%= @ceo_summary.title %></h2>
        <div class="aicoo-grid aicoo-grid-2">
          <div class="aicoo-card aicoo-card-compact">
            <h3>なぜやるか</h3>
            <ul class="compact-list">
              <% @ceo_summary.reason_lines.first(5).each do |line| %>
                <li><%= line %></li>
              <% end %>
            </ul>
          </div>
          <div class="aicoo-card aicoo-card-compact">
            <h3>何をするか</h3>
            <ul class="compact-list">
              <% @ceo_summary.work_lines.first(5).each do |line| %>
                <li><%= line %></li>
              <% end %>
            </ul>
          </div>
        </div>
        <div class="metric-grid aicoo-owner-secondary">
          <div class="metric-card"><span>期待利益</span><strong><%= @ceo_summary.expected_profit_yen ? number_to_currency(@ceo_summary.expected_profit_yen, unit: "¥", precision: 0) : "-" %></strong></div>
          <div class="metric-card"><span>期待費用対効果</span><strong><%= @ceo_summary.roi.present? ? number_with_precision(@ceo_summary.roi, precision: 2) : "-" %></strong></div>
          <div class="metric-card"><span>成功率</span><strong><%= @ceo_summary.success_probability.present? ? number_to_percentage(@ceo_summary.success_probability.to_d * 100, precision: 1) : "-" %></strong></div>
          <div class="metric-card"><span>所要時間</span><strong><%= @ceo_summary.total_minutes.positive? ? "#{@ceo_summary.total_minutes}分" : "-" %></strong></div>
        </div>
        <% if @ceo_summary.time_lines.any? || @ceo_summary.completion_criteria.any? %>
          <div class="aicoo-grid aicoo-grid-2">
            <div class="aicoo-card aicoo-card-compact">
              <h3>時間の目安</h3>
              <ul class="compact-list">
                <% @ceo_summary.time_lines.first(6).each do |line| %>
                  <li><%= line %></li>
                <% end %>
              </ul>
            </div>
            <div class="aicoo-card aicoo-card-compact">
              <h3>完了条件</h3>
              <ul class="compact-list">
                <% @ceo_summary.completion_criteria.first(5).each do |criterion| %>
                  <li><%= criterion %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>
        <% if @opportunity_focus_item %>
          <% opportunity = @opportunity_focus_item.opportunity %>
          <div class="actions compact-actions">
            <%= button_to "実行する", focus_convert_to_candidate_owner_opportunity_path(opportunity), method: :post, class: "button" %>
            <%= link_to "詳細を見る", @top_task_detail_path, class: "button secondary" %>
            <%= button_to "後でやる", focus_review_owner_opportunity_path(opportunity), method: :patch, class: "button secondary" %>
          </div>
        <% else %>
          <div class="actions compact-actions">
            <% primary_action = task.quick_actions.find { |action| action.method.to_s != "get" && action.style != "danger" } %>
            <% if primary_action %>
              <% data = primary_action.confirm_message.present? ? { turbo_confirm: primary_action.confirm_message } : {} %>
              <%= button_to "実行する", primary_action.path, method: primary_action.method, class: "button", data: %>
            <% elsif @top_task_action_candidate %>
              <%= button_to "実行する", generate_codex_prompt_draft_action_candidate_path(@top_task_action_candidate), method: :post, class: "button" %>
            <% end %>
            <%= link_to "詳細を見る", @top_task_detail_path || task.target_path, class: "button secondary" %>
            <%= link_to "後でやる", owner_tasks_path, class: "button secondary" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="aicoo-card aicoo-empty-state">
        <% if @owner_execution_queue_summary.top_item %>
          <% queue_item = @owner_execution_queue_summary.top_item %>
          <h2><%= queue_item.title %></h2>
          <p><%= queue_item.reason %></p>
          <div class="actions compact-actions">
            <%= link_to "詳細を見る", queue_item.target_path, class: "button secondary" %>
            <%= button_to "後でやる", skip_owner_execution_queue_item_path(queue_item), method: :patch, class: "button secondary" %>
          </div>
        <% else %>
          <h2>今すぐ処理すべきタスクはありません。</h2>
          <p>実行・結果登録・承認・異常対応が必要になるとここに出ます。</p>
        <% end %>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>追加で確認すること</h2>
      <p>必要な分析だけを選びます。作業の主役は上の1件です。</p>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>確認候補</span><strong><%= @analysis_monitor.today_count %>件</strong></div>
      <div class="metric-card"><span>人の確認が必要</span><strong><%= @analysis_monitor.manual_count %>件</strong></div>
      <div class="metric-card"><span>予想コスト</span><strong><%= number_to_currency(@analysis_monitor.estimated_cost_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>期待値</span><strong><%= number_to_currency(@analysis_monitor.expected_value_yen, unit: "¥", precision: 0) %></strong></div>
    </div>
    <div class="aicoo-card aicoo-card-compact">
      <ul class="compact-list">
        <% @analysis_monitor.top_candidates.first(3).each do |candidate| %>
          <li>
            <strong><%= candidate.display_name %></strong>
            / <%= candidate.business.name %>
            / 費用対効果 <%= candidate.roi_label %>
            / <%= Aicoo::CeoSummaryBuilder.human_label(candidate.reason) %>
          </li>
        <% end %>
        <% if @analysis_monitor.top_candidates.empty? %>
          <li>追加で確認する分析はまだありません。</li>
        <% end %>
      </ul>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>今日の処理状況</h2>
      <p>見るべき数字だけを表示します。</p>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>実行待ち</span><strong><%= @owner_home_summary.execution_ready_count %>件</strong></div>
      <div class="metric-card"><span>結果登録待ち</span><strong><%= @owner_home_summary.result_registration_count %>件</strong></div>
      <div class="metric-card"><span>評価式承認待ち</span><strong><%= @owner_home_summary.pending_calibration_count %>件</strong></div>
      <div class="metric-card"><span>機会確認待ち</span><strong><%= @owner_home_summary.pending_opportunities_count %>件</strong></div>
      <div class="metric-card"><span>探索確認待ち</span><strong><%= @owner_home_summary.explore_review_count %>件</strong></div>
      <div class="metric-card"><span>あとで処理</span><strong><%= @owner_home_summary.today_queue_count %>件</strong></div>
      <div class="metric-card"><span>処理済み</span><strong><%= @owner_home_summary.today_queue_completed_count %>件</strong></div>
      <div class="metric-card"><span>今日の判断記録</span><strong><%= @owner_decision_summary.today_count %>件</strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>あとで処理する候補</h2>
      <p>上の1件が終わったら見る候補です。</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>タイトル</th>
            <th>理由</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @owner_execution_queue_summary.items.first(5).each do |item| %>
            <tr>
              <td><%= item.title %></td>
              <td><%= Aicoo::CeoSummaryBuilder.human_label(item.reason) %></td>
              <td>
                <div class="actions compact-actions">
                  <%= link_to "詳細を見る", item.target_path, class: "button secondary" %>
                  <%= button_to "後でやる", skip_owner_execution_queue_item_path(item), method: :patch, class: "button secondary" %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @owner_execution_queue_summary.items.empty? %>
            <tr><td colspan="3">あとで処理する候補はありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <% critical_healths = @business_integration_health.critical_businesses.first(3) %>
  <% if critical_healths.any? %>
    <section class="dashboard-section">
      <div class="section-heading">
        <h2>重大な連携注意</h2>
        <p>AICOOが正常にデータ取得できていない可能性があります。</p>
      </div>
      <div class="aicoo-card-grid">
        <% critical_healths.each do |row| %>
          <div class="aicoo-card aicoo-card-compact">
            <p><span class="pill">状態 <%= number_with_precision(row.health_score, precision: 1) %></span></p>
            <h3><%= row.business.name %></h3>
            <p><%= row.warnings.first %></p>
            <%= link_to "事業を見る", row.business, class: "button secondary" %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>システム状態</h2>
      <p>異常があるかだけ確認します。</p>
    </div>
    <div class="metric-grid aicoo-owner-secondary">
      <div class="metric-card"><span>自動巡回</span><strong><%= Aicoo::CeoSummaryBuilder.human_label(@owner_home_summary.daily_run_status) %></strong></div>
      <div class="metric-card"><span>学習状態</span><strong><%= Aicoo::CeoSummaryBuilder.human_label(@owner_home_summary.learning_status) %></strong></div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>詳細画面</h2>
      <p>必要な時だけ開きます。</p>
    </div>
    <div class="actions compact-actions">
      <%= link_to "全タスク", owner_tasks_path, class: "button secondary" %>
      <%= link_to "学習を見る", owner_learning_report_path, class: "button secondary" %>
      <%= link_to "探索を見る", admin_explore_path, class: "button secondary" %>
      <%= link_to "運用状態を見る", dashboard_path, class: "button secondary" %>
    </div>
  </section>
</div>
