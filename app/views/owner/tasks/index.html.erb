<% content_for :title, "今日の確認タスク" %>

<% header_actions = capture do %>
  <%= link_to "オーナーモードへ戻る", owner_dashboard_path, class: "button secondary" %>
  <%= link_to "SYSTEM MODE", dashboard_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "今日の確認タスク",
             description: "承認・警告・失敗対応をまとめて確認します。",
             active_main: :revenue,
             actions: header_actions %>

  <section class="dashboard-section">
    <div class="aicoo-card aicoo-card-compact">
      <div class="section-heading">
        <h2>迷ったらFocusで1件ずつ処理</h2>
        <p><%= @owner_focus_home.summary_message %></p>
      </div>
      <% if @owner_focus_home.top_task %>
        <p><span class="pill"><%= @owner_focus_home.top_task.priority %></span> <%= @owner_focus_home.top_task.title %></p>
      <% end %>
      <div class="actions compact-actions">
        <%= link_to "Focusで処理", owner_focus_path, class: "button" %>
      </div>
    </div>
  </section>

  <%= render "shared/owner_task_inbox",
             owner_task_inbox: @owner_task_inbox,
             tasks: @tasks,
             show_filters: true %>
</div>
