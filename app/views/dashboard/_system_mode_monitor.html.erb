<section class="dashboard-section" id="system-playbook">
  <div class="section-heading">
    <h2>Playbook</h2>
    <p>Businessごとの勝ちパターン学習状態を確認します。</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Business</th><th>Confidence</th><th>Samples</th><th>Top Action</th><th>Worst Action</th><th>ROI</th></tr>
      </thead>
      <tbody>
        <% monitor.playbook_rows.each do |playbook| %>
          <tr>
            <td><%= link_to playbook.business.name, playbook.business %></td>
            <td><%= number_with_precision(playbook.confidence_score, precision: 1) %></td>
            <td><%= playbook.sample_count %></td>
            <td><%= playbook.top_action_type.presence || "-" %></td>
            <td><%= playbook.worst_action_type.presence || "-" %></td>
            <td><%= playbook.average_roi ? number_with_precision(playbook.average_roi, precision: 2) : "-" %></td>
          </tr>
        <% end %>
        <% if monitor.playbook_rows.empty? %>
          <tr><td colspan="6">Playbookはまだ学習されていません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

