<% content_for :title, "AICOO 操作盤" %>

<% header_actions = capture do %>
    <%= button_to "AIで全事業TOP10生成", generate_ai_top10_dashboard_path, method: :post, class: "button" %>
    <%= link_to "実行指示", admin_aicoo_executor_path, class: "button secondary" %>
    <%= link_to "実績データ", admin_aicoo_datahub_path, class: "button secondary" %>
    <%= link_to "GA4/GSCデータ取込", admin_analytics_imports_path, class: "button secondary" %>
    <%= link_to "サイト別分析設定", admin_analytics_sites_path, class: "button secondary" %>
    <%= link_to "AICOO設定", aicoo_setting_path, class: "button secondary" %>
    <%= link_to "行動候補を追加", new_action_candidate_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "AICOO 操作盤",
             description: "今日やる行動を選び、実行し、実績から予測精度を高めます。",
             active_main: :dashboard,
             actions: header_actions %>
  <%= render "shared/aicoo_execution_tabs", active: :dashboard %>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>AICOO完成段階</h2>
    <p>今AICOOがどこまで自走できているかを、7段階で確認します。</p>
  </div>
  <div class="aicoo-card-grid">
    <% @aicoo_completion_levels.each do |level| %>
      <div class="aicoo-card aicoo-card-compact">
        <h3>Lv<%= level.level %> <%= level.title %></h3>
        <p><span class="pill"><%= level.status_label %></span></p>
        <p class="aicoo-lab-help">不足: <%= level.missing_item %></p>
        <small>現在 <%= level.current_count %> / 目安 <%= level.required_count %></small>
        <div class="actions compact-actions">
          <% if level.next_action.available? %>
            <%= link_to level.next_action.label, level.next_action.path, class: "button secondary" %>
          <% else %>
            <span class="button secondary disabled"><%= level.next_action.label %></span>
          <% end %>
        </div>
        <small><%= level.next_action.reason %></small>
      </div>
    <% end %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>総合ランキング TOP10</h2>
    <p>総合ランキングを主役にし、部門別ランキングは深掘り用に分けています。</p>
  </div>

  <div class="aicoo-card-grid">
    <% @department_ranking.department_leaders.each do |department, score| %>
      <div class="aicoo-card aicoo-card-compact">
        <h3><%= ActionCandidateDepartmentRanking::DEPARTMENTS.fetch(department) %> 1位</h3>
        <% if score %>
          <% action = score.action_candidate %>
          <p><strong><%= link_to action.title, action %></strong></p>
          <p><%= action.business.name %> / <%= number_with_precision(score.judge_adjusted_score, precision: 1) %></p>
          <p class="aicoo-lab-help"><%= score.summary_reason %></p>
        <% else %>
          <p>表示できる候補はありません。</p>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>順位</th>
          <th>行動</th>
          <th>事業</th>
          <th>部門</th>
          <th>期待利益</th>
          <th>Judge補正後</th>
        </tr>
      </thead>
      <tbody>
        <% @department_ranking.rankings.each.with_index(1) do |score, index| %>
          <% action = score.action_candidate %>
          <tr>
            <td class="number"><%= index %></td>
            <td><%= link_to action.title, action %></td>
            <td><%= action.business.name %></td>
            <td><span class="pill"><%= ActionCandidateDepartmentRanking::DEPARTMENTS.fetch(action.department, action.department) %></span></td>
            <td class="number"><%= number_to_currency(action.expected_profit_yen, unit: "¥", precision: 0) %></td>
            <td class="number"><%= number_with_precision(score.judge_adjusted_score, precision: 1) %></td>
          </tr>
        <% end %>
        <% if @department_ranking.rankings.empty? %>
          <tr><td colspan="6">表示できるActionCandidateがありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="actions compact-actions">
    <%= link_to "部門別ランキングを見る", department_rankings_path, class: "button secondary" %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>部門別精度サマリー</h2>
    <p>ActionResultをもとに、Revenue / Lab / 新規事業ごとの当たり具合を小さく確認します。</p>
  </div>
  <div class="aicoo-card-grid">
    <% @department_precision_summaries.each do |summary| %>
      <div class="aicoo-card aicoo-card-compact">
        <h3><%= summary.label %></h3>
        <dl class="detail-list compact-list">
          <dt>実行済み</dt>
          <dd><%= summary.executed_count %>件</dd>
          <dt>成功率</dt>
          <dd><%= summary.success_rate ? number_to_percentage(summary.success_rate * 100, precision: 1) : "データ不足" %></dd>
          <dt>予測との差</dt>
          <dd><%= number_to_currency(summary.prediction_gap_yen, unit: "¥", precision: 0) %></dd>
        </dl>
      </div>
    <% end %>
  </div>
</section>

<%= render "shared/learning_loop_summary",
           summary: @learning_loop_summary,
           action_center: @learning_loop_action_center %>

<%= render "shared/learning_loop_action_center",
           action_center: @learning_loop_action_center %>

<%= render "shared/execution_feasibility_insight",
           execution_feasibility: @execution_feasibility_insight %>

<%= render "shared/execution_feasibility_correction_overview",
           overview: @execution_feasibility_correction_overview %>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>評価関数精度</h2>
    <p>ActionCandidateの予測利益と実績利益のズレから、action_typeごとの評価係数を補正します。</p>
  </div>
  <div class="metric-grid">
    <div class="metric-card"><span>総サンプル数</span><strong><%= @action_prediction_calibration_summary.total_sample_count %>件</strong></div>
    <div class="metric-card">
      <span>平均利益誤差率</span>
      <strong><%= @action_prediction_calibration_summary.average_profit_error_rate ? number_to_percentage(@action_prediction_calibration_summary.average_profit_error_rate * 100, precision: 1) : "データ不足" %></strong>
    </div>
    <div class="metric-card"><span>補正対象action_type数</span><strong><%= @action_prediction_calibration_summary.calibrated_action_type_count %></strong></div>
    <div class="metric-card">
      <span>最も予測過大</span>
      <strong><%= @action_prediction_calibration_summary.most_overestimated&.action_type || "データ不足" %></strong>
    </div>
    <div class="metric-card">
      <span>最も予測過小</span>
      <strong><%= @action_prediction_calibration_summary.most_underestimated&.action_type || "データ不足" %></strong>
    </div>
    <div class="metric-card">
      <span>最終補正日時</span>
      <strong><%= @action_prediction_calibration_summary.last_calculated_at ? l(@action_prediction_calibration_summary.last_calculated_at, format: :short) : "-" %></strong>
    </div>
  </div>
  <div class="actions compact-actions">
    <%= link_to "補正係数を見る", admin_aicoo_calibration_path, class: "button secondary" %>
  </div>
</section>

<% today_summary = @dashboard_summary.today %>
<% judge_summary = @dashboard_summary.judge %>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>Insight Engine</h2>
    <p>GSC・GA4・収益・実績データから、次にやるべき改善案を生成します。</p>
  </div>
  <div class="metric-grid">
    <div class="metric-card"><span>Insight件数</span><strong><%= @aicoo_insight_summary.total_count %></strong></div>
    <div class="metric-card"><span>今日生成した改善案</span><strong><%= @aicoo_insight_summary.today_count %></strong></div>
    <div class="metric-card">
      <span>最終Insight生成日時</span>
      <strong><%= @aicoo_insight_summary.latest_run ? l(@aicoo_insight_summary.latest_run.started_at, format: :short) : "-" %></strong>
    </div>
    <div class="metric-card"><span>Insight生成失敗件数</span><strong><%= @aicoo_insight_summary.failed_count %></strong></div>
    <div class="metric-card">
      <span>最重要改善案</span>
      <% if @aicoo_insight_summary.top_action %>
        <strong><%= link_to @aicoo_insight_summary.top_action.title, @aicoo_insight_summary.top_action %></strong>
      <% else %>
        <strong>未生成</strong>
      <% end %>
    </div>
  </div>
  <div class="actions compact-actions">
    <%= link_to "改善案を見る", admin_aicoo_insights_path, class: "button secondary" %>
  </div>
</section>

<section class="dashboard-section">
  <div class="aicoo-card">
    <h2>LP外部公開URL</h2>
    <p>公開LPだけをSNS共有できます。Dashboardや管理画面は本番ではBasic認証で保護します。</p>
    <dl class="detail-list compact-list">
      <dt>現在のURL</dt>
      <dd><%= aicoo_current_base_url_label %></dd>
      <dt>本番URL</dt>
      <dd><%= aicoo_public_base_url.presence || "未設定（AICOO_PUBLIC_BASE_URL をRenderで設定してください）" %></dd>
      <dt>共有できる公開LP</dt>
      <dd><code>/aicoo_lab/lp/:slug</code></dd>
    </dl>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>AICOO TODAY</h2>
    <p>Daily Run・Judge・行動候補をまとめた、AI COO司令室です。</p>
  </div>

  <div class="aicoo-card-grid">
    <div class="aicoo-card">
      <h3>Daily Run</h3>
      <p><span class="pill"><%= today_summary.status %></span></p>
      <dl class="detail-list compact-list">
        <dt>実行日時</dt>
        <dd><%= today_summary.started_at ? l(today_summary.started_at, format: :short) : "未実行" %></dd>
        <dt>対象日</dt>
        <dd><%= today_summary.target_date %></dd>
        <dt>新規候補</dt>
        <dd>+<%= today_summary.action_candidates_generated_count %>件</dd>
        <dt>評価完了</dt>
        <dd><%= today_summary.action_results_evaluated_count %>件</dd>
      </dl>
    </div>

    <div class="aicoo-card">
      <h3>事業実績</h3>
      <dl class="detail-list compact-list">
        <dt>売上</dt>
        <dd><%= number_to_currency(today_summary.revenue_total_yen, unit: "¥", precision: 0) %></dd>
        <dt>利益</dt>
        <dd><%= number_to_currency(today_summary.profit_total_yen, unit: "¥", precision: 0) %></dd>
        <dt>proxy_score</dt>
        <dd><%= today_summary.proxy_score_change_rate ? number_to_percentage(today_summary.proxy_score_change_rate * 100, precision: 1) : "データ不足" %></dd>
      </dl>
    </div>

    <div class="aicoo-card">
      <h3>Judge</h3>
      <dl class="detail-list compact-list">
        <dt>的中率</dt>
        <dd><%= judge_summary.summary.hit_rate ? number_to_percentage(judge_summary.summary.hit_rate * 100, precision: 1) : "データ不足" %></dd>
        <dt>平均誤差率</dt>
        <dd><%= judge_summary.summary.average_prediction_error_rate ? number_to_percentage(judge_summary.summary.average_prediction_error_rate * 100, precision: 1) : "データ不足" %></dd>
        <dt>評価済み</dt>
        <dd><%= judge_summary.summary.evaluated_count %>件</dd>
        <dt>skipped</dt>
        <dd><%= judge_summary.summary.skipped_count %>件</dd>
      </dl>
    </div>

    <div class="aicoo-card">
      <h3>Top Generation Source</h3>
      <% if judge_summary.top_generation_source %>
        <p><strong><%= judge_summary.top_generation_source.label %></strong></p>
        <p>的中率 <%= number_to_percentage(judge_summary.top_generation_source.hit_rate * 100, precision: 1) %> / 評価 <%= judge_summary.top_generation_source.evaluated_count %>件</p>
      <% else %>
        <p>データ不足</p>
      <% end %>
    </div>

    <div class="aicoo-card">
      <h3>Top Action Type</h3>
      <% if judge_summary.top_action_type %>
        <p><strong><%= judge_summary.top_action_type.label %></strong></p>
        <p>的中率 <%= number_to_percentage(judge_summary.top_action_type.hit_rate * 100, precision: 1) %> / 評価 <%= judge_summary.top_action_type.evaluated_count %>件</p>
      <% else %>
        <p>データ不足</p>
      <% end %>
    </div>

    <div class="aicoo-card">
      <h3>Top Business</h3>
      <% if judge_summary.top_business %>
        <p><strong><%= judge_summary.top_business.label %></strong></p>
        <p>的中率 <%= number_to_percentage(judge_summary.top_business.hit_rate * 100, precision: 1) %> / 評価 <%= judge_summary.top_business.evaluated_count %>件</p>
      <% else %>
        <p>データ不足</p>
      <% end %>
    </div>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>今日やるべきこと TOP10</h2>
    <p>既存ActionCandidateを、過去の的中率で軽く補正して並べています。補正は0.5倍〜2倍に抑えています。</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>順位</th>
          <th>タイトル</th>
          <th>Business</th>
          <th>生成元</th>
          <th>行動タイプ</th>
          <th>期待利益</th>
          <th>信頼度</th>
          <th>Judge補正後スコア</th>
        </tr>
      </thead>
      <tbody>
        <% @dashboard_summary.top_action_candidates.each.with_index(1) do |score, index| %>
          <% action = score.action_candidate %>
          <tr>
            <td class="number"><%= index %></td>
            <td><%= link_to action.title, action %></td>
            <td><%= link_to action.business.name, action.business %></td>
            <td><span class="pill"><%= action.generation_source %></span></td>
            <td><%= action.action_type %></td>
            <td class="number"><%= number_to_currency(action.expected_profit_yen, unit: "¥", precision: 0) %></td>
            <td class="number"><%= action.confidence_score %></td>
            <td class="number"><%= number_with_precision(score.judge_adjusted_score, precision: 1) %></td>
          </tr>
        <% end %>
        <% if @dashboard_summary.top_action_candidates.empty? %>
          <tr><td colspan="8">表示できるActionCandidateがありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<% score_snapshots = @dashboard_summary.score_snapshots %>
<section class="dashboard-section">
  <div class="section-heading">
    <h2>Judge補正の順位変動</h2>
    <p><%= score_snapshots.recorded_on %> 時点の補正ログです。順位がなぜ上がった/下がったかを検証します。</p>
  </div>
  <div class="metric-grid">
    <div class="metric-card"><span>データ不足で補正なし</span><strong><%= score_snapshots.no_adjustment_count %>件</strong></div>
  </div>

  <% [
    [ "今日の順位上昇TOP5", score_snapshots.rank_up ],
    [ "今日の順位低下TOP5", score_snapshots.rank_down ],
    [ "補正倍率が大きい候補TOP5", score_snapshots.largest_multiplier ]
  ].each do |title, snapshots| %>
    <h3><%= title %></h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>タイトル</th>
            <th>Business</th>
            <th>raw_rank</th>
            <th>adjusted_rank</th>
            <th>rank_delta</th>
            <th>倍率</th>
            <th>理由</th>
          </tr>
        </thead>
        <tbody>
          <% snapshots.each do |snapshot| %>
            <tr>
              <td><%= link_to snapshot.action_candidate.title, snapshot.action_candidate %></td>
              <td><%= link_to snapshot.business.name, snapshot.business %></td>
              <td class="number"><%= snapshot.raw_rank %></td>
              <td class="number"><%= snapshot.adjusted_rank %></td>
              <td class="number"><%= snapshot.rank_delta %></td>
              <td class="number"><%= number_with_precision(snapshot.adjustment_multiplier, precision: 2) %></td>
              <td><%= snapshot.reason %></td>
            </tr>
          <% end %>
          <% if snapshots.empty? %>
            <tr><td colspan="7">該当する順位変動はありません。</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>

<%= render "shared/correction_readiness",
           readiness: @dashboard_summary.correction_readiness,
           show_action_button: true %>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>データ整備タスク</h2>
    <p>Judge補正やproxy_score補正に必要な不足データを埋めるためのActionCandidateです。通常の収益候補とは分けて管理します。</p>
  </div>
  <% queue_summary = @dashboard_summary.data_preparation_queue %>
  <div class="metric-grid">
    <div class="metric-card"><span>Data Preparation Queue</span><strong><%= queue_summary.auto_queue_enabled ? "自動投入ON" : "自動投入OFF" %></strong></div>
    <div class="metric-card"><span>approval_pending</span><strong><%= queue_summary.approval_pending_count %>件</strong></div>
    <div class="metric-card"><span>今日追加</span><strong><%= queue_summary.today_added_count %>件</strong></div>
  </div>
  <div class="actions compact-actions">
    <%= link_to "AICOO設定で切り替える", aicoo_setting_path, class: "button secondary" %>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>タイトル</th>
          <th>Business</th>
          <th>不足タイプ</th>
          <th>現在数</th>
          <th>必要数</th>
          <th>状態</th>
          <th>Executor</th>
        </tr>
      </thead>
      <tbody>
        <% @dashboard_summary.data_preparation_tasks.each do |task| %>
          <% executor_task = task.unfinished_executor_task %>
          <% current_count = task.metadata["current_count"] %>
          <% required_count = task.metadata["required_count"] %>
          <tr>
            <td><%= link_to task.title, task %></td>
            <td><%= link_to task.business.name, task.business %></td>
            <td><%= Array(task.metadata["missing_type"]).join(", ") %></td>
            <td><%= current_count.respond_to?(:to_h) ? current_count.to_h.values.join(" / ") : current_count.to_i %></td>
            <td><%= required_count.respond_to?(:to_h) ? required_count.to_h.values.join(" / ") : required_count.to_i %></td>
            <td><span class="pill"><%= task.status %></span></td>
            <td>
              <% if executor_task %>
                <%= link_to "Executor送信済み", admin_aicoo_executor_task_path(executor_task), class: "button secondary" %>
              <% else %>
                <%= button_to "Executorへ送る", send_to_executor_action_candidate_path(task), method: :post, class: "button" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @dashboard_summary.data_preparation_tasks.empty? %>
          <tr><td colspan="7">まだデータ整備タスクはありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>AICOO Daily Run</h2>
    <p>代理指標更新、重み補正、行動候補生成、実行結果評価をまとめて実行します。</p>
  </div>
  <%= form_with url: aicoo_daily_runs_path, scope: :aicoo_daily_run, class: "filters" do |form| %>
    <div class="field compact-field">
      <%= form.label :target_date, "対象日" %>
      <%= form.date_field :target_date, value: Date.yesterday %>
    </div>
    <%= form.submit "AICOO Daily Runを実行", class: "button" %>
    <%= link_to "Daily Run履歴", aicoo_daily_runs_path, class: "button secondary" %>
  <% end %>

  <% if @latest_aicoo_daily_run %>
    <div class="metric-grid">
      <div class="metric-card"><span>最新Daily Run</span><strong><%= link_to @latest_aicoo_daily_run.status, @latest_aicoo_daily_run %></strong></div>
      <div class="metric-card"><span>対象日</span><strong><%= @latest_aicoo_daily_run.target_date %></strong></div>
      <div class="metric-card"><span>最終成功日時</span><strong><%= @daily_run_scheduler_status.last_success_at ? l(@daily_run_scheduler_status.last_success_at, format: :short) : "-" %></strong></div>
      <div class="metric-card"><span>次回予定時刻</span><strong><%= l(@daily_run_scheduler_status.next_run_at, format: :short) %></strong></div>
      <div class="metric-card"><span>retry回数</span><strong><%= @daily_run_scheduler_status.retry_count %> / <%= @daily_run_scheduler_status.max_retry_per_day %></strong></div>
      <div class="metric-card"><span>最終エラー</span><strong><%= @daily_run_scheduler_status.last_error.presence || "-" %></strong></div>
      <div class="metric-card"><span>Analytics取得</span><strong><%= @latest_aicoo_daily_run.analytics_fetch_count %></strong></div>
      <div class="metric-card"><span>DataHub Snapshot</span><strong><%= @latest_aicoo_daily_run.snapshot_count %></strong></div>
      <div class="metric-card"><span>Insight生成</span><strong><%= @latest_aicoo_daily_run.insight_generated_count %></strong></div>
      <div class="metric-card"><span>候補生成</span><strong><%= @latest_aicoo_daily_run.action_candidates_generated_count %></strong></div>
      <div class="metric-card"><span>結果評価</span><strong><%= @latest_aicoo_daily_run.action_results_evaluated_count %></strong></div>
    </div>
  <% end %>
  <div class="actions compact-actions">
    <%= link_to "Daily Run設定", admin_aicoo_daily_run_settings_path, class: "button secondary" %>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>代理指標更新</h2>
    <p>GSC・GA4・DataHub Snapshotから、全事業の日次 proxy_score を作成/更新します。</p>
  </div>
  <div class="actions compact-actions">
    <%= button_to "今日の代理指標を更新", import_business_metrics_today_dashboard_path, method: :post, class: "button" %>
