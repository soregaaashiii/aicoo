<section class="dashboard-section">
  <div class="section-heading">
    <h2>1. 純粋な期待値ランキング</h2>
    <p>短期的に一番儲かる行動を見るためのランキングです。</p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>順位</th>
          <th>事業名</th>
          <th>行動タイトル</th>
          <th>action_type</th>
          <th>短期利益</th>
          <th>成功確率</th>
          <th>期待利益</th>
          <th>時間</th>
          <th>期待時給</th>
          <th>費用</th>
          <th>ROI</th>
          <th>信頼度</th>
          <th>状態</th>
          <th>評価理由</th>
          <th>execution_prompt</th>
        </tr>
      </thead>
      <tbody>
        <% @expected_value_rankings.each.with_index(1) do |action_candidate, rank| %>
          <tr>
            <td class="rank"><%= rank %></td>
            <td><%= action_candidate.business.name %></td>
            <td><%= link_to action_candidate.title, action_candidate %></td>
            <td><%= action_candidate.action_type %></td>
            <td class="number"><%= number_to_currency(action_candidate.immediate_value_yen, unit: "¥", precision: 0) %></td>
            <td class="number"><%= number_to_percentage(action_candidate.success_probability.to_d * 100, precision: 1) %></td>
            <td class="number"><%= number_to_currency(action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></td>
            <td class="number"><%= action_candidate.expected_hours || "-" %></td>
            <td class="number"><%= action_candidate.expected_hourly_value_yen.present? ? number_to_currency(action_candidate.expected_hourly_value_yen, unit: "¥", precision: 0) : "-" %></td>
            <td class="number"><%= number_to_currency(action_candidate.cost_yen, unit: "¥", precision: 0) %></td>
            <td class="number"><%= action_candidate.roi.present? ? number_with_precision(action_candidate.roi, precision: 2) : "-" %></td>
            <td class="number"><%= action_candidate.confidence_score %></td>
            <td><span class="pill"><%= action_candidate.status %></span></td>
            <td><%= link_to "評価理由", action_candidate_path(action_candidate, anchor: "evaluation_reason") %></td>
            <td class="wide-text"><%= truncate(action_candidate.execution_prompt, length: 120) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="dashboard-section">
  <div class="section-heading">
    <h2>2. 分散込みの推奨ランキング</h2>
    <p>短期利益、戦略価値、事業分散を合わせて今週やるべき行動を見ます。</p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>順位</th>
          <th>事業名</th>
          <th>行動タイトル</th>
          <th>期待利益</th>
          <th>期待時給</th>
          <th>戦略価値</th>
          <th>リスク低減</th>
          <th>最終スコア</th>
          <th>evaluation_reason</th>
          <th>execution_prompt</th>
        </tr>
      </thead>
      <tbody>
        <% @recommendation_rankings.each.with_index(1) do |action_candidate, rank| %>
          <tr>
            <td class="rank"><%= rank %></td>
            <td><%= action_candidate.business.name %></td>
            <td><%= link_to action_candidate.title, action_candidate %></td>
            <td class="number"><%= number_to_currency(action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></td>
            <td class="number"><%= action_candidate.expected_hourly_value_yen.present? ? number_to_currency(action_candidate.expected_hourly_value_yen, unit: "¥", precision: 0) : "-" %></td>
            <td class="number"><%= action_candidate.strategic_value_score %></td>
            <td class="number"><%= action_candidate.risk_reduction_score %></td>
            <td class="number"><%= number_with_precision(action_candidate.final_score, precision: 1) %></td>
            <td class="wide-text"><%= truncate(action_candidate.evaluation_reason, length: 120) %></td>
            <td class="wide-text"><%= truncate(action_candidate.execution_prompt, length: 120) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

