<section class="dashboard-section">
  <div class="section-heading">
    <h2>事業別サマリー</h2>
    <p>意思決定の補助として、Business フォルダごとの状態を確認します。</p>
    <div class="actions compact-actions">
      <%= link_to "事業名順", dashboard_path, class: "button secondary" %>
      <%= link_to "今月利益順", dashboard_path(business_sort: "current_month_profit"), class: "button secondary" %>
      <%= link_to "累計利益順", dashboard_path(business_sort: "cumulative_profit"), class: "button secondary" %>
      <%= link_to "今月proxy順", dashboard_path(business_sort: "current_month_proxy_score"), class: "button secondary" %>
      <%= link_to "累計proxy順", dashboard_path(business_sort: "cumulative_proxy_score"), class: "button secondary" %>
    </div>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>事業名</th>
          <th>行動候補数</th>
          <th>期待利益合計</th>
          <th>期待時給平均</th>
          <th>最終スコア合計</th>
          <th>今月利益</th>
          <th>累計利益</th>
          <th>今月 impressions</th>
          <th>今月 clicks</th>
          <th>今月 sessions</th>
          <th>今月 pageviews</th>
          <th>今月 phone_clicks</th>
          <th>今月 map_clicks</th>
          <th>今月 affiliate_clicks</th>
          <th>直近7日 proxy_score</th>
          <th>直近30日 proxy_score</th>
          <th>今月 proxy_score</th>
          <th>累計 proxy_score</th>
          <th>評価軸</th>
          <th>上位アクション3件</th>
        </tr>
      </thead>
      <tbody>
        <% @business_summaries.each do |summary| %>
          <tr>
            <td><%= link_to summary.business.name, summary.business %></td>
            <td class="number"><%= summary.action_count %></td>
            <td class="number"><%= number_to_currency(summary.expected_profit_total, unit: "¥", precision: 0) %></td>
            <td class="number"><%= summary.average_hourly_value.present? ? number_to_currency(summary.average_hourly_value, unit: "¥", precision: 0) : "-" %></td>
            <td class="number"><%= number_with_precision(summary.final_score_total, precision: 1) %></td>
            <td class="number"><%= number_to_currency(summary.current_month_profit, unit: "¥", precision: 0) %></td>
            <td class="number"><%= number_to_currency(summary.cumulative_profit, unit: "¥", precision: 0) %></td>
            <td class="number"><%= summary.current_month_metric_total(:impressions) %></td>
            <td class="number"><%= summary.current_month_metric_total(:clicks) %></td>
            <td class="number"><%= summary.current_month_metric_total(:sessions) %></td>
            <td class="number"><%= summary.current_month_metric_total(:pageviews) %></td>
            <td class="number"><%= summary.current_month_metric_total(:phone_clicks) %></td>
            <td class="number"><%= summary.current_month_metric_total(:map_clicks) %></td>
            <td class="number"><%= summary.current_month_metric_total(:affiliate_clicks) %></td>
            <td class="number"><%= number_with_precision(summary.recent_7d_proxy_score, precision: 2) %></td>
            <td class="number"><%= number_with_precision(summary.recent_30d_proxy_score, precision: 2) %></td>
            <td class="number"><%= number_with_precision(summary.current_month_proxy_score, precision: 2) %></td>
            <td class="number"><%= number_with_precision(summary.cumulative_proxy_score, precision: 2) %></td>
            <td><span class="pill"><%= summary.evaluation_focus %></span></td>
            <td>
              <% if summary.top_actions.any? %>
                <ol class="compact-list">
                  <% summary.top_actions.each do |action_candidate| %>
                    <li><%= link_to action_candidate.title, action_candidate %></li>
                  <% end %>
                </ol>
              <% else %>
                -
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
