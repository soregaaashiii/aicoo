    <table>
      <thead>
        <tr>
          <th>対象</th>
          <th>source</th>
          <th>confidence</th>
          <% ProxyScoreWeight::DEFAULT_WEIGHTS.each_key do |column| %>
            <th><%= column %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>全体共通</td>
          <td><%= @proxy_score_global_weight.source_type %></td>
          <td class="number"><%= @proxy_score_global_weight.confidence_score %></td>
          <% ProxyScoreWeight::DEFAULT_WEIGHTS.each_key do |column| %>
            <td class="number"><%= number_with_precision(@proxy_score_global_weight.public_send(column), precision: 4) %></td>
          <% end %>
        </tr>
        <% @proxy_score_weight_summaries.each do |summary| %>
          <tr>
            <td><%= link_to summary.business.name, summary.business %></td>
            <td><%= summary.source_label %></td>
            <td class="number"><%= summary.confidence_score %></td>
            <% ProxyScoreWeight::DEFAULT_WEIGHTS.each_key do |column| %>
              <td class="number"><%= number_with_precision(summary.weight.public_send(column), precision: 4) %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <h3>直近の補正ログ</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>日時</th>
          <th>対象</th>
          <th>期間</th>
          <th>confidence</th>
          <th>補正率</th>
          <th>理由</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_proxy_score_weight_logs.each do |log| %>
          <tr>
            <td><%= l(log.adjusted_at, format: :short) %></td>
            <td><%= log.business&.name || "全体共通" %></td>
            <td><%= log.start_date %>〜<%= log.end_date %></td>
            <td class="number"><%= log.confidence_score %></td>
            <td class="number"><%= number_to_percentage(log.adjustment_rate.to_d * 100, precision: 3) %></td>
            <td><%= log.reason %></td>
          </tr>
        <% end %>
        <% if @recent_proxy_score_weight_logs.empty? %>
          <tr><td colspan="6">まだ補正ログはありません。</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

