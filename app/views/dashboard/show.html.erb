<% content_for :title, "AICOO SYSTEM MODE" %>

<% header_actions = capture do %>
  <%= link_to "Owner Focus", owner_focus_path, class: "button secondary" %>
  <%= link_to "Daily Run", aicoo_daily_runs_path, class: "button secondary" %>
  <%= link_to "Analytics", admin_analytics_sites_path, class: "button secondary" %>
  <%= link_to "Settings", aicoo_setting_path, class: "button secondary" %>
<% end %>

<div class="aicoo-page">
  <%= render "shared/aicoo_header",
             title: "AICOO SYSTEM MODE",
             description: "AICOO自身の監視室です。Snapshotを読むだけの軽量表示で、Health・連携・Pipeline・Queue・Learningを確認します。",
             active_main: :dashboard,
             actions: header_actions %>
  <%= render "shared/aicoo_execution_tabs", active: :dashboard %>

  <%= render "dashboard/system_mode_monitor", monitor: @system_mode_monitor %>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>Cost Summary / Data Source Monitor</h2>
        <p>Data Sourceごとの月間APIコスト、実行方式、ROIを監視します。</p>
      </div>
      <%= link_to "Data Source設定", aicoo_setting_path(anchor: "data-source-costs"), class: "button secondary" %>
    </div>

    <div class="metric-grid">
      <div class="metric-card"><span>月間APIコスト</span><strong><%= number_to_currency(@cost_summary.monthly_api_cost_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>月間予算</span><strong><%= number_to_currency(@cost_summary.monthly_budget_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>ROI</span><strong><%= @cost_summary.roi ? number_with_precision(@cost_summary.roi, precision: 1) : "無料/未計算" %></strong></div>
      <div class="metric-card"><span>Auto</span><strong><%= @cost_summary.auto_count %></strong></div>
      <div class="metric-card"><span>Smart</span><strong><%= @cost_summary.smart_count %></strong></div>
      <div class="metric-card"><span>Manual</span><strong><%= @cost_summary.manual_count %></strong></div>
    </div>

    <div class="system-status-grid compact">
      <% @cost_summary.estimates.first(8).each do |estimate| %>
        <div class="system-status-card status-<%= estimate.warning.present? ? "warning" : "healthy" %>">
          <span><%= estimate.name %></span>
          <strong><%= estimate.execution_mode.upcase %></strong>
          <small>
            cost <%= number_to_currency(estimate.estimated_cost_yen, unit: "¥", precision: 0) %> /
            ROI <%= estimate.roi ? number_with_precision(estimate.roi, precision: 1) : "無料" %>
          </small>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section" id="analysis-monitor">
    <div class="section-heading">
      <div>
        <h2>Analysis Monitor</h2>
        <p>Businessごとに今日回すべき分析を、期待値・コスト・ROIで監視します。</p>
      </div>
      <%= button_to "今日のAnalysis Candidateを生成", generate_analysis_candidates_dashboard_path, method: :post, class: "button secondary" %>
    </div>

    <div class="metric-grid">
      <div class="metric-card"><span>Today</span><strong><%= @analysis_monitor.today_count %></strong></div>
      <div class="metric-card"><span>Pending</span><strong><%= @analysis_monitor.pending_count %></strong></div>
      <div class="metric-card"><span>Auto / Smart / Manual</span><strong><%= @analysis_monitor.auto_count %> / <%= @analysis_monitor.smart_count %> / <%= @analysis_monitor.manual_count %></strong></div>
      <div class="metric-card"><span>推定コスト</span><strong><%= number_to_currency(@analysis_monitor.estimated_cost_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>期待値</span><strong><%= number_to_currency(@analysis_monitor.expected_value_yen, unit: "¥", precision: 0) %></strong></div>
      <div class="metric-card"><span>ROI</span><strong><%= @analysis_monitor.roi ? number_with_precision(@analysis_monitor.roi, precision: 1) : "無料/未計算" %></strong></div>
    </div>

    <% if @analysis_monitor.warnings.any? %>
      <div class="aicoo-card aicoo-card-compact">
        <%= @analysis_monitor.warnings.join(" / ") %>
      </div>
    <% end %>

    <div class="system-status-grid compact">
      <% @analysis_monitor.top_candidates.each do |candidate| %>
        <%= link_to candidate.business, class: "system-status-card status-#{candidate.manual? ? "warning" : "healthy"}" do %>
          <span><%= candidate.business.name %> / <%= candidate.display_name %></span>
          <strong><%= candidate.execution_mode.upcase %></strong>
          <small>
            期待値 <%= number_to_currency(candidate.expected_value_yen, unit: "¥", precision: 0) %> /
            コスト <%= number_to_currency(candidate.estimated_cost_yen, unit: "¥", precision: 0) %> /
            ROI <%= candidate.roi_label %>
          </small>
        <% end %>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2>Engagement Summary</h2>
        <p>GA4の滞在・回遊・CV導線から、収益につながる読まれ方を監視します。</p>
      </div>
      <%= link_to "Business Analytics", businesses_path, class: "button secondary" %>
    </div>

    <div class="metric-grid">
      <div class="metric-card"><span>平均Engagement Score</span><strong><%= number_with_precision(@engagement_summary.average_engagement_score, precision: 1) %></strong></div>
      <div class="metric-card"><span>平均滞在</span><strong><%= number_with_precision(@engagement_summary.average_engagement_time_seconds, precision: 0) %>秒</strong></div>
      <div class="metric-card"><span>平均回遊</span><strong><%= number_with_precision(@engagement_summary.average_views_per_session, precision: 2) %></strong></div>
      <div class="metric-card"><span>Engagement Rate</span><strong><%= number_to_percentage(@engagement_summary.average_engagement_rate * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>CV率</span><strong><%= number_to_percentage(@engagement_summary.average_conversion_rate * 100, precision: 1) %></strong></div>
      <div class="metric-card"><span>改善余地Business</span><strong><%= @engagement_summary.low_engagement_business_count %>件</strong></div>
    </div>

    <div class="system-status-grid compact">
      <% @engagement_summary.weak_businesses.first(5).each do |row| %>
        <% status_class = row.warning.present? ? "warning" : "healthy" %>
        <%= link_to row.business, class: "system-status-card status-#{status_class}" do %>
          <span><%= row.business.name %></span>
          <strong><%= number_with_precision(row.engagement_score, precision: 1) %></strong>
          <small><%= row.warning.presence || "Engagement安定" %></small>
        <% end %>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Detailed Operations</h2>
      <p>重い詳細集計は専用画面で確認します。SYSTEM MODEの初期表示では実行しません。</p>
    </div>
    <div class="system-status-grid compact">
      <%= link_to admin_explore_path, class: "system-status-card status-healthy" do %>
        <span>Explore</span>
        <strong>Open</strong>
        <small>Explore Data Hub</small>
      <% end %>
      <%= link_to owner_learning_report_path, class: "system-status-card status-healthy" do %>
        <span>Learning</span>
        <strong>Open</strong>
        <small>Learning Report</small>
      <% end %>
      <%= link_to admin_aicoo_calibration_path, class: "system-status-card status-healthy" do %>
        <span>Calibration</span>
        <strong>Open</strong>
        <small>評価関数補正</small>
      <% end %>
      <%= link_to codex_queue_auto_revision_tasks_path, class: "system-status-card status-healthy" do %>
        <span>Executor</span>
        <strong>Open</strong>
        <small>Codex Queue</small>
      <% end %>
      <%= link_to admin_aicoo_datahub_path, class: "system-status-card status-healthy" do %>
        <span>DataHub</span>
        <strong>Open</strong>
        <small>実績データ</small>
      <% end %>
      <%= link_to businesses_path, class: "system-status-card status-healthy" do %>
        <span>Business</span>
        <strong>Open</strong>
        <small>Business一覧</small>
      <% end %>
      <%= link_to action_candidates_path, class: "system-status-card status-healthy" do %>
        <span>ActionCandidate</span>
        <strong>Open</strong>
        <small>候補一覧</small>
      <% end %>
      <%= link_to admin_aicoo_daily_run_settings_path, class: "system-status-card status-healthy" do %>
        <span>Scheduler</span>
        <strong>Open</strong>
        <small>Daily Run設定</small>
      <% end %>
    </div>
  </section>
</div>
