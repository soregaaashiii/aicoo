<%= form_with(model: action_result, class: "form") do |form| %>
  <% if action_result.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(action_result.errors.count, "error") %> prohibited this result from being saved:</h2>
      <ul>
        <% action_result.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form.hidden_field :action_candidate_id %>
  <%= form.hidden_field :action_execution_id %>
  <%= form.hidden_field :business_id %>

  <% if action_result.action_execution %>
    <% execution = action_result.action_execution %>
    <div class="aicoo-card aicoo-card-compact">
      <h3>Execution Draft</h3>
      <div class="metric-grid">
        <div class="metric-card"><span>予測利益</span><strong><%= number_to_currency(execution.predicted_profit_yen_snapshot.to_i, unit: "¥", precision: 0) %></strong></div>
        <div class="metric-card"><span>予測成功率</span><strong><%= number_to_percentage(execution.predicted_success_probability_snapshot.to_d * 100, precision: 1) %></strong></div>
        <div class="metric-card"><span>予測時間</span><strong><%= execution.predicted_hours_snapshot || "-" %>h</strong></div>
        <div class="metric-card"><span>実績時間</span><strong><%= execution.actual_hours || "-" %>h</strong></div>
        <div class="metric-card"><span>予測コスト</span><strong><%= number_to_currency(execution.predicted_cost_yen_snapshot.to_i, unit: "¥", precision: 0) %></strong></div>
        <div class="metric-card"><span>実績コスト</span><strong><%= number_to_currency(execution.actual_cost_yen.to_d, unit: "¥", precision: 0) %></strong></div>
        <div class="metric-card"><span>score</span><strong><%= number_with_precision(execution.action_score_snapshot.to_d, precision: 1) %></strong></div>
      </div>
      <p><strong>Execution結果:</strong> <%= execution.result_summary.presence || "-" %></p>
    </div>
  <% end %>

  <% expansion = action_result.action_candidate&.metadata.to_h.fetch("action_expansion", {}) %>
  <% expansion_tasks = Array(expansion["recommended_tasks"]) %>
  <% if expansion_tasks.any? %>
    <% selected_tasks = Array(action_result.metadata.to_h.dig("action_expansion_learning", "executed_tasks")) %>
    <div class="aicoo-card aicoo-card-compact">
      <h3>実行したExpansion Task</h3>
      <p>今回のActionResultに、どの実行手順を実際に行ったかを保存します。</p>
      <div class="compact-list">
        <% expansion_tasks.each do |task| %>
          <label class="checkbox-row">
            <%= check_box_tag "executed_expansion_tasks[]", task, selected_tasks.include?(task) %>
            <span><%= task %></span>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="grid">
    <div class="field">
      <%= form.label :executed_on, "実行日" %>
      <%= form.date_field :executed_on %>
    </div>
    <div class="field">
      <%= form.label :evaluated_on, "評価日" %>
      <%= form.date_field :evaluated_on %>
    </div>
    <div class="field">
      <%= form.label :actual_revenue_yen, "実績売上" %>
      <%= form.number_field :actual_revenue_yen, step: 1 %>
    </div>
    <div class="field">
      <%= form.label :actual_profit_yen, "実績利益" %>
      <%= form.number_field :actual_profit_yen, step: 1 %>
    </div>
    <div class="field">
      <%= form.label :evaluation_status, "評価状態" %>
      <%= form.select :evaluation_status, ActionResult::EVALUATION_STATUSES %>
    </div>
  </div>

  <div class="field">
    <%= form.label :note, "メモ" %>
    <%= form.textarea :note, rows: 5 %>
  </div>

  <div class="actions">
    <%= form.submit "保存", class: "button" %>
  </div>
<% end %>
