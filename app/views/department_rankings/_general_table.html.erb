<table>
  <thead>
    <tr>
      <th>順位</th>
      <th>行動</th>
      <th>事業</th>
      <th>部門</th>
      <th>行動タイプ</th>
      <th>期待利益</th>
      <th>信頼度</th>
      <th>Judge補正後</th>
      <th>状態</th>
    </tr>
  </thead>
  <tbody>
    <% rows.each.with_index(1) do |row, index| %>
      <% action_candidate = row.action_candidate %>
      <tr>
        <td class="number"><%= index %></td>
        <td><%= link_to action_candidate.title, action_candidate %></td>
        <td><%= link_to action_candidate.business.name, action_candidate.business %></td>
        <td><span class="pill"><%= ActionCandidateDepartmentRanking::DEPARTMENTS.fetch(action_candidate.department, action_candidate.department) %></span></td>
        <td><%= action_candidate.action_type %></td>
        <td class="number"><%= number_to_currency(action_candidate.expected_profit_yen, unit: "¥", precision: 0) %></td>
        <td class="number"><%= action_candidate.confidence_score %></td>
        <td class="number"><%= number_with_precision(row.judge_adjusted_score, precision: 1) %></td>
        <td><span class="pill"><%= action_candidate.status %></span></td>
      </tr>
    <% end %>
    <% if rows.empty? %>
      <tr><td colspan="9">この部門に表示できるActionCandidateはありません。</td></tr>
    <% end %>
  </tbody>
</table>
