<% content_for :title, "#{@business.name} LP Version比較" %>
<div class="aicoo-page lovable-workspace">
  <%= render "shared/aicoo_header", title: "LP Version比較", description: "Prompt、変更理由、Preview、diffを並べて確認します。", active_main: :businesses, actions: link_to("LP Studioへ戻る", business_lovable_landing_page_path(@business), class: "button secondary") %>
  <section class="dashboard-section">
    <%= form_with url: compare_business_lovable_landing_page_path(@business), method: :get, class: "inline-form", data: { turbo: false } do |form| %>
      <%= form.label :before_id, "Before" %>
      <%= form.select :before_id, @versions.map { |run| [ run.metadata.to_h["version_label"], run.id ] }, selected: @before_version&.id %>
      <%= form.label :after_id, "After" %>
      <%= form.select :after_id, @versions.map { |run| [ run.metadata.to_h["version_label"], run.id ] }, selected: @after_version&.id %>
      <%= form.submit "比較", class: "button" %>
    <% end %>
  </section>
  <section class="dashboard-section lovable-version-comparison">
    <% [ ["Before", @before_version], ["After", @after_version] ].each do |label, run| %>
      <% learning = run ? @version_learning.fetch(run.id, {}) : {} %>
      <article>
        <h2><%= label %> <%= run&.metadata.to_h&.dig("version_label") || "-" %></h2>
        <% if run&.metadata.to_h&.dig("preview_url").present? %>
          <iframe src="<%= run.metadata.to_h['preview_url'] %>" title="<%= label %> preview" loading="lazy"></iframe>
        <% end %>
        <dl class="detail-list">
          <dt>CVR / CV</dt><dd><%= learning["cvr"] ? number_to_percentage(learning["cvr"] * 100, precision: 1) : "-" %> / <%= learning["conversions"] || "-" %></dd>
          <dt>CTA率</dt><dd><%= learning["cta_rate"] ? number_to_percentage(learning["cta_rate"] * 100, precision: 1) : "-" %></dd>
          <dt>滞在 / 離脱</dt><dd><%= learning.dig("ga4", "engagement_seconds") || "-" %>秒 / <%= learning.dig("ga4", "bounce_rate") ? number_to_percentage(learning.dig("ga4", "bounce_rate") * 100, precision: 1) : "-" %></dd>
          <dt>ROI / 信頼度</dt><dd><%= learning["roi"] || "-" %> / <%= learning["confidence"] ? number_to_percentage(learning["confidence"] * 100, precision: 0) : "-" %></dd>
          <dt>Learning根拠</dt><dd><%= run&.metadata.to_h&.dig("landing_page_improvement_analysis", "improvements")&.map { |item| item["reason"] }&.join(" / ").presence || "改善判定なし" %></dd>
          <dt>変更理由</dt><dd><%= run&.metadata.to_h&.dig("change_request").presence || "初回生成" %></dd>
          <dt>Lovable Prompt</dt><dd><pre><%= run&.prompt || "-" %></pre></dd>
          <dt>Diff</dt><dd><pre><%= JSON.pretty_generate(run&.metadata.to_h&.dig("diff") || {}) %></pre></dd>
        </dl>
      </article>
    <% end %>
  </section>
</div>
